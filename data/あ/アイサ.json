        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、秋沙は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは秋沙が重要です。",
              "source": "幻辞"
            },
            {
              "text": "秋沙に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では秋沙が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で秋沙について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から秋沙についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では秋沙について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では秋沙が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では秋沙が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に秋沙は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において秋沙は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に秋沙を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に秋沙をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で秋沙が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、秋沙の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は秋沙を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は秋沙に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で秋沙について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から秋沙は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは秋沙を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "○山の際に渡る秋沙の行きて居むその河の瀬に浪立つなゆめ　〔巻七・一一二二〕　作者不詳　詠鳥、作者不明。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「秋沙」は、鴨の一種で普通｜秋沙鴨、小鴨などと云っている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首の意は、山のあいを今飛んで行く秋沙鴨が、何処かの川に宿るだろうから、その川に浪立たずに呉れ、というので、不思議に象徴的な匂いのする歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者はほんのりと恋愛情調を以て詠んだのだろうが、情味が秋沙鴨に対する情味にまでなっている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「子供が立つてあいさつした。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野口氏も明らかに間の惡い思ひを感じたらしく、直ちに私にあいさつして會場を退席された。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に散會する時、だれもが親しい微笑を交してあいさつした。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの世へ行ったら太宰さんの御両親様にも御あいさつしてきっと信じて頂くつもりです。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごあいさつだわねえ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」というあいさつさえも、よそよそしく、「きょうは女房を連れて来ました。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、いいんです」ジョバンニは、少し肩をすぼめてあいさつしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人がそのあかしの前を通って行くときは、その小さな豆いろの火はちょうどあいさつでもするようにぽかっと消え、二人が過ぎて行くときまた点くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると博士はジョバンニがあいさつに来たとでも思ったものですか、しばらくしげしげジョバンニを見ていましたが、「あなたはジョバンニさんでしたね。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくのあいさつはこうだ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かあいさうに、麻はもうみんな食はれてしまった。",
              "citation": {
                "source": "畑のへり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒームカさんがまばゆい新らしい碧いきものを着てお日さまの出るころは、きっと一番さきにお前にあいさつするぜ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん地べたがつめたくなりましたね」　とあいさつをしました。",
              "citation": {
                "source": "どろぼう猫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "』これがかれの開口第一のあいさつであった。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が慇懃にあいさつする言葉を打ち消して、『いやそうあらたまれては困る。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "と押しあいへしあいされながら婆やの体はすうっと横の方に動いていった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山男はもうすつかりかあいさうになつて、いまのはうそだよと云はうとしてゐましたら、外の支那人があはれなしはがれた声で言ひました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そいつはかあいさうだ。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくのあいさつはかうだ。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お早う」とあいさつをしましたが、りすは二｜疋とも堅くなってしまって、いっこうことばも出ませんでした。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お早う今朝は暖かですね」本線のシグナル柱は、キチンと兵隊のように立ちながら、いやにまじめくさってあいさつしました。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉十の手拭はかあいさうに泥がついてところどころ穴さへあきました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かあいさうに、これでも鼻がありまさアね。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、ここには、友だちひとりいるわけではありませんし、あいさつの声をかけてくれるような顔なじみもなかったのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮中の人たちは、もうおなくなりになったものと思って、みんな、新しい皇帝にごあいさつするために、かけていってしまいました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "王女と影とは、バルコニに姿をあらわして、人民たちにあいさつをたまわり、もういちど人民たちから万歳の声をあびました。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
