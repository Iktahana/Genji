        "examples": {
          "standard": [
            {
              "text": "朝ごはんの例文",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私たちは、おそい朝ごはんを、気まずい思いで食べた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝ごはんを食べて、家のちかくの井之頭公園へ散歩に出かけ、行く途々も、議論であります。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、朝ごはんまへに、校正のはうを片附けてしまふつもりで、机にむかつたら、ひよつこり母がたづねて來た。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母がかへつて、私は校正にとりかかり、ひるごろまでに濟まして、晩い朝ごはんをたべ、それから、〆切のせまつてゐる小説を少しづつ書きつづけ、そのうちに、しきりと侘びしくなつて來た。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）家内は、朝ごはんの後片附がすむと、湯道具持って、毎日そこへ通った。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人も今朝は、七時ごろに起きて、朝ごはんも早くすませて、それから直ぐにお仕事。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝ごはんの時、「日本は、本当に大丈夫でしょうか。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもその朝は、仕事が気になって、衣服の事などめんどうくさく、何も言わずにさっさと着て朝ごはんも食べずに仕事をはじめた。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族そろって朝ごはんの食卓についた時にも、自分だけは、特に、パンと牛乳だけで軽くすませた。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝ごはんを食べて、それからすぐに二人で砂浜へ出てゴルフを始めたが、最初の時ほど面白くなかった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る朝、私がわびしい気持で朝ごはんを食べてゐたら、主人がお銚子と、小さいお皿を持つて来て、「あなたは、津島さんでせう。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る朝、朝ごはんを食べながら、呻くばかりでありました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へんに気になって、朝ごはんの時、給仕に出て来た狐の女中に、あの娘さんは何ですか、とたずねてみました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの言いぶんに拠れば、字義どおりの一足ちがい、宿の朝ごはんの後、熱い番茶に梅干いれてふうふう吹いて呑んだのが失敗のもと、それがために五分おくれて、大事になったとのこと、二人の給仕もいれて十六人の社員、こぞって同情いたしました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、朝ごはんのときに、家人へその紙きれを見せ、あれは、きっといい子だから、毎日あそびによこすよう、お隣りへおねがいして来い、と言いつけた。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝ごはんの前に使いに遣ると、使いが早いというのです。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、瀬多川で顔を洗い、駅前の飯屋で朝ごはんを食べると、もう十五銭しか残っていなかった。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちは、ちょうど朝ごはんの最中だった。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お座敷では、もうお客さまが朝ごはんをたべていました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、朝ごはんをたいても、いつもたきたてのごはんがおとうさんや僕のべんとうばこへおさまるのです。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしや朝ごはんを食べとらんと……」　　　　　石家荘　兵士たちは、実に無口である。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、からだをあたためて、朝ごはんを食べようと思いました。",
              "citation": {
                "source": "森のなかの三人の小人",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがすむと朝ごはんのお給仕をして、縫物をして、それからお午になり、夕方になります。",
              "citation": {
                "source": "子守つ子",
                "author": "アントン・チエーホフ　Anton Chehov",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の　朝ごはんのあと　おやすみできたか　おたずねに　あがりますよ。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん　これから　ひとねむりするから　みんな　朝ごはんに　おあずけのはず。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロプシーと　ぴょんぴょんじいさんは　ばんごはんの　ときにも　口げんか、　そのあと　夜も　ねむれず、　朝ごはんのときに　また　口げんか。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう朝ごはんすんで？",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガンのいたずら三月二十一日、火曜日　ガンが、朝ごはんをたべていると思われるあいだは、森の中ではべつに変わったこともありませんでした。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの朝、農家の人たちが朝ごはんに集まってきたとき、おばあさんはゆうべ見たことを話さずにはいられませんでした。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわりあって、朝ごはんをたべ、昼ごはんをたべ、それから二時間、三時間、四時間、もう夕がたに近づいても、なにごともおこりません。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
