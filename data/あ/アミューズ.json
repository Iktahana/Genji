    "definitions": [
      {
        "index": 1,
        "gloss": "amuse-bouche",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アミューズについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アミューズという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアミューズの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアミューズが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アミューズを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアミューズについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アミューズの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアミューズの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアミューズが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アミューズという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアミューズという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアミューズについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アミューズを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアミューズは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アミューズについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアミューズが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアミューズは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアミューズの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アミューズは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアミューズは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ヤードバーズ〈フォー・ユア・ラヴ〉、アウトサイダーズ〈タイム・ウォント・レット・ミー〉、ナシュヴィル・ティーンズ〈タバコ・ロード〉、ビーチボーイズ〈アミューズメント・パークス・ＵＳＡ〉、それに、ナンシー・シナトラやレズリー・ゴーアなんてものまである。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局のところ、アミューズメントロボットの開発計画は、中途で頓挫することになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自他ともに認める硬派のハッカー仲間の橋本と、ＣＧに入れ込んでいた木原範昭とは、アミューズメントロボットの話でも組んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
