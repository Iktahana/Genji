[
  {
    "uuid": "18a81ed9-d758-5cca-b88c-183ce8328011",
    "entry": "案ずる",
    "reading": {
      "primary": "あんずる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-ずる変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be anxious (about)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日案ずるについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "案ずるという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は案ずるの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には案ずるが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "案ずるを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは案ずるについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "案ずるの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は案ずるの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では案ずるが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "案ずるという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に案ずるという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では案ずるについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "案ずるを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると案ずるは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "案ずるについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では案ずるが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に案ずるは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により案ずるの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "案ずるは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に案ずるは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "画家は再び戸を鎖し、跡に戻り、物を案ずる様にて部屋の内をあちこち歩き、何かそこらの物を手に取りては置き、また外の物を手に取りては置き、紙巻を一本取りて火を付け、一吸吸い、忽ちそれを投げ捨て、右手の為事机に駈け寄り、慌ただしく物をかき始む。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "案ずるに、「ダス・ゲマイネ」の註釋などせよとの親切心より發せしお言葉ならむ。",
              "citation": {
                "source": "「地球圖」序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅く案ずるに、此の随筆から取つて講釈に仕組んで演ずるのであらうと思ふが、書いた方を読むと、嘘らしいが魅せられて事実に聞こえる。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の上にて山々の遙に連なりつ断えつするを望み、海の音のとゞろき渡るを聞きながら、旅のおもひを歌なんどに案ずる折から、ゆかしき香を手綱かいくるついでに聞きつけて、ふと見る眼の下に、この花のあやしき蔓草まじり二つ三つ咲きたるを認めたる、おもしろさ何とも云ひがたし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を切るような風吹きて霙降る夜の、まだ宵ながら餅屋ではいつもよりも早く閉めて、幸衛門は酒一口飲めぬ身の慰藉なく堅い男ゆえ炬燵へ潜って寝そべるほどの楽もせず火鉢を控えて厳然と座り、煙草を吹かしながらしきりに首をひねるは句を案ずるなりけり。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれ、かかる時は、あすの逢瀬を楽みに、帰途を案ずるも心ゆかし、寐られぬ夜半の待人掛ける、小さな犬も拵え交ぜて、お千世に背打たれて微笑みもしたが。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然まで案ずる事はあるまい。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "因りて倩々案ずるに、國許に候恩田杢と申者、老職末席にて年少なれど、きつと器量ある者につき、國家の政道を擧げて任せ申さむと存ずるが、某も渠も若年なれば譜代の重役をはじめ家中の者ども、決して心服仕らじ、しかする時は杢が命令行はれで、背く者の出で來らむには、却て國家の亂とならむこと、憂慮しく候。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "案ずるに、團子は附燒を以て美味いとしてある。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘其郡邑矣、とあるから何處のものとも知れぬが、案ずるに金丸商店仕入れの弗箱を背負つて、傲然と控へる人體。",
              "citation": {
                "source": "畫の裡",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諺にも何でさ、案ずるより産むが易いって謂いまさ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と思い案ずる目を半ば閉じて、屈託らしく、盲目が歎息をするように、ものあわれな装して、「うっかり飛んだ事を申上げて、私、そんなつもりで言ったんじゃありませんわ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "案ずるに、潰と云ひ、藝子と云ひ投と云ひ、奴はた文金、我が島田髷のがつくりと成るは、非常の時のみ。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本草には出て居まいが、案ずるに燒芋と※パンは浮氣をとめるものと見える……が浮氣がとまつたか何うかは沙汰なし。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "案ずるに、ちよろ／＼水も、くたびれを紛らした串戲らしい。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――案ずるに、此は修善寺の温泉に於ける、河鹿が吐く蜃氣樓であるらしい。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名案はないかな、と字の如く案ずると……あゝ、今にして思當つた。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まゝよ、一分でも乘後れたら停車場から引返さう、それが可い、と目指す大阪を敵に取つて、何うも恁うはじめから豫定の退却を畫策すると云ふのは、案ずるに懷中のためではない。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……案ずるに我が家の門附を聞徳に、いざ、その段になった処で、件の（出ないぜ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一の身の上を案ずることで自分の身の上を考えた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "案ずるに先生はこのたびの茶会に於いて、かの千利休の遺訓と称せられる「茶の湯とはただ湯をわかし茶をたてて、飲むばかりなるものと知るべし」という歌の心を実際に顕現して見せようと計ったのであろう。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其間に氏郷は印籠から「西大寺」（宝心丹をいう）を取出して、其水で服用し、彼に計謀あれば我にも防備あり、案ずるな、者共、ハハハハハハ、と大きく笑って後を向くと、西大寺の功験早く忽ちにカッと飲んだ茶を吐いて終った。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」伏して昭穆を案ずるに、将門は已に栢原帝王五代之孫なり、たとひ永く半国を領するとも、豈非運と謂はんや。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と酒井先生方の書生が主税に告げたのと、案ずるに同日であるから、その編上靴は、一日に市中のどのくらいに足跡を印するか料られぬ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "案ずるまでもありませんや、お道姉さんが心入れのお手料理か何かを、旅館から運ぶんだね。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚案ずるに、がばりは雪を切る音なるべし。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一室｜寂たることしばしなりし、謙三郎はその清秀なる面に鸚鵡を見向きて、太く物案ずる状なりしが、憂うるごとく、危むごとく、はた人に憚ることあるもののごとく、「琵琶。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　案ずるに、此の車を以つて、我が作品を礼するのであらう。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "案ずるに、この記事を載せた「一話一言」の第三巻は天明五年ごろの集録であるから、その当時のお七の墓はよほど荒廃していたらしい。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ほんとに妹の身をあんずる、兄の心持ちがわかるような気がして、まぶたがあつくなりました。",
              "citation": {
                "source": "どこかで呼ぶような",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
