        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "作品のテーマは人間の本質を問う。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品は多くの解釈の余地を持つ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動は心の表現である。",
              "source": "幻辞"
            },
            {
              "text": "文学は時代を映す鏡となる。",
              "source": "幻辞"
            },
            {
              "text": "美的感覚は個人の経験により形成される。",
              "source": "幻辞"
            },
            {
              "text": "詩人の言葉遣いが読者の心を打つ。",
              "source": "幻辞"
            },
            {
              "text": "舞台作品は観客に深い感動を与える。",
              "source": "幻辞"
            },
            {
              "text": "音楽は言葉を超えた表現手段だ。",
              "source": "幻辞"
            },
            {
              "text": "絵画の色彩が感情を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "彫刻作品の立体感が空間を支配する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "廊下の東詰の流しの上の明かり窓から病院の動物小屋が見える。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、それがかすかな雪明かりに窓からちらと見えた後影だけで消えてしまった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、およその見当に温泉の浴室があり、その建物の高い軒下には天井の周囲を帯状にめぐらす明かり窓があって浴室内の電燈の光に照らされたその窓が細長い水平な光の帯となって空中にかかっている。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの可能性は、上記の浴室の軒の明かり窓の光が一時消えていたのが突然ぱっと一時に明るくなったと仮定すると、その光の帯が暗がりになれていた人の横目には一方から一方に移動する光のように感ぜられたのではないかということである。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような事のある一方で、私の宅の客間の電燈をつけたり消したりするために壁に取りつけてあるスイッチが破損して、明かりがつかなくなってしまった。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「月細く小雨にぬるる石地蔵」「酒しぼるしずくながらに月暮れて」「塩浜にふりつづきたる宵の月」「月暮れて雨の降りやむ星明かり」以上いずれも雨の月であるが、もう一つおまけに「傘をひろげもあえずにわか雨」というのがある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその魚籠のなかには四、五匹の大きい魚が月明かりに光っていた。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼ざめた星が黒い松の上に凍り着いたように寂しく光って、鼠色の靄につつまれたお茶の水の流れには水明かりすらも見えなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも眼を閉じさえすれば、ツルのかくした花や南京玉が、水のしたたる美しさでうす明かりの中にうかぶのであった。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "白樺の林が月明かりに見えた。",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて月明かりでもあるといいのだが、あいにくに今夜は闇だ。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ薄暗いなかで、雪明かりを頼りにぼんやり見たのですから自分にも確かなことは判りません。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人家のまばらな田舎道のところどころに、大きい櫨の木が月のひかりを浴びて白く立っているばかりで、川らしい水明かりは見当らなかった。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "カールスルーエからはもうすっかり暗くなって、月明かりはあったが景色は見えなかった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろその暗やみへ向かって飛び込んで行くと、ある時間の後にはどこからか明かりがさして来て夜の明けるようになるのであった。",
              "citation": {
                "source": "球根",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　炬火の薄明かりの中へ地主の藤沢が事務所から出て来た。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場の明かりで、彼が非常に蒼ざめて、興奮の余りブルブル震えていることが分かった。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、船長が明かり窓を降りて来るのが聞こえるぞ。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼の力は足らず、集会室の明かり窓によろめき退って来て、そこに彼はあえぎ疲れて倚りかかってしまった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔色は蒼白となったので、私はきっと彼が意識を失うものと思って、時を移さずに彼を伴って明かり窓を降りて、船室のソファの上にそのからだを横たえさせた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "明かり取りのあるところを降りて来ると、見張り番交代に昇って来るミルン氏に逢った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私たちの部屋からもれる明かりは、この夜遅い訪問客が、私たちを待ちもうけていると云うことを物語っているように見えた。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓からさし込む朝のうす明かりの中に、もう不断服に着かえたホームズが、私の寝台の側に立っているのを見出した。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "採光窓から漏れ出る半円形の明かりの下、外で何かを待っている。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」明かりのついた露店街を思い思いに歩く人混みを縫って、我が友人はすっとその小柄な男に追いつき、肩に触れた。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが話の終わる頃には、また村に入っていて、両側の家々からわずかな明かりが見える。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "木々のあいだから明かりが見えるだろう？",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその明かりのかたわらで、ご婦人が腰をかけている。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプの放つ薄明かりのなか、私はホームズがそこに座っているのを見た。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前二時頃、私は窓際に腰掛けていて、外は月明かり以外まったく光がありません。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
