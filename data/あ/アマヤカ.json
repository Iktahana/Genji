    "definitions": [
      {
        "index": 1,
        "gloss": "sweet (voice, fragrance, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日甘やかについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "甘やかという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は甘やかの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には甘やかが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "甘やかを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは甘やかについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "甘やかの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は甘やかの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では甘やかが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "甘やかという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に甘やかという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では甘やかについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "甘やかを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると甘やかは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "甘やかについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では甘やかが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に甘やかは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により甘やかの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "甘やかは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に甘やかは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかも結局して、私は彼にいたはられ、甘やかされ、故意に駄々をこねることの悦びにさへ、充分自ら飽滿してゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は比較的良家の生れ、子供の時に甘やかされて育った為に、他人との社交について、自己を抑制することができないのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という上品で甘やかなメロデーだと賞めそやしました。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の云うことを聞けば宜いと云って人を甘やかすばかりが慈悲ではありません。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、ほんの表面の薄い層だけ湿るようなやり方をしていると、芝の根がついつい欺されて甘やかされて、浅い上層だけに発達して来る。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畜生ふびんのゆえをもって、人はこれを甘やかしているからいけないのだ。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたが甘やかしてばかりいるからよ。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたはいつでも皆さんを甘やかして、いけなくしてしまうのです。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘やかしているように見えるだろうが、僕には、ちゃんとした考えがあって、やっている事なんだ。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自体拙者は気に入らないので、頻りと止めてみたが、もともと強情我慢な母親、妹は我儘者、母に甘やかされて育てられ、三絃まで仕込まれて自堕落者に首尾よく成りおおせた女。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "母というはお豊といい、言葉の少ない、柔和らしく見えて確固した気象の女でしたが、僕を叱ったこともなく、さりとて甘やかす程に可愛がりもせず、言わば寄らず触らずにして居たようです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬいはその感触に甘やかされて、今度は写真を両手で胸のところに抱きしめた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいうことを聴けば宜いといって人を甘やかすばかりが慈悲ではありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも虚栄の姿は、もっとも甘やかに華やかに人々を誘惑の手で手招くのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも甘やかされるよりも、たたかれる方が、たたかれた新人自身を強くすることもある。",
              "citation": {
                "source": "文学的饒舌",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の前を避けてそうしたのは、坂田に恥をかかすまいという心遣いからだと、松本は咄嗟に自分を甘やかして、わざと雪で顔を濡らせていた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一個一厘の廃球を割ったり、同級生の頭をこついたりしてみても、如何にもけちくさく、それよりか、一里以上もある道を築港まで歩いて行き、黄昏れる大阪湾をながめて、豹一おまえは可哀そうなやっちゃと自分を甘やかしている方が気が利いていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "均平は芝居や小説にある花柳｜情緒の感傷的な甘やかしさ美しさに触れるには、情感も疾うの昔しに乾ききり、むしろ生まれつき醜悪な心情の持主でさえあったが、二人の愛慾の悩みは、あながちよそごとのようにも思えなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と婆さんは、娘を可愛がって甘やかしていますから、ちっとも怒らず、無理に笑ってあやまりました。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしの婆さんは、こわい魔法使いですが、でも、あたしをずいぶん甘やかして育てて下さいました。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが宇宙の決定されてる方則は、悲しい人間共の祈祷を、甘やかしに聽いてはくれないのである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世で甘やかされるものは、その暖かい寢床に眠つて、母親にかしづかれてる子供だけだ。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は比較的良家に生れ、子供の時に甘やかされて育つた為に、他人との社交について、自己を抑制することができないのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あまやかしてゐればそれですむんぢやないんだ――」　彼は又気息をついた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子は、あまやかされて、育てられたうえに、人いちばい、ごうじょうときています。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、年とつたお母さんはお母さんで、嫁ごは子供をあまやかしすぎる、子供と猫はあまやかすほどぞうちやうする、とひびのはいつた金だらひを叩くやうな声で、いひはつてをりました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをただ矢鱈にあまやかしても、日本の現政府の外交方針に、もとるような結果になりはせぬか。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女としてあまやかされ、わがままに育ったから、肉親に対しては、いつも無口で不機嫌で、殊にガッチリした新子に対してなぞ、始終いらいらしがちで、お互に語り合うようなことがなかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い綿雲が邪魔扱いにされて、低い空をグングン流れて行く、一番いたぶられた月見草や芝草が、綺麗に露で化粧をして、あまやかな土から、徐々に頭をもたげかけている。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、あまりに人相の鑑定がピッタリ当ったうれしさに、相手をあまやかしているのではないかと云う、自分自身の反省には、しばらくの間悩まされたのである。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
