    "definitions": [
      {
        "index": 1,
        "gloss": "to become red",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学習を通じて知識の幅が広がる。",
              "source": "幻辞"
            },
            {
              "text": "研究論文は学問の進展を示す。",
              "source": "幻辞"
            },
            {
              "text": "教育的な価値観が人生を左右する。",
              "source": "幻辞"
            },
            {
              "text": "学問的な探求は終わることのない旅だ。",
              "source": "幻辞"
            },
            {
              "text": "講座に参加して専門知識を習得した。",
              "source": "幻辞"
            },
            {
              "text": "教授の指導により研究が進展した。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは積極的に学習に取り組んでいる。",
              "source": "幻辞"
            },
            {
              "text": "学位論文の完成に向けて努力が続いている。",
              "source": "幻辞"
            },
            {
              "text": "教科書の内容は実践的である。",
              "source": "幻辞"
            },
            {
              "text": "学習成果の評価が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "食材の新鮮さが料理の質を決める。",
              "source": "幻辞"
            },
            {
              "text": "調理技法は世代から世代へと伝えられる。",
              "source": "幻辞"
            },
            {
              "text": "食文化は地域の歴史を物語る。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの取れた食事が健康を支える。",
              "source": "幻辞"
            },
            {
              "text": "食卓は家族の絆を深める場である。",
              "source": "幻辞"
            },
            {
              "text": "季節の食材を活用することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "料理の味わいは思い出を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "食べることは人生の喜びの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "伝統的な食べ方が継承されている。",
              "source": "幻辞"
            },
            {
              "text": "食材との対話が調理の極意だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いまはもう、胸がどきどきして顔が赤らむどころか、あんまり苦しくて顔が蒼くなり額に油汗のにじみ出るような気持で、花江さんの取り澄まして差出す証紙を貼った汚い十円紙幣を一枚二枚と数えながら、矢庭に全部ひき裂いてしまいたい発作に襲われた事が何度あったか知れません。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雪は少年が優しく懸けた、肩の手を静かに払って、颯と赤らむ顔とともに、声の下で、「はい、私はあのお邸へ上ります訳には参りませんのでございます。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の※も赤らむまで、ほかほかとしたと云う。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔓の黄葉を眞探りて、おどろがさ枝に藷蕷を堀り、霜に赤らむ梢の柿、澁きを、榾の火に燒きて。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介自身、そんなことはなかつたとはいへないある時々の自分の言葉なり、擧動なりを、ただひとりゐて顏の赤らむ恥づかしさで憶ひ出す。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「ぱッと顔の赤らむ直截な感情である」羞恥とはなんであろうか、ということをこの作者は生々しい感情から扱いえなくて中村光夫さんはこういうふうに論じている、誰それは、というふうに、と羞恥論をやっています。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『いいや、それは……』　鷺太郎は、（畜生――）　と思いながらも、ぽーっと耳朶の赤らむのを感じて、『いや、それにしても……成るほど、あそこに寝るまで手に何も持っていなかったですね……匕首が落ちていたんじゃないかな』『冗談でしょう。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "vaio は栗鼠族の動物の名、紋章の語にてはその皮模樣を紋所に現はすをいふ、ピーリ家の家紋はヴァイオの一縱線（即ち柱）を赤地にあらはしゝものなれはかく言へり〔サッケッティ、ジュオキ〕等フィレンツェの舊家名族を擧ぐ〔赤らむ家族〕「キアラモンテージ」家。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は顔の赤らむ思いがし、そして、へんに惨めな気持ちになった。",
              "citation": {
                "source": "復讐",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはちょっと戸惑った気持ちで、そして顔が少し赤らむ気持ちで、振り向くと、あの人は、わたしの視線を避けて、立ち上ってゆき、硝子戸を一杯に明け放した。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も何故となく顔が赤らむのを覚えた。",
              "citation": {
                "source": "人間繁栄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがその通りである証拠に、彼女自身、伏見菊人と向ひ合つて、どこか意を迎へるやうなところを見せてはゐなかつたか、と、顔の赤らむやうな思ひでした。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "曠野の限りを、赤らむだ額を夜空の下に、戦士達蒼ざめた馬を徐かに進める！",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "その度毎に、彼のこの頃あまり血色のよくない顏は目に見えないくらゐ、かすかに赤らむのだつた。",
              "citation": {
                "source": "顏",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに怒つても顏が赤らむだけで、眼はいつも夢でも見てゐるやうにぼんやりしてゐた。",
              "citation": {
                "source": "蒼白き巣窟",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は顔の赤らむ思いがあった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度山々では紅葉が赤らむのでね、善光寺詣りの団体くずれが、大群をなして温泉めぐりをやり、渋からこの上林へとくり上って来る。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる代価をもって彼にパンを買わしてる人々こそ、顔を赤らむべきであった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき登は頬が赤らむのを感じたものである。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "鶯ばか",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ人から貰うた、大切な品ですけ」「新さん、あんた、なにを……」　マンは、びっくりして、赤らむと、新之助の膝を、はげしく、つねった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "市会でも、採決のときには、自分たちも、よく、これと同じことをやるのだが、傍聴席から見ると、やはり、そんな風に見えるのだろうかと、顔の赤らむ思いがした。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それが、これは云いたくはないんだが、原稿といっても実は恥ずかしくて顔の赤らむのを誰だって拒絶することができやしない。",
              "citation": {
                "source": "陽気な客",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それがきみ、それが、……そんな土地へめり込んで、うす暗いじめじめしたごみ溜のような編集室の隅で、椅子の上にあぐらをかいて、ねじり鉢巻で、茶碗酒を呷りながら、ばりばりがりがりとペンの音をさせながら、そんなような思わず顔の赤らむような原稿を書いているんだ。",
              "citation": {
                "source": "陽気な客",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は俺の顔が、かーっと赤らむのを覚えた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も時には覗かしてもらうこともありましたけれど、偶然妙なものを、すぐ目の前に発見したりして、いっそ顔の赤らむようなこともないではありませんでした。",
              "citation": {
                "source": "鏡地獄",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の赤らむ様なある仕草、ある言葉さえもが、冷酷に描写してあった。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲麦の芒を厭うて、毎年暮春の麦の赤らむ頃から、飛羽を着て天に昇り、夏の稲取入れが終って後に、戻って来るのを習いとしていた。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "道のほとりに咲く草花、あからむ覆盆子などさすがになつかしくて根岸庵のあるじがり端書をやる。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか、いい旦那がついたから、とも思いませんが、私は花江さんの通帳に弐百円とか参百円とかのハンコを押すたんびに、なんだか胸がどきどきして顔があからむのです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜は頬のあからむほど嬉しくなった。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
