    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to become luminous at dawn (esp. the sky)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "毎日の生活の中で色々な発見がある。",
              "source": "幻辞"
            },
            {
              "text": "友人との会話を通じて新しい視点が得られた。",
              "source": "幻辞"
            },
            {
              "text": "家族と過ごす時間は何より大切だ。",
              "source": "幻辞"
            },
            {
              "text": "日常の小さなことに感謝する心が大事。",
              "source": "幻辞"
            },
            {
              "text": "普通の日々が実は貴重なものだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時間が一家団らんの大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人との付き合いが近所の絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "日々のルーティンの中に喜びを見出す。",
              "source": "幻辞"
            },
            {
              "text": "身近な人との関係を大事にしたい。",
              "source": "幻辞"
            },
            {
              "text": "日常生活は学びの場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "生をあきらめ死をあきらめる　「生を諦め、死を明らむるは、これ仏家一大事因縁なり」　と。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "分け入つても分け入つても青い山しとどに濡れてこれは道しるべの石炎天をいただいて乞ひ歩く放哉居士の作に和して鴉啼いてわたしも一人生を明らめ死を明らむるは仏家一大事の因縁なり（修証義）生死の中の雪ふりしきる木の葉散る歩きつめる昭和二年三年、或は山陽道、或は山陰道、或は四国九州をあてもなくさまよふ。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "発信地は福島の郡山からだが、川端康成から鎌倉文庫へ入社の奨めをうけ、目前明らむ思いで今汽車に乗っているところとある。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ、竹の声に道を悟り、桃の花に心を明らむるものがある。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道のほとりに咲く草花、あからむ覆盆子などさすがになつかしくて根岸庵のあるじがり端書をやる。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか、いい旦那がついたから、とも思いませんが、私は花江さんの通帳に弐百円とか参百円とかのハンコを押すたんびに、なんだか胸がどきどきして顔があからむのです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜は頬のあからむほど嬉しくなった。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉分の光はだらに、白き菱の花さして、樹暗もあからむ眞夏日なか、水馬うかべる水隱れ、藻伏小鮒とらへ來て、朱脛やすらふ柳瑞枝、したり顏の若音には、葉守の神さへ醉に入らむ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひところは本当にひどくて、女の独断がそのまま色彩のとりあわせや帽子の形やにあらわれているようで、そういう人たちがいわば無邪気であればあるほどこちらで何となし顔のあからむような思いもないことはなかった。",
              "citation": {
                "source": "新しい美をつくる心",
