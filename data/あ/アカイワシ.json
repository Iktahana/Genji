        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史的な出来事は現在に影響を与えている。",
              "source": "幻辞"
            },
            {
              "text": "文化的な多様性は社会の財産だ。",
              "source": "幻辞"
            },
            {
              "text": "伝統の継承と革新のバランスが課題である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産の保存に力が入れられている。",
              "source": "幻辞"
            },
            {
              "text": "異文化理解が国際関係を深める。",
              "source": "幻辞"
            },
            {
              "text": "民族の歴史が現在の価値観を形作る。",
              "source": "幻辞"
            },
            {
              "text": "文化遺産は人類共通の財産である。",
              "source": "幻辞"
            },
            {
              "text": "過去の教訓が未来を導く。",
              "source": "幻辞"
            },
            {
              "text": "伝統芸能の継承が困難な状況だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史研究により新たな真実が明かされる。",
              "source": "幻辞"
            },
            {
              "text": "旅行により見知らぬ世界への扉が開く。",
              "source": "幻辞"
            },
            {
              "text": "交通網の整備により移動が便利になった。",
              "source": "幻辞"
            },
            {
              "text": "観光地の特色を知ることは人生を豊かにする。",
              "source": "幻辞"
            },
            {
              "text": "旅の経験は人を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "交通機関の発展により世界が近くなった。",
              "source": "幻辞"
            },
            {
              "text": "旅先での出会いが人生を変える。",
              "source": "幻辞"
            },
            {
              "text": "交通の安全が旅の基本である。",
              "source": "幻辞"
            },
            {
              "text": "観光産業は地域経済を支える。",
              "source": "幻辞"
            },
            {
              "text": "旅の計画は冒険の始まりだ。",
              "source": "幻辞"
            },
            {
              "text": "移動時間も旅の醍醐味の一つだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "東　亭主の好きな赤烏帽子西　寺から里へ　松浦肥前守、赤き烏帽子を戴きしといふ奇解の塩尻に出でしより、人皆之に従ひて怪まず、多くの画にも、人の赤き烏帽子冠れるさまを描きたれど、土地によりては、赤烏帽子と云はずして、「亭主の好きな赤鰯」といふもあるなり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤鰯は鰯の塩蔵｜若くは乾蔵せるものにして、其の味の美ならざること言ふまでも無し。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "語の意は、赤鰯珍とするに足らず、されど亭主之を好まば又数※用ゐられんのみ、人之を如何ともする無し、といふに在り。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、こりゃお岩が死んでおる」刀を見つけて、「こりゃ小平めの赤鰯じゃ、そんなら彼奴が殺したか」　伊右衛門は一方の襖をあけた。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤鰯ではねえということは、御連中さま、もうよく、お目を止められましたぜ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "其で「さばと言ふのに赤鰯はこれ如何に」などゝ矛盾を感じ出して、塩鯖にきまつたのかと思うてゐる。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっはっは、妻恋坂殿様の御用人、あんまり性のよくねえ赤鰯さ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "表店には相違ありませんが、屑屋の少し體の良い古道具屋で、鰻の寢床のやうな長い店には役に立たない物や、片輪な品物ばかりを集め、まことに慘憺たる有樣です、赤鰯のやうな脇差や、槍の穗も轉がつて居りますが、血だらけな匕首などは無く、平次も手を空しくして此處を引上げる外はありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "處女神聖",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙間を狙って亡きものにしようとした田舎出の私は、やっと赤鰯の腰の物は他人に呉れて遣り、いっぱし一人前のぴかぴかした刀を差して後ろに坐っているが、人を斬るどころか、人に斬られてもくそくらえという平気な顔付で、肩の骨柱を聳やかしていた。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "實は親分も知つて居なさるあつしの赤鰯を、望み手があつて賣つたんで」「何？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鉄砲汁",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ふまでもなく三日前にガラツ八が吉三郎に賣つた、十兩の赤鰯丸です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鉄砲汁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無駄だらう、今朝拔かれてしまつたよ、――赤鰯丸なんか持つて行つても仕樣があるまい、――十兩の金さへ返しや氣が濟む。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鉄砲汁",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は親分も知っていなさるあっしの赤鰯を、望み手があって売ったんで」「何？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鉄砲汁",
                "note": "青空文庫"
              }
            },
            {
              "text": "言うまでもなく三日前にガラッ八が吉三郎に売った、十両の赤鰯丸です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鉄砲汁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無駄だろう、今朝抜かれてしまったよ、――赤鰯丸なんか持って行っても仕様があるまい、――十両の金さえ返しゃ気が済む、さア帰ろうか、八」　平次はもう何の未練気もなく立ち上がるのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鉄砲汁",
                "note": "青空文庫"
              }
            },
            {
              "text": "また研ぎがよほど乱暴――それは大道の古道具屋で買ったときまったくの赤鰯だったので、肉の減るほど研がなければならなかったわけだが――だったとみえ、にえも匂いもみだれも殆んど消滅し、まるで「相済みません」と詫びを入れているような刀相をしていた。",
              "citation": {
                "source": "長屋天一坊",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伝来の刀とか、秘蔵の名剣とか、聞えている物ほど、ただ大事がるばかりで、赤鰯にしてしまっているのが多いようです。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめえの作る刀の未来も分るぞ、眼からして、もう赤鰯だ。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
