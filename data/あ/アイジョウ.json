    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's beloved daughter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、愛嬢は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは愛嬢が重要です。",
              "source": "幻辞"
            },
            {
              "text": "愛嬢に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では愛嬢が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で愛嬢について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から愛嬢についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では愛嬢について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では愛嬢が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では愛嬢が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に愛嬢は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において愛嬢は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に愛嬢を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に愛嬢をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で愛嬢が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、愛嬢の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は愛嬢を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は愛嬢に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で愛嬢について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から愛嬢は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは愛嬢を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あまり人の行かぬデルハ岬の海岸に、二人の奇麗な娘が遊んでおった、二人ともモンテス博士の愛嬢で、景色よき岬の上には博士の別荘があるのだ。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして只圓翁の凜烈の気象は暗にこれに賛助した事になるので、翁の愛嬢で絶世の美人といわれた到氏夫人千代子女史が、夫君の後を趁うて雪中を富士山頂に到り夫君と共に越冬し、満天下の男女を後に撞着せしめた事実も、さもこそとうなずかれる節があるやに察せられる。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "左大臣の愛嬢として、源氏の夫人として葬送の式に列る人、念仏のために集められた寺々の僧、そんな人たちで鳥辺野がうずめられた。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の舞い姫はそのまま続いて女官に採用されることになっていたから、愛嬢を惜しまずに出すのであると言われていた。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正六年の九月の末に、東京大阪の各新聞紙が筆を揃えて報道した唐沢｜男爵の愛嬢｜瑠璃子の結婚を。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正六年の九月の末に、東京大阪の各新聞紙が筆を揃へて報道した唐沢男爵の愛嬢瑠璃子の結婚を。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たつた一人きりの愛嬢瑠璃子さんが、京都の銅駝校を出ると、博士は東京芝の聖心女学院へ入学させるために夫人と一緒に瑠璃子さんを東京へ送り、自分は独身生活を営んで、冷い弁当飯で過してゐたが、その寂しい生活が大分健康に障つたらしい。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚と奴隷10・15（夕）　米国はヰスコンシンの上院議員ラ・フオレツト氏の愛嬢フオラ・ラ・フオレツト女史は彼国でも新しい女として名高い人で、先年脚本作家のヂヨルヂ・ミツドルトン氏と結婚したが、結婚後も良人の姓は名乗らないで、矢張｜里方の娘の儘で押通してゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　で、長谷川氏夫妻はともかくも聟がね二人を愛嬢のために見比べさせるために園遊会を開く事にした。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "長谷川氏の愛嬢は物蔭から火のやうな眼をして、その騒ぎを見てゐたが、暫くすると、猿の中にたつた一人の人間を見つけた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」長谷川夫人は自分も処女に後がへりしたやうな若い気持で愛嬢の顔をさしのぞいた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、愛嬢楊子さんの勉強方針に関して、さりげなく示されている順序も、尾崎氏が、自身の思想構成の正当さについてゆるぎない信念をもっていられたことを示している。",
              "citation": {
                "source": "人民のために捧げられた生涯",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような良人たちの開化の精神の位置と程度とは、我が愛嬢を中心にお茶屋がひらけると冗談を云う大官たる作者の父親の心情と、果してどの位距りをもっていただろう。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛嬢の競争者の夫人を喜ばないのであるが、宮の思召しをはばかって、当夜は子息たちを何人も送り、接客の用を果たさせもした。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間には母親のある子ばかりではないのだから」　と守は言い、愛嬢を昼から乳母と二人で撫でるようにして繕い立てていたから、そう醜いふうの娘とは見えなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "家ではどんなふうに見えるであろう、まだ自家の中で打ち解けた姿をしているところを自分は見なかったと思い、少将がくつろいでいる昼ごろに今では守の愛嬢の居室に使われている西座敷へ来て夫人は物蔭からのぞいた。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "原氏の前夫人は中井桜洲氏の愛嬢で美人のきこえが高かったが、放胆な家庭に人となったので、有為の志をいだく青年の家庭をおさめる事は出来にくく離別になったが、困らぬように内々面倒は見てやられるのだとも聞いていた。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日本｜街に加はつて日本画を描いたり日本｜陶器を売つたりして居る真面目な両親の愛嬢である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレ浜子さんは御愛嬢だから。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には貴族の子もあり富豪の愛嬢もあり、また学者の後裔もある。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は花を襟に挿して、残りの十の、まだ朝露にぬれたのを、日記の間にはさんで、もう今は世に亡き、高野兄の愛嬢に贈った。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "道三に会って、信秀の長男信長のヨメに道三の愛嬢濃姫をいただきたい、そして末長く両家のヨシミを結びたいと懇願したのである。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人と二人の愛嬢によろしく。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めわたしはさして苦しまずに、女主人公の老父がその愛嬢の帰朝を待つ胸中を描き得たのは、維新前後に人と為った人物の性行については、とにかく自分だけでは安心のつく程度まで了解し得るところがあったからである。",
              "citation": {
                "source": "十日の菊",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田氏はホテルの食堂で、日ごろ尊敬する石井長六閣下の愛嬢に対する、沼間一族の高慢無礼な仕打ちに腹を立て、義憤のあまり、報酬的に沼間家の裏の事情をワニ君にすっぱぬいた。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "この競売を一層効果的にするために、時局｜柄、光栄ある石井長六閣下の愛嬢を、近親として手元にひきつけておく必要があったのだ。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "為也の別て、一郎が気骨を愛し、古参を超えて任用の、一ツは秘蔵の愛嬢が、教科書の復読をさへに、これに托したるを妬めば、得意につけ、失意につけ、さても至るところ冷笑の多き世や。",
              "citation": {
                "source": "誰が罪",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年十五の御愛嬢、母御におくれたまひしが、もの読む事を好みたまひて。",
