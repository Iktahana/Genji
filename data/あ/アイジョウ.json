        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、哀情は私たちの生活に欠かせません。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスシーンでは哀情が重要です。",
              "source": "幻辞"
            },
            {
              "text": "哀情に関する科学的研究が進みました。",
              "source": "幻辞"
            },
            {
              "text": "その小説では哀情が物語の中心となっています。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で哀情について学びました。",
              "source": "幻辞"
            },
            {
              "text": "医師から哀情についてのアドバイスを受けました。",
              "source": "幻辞"
            },
            {
              "text": "法律では哀情について明確に定義されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合では哀情が勝敗を決めました。",
              "source": "幻辞"
            },
            {
              "text": "自然界では哀情が見られる現象です。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に哀情は重要な位置づけです。",
              "source": "幻辞"
            },
            {
              "text": "料理において哀情は重要な食材です。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に哀情を見学することができました。",
              "source": "幻辞"
            },
            {
              "text": "朝食の時に哀情をいただきました。",
              "source": "幻辞"
            },
            {
              "text": "営業会議で哀情が議論されました。",
              "source": "幻辞"
            },
            {
              "text": "実験の結果、哀情の性質が明らかになりました。",
              "source": "幻辞"
            },
            {
              "text": "著者は哀情を象徴的に表現しています。",
              "source": "幻辞"
            },
            {
              "text": "教科書の第三章は哀情に関する内容です。",
              "source": "幻辞"
            },
            {
              "text": "健康診断で哀情について医者に相談しました。",
              "source": "幻辞"
            },
            {
              "text": "法的な観点から哀情は重要な問題です。",
              "source": "幻辞"
            },
            {
              "text": "アスリートは哀情を高めるため日々訓練しています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "『そこで僕は今夜のような晩に独り夜ふけて燈に向かっているとこの生の孤立を感じて堪え難いほどの哀情を催して来る。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其夜、淡い霞のやうに僕の心を包んだ一片の哀情は年と共に濃くなつて、今はたゞ其時の僕の心持を思ひ起してさへ堪え難い、深い、靜かな、やる瀬のない悲哀を覺えるのである。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫時無言で二人は歩いていたが、大友は斯く感じると、言い難き哀情が胸を衝いて来る。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその夜、うすいかすみのように僕の心を包んだ一片の哀情は、年とともに濃くなって、今はただその時の僕の心持ちを思い起こしてさえ堪えがたい、深い、静かな、やる瀬のない悲哀を覚えるのである。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどかれも年若き男なり、時にはわが語る言葉の端々に喚びさまされて旧歓の哀情に堪えやらず、貴嬢がこの姿をかき消すこともあれど、要するに哀れの少女よとかこつ言葉は地震の夜の二郎にはあらず、燃ゆる恋はいつしか静かなる憐みと変われり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何心なくながめてありしわれは幾百年の昔を眼前に見る心地して一種の哀情を惹きぬ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の上に山が重なり、秋の日の水のごとく澄んだ空気に映じて紫色に染まり、その天末に糸を引くがごとき連峰の夢よりも淡きを見て自分は一種の哀情を催し、これら相重なる山々の谷間に住む生民を懐わざるを得なかった。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と自分は何心なく答えて、そしてわれ知らず、未だかつて経験した事のない哀情が胸を衝いて起こった。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡老人はそのまま三人の者の足音の聞こえなくなるまで対岸を白眼んでいたが、次第に眼を遠くの禿山に転じた、姫小松の生えた丘は静に日光を浴びている、その鮮やかな光の中にも自然の風物は何処ともなく秋の寂寥を帯びて人の哀情をそそるような気味がある。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしい切々たる哀情が私の胸をうつた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "梯子飮みの蝶二、獨り舟中にて飮み、獨り醉ひて獨り元氣なるにひきかへ、天隨悄然として溜息をもらせるは、歡樂きはまりて哀情多きにや。",
              "citation": {
                "source": "水戸觀梅",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分を憐れむともＫを憐れむとも知れない哀情がこみ上げて、Ｋの手を取り上げてなでてみたい衝動を幾度も感じながら、女々しさを退けるようにむずかゆい手を腕の所で堅く組む。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「歓楽｜極まって哀情多し」というか、「満足の悲哀」というか、とにかく不満の反対は退屈です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇はその哀情を深く思召され勅諚をもって繍帳を二張つくらしめ給うた、その下絵には絵師の東漢末賢、高麗加世溢、漢奴加己利を、尚｜椋部秦久麻をその令者として諸采女たちに繍を命じ給うた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれを聞いている中に、自らな一味の哀情が、徐に彼をつつんで来るのを意識した。",
              "citation": {
                "source": "或日の大石内蔵助",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日でも支那の葬式は、外觀の形式の仰々しい割合に、肝心の死者に對する哀情が伴はぬ。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "山上に屹立する二百十八尺の円筒形白色の表忠塔が、その白色の故に特に予等の哀情を痛切ならしめた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓地は平原の中に広大な地域を占めて、楡の森が好い若葉の蔭を成してゐる間に、大理石の欧風の墓碑が白く並び、墓碑毎に花環とラムプの燭とが棒げられ、また其前に色色の花が植ゑられてゐる光景は、日本の墓のやうに陰気でなくて卻て哀情が深い。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然異郷で逢つて、一所に旅行した日数は短かつたが、共に経験した地域と情趣は広く且つ深いので、唐人の「我は瀟湘に向ひ、君は秦に向ふ」と云つたやうな別離の哀情を感じるのであつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄瑠璃に哀情のたっぷりある盲人｜沢一お里の、夢か浮世かの壺坂寺に詣でて、私はただひとり草鞋の紐のゆるんだのを気にしながら、四月の黄な菜の花匂うほこりの路をスタスタと、疲れてしかし夢みつつ歩いて行った。",
              "citation": {
                "source": "菜の花物語",
                "author": "児玉花外",
                "note": "青空文庫"
              }
            },
            {
              "text": "離別の際、作左が武骨の哀情眼前に髣髴たり。",
              "citation": {
                "source": "大久保湖州",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの哀情深くはぐまれて、「郭公の賦」、「破甕の賦」、「夕暮海辺に立ちて」、「暗夜樹蔭に立ちて」、「夕の歌」等の秀什は成りぬとおぼゆ。",
              "citation": {
                "source": "『行く春』を読む",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「錦風波」の吹き方は、日本海の荒海のように豪壮で、淡泊で、しかもその中に、切々たる哀情が豊かに籠っている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「歓楽きわまりて哀情多し」の感なきを得ない。",
              "citation": {
                "source": "美食七十年の体験",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と亡びゆく古るい街、その間に永い哀情が横たへ、深かい／＼闇に沈んでゆく。",
              "citation": {
                "source": "古街",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この朝鮮人が、朝鮮には考古学的の興味がまるで無いことを正直に告白した言葉は、私の哀情をそそった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
