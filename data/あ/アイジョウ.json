  {
    "uuid": "925155a1-251a-5d06-bb05-ab81d6d53a23",
    "entry": "愛嬢",
    "reading": {
      "primary": "あいじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
