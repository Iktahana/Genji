        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日アナーキストについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アナーキストという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアナーキストの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアナーキストが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アナーキストを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアナーキストについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アナーキストの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアナーキストの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアナーキストが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アナーキストという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアナーキストという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアナーキストについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アナーキストを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアナーキストは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アナーキストについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアナーキストが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアナーキストは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアナーキストの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アナーキストは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアナーキストは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私は自分が悪文家であるからでもあろうが、夙くから文章を軽蔑する極端なる非文章論を主張し、かつて紅葉から文壇の野獣視されて、君の文章論は狼の遠吠だと罵られた事があるくらい、文章上のアナーキストであったから、文章論では二葉亭とも度々衝突して、内心｜窃に二葉亭の古い文章家気質を慊らなく思っていた。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アナーキストの看板じゃタウルの半ダースぐらいじゃ引受けられない」といって笑った。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンマ・ゴルドマンを私淑する危険な女アナーキストとは少しも見えなかった。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大杉に何処かソコラの木の下に立ってもらってアナーキストの避難は面白かろう。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナーキストでも地震の威力には協わない、」と笑った。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居乎何乎は知らぬが大杉はアナーキストとして死んだ。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "百年｜稀に見る自然の大破壊を背景として大陸軍を背後に控える一軍憲の手でアナーキストに相応しい最後の幕を閉じた。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いかにもアナーキストらしいその最後に一寸暗い心を誘はれるのであつた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬瓶で寝台のふちを叩きながら革命歌かなんか歌っているうちに死んじゃったのですが」　いかにもアナーキストらしいその最後にちょっと暗い心を誘われるのであった。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（アナーキストとの分離、マルクス主義的転換に関する論争激甚を極めたる時代、一面、福本主義的政治理論の文芸理論の領域における移入の時代、日本プロレタリア芸術連盟の分裂、労農芸術家連盟の結成、同連盟の分裂、前衛芸術家同盟の結成等。",
              "citation": {
                "source": "『文芸評論』出版について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "グロッスはアナーキスト的な世界観で、階級的醜と悪とを暴露したのはいいが、暴露しっぱなしだ。",
              "citation": {
                "source": "新たなプロレタリア文学",
                "author": "――アレゴリーと諷刺――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシアの歴史的なアナーキストであり、地質学者でもある公爵ピョートル・クロポトキンが一九〇一年に、ボストン市で「ロシア文学の理想と現実」という講演をやったことがあった。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バクーニン、クロポトキン、ルクリュ、マラテスタ、その他どのアナーキストでも、まず巻頭には天文を述べてある。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルベエル（仏国アナーキスト）の『自由恋愛論』を読む。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "バクーニン、クロポトキン、ルクリュ、マラテスタ、その他どのアナーキストでも、まず巻頭には天文を述べている。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "イプセン、エレン・ケイの婦人解放思想がうけ入れられたが、やがて奥村博史と結婚したらいてうの生活が家庭の平和をもとめて『青鞜』の仕事から分離したことと、その後をひきついだ伊藤野枝がアナーキスト大杉栄とむすばれて、神近市子との間に大きい生活破綻をおこしたことなどから、『青鞜』は歴史の波間に没した。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕角帯をしめ、野枝さん丸髷に赤き手柄をかけ、黒襟の衣物を着し、三味線をひき、怪し気なる唄をうたったが、一躍して婦人解放運動者となり、アナーキストとなって一代の風雲児と稀有なる天災の最中、悲劇的の最後を遂げたるはまことに悲惨である。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、僕の交遊の種類はまことに千差万別で、僕はどうやら、社会の職業は文士であるようではあるが、文士や芸術家以外に職人、役者、相場師、落語家、娼婦、社会主義、船乗り、アナーキスト、坊主、女工、芸者、――その他なんでもござれである。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧州大戦三年目の日本では、吉野作造がデモクラシーを唱え一般に強い反響をよびおこしていたが、『新社会』による堺、高畠、山川均等と『近代思想』によるアナーキスト大杉栄との間に、思想的対立の兆したのは既にその前年のことであった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼自身のアナーキストとしての理論やその実践に含まれていた破綻の因子については、追究の筆をすすめていない、雑文家の才筆で現象を語っているだけで、「マア理窟はどうでもいいとして」と云って過ぎている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして日本プロレタリア芸術連盟（プロ芸）となり、『文芸戦線』もアナーキストとして態度を明瞭にした村松正俊、中西伊之助等が中心を退いた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」は、この作者の代表作である「施療室にて」などとともに、アナーキストである男と朝鮮、満州を放浪した時代の生活を描きつつそこから何かの方面へ脱け出て行こうとする一人の若い女性のもがきを描いたものであった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二七年にかかれた「嘲る」という短篇は、大正末から昭和のはじめ頃のアナーキストの群の生活感情、ものの考えかたを、そのうちに息づいた女の側からむき出しに描いていて、これまでの婦人作家の文学にない世界を展開した。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はその男の部屋へ訪ねてゆき、来あわせたアナーキスト仲間と丸の内の或る会社の寄附デーへ出かけて行って、五円ずつのところを十円とって来る。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "江口渙、壺井繁治、今野大力などアナーキストであった作家詩人が、次第に共産主義に接近しつつあった。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第二巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナーキスト出身で著名な婦人作家で、その才能の素質と妻としておかれている偽瞞的な環境のためにアナーキズムから社会観を本質的に高められることができず、労働者弾圧にも動員される右翼の暴力団の生活に近接する機会をもつようになって、その描きてとしてあらわれているひともある。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十五巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はそんなアナーキストと関係はない。",
              "citation": {
                "source": "殺人狂の話",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は実に神のアナーキストである」と。",
              "citation": {
                "source": "殺人狂の話",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＥとＴ氏とはいろんな点で従来は深いつながりを持つてゐたが此の五六年Ｅのアナーキストとしての旗幟が鮮明になると同時に思想的にも、感情的にも二人は折れ会ふ事が出来なくなつてゐた。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナーキストとして有名なクロポトキンには著書『倫理学』があり、マルクス主義運動家時代のカウツキーにさえ『倫理学と唯物史観』の著があるくらいである。",
              "citation": {
                "source": "学生と教養",
                "author": "――教養と倫理学――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
