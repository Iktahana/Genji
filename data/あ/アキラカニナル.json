[
  {
    "uuid": "0753b65e-5800-54d4-b509-5bb1ed77ec92",
    "entry": "明らかになる",
    "reading": {
      "primary": "あきらかになる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
