        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "これはＩＳの例句です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そんな同年の五月、新しいＪＩＳ漢字コードの策定作業にあたっていた芝野耕司さんから、「青空文庫の作業の中で見つかった外字の情報を、まとめて提供してくれないか」と連絡をもらった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般のパソコンで使える漢字は、ＪＩＳ X ０２０８という規格で決められた、第一水準第二水準の範囲のものだ。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "後にＪＩＳ X ０２１３と名付けられる規格の第三水準第四水準漢字原案は、一九九八年一二月に示され、翌一九九九年二月末を締め切りとして公開レビューが行われることになっていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三水準第四水準の漢字を定めたＪＩＳ X ０２１３は、二〇〇〇年一月に制定された。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "この反省を踏まえ、新しい規格にもない文字の使用状況に関する調査が先々必要になった場合に備えて、作品中にＪＩＳ X ０２１３外字が使われていた際は、底本の何頁何行目に現れるかの情報を添え、外字情報だけを簡単に切り出せるように、ＸＨＴＭＬファイルの末尾に集約しておくことにした。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＯＳ／２だＷｉｎｄｏｗｓだ、ＵＮＩＸは流行る流行らん、ＲＩＳＣがああだ、Ｌａｎ　Ｍａｎａｇｅｒがこうだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ハードウエアでは、独自に開発したＲＩＳＣタイプのマイクロコンピューター、ＳＰＡＲＣのデザインを半導体メーカーにライセンスし、ハード・メーカーにＳＰＡＲＣマシンの開発を促して、標準アーキテクチャを確立する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ここに出てきたＲＩＳＣという暗号は、縮小命令セット・コンピューター＝ Reduced Instruction Set Computer という念仏の略である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにコンパックは、ＲＩＳＣという高速化技術に対応するに当たって、良く言えば当初から標準化を目指す、別の言い方をすれば徒党を組む戦術にでた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンは誰が何といおうとＳＰＡＲＣを推進するし、アップルは自分でマッキントッシュのＯＳをＲＩＳＣに乗せる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンパックとしても、ＲＩＳＣに対応しないことのリスクは大きすぎる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずは本命の、ミップス製ＲＩＳＣを使用したマシン。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの柱だったはずのデジタルイクイップメントは、ＲＩＳＣに関して独自路線に大きく舵を切り直した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コムデックスの会場では早くもミップスのＲ４０００（吉野家流でスピードを稼ぐ、例のＲＩＳＣ方式のマイクロコンピューターだ）の上でＷｉｎｄｏｗｓＮＴが動いていたそうで、これはこれで実にたまげた話ではある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで出てきたのが、一段上のＲＩＳＣ（吉野家）レベルでのＩＢＭ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロコンピューターはインテルの３８６以上かミップスのＲＩＳＣ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かに５８６やＲＩＳＣで動かせば、そいつは速いだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃこのオレも、大組織の運営効率を高めるＭＩＳ部門のエリートにでも収まっているのなら、システム本位で物事を考えるかも知れない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして次のステップはＩＢＭの開発するＲＩＳＣチップ、ＰｏｗｅｒＰＣを将来のハイエンドのマッキントッシュに採用していく点。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを従来の自社のＲＩＳＣチップＳＰＡＲＣに加えて、インテルのマイクロコンピューターにも載せ、幅を持ったＨＭＮＭプラットフォームとしようということだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "不況も加わってＭＩＳ部門に予算圧縮の圧力がかかり、メインフレーム中心のメーカーは従来のスタイルは通らないと白旗を上げた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレが何をほざこうと、あんたたちはＭＩＳ予算の分捕り合いに血道を上げるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "見りゃ、わかるだろうが」　高志は、ばかばかしそうに、横断歩道のむこうに見える「ＩＳＥＺＡＫＩ　ＣＨＯ」と書かれた、骨組だけの塔のようなものを、アゴでしゃくって示した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｑ１Ｎ　　　＿＿＿＿＿＿１ＭＬ）ＱＴＰＡＩ　　　　ＱＩＳ　　　　―――――　　　　　ＱＰＡ　　　　　１ＭＬ　　　　　――――　　　　　１１１Ｉ　　　　　１ＳＮＳ　　　　　――――　　　　　　　ＭＩ　さあ、こんどはどこに第二の鍵を發見すべきであらうか。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｑ１Ｎ　　　＿＿＿＿＿＿１ＭＬ）ＱＴＰＡＩ　　　　ＱＩＳ　　　　―――――　　　　　ＱＰＡ　　　　　１ＭＬ　　　　　――――　　　　　１１１Ｉ　　　　　１ＳＮＳ　　　　　――――　　　　　　　ＭＩ　さあ、こんどはどこに第二の鍵を発見すべきであろうか。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＯＮ・ＰＡＲＩＳ！",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＦＩＮＩＳ　といったように、これだって君、あの、この頃産業的に需用の多い「朝飯の食卓で焼麺麭・卵子・珈琲と一しょに消化してあとへ残らない程度の退屈で幸福な近代結婚生活の小説」の作例には、ちゃんとなってるじゃないか。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇黒がＬＩＳＢＯＡの海岸通りを包むとき！",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "その古趣と不潔と野蛮と俗臭の小首府、神様と文明に忘れられたＬＩＳＢＯＡが、こうおりぶ油くさい嗄れ声を発して僕の入市に挨拶した。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすることによって、僕は完全にＬＩＳＢＯＮ港の｜お客になってたのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            }
          ]
        }
