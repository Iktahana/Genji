        "examples": {
          "standard": [
            {
              "text": "健康的な食生活を心がけることが大事。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣は体の健康に直結する。",
              "source": "幻辞"
            },
            {
              "text": "医学的な知見に基づいた治療を受ける。",
              "source": "幻辞"
            },
            {
              "text": "健康診断の結果は良好だった。",
              "source": "幻辞"
            },
            {
              "text": "予防医学の重要性が認識されている。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断により病状が明確になった。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションが回復を助ける。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的なアドバイスが役に立つ。",
              "source": "幻辞"
            },
            {
              "text": "精神衛生も身体の健康と同等に大事だ。",
              "source": "幻辞"
            },
            {
              "text": "ウイルス対策が日々の課題となっている。",
              "source": "幻辞"
            },
            {
              "text": "最新の技術革新により製品性能が向上した。",
              "source": "幻辞"
            },
            {
              "text": "研究チームは新しい発見に成功した。",
              "source": "幻辞"
            },
            {
              "text": "理論的な検証が実施されている。",
              "source": "幻辞"
            },
            {
              "text": "科学的な方法論に基づいた実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "技術的な課題の解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "量子力学の原理が応用されている。",
              "source": "幻辞"
            },
            {
              "text": "遺伝子研究が医学に革命をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "人工知能の発展が急速に進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "ナノテクノロジーの可能性は無限だ。",
              "source": "幻辞"
            },
            {
              "text": "宇宙技術の進展により新しい知見が得られた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "廊下の東詰の流しの上の明かり窓から病院の動物小屋が見える。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、およその見当に温泉の浴室があり、その建物の高い軒下には天井の周囲を帯状にめぐらす明かり窓があって浴室内の電燈の光に照らされたその窓が細長い水平な光の帯となって空中にかかっている。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの可能性は、上記の浴室の軒の明かり窓の光が一時消えていたのが突然ぱっと一時に明るくなったと仮定すると、その光の帯が暗がりになれていた人の横目には一方から一方に移動する光のように感ぜられたのではないかということである。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、船長が明かり窓を降りて来るのが聞こえるぞ。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼の力は足らず、集会室の明かり窓によろめき退って来て、そこに彼はあえぎ疲れて倚りかかってしまった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔色は蒼白となったので、私はきっと彼が意識を失うものと思って、時を移さずに彼を伴って明かり窓を降りて、船室のソファの上にそのからだを横たえさせた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "目は刃物のようだが、それを見ず顔だけに明かり窓の光を当てたら、喜んでいるとも受け取れる、といった具合だ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その影は消えて、僕のからだは廊下の明かり窓の手欄に支えられているのに気がついた時、初めて僕はぞっとして髪が逆立つと同時に、冷や汗が顔に流れるのを感じた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "上床",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで原稿や帳簿の取り出しにかかって、まだその全部を出し切らないうちに、もう明かり窓の上の日覆いに火がついていた。",
              "citation": {
                "source": "地異印象記",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は最上階へ上がって、天井の明かり窓を点検する。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初ちょっと不審なそぶりを見せたが、邸宅が静かで、明かり窓がこうこうと輝いているので、疑惑が晴れたようだ。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
