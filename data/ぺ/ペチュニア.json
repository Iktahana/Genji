        "examples": {
          "standard": [
            {
              "text": "春から秋にかけて、庭のプランターにはピンクや紫の鮮やかなペチュニアの花が咲き乱れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ホームセンターの園芸コーナーで、雨に強い品種に改良されたという新しいペチュニアの苗を買ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ペチュニアは次々と花を咲かせるので、こまめに花がら摘みをしないとすぐに株が弱ってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ペチュニアの甘っぽい香りが、覧台の墻の下に眠ってる暗い運河の、白けたやや腐れっぽい匂いに交っていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
