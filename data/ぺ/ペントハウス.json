        "examples": {
          "standard": [
            {
              "text": "彼は都心の超高層マンションの最上階にある、豪華なペントハウスに住んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ペントハウスのテラスからは、街の夜景が一望できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一度はこんな広いペントハウスで、パーティーを開いてみたいものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女が来たら部屋はこのぼくに世話させてくれ、と友人のエドワードが言い張り、このコンドミニアムのペントハウスに部屋をとってくれた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の気配のない静かな建物のなかに入り、エレヴェーターでぼくたちはペントハウスに上がった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのペントハウスの部屋は、簡単に言ってしまうなら、３ベッドルームだ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
