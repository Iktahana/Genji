        "examples": {
          "standard": [
            {
              "text": "洗顔後、化粧水を肌にしっかり浸透させるために両手で頬をペシペシと叩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "子供が水たまりを長靴でペシペシと踏んづけて、泥水を跳ね上げながら遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "言い合いになった途端、彼女は怒って丸めた雑誌で彼の背中をペシペシと連続で叩き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "（ペシペシと枯れ枝を踏んで走りおりて来る）敦子　（これも、それに従いながら）そんなに急いでは転ぶわ春子さん！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お豊　……（ペシペシとタキギを折りくべながら）また吹雪が来るようだなし。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
