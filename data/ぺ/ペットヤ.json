        "examples": {
          "standard": [
            {
              "text": "商店街の角にあるペット屋のショーケースを覗くと、可愛い子犬が元気に跳ね回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔ながらのペット屋で、水槽の掃除をしている店主と金魚の飼い方について話し込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "週末になると、ペット屋の奥にあるトリミングサロンには多くの飼い主が訪れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "トランペットやトロンボンのはげしい爆音の林立が斜めに交互する槍の行列のような光線で示されるところもあったようである。",
              "citation": {
                "source": "踊る線条",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トランペットやサキソオホンの物哀しい誘ふやうな音色が遠くでしてゐた。",
              "citation": {
                "source": "下町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
