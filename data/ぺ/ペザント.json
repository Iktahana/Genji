        "examples": {
          "standard": [
            {
              "text": "舞台の衣装合わせで、彼女は中世の農民をイメージした素朴なペザントルックのドレスを試着した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "美術館で見た19世紀の絵画には、厳しい自然の中で働くペザントたちの生活がありありと描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "春夏のファッショントレンドとして、ふんわりとしたシルエットのペザントブラウスが注目を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「この麻糸をこんなに並べたところなぞはオースタリヤあたりのペザント・アートにでもありさうだね。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝいふ素朴なペザントアートがまだ田舍には殘つてゐるであらうか。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
