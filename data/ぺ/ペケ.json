        "examples": {
          "standard": [
            {
              "text": "テストの答案用紙が返ってきたら、自信があった数学の図形問題に大きなぺけがつけられていて落ち込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "回覧板の自分の名前の横に、確認済みの印として赤いペンで小さくぺけを書いておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "間違えて入力した箇所には、分かりやすいように赤色でぺけのマークをつけておいてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
