        "examples": {
          "standard": [
            {
              "text": "彼の父は長年、建物の外壁を美しく塗り替えるペンキ職人として働いてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "熟練のペンキ職人が手掛ける仕事は、仕上がりが格段に違う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ペンキ職人になるためには、色の知識と塗装技術が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――『その日も昼間に一度やって来たペンキ職人のミコライという男が、金の耳輪と宝石類のはいったこの箱を持って参りまして、それを抵当に二ルーブリ貸してくれと申します。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
