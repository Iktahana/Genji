        "examples": {
          "standard": [
            {
              "text": "ペプシコは飲料だけでなく、フリトレーブランドのスナック菓子も展開している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "投資家として、ペプシコの株価チャートと配当利回りをチェックした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ペプシコは世界最大級の食品・飲料メーカーであり、多くの有名ブランドを所有している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼はペプシコ社から移籍して社長となっていたジョン・スカリーあてのメモで、「一リットルのガソリンタンクしか持たないホンダ」とマックを評した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動販売機でジュースを買って来ようと思い、浩がふと立ち上がって部室を出ようとすると俊文に呼び止められ、ペプシコーラをついでに買って来てほしいと言って百円玉を渡された。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、併し、ペプシコーラの方が好きだったが。",
              "citation": {
                "source": "清涼飲料",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
