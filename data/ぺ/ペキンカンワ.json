      {
        "index": 1,
        "gloss": "Beijing dialect of Standard Chinese as spoken during the Qing dynasty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
