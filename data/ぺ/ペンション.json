        "examples": {
          "standard": [
            {
              "text": "家族旅行で、富士山の見える小さなペンションに泊まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬になると、スキー客で賑わう高原のペンションは予約が取りにくい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学生時代の友人たちと、貸し切りのペンションで久しぶりに再会した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また、粘土などを水に混じた微粒のサスペンションが容器の中で水平な縞状の層を作る不思議な現象がある。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "びっくり、びっくり」　フレームやサスペンションの出来ぐあいについて、沢田は、シートにミーヨをまたがらせたまま、説明して聞かせた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
