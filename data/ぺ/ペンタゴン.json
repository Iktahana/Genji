        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ニュースで、ペンタゴンが新しい国防予算案を発表したと報じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ペンタゴンの建物は、上空から見ると巨大な五角形をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はワシントンD.C.のペンタゴンで情報分析官として働いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "吉田のペンタゴンか。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンタゴンなんか相手にしていたんじゃなあ……柿江なんぞも、田舎新聞にひとりよがりな投書ぐらい載せてもらって得意になっていないで、ちっと眼を高所大所に向けてみろ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二次世界大戦の間は、実際の軍務にも、ペンタゴン勤務にすら高齢すぎるため、４Ｆ(*5)の者と少年と太鼓腹の中年男たちからなる国防市民軍中隊の練兵にあたった。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
