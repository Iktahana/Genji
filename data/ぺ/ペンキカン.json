        "examples": {
          "standard": [
            {
              "text": "物置の奥から、数年前に使ったペンキ缶が出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "空になったペンキ缶は、地域の回収日に出す必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はペンキ缶の蓋を丁寧に開け、中身を混ぜ始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その上に、気にかかるのは、彼の秘蔵していたペンキ缶に仕かけてある短波無電器がなくなって、今は祖国日本へこの重大な心配を通信するみちがなくなったことである。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ある日主人が店の間へ出て来ると、多くのペンキ缶のなかに、たつた一つ曾ぞ自分の店で取扱つた事の無いペンキ缶が転がつてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
