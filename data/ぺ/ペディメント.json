        "examples": {
          "standard": [
            {
              "text": "ギリシャ神話の神々が彫刻された巨大なペディメントが、神殿の入り口で威容を誇っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ルネサンス様式の建物の窓上にある、三角形のペディメントの意匠に目を奪われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その古い銀行の正面には、精巧な装飾が施されたペディメントが今も残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "今ややつれが目立つ彩色されたペディメントに赤いヒールと鬘が映えていた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
