        "examples": {
          "standard": [
            {
              "text": "週末は趣味のボディペインティングのイベントに参加して、全身をアートに変える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "現代美術の展覧会で、大胆なペインティングの手法を用いた作品が注目を集めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古くなった家具にDIYでペインティングを施し、アンティーク風に仕上げてみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "クアラスリシーの呉れたラジプット・ペインティングの中に集められた画との対照が、自ら心に生じる。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はコーレアンの作とは信ぜず、ラジプット・ペインティングの中に集められたものとごく似たもの（線の活々しさ、純粋さ、）豊満さ、特に眼、唇の特長などを認める、ただ純インドのあの圧迫的くらさは少し。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようにして、皮膚に土を塗りつけることが身体のペインティングになり、傷を乱切して土やゴミを塗るのは（痛みが減るかどうかは別として）入れ墨になる。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来上がったときには、畳二枚ほどの大きなオイル・ペインティングでね。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
