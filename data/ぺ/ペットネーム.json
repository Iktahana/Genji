        "examples": {
          "standard": [
            {
              "text": "このモデルの製品には、社内だけで通用するユニークなペットネームが付けられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「サブマリーナー」というペットネームは、時計愛好家の間で広く浸透している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新型車両に愛着を持ってもらうため、一般公募でペットネームを決定することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこに菅谷君という小僧さんがいてね、一種のペットネームのようにうちでは伝八さんと云っていたの、わたしはそういう名だと思っていたら、本名ではなかったのですって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
