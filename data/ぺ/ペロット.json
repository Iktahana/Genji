    "definitions": [
      {
        "index": 1,
        "gloss": "(eating up) quickly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「お腹空いてたんだね、ケーキをぺろっと平らげちゃった！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供は出されたご飯をぺろっと食べて、おかわりを要求した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は大盛りラーメンもぺろっと完食してしまう大食漢だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "僕はあいつを最初｜瞥見したとき、こんにゃくの舌で顔をぺろっと舐められたような気がしたよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一升ほど持って帰っても、じきにぺろっと失くなるのやそうで……」　峻が語を聴きながら豆を咬んでいると、裏口で音がして信子が帰って来た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女だってもう結婚するんですもの」　そして急に眼鏡を外して、そっと涙を拭いたかと思うと、何思ったのかいきなり、ぺろっと舌を出して、幸福そうに笑った。",
              "citation": {
                "source": "眼鏡",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足ずつ静かに近寄って、適当な距離に来ると、じっとカナブンを見守っているのだが、死んだものは食えぬとでもいうのか、カナブンが身動きするのを見届けてはじめて、ぺろっと食ってしまうのだ。",
              "citation": {
                "source": "月見草",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "家ん中、もう、なんちゃ売るもんもないんで」「そんなこと、いわんものよ」　かるく背中をたたくと、小ツルはぺろっと舌を出す。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぺろっと舌を出し、はっはっとかわいらしく笑った。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　閑子はぺろっと舌を出した。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "津留はうちひしがれたように溜息をつき、よわよわしく立って、廊下へ出るなりぺろっと舌を出した、そして自分の部屋へはいっていった。",
              "citation": {
                "source": "思い違い物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十太夫が「やかましい」とどなり、おみのが燗番をひき受け、おわかたちは去っていったが、出てゆくときにおわかは振返って、十太夫にぺろっと舌を見せた。",
              "citation": {
                "source": "饒舌り過ぎる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときの印象が強烈だったのだろう、ずっと大きくなってからも、女の顔をみつめていると、その口が急に耳まで裂け、赤い舌をぺろっと出すように思える。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼き魚は骨までしゃぶったし、歯にはさまった小骨は、口へ指を突っ込んでほじり出し、ちゃぶ台の上へこすりつけ、その指を平気でぺろっと舐めた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、赤いしたをぺろっと出して、「おじさん、こんにちは……。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "quickly (sticking out one's tongue)",
        "register": "standard",
