        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "日焼けした背中の皮が、ぺろっとむけてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "壁に貼ったポスターが古くなり、端からぺろっと剥がれてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゆで卵の殻が、きれいにぺろっと剥けて気持ちよかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
