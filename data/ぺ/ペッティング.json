        "examples": {
          "standard": [
            {
              "text": "映画のレイティング審査で、過激なペッティングのシーンが含まれているため15歳未満の鑑賞が制限された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "思春期の若者向けに、避妊や性感染症予防だけでなく、ペッティングのリスクについても正しい知識を教えるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "車のバックシートでペッティングに夢中になっていたカップルが、巡回中の警察官に窓をノックされて慌てていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ペッティングっていうのはね、とささやいたあとは、なにを云っているのかまったく聞こえなかった。",
              "citation": {
                "source": "超過勤務",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレガ成立シタバカリデナク、母ノ忰デアル予ガ孫ノ嫁ノ魅力ニ溺レ、彼女ニペッティングヲ許シテ貰イ、ソノ代償ニ三百萬圓ヲ投ジテ猫眼石ヲ買ッテヤルナンテ事件ガアッタラ、母ハ驚イテ気絶スルダロウ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
