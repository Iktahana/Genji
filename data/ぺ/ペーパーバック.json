          "standard": [
            {
              "text": "電車での読書には、軽くて持ち運びやすいペーパーバックが最適だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新刊がハードカバーで発売された後、数ヶ月でペーパーバック版も出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の書棚には、様々なジャンルのペーパーバックがぎっしりと並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あまり眠くないので読みかけのミステリーのペーパーバックを開いて寝ながらページを繰った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどペーパーバックを読み終わるか終わらないかぐらいの頃に、いつも決まって訳本が発刊になるんだもの。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
