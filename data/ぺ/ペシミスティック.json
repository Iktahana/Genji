        "examples": {
          "standard": [
            {
              "text": "彼は失敗を恐れるあまり、新しいプロジェクトに対しても常にペシミスティックな見方をしてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "会議で彼女が発言すると、あまりにもペシミスティックな意見ばかりで職場の空気が重くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "経済の先行きについて、専門家たちはかつてないほどペシミスティックな予測を立てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もっともその他の点では、その考え方はペシミスティックである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "螽が嗤ふほどのペシミスティックな子供たち！",
              "citation": {
                "source": "希臘十字",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろペシミスティックであり、ペシミスティックでありながら、体に作用してくる不思議な音だった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴隷労働者たちが教会でうたったスピリチュアルな歌は、このつらさの歌であり、世代がすすむにつれて、いつかは死によってこの求めざる土地から解放され天国にいけるのだという、宗教上の希望によって支えられたペシミスティックな生の肯定の歌にかわった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この穴のなかから、一九五〇年代のなかばに、ある種の人たちを這いあがらせてとりあえず解放したのが、すぐれてハッピーで同時にペシミスティックなあのロックンロールだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちらっと明るいところがあって、そのほかはペシミスティックでブルーな曲にしようと思ってるんだけど、セリカで走っているうちに、オートバイも曲のなかにとりこみたくなったんだ」「なるほど」「日曜日に馬鹿な四輪でトロトロ走ってるうちに、男は何度もオートバイを見る。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
