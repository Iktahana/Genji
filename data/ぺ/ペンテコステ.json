        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ユダヤ教の祭日であるペンテコステには、初物の収穫を感謝する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "七週の祭り、別名ペンテコステのために、人々はエルサレムに集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "伝統的な家庭では、ペンテコステにチーズケーキなどの乳製品を食べる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
