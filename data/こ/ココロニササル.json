        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "信頼していた友人から放たれた無神経な一言が、鋭いトゲのように心に刺さった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「君にはもう期待していない」という冷淡な言葉が、いつまでも心に刺さって離れない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "些細な口論の最中に口を滑らせた皮肉が、相手の心に刺さる致命傷になってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "とたんに、彼の心に刺さるものがあった。",
              "citation": {
                "source": "ジャンの新盆",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
