        "examples": {
          "standard": [
            {
              "text": "授業が終わると、当番の生徒が黒板消しで黒板をきれいにする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は黒板消しを手に、チョークの粉を払い落とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "黒板消しが古くなっていたので、新しいものに交換した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "田口七郎兵衛は矢庭に黒板消しをつかんだが間にあわなかった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白雲頭の田口七郎兵衛は黒板消しを持ったまま不動のしせいをとった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は、また――男のセイトキライ――と書かれている方を見て微笑しながら、「さア、その黒板消しを先生にお返して、席におつきなさい」　と、静かに教壇に上って行った。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
