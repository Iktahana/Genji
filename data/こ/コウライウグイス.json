        "examples": {
          "standard": [
            {
              "text": "森の奥から高麗鶯の美しいさえずりが聞こえてきて、ふと足を止めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "黄色の羽が鮮やかな高麗鶯が、木の枝から枝へと軽やかに飛び移っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "双眼鏡を覗くと、高麗鶯が雛にせっせと餌を運んでいる様子がはっきりと見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また、先頃フィリッピンのバシラン島附近で高麗鶯の新種を発見して博物学界に貢献した、博物採集を仕事としている山村八重子さんの自分の仕事に対する愛情は、すべての事情からいわゆる商売気は離れています。",
              "citation": {
                "source": "現実の道",
                "author": "――女も仕事をもて――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
