      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to become hollow (with age, illness, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "久しぶりに会った彼は、病を患ったせいか頬がすっかり痩けていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "徹夜続きの仕事のせいで、鏡の中の自分の顔はひどく痩けて見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "年齢を重ねて顔が痩けてくると、どことなく寂しげな印象を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
