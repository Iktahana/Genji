  {
    "uuid": "588647e1-c2f1-526b-bf5e-d738a55753a3",
    "entry": "痩ける",
    "reading": {
      "primary": "こける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
