    "definitions": [
      {
        "index": 1,
        "gloss": "to continue heartily doing ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は負けず嫌いで、一度勝負が始まると最後までやりこける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幼い娘は、お気に入りのおもちゃでいつまでも遊びこけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夢中になって本を読みこけていたら、いつの間にか外が明るくなっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大概の家では女中らはもちろん奥さんや娘さんまでのぞきに出て来て、道化た面をかぶった異風な小こじきの狂態に笑いこける。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもないことにでも大聲たてて笑ひこける。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで子供らは、そういういくつかの取っておきの話の中から、あれをこれをと注文して話させては笑いこけるのであった。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また晴天の日、松林を走るやうな愉快な疳の高い日の氏は、腸の蟲まで笑ひこける、押へつけられないやうな氣がする。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私がその事を話すと男の児の様な快活な母は大きな口を開いて笑ひこけるのでした。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ばん先に欲しがられた雀こ、大幅こけるどもし、おしめの一羽は泣いても泣いても足えへんでば。",
              "citation": {
                "source": "雀こ",
                "author": "井伏鱒二へ。津軽の言葉で。",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　一日、雪降り凜※たる寒気の中を例の如く太七の家の前を通るうち、プッツと切れた下駄の鼻緒に転ぶ途端、無作法に笑ひこける太七の家の職人共に、何が可笑しいと詰り寄るうち、ふと一人の職人が細工場の戸を開けて外を窺つた。",
              "citation": {
                "source": "名工出世譚",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが大抵は語れば一座が皆どつと笑ひこけるやうなことのみに屬して居るらしい。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "この様子があまりに滑稽なので皆の笑いこけるのにつり込まれて自分も近ごろになく腹の中から笑ってしまった。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれにしても、正直ずっこける。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "草刈籠がすつと地上にこける時蜀黍の大な葉へ觸れてがさりと鳴つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "親に成つた一人が八｜本の綱の本を掴んで一｜度ぎつと指へ絡んでばらりと投げ出すと、悉皆が一つづゝ掴んで此れも其の端を指へぎりつと絡んで一｜度に引くと七｜本の綱が空しくすつとこける。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を動かせばずる／＼と下へこける。",
              "citation": {
                "source": "痍のあと",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "あせればあせる程こけるのである。",
              "citation": {
                "source": "痍のあと",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "躰を屈めると荷物がぶらつと胸へさがつて蓙が前へこける。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "思え、ただ仮初めの恋にも愛人の頬はこけるではないか。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついて来た女将は立ったまましばらく二人を見くらべていたが、「ようよう……変てこなお内裏雛様」　と陽気にかけ声をして笑いこけるようにぺちゃんとそこにすわり込んだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫が、他の女性のことを考えて、ボンヤリしているのを、可笑しいと云って無邪気に笑いこける妻のいじらしさが、分らない信一郎ではなかったが、それでも彼は刻々に頭の中に、浮んで来る美しい面影を拭い去ることが出来なかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくは、みんなが笑いこけるだろうな」　といって、高志は満足げな笑みを泛かべた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝こけるなんてのは、予測不能だ」　兄妹は声をそろえて笑った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
