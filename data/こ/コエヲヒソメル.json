        "examples": {
          "standard": [
            {
              "text": "「このことはまだ部長には内緒だよ」と、同僚は声を潜めてささやいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "真夜中のキッチンで、子供たちが親に隠れて声を潜めながらお菓子を食べている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "探偵は怪しい男たちの会話を録音するため、壁越しに声を潜めて待機した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」　姉は大きな声で笑ひかけたが、急に声を潜めると赤い顔をしてまた三重子の寝顔を窺つた。",
              "citation": {
                "source": "悲しめる顔",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内の者は何かしら気忙しそうに、物言いも声を潜めるようになり相手をしてくれることもなくなった。",
              "citation": {
                "source": "山の手の子",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして声を潜めるようにして、　実は僕も中学の入学試験に落第したことがあるんだ。",
              "citation": {
                "source": "先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じつはね、親分、」と甚八は声を潜める。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろぐらいことがなかったら、何も恐いことなんかありゃしないじゃないか」　山木は今にも泣き出しそうな顔になって、声を潜めると、「恐いことがあるんだ。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
