        "examples": {
          "standard": [
            {
              "text": "部下のミスを厳しく責めずに「次で挽回すればいい」と言える心の広い上司だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "どんな立場の人からの意見も偏見なく受け入れられる、心の広い人間でありたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は心の広い持ち主で、近所の野良猫たちの面倒も一手に引き受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "サンノム老人は、神のように心の広い人で、元は船長であったそうだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもお心の広いことだ。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにカチェリーナは、あれほど心の広い女でありながら、偏屈なところがあります……しかし、わしはちゃんとわかっとる……あいつがわしの髪を取って、引きずり回すのは、要するに憐憫の心から出ることにほかならん、それは自分でも承知しております。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の広い私と致しまして……」「マザロフ王子、キミの心の広さは評判じゃよ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
