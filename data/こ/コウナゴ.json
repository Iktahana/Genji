        "examples": {
          "standard": [
            {
              "text": "釜揚げされた小女子は、ご飯によく合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "漁師たちは、春の訪れと共に小女子漁に出かける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この小女子の佃煮、最高だね！」と彼は満面の笑みで言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」　おかみさんはいかがですと、小女子魚の佃煮を佐藤に分けてやると、佐藤は豆の煮たのを返礼にした。",
              "citation": {
                "source": "にぎり飯",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんは小女子魚は近処の浦安で取れるからお弁当のおかずには不自由しないような話をする。",
              "citation": {
                "source": "にぎり飯",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おかみさんはいかゞですと、小女子魚の佃煮を佐藤に分けてやると、佐藤は豆の煮たのを返礼にした。",
              "citation": {
                "source": "にぎり飯",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんは小女子魚は近処の浦安で取れるからお弁当のおかずには不自由しないやうな話をする。",
              "citation": {
                "source": "にぎり飯",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "是を紡績するに秘術ありて火浣布を造るなり、其秘術を得ば小女子も火浣布を織るべし。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、けっこうなごちそうが、まもなく出ましたが、若い王子は、サンドリヨンの顔ばかりながめていて、ひとつものどにはとおりませんでした。",
              "citation": {
                "source": "灰だらけ姫",
                "author": "またの名「ガラスの上ぐつ」",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちゃんとテーブルごしらえがしてあって、けっこうなごちそうと、のみものが、山とならんでいるよ。",
              "citation": {
                "source": "ブレーメンの町楽隊",
                "author": "DIE BREMER STADTMUSIKANTEN",
                "note": "青空文庫"
              }
            }
          ]
        }
