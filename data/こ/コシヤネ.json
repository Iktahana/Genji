        "examples": {
          "standard": [
            {
              "text": "伝統的な農家の屋根には、換気や採光のために小さな越屋根が設けられていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "越屋根のある家は、夏場でも熱気が上に逃げるため、室内が比較的涼しく保たれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あの越屋根のデザイン、この風景にとても馴染んでいて素敵ね」と観光客が話した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "角張ったジョージ王朝風の家には越屋根があり、扇状の彫刻のある古典的な戸口、小さなガラスをはめた窓といったあらゆる十九世紀初期の造りをしていた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトリエは越屋根のガラスから良い光線が入る北側の屋根裏に構えた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
