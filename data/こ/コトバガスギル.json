        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は酔っ払うと、つい言葉が過ぎてしまう癖がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "相手を傷つけるような言葉が過ぎる発言は避けるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「すみません、少し言葉が過ぎました」と彼は反省していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ミルキ閣下などはそばへ寄れないくらいの偉人なんです」「お言葉が過ぎるようにぞんじます。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「君子は言葉が過ぎるのを恥じる。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がその文章や作品で示している気質はひどく「貴族的」――というと言葉が過ぎる――たとえば芥川竜之介などと同じ系列に属する「選民意識」――と言ってもピタリと当った言葉とは言えないが、さればと言ってチョットほかに言いようのない高級な趣味的気質――に貫かれているものである。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
