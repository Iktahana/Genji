    "definitions": [
      {
        "index": 1,
        "gloss": "to do as one wishes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "退職後はスケジュールを立てず、その日の心に任せて気ままに過ごしたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "周囲の顔色を伺うのはもうやめて、一度くらい自分の心に任せて行動してみよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "筆の動くまま、心に任せて書き殴った文章にこそ、本音が現れるものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "今のヨーロッパで見いだした信仰の基本とは、人々銘々の心に任せるよりほかにいたし方もないと決着したとある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとはもう、神様の御心に任せる他ありませんでした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A DOG OF FLANDERS",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to happen as one expects",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
