        "examples": {
          "standard": [
            {
              "text": "正倉院には、貴重な古代裂れが多数収蔵されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この古代裂れは、千年以上前のものだと鑑定された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代裂れの文様には、当時の文化が色濃く反映されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "事変がはじまつてから三年、でも未だ未だ世並は割合によくて年の市の晩に、伝法院界隈の古代裂れなどひさぐ小体に気の利いた店の二階、同好寄りつどつて運座を催したことがある。",
              "citation": {
                "source": "下町歳事記",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
