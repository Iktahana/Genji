        "examples": {
          "standard": [
            {
              "text": "その悲報を聞き、彼は言葉を失った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あまりの驚きに、私は言葉を失い、ただ立ち尽くすばかりだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "目の前で起きた信じられない光景に、観衆は皆、言葉を失っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」第七章　暗中の光明　レストレードがもたらした知らせは、我々に驚きと深い衝撃を与え、三名とも言葉を失うほかなかった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "共に語るに足りない人に会って、みだりにその人と語れば言葉を失うことになる。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」○　「言葉を失う」のは、単に言葉が「むだになる」だけでなく、「大害の原因になる」ということも忘れてはならないだろう。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
