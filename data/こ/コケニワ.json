        "examples": {
          "standard": [
            {
              "text": "京都の寺院で、一面に広がる美しい苔庭を眺めながら静かな時間を過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雨の日になると、苔庭の緑がより一層深く、幻想的な色合いを見せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父は毎日、苔庭に落ちた枯れ葉を丁寧に取り除いて手入れをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "嵯峨の臨川寺の本堂前も、二十七、八年前からそういう苔庭になっている。",
              "citation": {
                "source": "京の四季",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞや一度彼の軽井沢の家に行つて、その美しい苔庭に感心したものであつた。",
              "citation": {
                "source": "天成の詩人",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
