      {
        "index": 1,
        "gloss": "Buddhist priest who is also an important politician",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
