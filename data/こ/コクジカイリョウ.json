          "standard": [
            {
              "text": "明治時代には、日本語の効率化を目指して、漢字の全廃やローマ字化を主張する国字改良運動が盛んに行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国字改良の議論は、教育の普及や近代化のスピードに大きな影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "現代においても、公用文の書き換えなど、広義の国字改良は継続的に行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "文章のわかりやすさ、無制限に数の多い漢字を整理し、複雑な仮名づかいを単純にして、子供たちの負担を軽くし、日本語の世界化によい条件をつくろうとしている国語国字改良の運動もある。",
              "citation": {
                "source": "今日の文章",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
