        "examples": {
          "standard": [
            {
              "text": "円安の影響で輸出価格が下がり、日本製品の国際競争力が一時的に向上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "質の高い労働力を確保できないことが、わが国の国際競争力を低下させる要因となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ブランドイメージを高めることで、価格競争に巻き込まれない国際競争力を構築する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "我が国のコンテンツ創造サイクルの活性化と国際競争力の向上を図るべきである。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "保護期間を延長し、著作物からの収益性や資金調達力を高め、新たな創作活動に投じる資金を増大させることにより、コンテンツ創造サイクルの活性化と国際競争力の向上を図るべきである。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意思決定にあたって、３はコンテンツ産業の活性化と国際競争力強化を重視すべきであるという。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした社会の根幹に関わる問題に、特定産業の国際競争力強化を目的として変更を加えることは、許されないと考える。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
