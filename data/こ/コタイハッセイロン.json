          "standard": [
            {
              "text": "個体発生論は、生物の成長と発達の過程を科学的に解明しようとする学問だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヘッケルの個体発生は系統発生を繰り返すという説は、後に修正された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は個体発生論に関する古典的な論文を読み返し、新たな視点を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして幾何学も又この経験的空間にその個体発生論的な原因を持っているであろう。",
              "citation": {
                "source": "範疇としての空間に就いて",
                "author": "――之は一つの習作である――",
                "note": "青空文庫"
              }
            }
          ]
        }
