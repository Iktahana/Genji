        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔ながらの甘味処で、氷小豆に練乳をかけてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "おばあちゃんが作る氷小豆は、小豆がふっくらと炊けていて美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "暑い日には、冷たい氷小豆が体の中から涼しくしてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "雪がそろそろ融け出すと氷小豆という奴になっているのでもうたべられる。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金時とは、東京でいう氷小豆だ。",
              "citation": {
                "source": "氷屋ぞめき",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "その氷小豆の上から、ミルク（牛乳のところもあるが、コンデンスミルクを溶いたものが多い）を、ジャブジャブと、かけたもの。",
              "citation": {
                "source": "氷屋ぞめき",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
