        "examples": {
          "standard": [
            {
              "text": "この出汁は、かつお節と昆布のバランスが絶妙で、深いこく味が感じられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スープを一口飲むと、熟成された肉の旨味とこく味が口いっぱいに広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「こく味を出すために、隠し味に味噌を少し加えてみたの」と母が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もし、こくみんに海へとびこめといいつけようものなら、国がひっくりかえる。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すてきなスープ　こくみどおさらでほかほか！",
              "citation": {
