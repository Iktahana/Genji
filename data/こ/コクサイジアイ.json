        "examples": {
          "standard": [
            {
              "text": "明日行われるサッカーの国際試合は、強豪ブラジルを相手にした大事な一戦だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "公式な国際試合の結果が、最新の世界ランキングに直接反映される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スタジアムは国際試合を一目見ようと集まった熱狂的なファンで埋め尽くされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "国籍異る世界最高、第一人者が名誉をかけて争う国際試合は、日本の歴史において、これが最初だ。",
              "citation": {
                "source": "本因坊・呉清源十番碁観戦記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "現状に於てもスポーツの最高エベントは国際試合に限るわけでなく、ウインブルトンの庭球、又はプロ・ボクシングの世界選手権試合に於けるが如く、人種、国家の如何をとわず、最高エベントが個人的に争われている例も少くはない。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "言うまでもないが、グラスゴウは三冠王であり、国際試合出場選手でもあった。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
