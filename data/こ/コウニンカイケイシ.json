        "examples": {
          "standard": [
            {
              "text": "彼は公認会計士の資格を持ち、多くの企業の監査を担当している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社の財務状況を改善するため、公認会計士に相談した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公認会計士になるためには、非常に難しい試験に合格する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこに書かれた金額は間違いなくニューヨークの一流公認会計士が認めたもの。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくとも大学院に進学したり、司法試験や公認会計士試験や公務員試験を受験しようとする学生は文句なく勉強している。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「父は公認会計士という職業の人で、母親もそうです。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
