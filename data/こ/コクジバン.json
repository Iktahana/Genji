        "examples": {
          "standard": [
            {
              "text": "駅の改札横にある告示板に、明日のダイヤ改正に関する詳細な案内が貼り出されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大学のキャンパス内の告示板は、サークル勧誘や休講情報でいつも埋め尽くされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "告示板の文字が雨で滲んでしまい、締め切り日がいつなのか読み取れなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "どの告示板の前にも、黒山のような人だかりだった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "告示板には、川上機関大尉の写真こそ出ていなかったが、その人相や背の高さ、それから皮膚の色や服装などもくわしく記されていたので、飛行島の人たちは、それをいそがしくノートにとったり、文字の読めない連中は、人に読んでもらったりして、めいめい川上機関大尉の顔をいろいろに想像して、胸の中におさめた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "告示板を利用して女優が自分の名前を宣伝していた。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
