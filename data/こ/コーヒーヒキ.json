        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母の家には、手回しの古いコーヒー挽きが大切に保管されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新鮮なコーヒーの香りは、コーヒー挽きで豆を挽く瞬間から始まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、豆の種類によってコーヒー挽きの粒度を細かく調整していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこにはストーヴ、ベッド、坐る場所、そこで生まれた家の赤んぼ、絹のパラソル、金めっきの縁のついた鏡、樫若木に釘づけにした新しい特許コーヒー挽き――全部でそれだけであった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "一からげの大きな荷がかれらの持物全部を含んでいた――ベッド、コーヒー挽き器、鏡、鶏――猫だけがそれにはいっていなかった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は東京では、どこ／＼のコーヒーが一寸飲めるといひ、自ら書斎の一隅にコーヒーひきとフイルトレの道具を用意し、「これはこの間フランスから取寄せたコルスレだ」などと、不眠症の客をへき易させる奇癖をもつてゐた。",
              "citation": {
                "source": "田巻安里のコーヒー",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はすぐコーヒーひきを手放して、Ｋのいる長椅子のところへやってきた。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
