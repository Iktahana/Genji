        "examples": {
          "standard": [
            {
              "text": "彼は映画界の巨匠として知られ、今や誰もが認める国際人としての地位を築いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "そのモデルはパリやニューヨークのランウェイを歩き、国際人として注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "世界的な賞を受賞したことで、彼は一夜にして時の人、そして国際人となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
