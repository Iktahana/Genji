        "examples": {
          "standard": [
            {
              "text": "彼は何事に対しても腰の重い性格で、新しい企画を提案してもなかなか動かない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "腰の重い政府がようやく重い腰を上げ、本格的な環境対策に乗り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんなに腰の重いこと言わずに、一度現場を見に行ってみようよ」と誘った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いっそのこと、亮さんの兄上孔明と叔父御の孔賓を助け奪る事のついでに、慕蓉をかたづけ、呼延灼を生けどり、州城の庫の物もそっくり貰って、ひとつ、窮民祭りでもしてやろうではないか」　言ったのは、日頃は腰の重い不性者、花和尚｜魯智深なのである。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
