        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "車内に吊るされた香袋から、心地よい香りが広がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この香袋は、消臭効果も兼ね備えているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの香袋、すごくいい香りだね。どこで買ったの？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
