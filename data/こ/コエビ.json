        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "水槽の中で透明な小エビがせっせとコケを食べて掃除をしてくれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "釣りの餌にするために、近所の小川で生きた小エビを網ですくい上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この小エビは淡水でも飼育できるので、アクアリウムの初心者にも人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "小エビや小魚、時には深い穴の中にヤリイカの群れがいることもある。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "揺すってみると、中にいた小エビたちが船底に落ちる。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
