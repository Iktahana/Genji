        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "博物館の展示ホールには、巨大な骨格標本に混じって小鯨の剥製も置かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "捕鯨船の乗組員は、網にかかった小鯨を海へ逃がしてやった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "穏やかな湾内に迷い込んだ小鯨を一目見ようと、野次馬たちが集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もっともミンクという奴は、せいぜい二三十尺の小鯨なのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
