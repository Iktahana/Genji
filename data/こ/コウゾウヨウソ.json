        "examples": {
          "standard": [
            {
              "text": "建物の主要な構造要素は、鋼鉄で作られており、高い強度を持っています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この機械の構造要素は、精密に加工されており、スムーズな動作を保証します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "チームの成功には、個々の才能だけでなく、協力という構造要素が不可欠です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "永久運動機関から修理をしばしば必要とする燃焼機関へ変わってきたが、これらの次々の理論において生体の構造要素は基本的に固定し安定した状態のものである。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "３．排泄物生成で構造要素の果たす役割　前の２回の講義において生体成分がいかに広範囲に再生されているかを示す努力をした。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            }
          ]
        }
