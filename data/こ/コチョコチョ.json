        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「こちょこちょー！」と言いながら、おじいちゃんが孫をくすぐる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小さい子供に「こちょこちょ」と声をかけると、嬉しそうに笑い出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寝ている赤ちゃんのお腹を、そっと「こちょこちょ」と触ってみた。",
              "citation": {
                "source": "幻辭AI",
