        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は心配事があると、いつも部屋の中をこちょこちょと歩き回る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試合前の選手たちは、落ち着かない様子でこちょこちょと動いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "緊張で心がこちょこちょして、なかなか眠りにつけなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
