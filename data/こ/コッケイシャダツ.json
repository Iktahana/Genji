          "standard": [
            {
              "text": "彼の滑稽洒脱な語り口に、聴衆は魅了された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "滑稽洒脱な人柄で、彼は多くの友人に囲まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は会議で、滑稽洒脱に自説を述べ、皆を納得させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "猿楽はもと滑稽な所作、猥雑な筋を演ずるものであつたが、貴族武家の生活、趣味に合致するやう次第に洗錬を経たのであつて、その間、一は能の厳粛典雅な悲劇的典型と、一は滑稽洒脱な狂言の喜劇的典型とに分れて今日に及んだのである。",
              "citation": {
                "source": "演劇と政治",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "魯文時代の引札類新世相を語る風俗資料　滑稽洒脱の引札は平賀源内に始まり、京伝三馬に至ってますますメイ文を振った。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
