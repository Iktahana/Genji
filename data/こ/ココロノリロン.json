        "examples": {
          "standard": [
            {
              "text": "発達心理学では、子供が心の理論を獲得する過程を研究している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "相手の意図を推測するには、高度な心の理論が必要とされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "自閉症スペクトラム障害のある人々は、心の理論の発達に困難を抱えることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "マクドゥーガルの社会心理学――群衆心理学乃至集団心理学・集団心の理論――は、吾々が見た之までの他の諸社会心理学と同じく、社会の分析から出発する代りに、意識の――無論其が個人的意識の――分析から出発する＊。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
