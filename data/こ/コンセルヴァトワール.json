        "examples": {
          "standard": [
            {
              "text": "彼女は、パリの有名なコンセルヴァトワールで音楽を学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この街には、音楽や演劇を専門とするコンセルヴァトワールがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "コンセルヴァトワール出身の演奏家たちは、高い技術を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "絶望と自棄とにすっかり自信を失ってしまったワグナーは、ある日コンセルヴァトワールでアベネックの指揮するベートーヴェンの合唱付シンフォニー「第九」を聴いた。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つはコンセルヴァトワールの美しいフランクへの理解の深さも手伝っているであろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
