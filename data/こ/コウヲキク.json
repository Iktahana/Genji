        "examples": {
          "standard": [
            {
              "text": "茶室で、客人は静かに香を聞きながら、心の落ち着きを取り戻した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母は毎朝、仏壇に香を焚き、その香を聞くことを日課としている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人と一緒に、香道体験で様々な種類の香を聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "香を焚くのは、どんな場合にもいいものですが、とりわけ梅雨の雨のなかに香を聞くほど心の落ちつくものはありません。",
              "citation": {
                "source": "雨の日に香を燻く",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその時私の覚えていた灯影無睡を照し心清妙香を聞くという古人の句を兄さんのために挙げました。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
