        "examples": {
          "standard": [
            {
              "text": "旅行の行程表には、毎日訪れる観光スポットが詳細に記されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「え？予定と違う！この行程表、最新のものじゃないの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ツアー参加者は、配布された行程表に従って行動します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
