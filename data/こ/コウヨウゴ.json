        "examples": {
          "standard": [
            {
              "text": "カナダでは英語とフランス語の双方が公用語として認められており、製品のパッケージも併記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アフリカの多くの国々では、旧宗主国の言語が依然として公用語として機能している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女はフィリピンの公用語であるタガログ語を独学でマスターした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それに対する公用語中の単語も、上等になって品位をそなえている。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋梁や道路に関する公用語では、それらの低部や鉄格子に Cassis（訳者注　ラテン語にてはくもの巣という意味になる）という意味深い名前を与えていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
