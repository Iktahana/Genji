        "examples": {
          "standard": [
            {
              "text": "航空機の部品には、軽量で強度の高いコンポジット素材が使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は複数の写真要素を組み合わせて、素晴らしいコンポジットアートを作り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このデータは、様々な情報源から集められたコンポジットデータとして分析される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "★家庭用のテレビをディスプレイに使ったアップル※では、カラーのビデオ信号は光の三原色の赤（Ｒ）、緑（Ｇ）、青（Ｂ）を一本の信号線で送るコンポジット（複合）形式が採用されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単に申し上げますれば、古羅馬初期に現れたる建築様式は、希臘から伝わったドーリア式、イオニア式、及びコリント式の三様式のほかに、エトルリアから習得しましたコンポジット式とタスカン式の、この五つに分れるのでありますが、この中で、羅馬人自身は、コリント式とコンポジット式とを最も好みました。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち古羅馬中葉期における羅馬の都会建築は、ことごとくコリント式とコンポジット式及びその折衷式のみであるということになるのでありますが、この第一図に現れている建築は、一軒残らずこの二つの様式及び折衷式のみでありまして、それ以外のものは何一つ混じってはおりません。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
