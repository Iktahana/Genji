        "examples": {
          "standard": [
            {
              "text": "国際人権規約は、すべての人間に備わるべき基本的人権を保障するための重要な枠組みだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "採択から数十年経った今も、国際人権規約の理念をどう実現するかが問われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日本政府に対し、国際人権規約の選択議定書を速やかに批准するよう求める声がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
