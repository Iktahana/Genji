        "examples": {
          "standard": [
            {
              "text": "高速道路では、後続車との車間距離を十分に保ちましょう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "運転中に急に進路変更をすると、後続車を危険にさらすことになります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "信号が青に変わったのに、後続車がまだ来ていないのでゆっくり発進した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "後続車の流れを見て、ぼくは、走りはじめた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "両腕と両脚をのこした胴体は、ねじりん棒のようになって転がり、後続車に次々に踏みつぶされる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
