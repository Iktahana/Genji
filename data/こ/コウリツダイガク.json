        "examples": {
          "standard": [
            {
              "text": "多くの公立大学が、独自の特色ある研究と教育を展開している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は難関の公立大学に合格し、家族や友人から祝福された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公立大学は、地域社会の発展に貢献する役割も担っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "尤も今日の私立大学が文部省的な資格に於て大学となったのは十五六年前のことに過ぎず、その点だけから云えば他の官公立大学と違いはないが、併し帝大を含めての官学に対立したものは、明治時代からの専門学校の資格としての私立「大学」だったのである。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の図書館（帝大官公立大学及び二三の私大）はいうまでもなく学術図書館でありそして実際に研究用具として役立っている。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
