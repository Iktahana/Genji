        "examples": {
          "standard": [
            {
              "text": "待ち合わせまで時間があったので、駅ビルの中にある珈琲館で一休みした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "珈琲館のトーストサンドは、珈琲との相性が抜群でランチによく利用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は珈琲館の落ち着いた雰囲気が好きで、仕事の打ち合わせにもよく使っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "大きなコーヒーかん、小さなミルクかん、白砂糖──このこまやかな心づかい。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長はうなずきながら聞いていたが、すぐにボーイにコーヒーかんなどを持って来させ、手ずから紙で包んだ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
