        "examples": {
          "standard": [
            {
              "text": "毎月の光熱費をいかに抑えるかが課題だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "引っ越したら、前の家よりも光熱費が安くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ねぇ、今月の光熱費、先月より上がってるよ！」と妻が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "光熱費を負担し、改造したり模様がえしたりせずにそのまま住んでもらえればそれでいい、ということだった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "百番地と言えば、光熱費をケチるようなところではない。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
