        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの掲示板では、みんな固定ハンドルを使って、匿名性を保ちながら会話しているんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「コテハンじゃないと書き込めないスレッドもあるんだよね」と友人が言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔は「コテハン」って言葉、よく使われたけど、最近はあまり聞かないかも。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
