        "examples": {
          "standard": [
            {
              "text": "国際恋愛は文化の違いから喧嘩も多いけれど、その分新しい発見があって楽しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "留学先での国際恋愛をきっかけに、彼女の母国語を猛勉強することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "遠距離になった国際恋愛を続けるために、毎日ビデオ通話で近況を報告し合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、今や、わが中野秀人は、お伽噺の中の王女を娶って国際恋愛の範を垂れようとしているのではないか。",
              "citation": {
                "source": "叛骨・中野正剛",
                "author": "――主観的な覚え書き",
                "note": "青空文庫"
              }
            },
            {
              "text": "一家の内部に起った事件として、国際恋愛の最後のすがたは、中野正剛が世に時めく革新政治家であるだけに、世間の噂に伴う好奇心に一層拍車をかけた。",
              "citation": {
                "source": "叛骨・中野正剛",
                "author": "――主観的な覚え書き",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
