        "examples": {
          "standard": [
            {
              "text": "狭い路地の多いこの地域では、大型のSUVよりも小型車のほうが取り回しが良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "初心者の私には、視界が広くて運転しやすい小型車がぴったりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "燃費性能に優れた小型車を選んだことで、ガソリン代の節約につながった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "二月終わり頃のある午後早く、自分の小型車に乗ってブロード街へと繰り出し、百五十七年前に全く同じ道を辿った厳粛な一隊のことを奇妙にも考えた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "路上で、黒色の小型車が待っていた。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
