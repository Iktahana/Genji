        "examples": {
          "standard": [
            {
              "text": "冷凍庫に入れたまま忘れていたパンが、こちんこちんになっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "泥で固まった道が、日差しでこちんこちんになって歩きにくい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お餅がこちんこちんになる前に、早めに食べた方がいいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "円山さんというのがいったい西洋窓のついた日本座敷みたいに、こちんこちんした無愛想な男だ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはほんとうですか」「そうだ、そのとおりだ」　それを聞くと、黒人たちは、たちまち別の人間のようになり、たがいに、ばたばたこちんこちんと、機械の修理にかかりました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
