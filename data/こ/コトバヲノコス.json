    "definitions": [
      {
        "index": 1,
        "gloss": "to leave words (behind one, e.g. after death)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖父は、最期に家族への感謝の言葉を残した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の残した言葉は、多くの若者に勇気を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史上の偉人たちは、後世に語り継がれる数々の言葉を残している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、「あたしに会いたければ、銀座のアルセーヌにいらっしゃい」　という言葉を残すと、三等室の中へすらりと伸びた姿を消してしまった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "地名にも「伊保内」とか「毛馬内」とか「沼宮内」とかのように、アイヌの言葉を残す所も少くありません。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石炭庫の中「おい、見つかったそうだ、ミマツ曲馬団の松ヶ谷団長が、石炭庫の中で」　船長は、おどろくべきことばをのこすと、すぐさま医務室をとびだした。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to leave some things unsaid",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は多くを語らず、あえて言葉を残すことで、相手に考えさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議では、全員が納得するように言葉を残さず話し合うべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "本当の気持ちは、言葉に残さず胸にしまっておくことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
