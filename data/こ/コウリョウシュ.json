        "examples": {
          "standard": [
            {
              "text": "寒い冬の夜には、高粱酒を一杯飲むと体が温まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "中国の食卓には、たいてい高粱酒が並べられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の家には年代物の高粱酒が大切に保管されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "支那服は野良犬の塩焼きと、一升ほどの高粱酒を相宿の連中に大盤振舞いして酔つぶれた翌朝から、ずっと姿を見せなかった。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "高粱酒を出して洋盃に注ぎながら、こっちが普通の方で、こっちが精製した方でと、またやりだしたから、いや御酒はたくさんですと断った。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが酒好きの是公も高粱酒の比較飲みは、思わしくないと見えて、並製も上製も同じく謝絶した。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえは高粱酒なんて、藁からとった酒ばかり飲んでいたんだろうが、わが日本の米の酒をのんで見ろ。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
