        "examples": {
          "standard": [
            {
              "text": "「あいつは本当に狡っ辛いから、うっかり信用すると足元をすくわれるぞ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "狡っ辛い笑みを浮かべて交渉を進める相手に、警戒心を強めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "些細な嘘を重ねて責任を逃れようとする、彼の狡っ辛いやり方には呆れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「あいつは末っ子のあまったれで、いくじなしのくせに向っ気が強くって、へんにこすっからいとこがあっていやなやつだ、ゆだんのならないおっちょこちょいだ、おれはあいつの顔を見るといつもぼんのくぼが痒くなったものだ、いまから云っておくが、あいつはろくなやつにはならないぞ」　長姉の（土方へ嫁した）よねは云う。",
              "citation": {
                "source": "末っ子",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民は正直だというが、農民ほどこすっからいものはない。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
