        "examples": {
          "standard": [
            {
              "text": "市の新しいコンベンションセンターは、最大で五千人を収容できる設計だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "展示会が行われているコンベンションセンターの周りは、昼休みになると会社員で溢れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "そのコンベンションセンターは駅から地下通路で直結しており、雨の日でも濡れずに済む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ロサンゼルスのローカル空港からバスにでも乗る感覚でサンノゼに飛び、会場のコンベンションセンターを訪ねると、そこにはもっと大きな衝撃が古川を待ち受けていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
