        "examples": {
          "standard": [
            {
              "text": "憲法改正の是非を問うために、ついに国民投票が実施されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "欧州連合からの離脱をめぐり、イギリスでは歴史的な国民投票が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "重大な国政の判断を国民に委ねる国民投票は、民主主義の重要な手続きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "例えば、雪舟の山水長巻と、下町の銭湯で見る富士山のペンキ画とを竝べて、どっちを美しいと思うかという国民投票をしたら、恐らく富士山の方が勝つであろう。",
              "citation": {
                "source": "小林秀雄と美",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この承認には、特別の国民投票又は国会の定める選挙の際行はれる投票において、その過半数の賛成を必要とする。",
              "citation": {
                "source": "日本国憲法",
                "author": "施行、昭和二二年・五・三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この承認には、特別の国民投票又は国会の定める選挙の際行われる投票において、その過半数を必要とする。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどの第二次大戦のあと、一九四六年六月二日に、イタリアでも、国民投票をもって王制は廃止された。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
