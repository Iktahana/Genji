    "definitions": [
      {
        "index": 1,
        "gloss": "award for distinguished service",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は長年の功績により、特別功労賞を受賞した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームは、リーグ優勝を達成し、多くの選手が功労賞を獲得した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この国際会議で、平和への貢献が認められ功労賞が贈られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは昭和の歌舞妓芝居から、最意味のある功労賞を贈るとすれば、まづ海老蔵と此人とに贈るのが、当を得た功績をあげてゐると思ふからである。",
              "citation": {
                "source": "自然女人とかぶき女",
                "author": "――新歌右衛門に寄する希望――",
                "note": "青空文庫"
              }
            }
          ]
        }
