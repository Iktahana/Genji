        "examples": {
          "standard": [
            {
              "text": "「ようやく地権者の肯諾を得ることができたので、来月から再開発工事に着手できます」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は私の無謀な提案に対しても、穏やかな微笑みを浮かべて肯諾してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "父の肯諾を取り付けるまで、私は三日三晩、書斎の前に座り込んで説得を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "然れども先生は従来他人の書に序を賜いたること更になし、今｜強てこれを先生に煩さんこと然るべからずと拒んで許さざりしに、児竊かにこれを携え先生の許に至り懇願せしかば、先生｜速に肯諾せられ、纔か一日にして左のごとくの高序を賜わりたるは、実に予の望外なり。",
              "citation": {
                "source": "瘠我慢の説",
                "author": "福沢先生を憶う",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
