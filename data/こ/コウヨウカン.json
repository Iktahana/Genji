        "examples": {
          "standard": [
            {
              "text": "初めての海外旅行を前に、出発ゲートで言葉にできない高揚感を覚えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ライブ会場の照明が落ちた瞬間、観客の間に一気に高揚感が広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プロジェクトの成功を確信したとき、胸の奥から静かな高揚感が湧き上がってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "緊張と期待の雰囲気を古外套のように脱ぎ捨て、代わりに完璧な勝利の高揚感を意地悪く隠しはじめたのだ。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
