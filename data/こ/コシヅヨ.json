        "examples": {
          "standard": [
            {
              "text": "彼は腰強な体格を活かして、ラグビー部でフォワードとして活躍している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「重い荷物を運ぶなら、あいつみたいな腰強な男に頼むのが一番だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "腰強な農夫たちが、黄金色に輝く稲穂を次々と刈り取っていく。",
              "citation": {
                "source": "幻辭AI",
