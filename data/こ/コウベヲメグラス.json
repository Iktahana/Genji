        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "故郷を離れて数十年、ふと昔の思い出に頭を回らすと、当時の友人の顔が鮮明に浮かぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "失敗を悔やむばかりでなく、これまでの道のりに頭を回らして改善点を見つけるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "人生の転機を前にして、自分がこれまで成し遂げてきたことに静かに頭を回らしてみる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
