        "examples": {
          "standard": [
            {
              "text": "アメリカ国務省は、同盟国との連携を強化するための新たな外交戦略を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "渡航制限に関する最新の情報は、国務省のウェブサイトで随時更新されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はワシントンの国務省ビルで、長年外交官として勤務してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "日本の五人の名流婦人たちが、「非武装国日本女性の講和問題についての希望要項」をダレス国務省顧問に託して、アメリカの世論に平和を訴えたことは非常にいいことだった。",
              "citation": {
                "source": "平和の願いは厳粛である",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯舞諸島のユリ島付近でＢ29がソ連戦闘機に撃墜される事件が起きたのは十月七日のことだが、私が札幌について二日目の十七日には、歯舞諸島は日本領土であるという米国務省の対ソ抗議覚書が発表された。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワシントンの国務省での第一回交渉のときには、米国側から「いったい日本は濃縮ウランが欲しいのか、欲しくないのか、どちらであるかを明らかにしてくれ」と聞かれて、返答に困ったそうである。",
              "citation": {
                "source": "科学ブームへの苦言",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月になって、米国国務省を通じて、唯一の報告書だという「南極記」と題した小冊子が届いた。",
              "citation": {
                "source": "南極記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
