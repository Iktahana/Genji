        "examples": {
          "standard": [
            {
              "text": "スマートフォンの画面に傷がつかないよう、硬度9Hのガラスコーティングを施した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "外壁のコーティングが剥がれてきたので、専門業者に依頼して塗り直してもらう予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このチョコレートは、薄く砂糖でコーティングされているため、口の中で上品に溶ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「まいった、まいった」　東屋に入ると、ビニールコーティングした敷物を投げだし、高志が笑った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの彫刻及び著述の方法は時代を下るにつれ奇妙に変化し、明らかに化学的なコーティングを伴うようになったのだが――恐らくは燐光性を保つため――そのコーティングのプロセスについては浅浮き彫りからははっきりしたことは※めなかった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
