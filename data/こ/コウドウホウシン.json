        "examples": {
          "standard": [
            {
              "text": "緊急事態が発生した際、会社は迅速に対応できるよう、明確な行動方針を定めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私たちは、顧客満足度を最優先するという行動方針のもと、業務に取り組んでいます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来月のプロジェクト会議で、今後の行動方針について最終決定を行う予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "自由主義私見――学芸自由同盟に関連して――豊島与志雄　自由主義は、行動方針の問題ではなくて、生活態度の問題である。",
              "citation": {
                "source": "自由主義私見",
                "author": "――学芸自由同盟に関連して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その翌年になってめざましく展開されてゆく国外勢力の行動方針は、文久三年中にすでに決定されていたということができる。",
              "citation": {
                "source": "尊攘戦略史",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "即座に行動方針を決めた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
