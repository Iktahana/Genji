        "examples": {
          "standard": [
            {
              "text": "巡礼者は、手にコンタツを握りしめ、静かに祈りを捧げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は亡くなった祖母から受け継いだコンタツを大切に持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その宗教施設では、礼拝の際にコンタツを使うのが一般的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "七十五里を一目に見る遠目金、芥子粒を卵の如くに見る近目金、猛虎の皮五十枚、五町四方見当なき鉄砲、伽羅百｜斤、八畳釣りの蚊帳、四十二粒の紫金を貫いたコンタツ。",
              "citation": {
                "source": "ハビアン説法",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は母が大切にしてゐる少女時代の記念品――御影やコンタツや、あるひは母の学生時代の写真などを、秀子と奪ひ合ふやうにしてねだるのだつた。",
              "citation": {
                "source": "母たち",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
