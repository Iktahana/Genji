        "examples": {
          "standard": [
            {
              "text": "神戸大学は、旧三商大の流れを汲む経済学と商学の分野で日本屈指の伝統を誇る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は猛勉強の末、難関と言われる神戸大学の医学部に合格し、医者への第一歩を踏み出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "神戸大学の六甲台キャンパスから見下ろす神戸の街は、勉強の疲れを癒してくれる絶景だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そして神戸大学文学部を中退して、米朝に入門。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと神戸大学の教授だった佐野一彦氏がその付近の伊深村に住んでおられて、居村の事情を非常に詳しく報告されたものがある。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
