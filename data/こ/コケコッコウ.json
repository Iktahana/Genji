    "definitions": [
      {
        "index": 1,
        "gloss": "cock-a-doodle-doo (sound made by cockerels, roosters)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「こけこっこう！」という威勢のいい声で、村の朝が始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "隣の家のニワトリが毎朝こけこっこうと鳴くので、目覚まし時計が必要ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "絵本を読み聞かせながら、「おんどりがこけこっこうと鳴きました」と声を真似た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "すると真闇な道の傍で、たちまちこけこっこうという鶏の声がした。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こけこっこうと鶏がまた一声鳴いた。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんどりはこけこっこうと、ときをつくりました。",
              "citation": {
                "source": "ブレーメンの町楽隊",
                "author": "DIE BREMER STADTMUSIKANTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、裏の納屋の方で、鶏が大きな声を出して、こけこっこううと鳴く。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
