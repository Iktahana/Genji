        "examples": {
          "standard": [
            {
              "text": "初めてのペアとは思えないほど呼吸が合い、コート上で見事なコンビネーションを見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼とは仕事の進め方についても呼吸が合うので、大きなプロジェクトでも安心して任せられます」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長年連れ添った夫婦だけあって、言葉を交わさずとも阿吽の呼吸で家事を分担している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "岩井半四郎という、日本一の踊り手のために、心から弾くのでございますから、呼吸が合うのでございます。",
              "citation": {
                "source": "京鹿子娘道成寺",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "巧く呼吸が合うと丁度龍が玉を狙って空中を飛躍するように見えて大喝采さ。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
