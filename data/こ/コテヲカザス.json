        "examples": {
          "standard": [
            {
              "text": "遠くの景色を眺めながら、思わず小手を翳して太陽の眩しさを避けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "砂浜で子供が、母親に向かって「ママ！あれ見て！」と小手を翳して指差した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夕日に向かって小手を翳し、何かをじっと見つめている彼の姿は、絵になるようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一先づ目前の小高い所に攀ぢ登つて小手を翳すと、北にあたつて一塊の岩峰がちらと眼に入つた。",
              "citation": {
                "source": "黒岩山を探る",
