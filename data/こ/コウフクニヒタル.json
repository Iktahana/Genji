        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年の夢が叶い、彼は心ゆくまで幸福に浸った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "結婚式の後、二人は新婚旅行で穏やかな幸福に浸っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "美しい音楽を聴きながら、彼女は静かに幸福に浸っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "が、さらに一月ばかり経って見ると、反って彼はそのために、前よりも猶安々と、いつまでも醒めない酔のような、怪しい幸福に浸る事が出来た。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の鬱憤を晴らして、類ひのない幸福に浸ることができたのである。",
              "citation": {
                "source": "村のひと騒ぎ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし異邦の人と互に心を打ち明け得たら、どんなにか人類は厚い幸福に浸るであろう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
