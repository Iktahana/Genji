        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は大手法律事務所を辞め、地元で念願の弁護士事務所を個人営業で始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "商店街にあるあのパン屋は、夫婦二人で個人営業を続けている名店だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "個人営業の歯科医院は、患者一人ひとりとじっくり向き合う診療が特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "個人営業のライターの看板を掲げた時期は、一般向け科学雑誌のブームにも重なり合いました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが昔ながら赤い車輪の辻馬車は、仲間で相互扶助的な組合をこしらえているが、生産手段を自分でもっている個人営業だ。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "СССР全経済組織は迅速に社会主義化され、個人営業の手工業者（靴直し屋、裁縫師、理髪など生産手段を自分で持っている職人）までが、集団的生産組合にまとめられつつある。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学物やコンピューター物の原稿を書き、週刊誌の取材記者を引き受け、僕は個人営業のライターとして歩きはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、個人営業をやめて靴工場で働くようになってからはじめての休みだ。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスク※の生活では、ホテルと云ってもそれはよその国での個人営業の客商売と同じ性質のものではなかったから、今の場合パッサージが伸子たちに室を与えるかどうかということは、つまりは、伸子たちがソヴェトに滞在している可能性があるかないかという客観的な条件までを間接に反映する事なのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
