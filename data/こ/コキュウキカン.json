        "examples": {
          "standard": [
            {
              "text": "魚類はエラという呼吸器官を使って、水中に溶け込んでいる酸素を効率よく血液に取り込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "人間の呼吸器官は、鼻や口から始まり、咽頭、気管、そして肺へと複雑に繋がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昆虫は皮膚の各所にある気門と呼ばれる小さな穴を呼吸器官として持ち、酸素を供給している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "家屋を建てゝ寒暑を防ぎ、市街を造つて安全に住居することは、総べての文明の礎とも云ふべきことであるが、其ため日夜悪い空気を吸ふて、呼吸器官が次第に弱くなり、終には誰も彼もが肺病に罹る様になつた。",
              "citation": {
                "source": "自然の復讐",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼吸器官が外界との扉を開けようと必死になっている。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "温度調節が困難なために特にアメリカの都市では建物を暖めすぎる傾向があり多くのアパートメントや事務室の熱く乾いた空気は呼吸器官に悪い影響を与えている。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
