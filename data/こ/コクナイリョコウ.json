        "examples": {
          "standard": [
            {
              "text": "今年の夏休みは、海外旅行ではなく国内旅行を楽しむ予定です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政府は国内旅行を奨励するキャンペーンを実施している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新幹線での国内旅行は、移動も快適で景色も楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "国内旅行　右から左にお受けしてはいかにも計画的のようで変だからというので、六月まで自由に歩き回ってから、七月から朝日の客員ということにしてもらった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内旅行者のためのリオン停車場では、パリ市民の日常に溢れている生活のこみあいがそのままそこにあった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
