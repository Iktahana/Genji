    "definitions": [
      {
        "index": 1,
        "gloss": "to choke up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "目の前に広がるあまりにも美しい夕焼けに、二人は思わず声を呑んで見惚れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "事故の悲惨な状況を目の当たりにした目撃者たちは、恐怖で声を呑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "発表された当選者の名前に、会場全体が驚きのあまり一瞬声を呑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大文字山を越ゆる松風の音までも気を呑み、声を呑むばかりなり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うう、と殺されそうな声を呑むと、私は、この場合、婦二人、生命を預る……私は、むくと起きて、しにみに覚悟して、蚊帳を刎ねた、その時、横ゆれに靡いて、あとへ下ったその婦が、気に圧されて遁げ状に板敷を、ふらふらとあと退りに退るのを夢中で引捉えようとしました。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「省さん、あとから手紙で申し上げますから、今夜は思うさま泣かしてください」　しどろもどろにおとよは声を呑むのである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を――」　と、叫びかけて、声を呑む。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも何処から聞えるのか、其は能く解らなかつたが、まあ楼梯の下あたり、暗い廊下の辺ででもあるか、誰かしら声を呑む様子。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、ギクリとして、「あッ」と、声を呑む。",
              "citation": {
                "source": "緑の星",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "万籟闃として声を呑む、無人の地帯にただ一人、姉の死体を湖の中へ引き摺り込むスパセニアの姿こそ、思うだに凄愴極まりない。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to hold one's tongue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "本当のことを言いそうになったが、ここで揉めるのは得策ではないと声を呑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "厳しい叱責を受けている最中、彼は反論したい気持ちを必死に抑えて声を呑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「それは秘密よ」と釘を刺され、彼は言いかけた言葉を慌てて声を呑んで隠した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
