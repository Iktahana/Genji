        "examples": {
          "standard": [
            {
              "text": "高年者向けの健康講座が、地域センターで開かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この街は高年者に優しいね」と彼は微笑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高年者の社会参加を促進する取り組みが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "故友伊沢蘭軒嘗擬招親交中高年者、設尚歯之宴、未果而歿、狩谷斎後之少卿。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は高年者に「侍」を賜うという事もある、家人・奴婢等がその主人に侍し、その用務を弁じ、その護衛に任ずるもの、これすなわち侍である。",
              "citation": {
                "source": "「特殊部落」と云う名称について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
