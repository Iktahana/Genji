        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "久しぶりに同級生から「可愛いね」なんて言われて、何だかこっ恥ずかしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家族の前で感謝の手紙を読み上げるのは、柄にもなくてこっ恥ずかしいものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分の幼い頃の写真がリビングに飾られているのを見るのは、少しこっ恥ずかしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "こっぱずかしいみてえにあそこあ、さっぱりしてる。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっぱずかしいみたいなもんだね」と白ばっくれている。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
