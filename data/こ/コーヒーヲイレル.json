        "examples": {
          "standard": [
            {
              "text": "毎朝、家族のために私がコーヒーを入れるのが習慣になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は来客があると、決まって丁寧にコーヒーを入れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ねぇ、そろそろコーヒーを入れようか？」と妻が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "出勤前にはコーヒーを入れる、クリームをわかす！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "カウンターへ歩く彼女、そしてカウンターの向こう側でコーヒーを入れる彼女を、彼は観察した。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはコーヒーをいれる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「念のために持って来ました」「コーヒーをいれるわ」　直子はカウンターへ歩いた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「相談ごともあるし」「コーヒーをいれるわ。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちはコーヒー豆はフレンチ・ローストなんです」　後藤幸吉がキチンへいき、コーヒーをいれる準備を始めた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "客が混んでいるときには彼女がコーヒーをいれる。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コーヒーをいれるわ。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「きれいです」「コーヒーをいれるわ」「エイヴォンという店名は、シェークスピアのあのエイヴォンですか」「そういうことをあなたは知ってるのね」　コーヒーをカウンターで飲み、午後一時からヨシオは仕事を始めた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
