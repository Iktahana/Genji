        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は優秀なプログラマーだけど、自分のウェブサイトは紺屋の白袴で手つかずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "紺屋の白袴じゃないけど、美容師の彼女はいつも髪がボサボサなんだよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "忙しい彼は、自分の健康は二の次で、まさに紺屋の白袴状態だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "紺屋の白袴、医者の不養生ということもあるが、物理の学徒等が日常お互いに自由に話し合う場合の用語には存外合理的でないものが多数にあって、問題の「速度のはやい」などもその一例である。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺屋の白袴とでもいうのか、元来心掛けの悪いためか、それとも不精なのか、おそらくそれのすべてであろう。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺屋の白袴どころでなく、これでは柳吉の遊びに油を注ぐために商売をしているようなものだと、蝶子はだんだんに関東煮屋をはじめたことを後悔しだした。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺屋の白袴どころでなく、これでは柳吉の遊びに油を注ぐために商売をしているようなものだと、蝶子はだんだん後悔した。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺屋の白袴かと訊いたら、未だ自分の鼻に応用するほど確信がないと答えました。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
