        "examples": {
          "standard": [
            {
              "text": "この街は多くの外国人観光客で溢れており、非常に国際色が豊かだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "空港のフードコートは、世界各国の料理が並んでいて国際色に富んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大学の寮では留学生が多いため、生活全般において国際色を感じることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "正面の廻転扉を押すと、中は国際色に満ちた大ホールである。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜じゅうは、ロンドン市民がダービーに熱するみたいな他愛なさと国際色に雑鬧する。",
              "citation": {
                "source": "天皇と競馬",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
