        "examples": {
          "standard": [
            {
              "text": "日本の中世史を深く研究するなら、やはり『国史大系』の史料に当たる必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "図書館の奥にある重厚な『国史大系』の背表紙を見ているだけで、歴史の重みを感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "卒論の参考文献として、最新版の『国史大系』を全巻揃えるのは金銭的に厳しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "皆｜活板本で実記（紀）は続国史大系本である。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて飯田武郷氏の日本紀通釈の如きもこれに従い、ハセツカベと訓めるは甚だしき誤りなりと喝破せられてハシヒトの訓を取り、新版国史大系本の日本紀の如きに至っては、おそらく平安朝以来の傍訓（少くも釈日本紀以来の傍訓）たるべきハセツカベを抹消して、無条件にハシヒトと改めているのである。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩波文庫が一棚ぎっしり並んでいて、その下に「国史大系」だの、『古事記伝』だの、「続｜群書類従」だのという本がすっかり揃っているのである。",
              "citation": {
                "source": "Ｉ駅の一夜",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
