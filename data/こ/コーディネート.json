        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日の彼女のコーディネートは、カジュアルでありながらも上品さが感じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このワンピースは一枚で着ても可愛いけど、カーディガンを羽織るとまた違ったコーディネートが楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの女優さんの今日のコーディネート、雑誌で見たけど本当に真似したい！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
