        "examples": {
          "standard": [
            {
              "text": "今日の会議は、各部門の意見をうまくコーディネートする必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は新しいプロジェクトのために、多様な才能を持つ人々をコーディネートした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この広々としたリビングには、どんな家具をコーディネートしようか迷ってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "matching (e.g. clothes, accessories, furniture, colours)",
        "register": "standard",
        "nuance": null,
