        "examples": {
          "standard": [
            {
              "text": "バッハのフーガは、完璧なコントラプンクト（対位法）によって構築されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "作曲の授業で、二つのメロディを組み合わせるコントラプンクトの技法を学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この楽曲の魅力は、複雑に絡み合うコントラプンクトにある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "連句の場合でもまさにそのとおりで前句と付け句とは心像の連鎖のコントラプンクトとしてのみその存在価値を有するものである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは和声やコントラプンクトや、曲全体の構造などについてはまだ多少学ぶべき余地もあったであろう。",
              "citation": {
                "source": "久野女史をいたむ",
                "author": "兼常清佐",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
