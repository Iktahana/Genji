          "standard": [
            {
              "text": "文学作品を読むときは、当時の社会的なコンテキストを考慮しないと真意を見誤ることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "単語の意味は、前後のコンテキストによって微妙に変化するため、辞書だけでは不十分だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この会議の発言は、プロジェクト全体のコンテキストの中で解釈されるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "君は著者は無意識の偉大や碎けたる心や自己沈潛を説く人だが、「然し」著者の文章には（從つてコンテキストから推せばその人格生活には）未だ此等のものゝ味が出てゐないと云つた。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
