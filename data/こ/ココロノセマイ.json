        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "些細な失敗をいつまでも根に持って攻撃するなんて、なんて心の狭い男なんだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分の意見と違うものを全て敵として否定するような、心の狭い人間にはなりたくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は心の狭いところがあって、他人の成功を素直に喜べない傾向がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "副詞にもあさはか（→あさむ）などがあるが、自分ながら自分の心の狭いのに驚くといふ言葉である。",
              "citation": {
                "source": "古代中世言語論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど心のうちでは、その杯よりも心の狭い小器な人物よと、かえって村重の態度を愍然なものと見ていた。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の狭い人は、良かれ悪しかれ、絶え間なく起こる些事によって、どうやら満足を得ているものだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、たよりと思う私から、あの様に疑い責められ、全く云い解くすべがないと知ると、心の狭い女の身では、一時の激動から、つい世を果敢なむ気になったのではあるまいか。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、心の狭い一部の納言や沙門たちが、その後になって、青蓮院の僧正こそは、世をあざむく似非法師じゃ、なぜなれば、なるほど、松を時雨の歌は、秀逸にはちがいないが、恋はおろか、女の肌も知らぬ清浄な君ならば、あんな恋歌が詠み出られるはずはない。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし我々は決して、実際には我々自身を越えて一歩も前進しないし、心の狭い範囲に現れた知覚以外には、どんな種類の存在も想像することはできないのである。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
