          "standard": [
            {
              "text": "桜餅には、こし餡がよく合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私はつぶ餡よりも、なめらかなこし餡の方が好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この大福は、上品な甘さのこし餡が特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もしいやでおありにならなければ、すこしあんなのをつづけましょうか。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうはえらいさわぎだったな」　居士はいつもかわりのない童顔に明るい微笑を波のようにたたえて、「わしも、すこしあんじられたので、きょうは早くからあれに腰をすえて見物していたのじゃ」　と、鳥居の上を指さした。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
