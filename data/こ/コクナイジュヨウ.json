        "examples": {
          "standard": [
            {
              "text": "政府は国内需要を喚起するために、新たな経済政策を打ち出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今期の売上は、海外市場の不振を国内需要がカバーした形だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新型コロナウイルスの影響で、観光業の国内需要が大幅に減少した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてある特殊の原因によって外国需要が国内需要以上にならない限り、この国民の独立はこの点においては恢復され得ないであろう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし前世紀中のある期間に、奨励金の刺戟によって輸出用の平均栽培超過が得られてから、我国の穀物に対する外国の需要が国内需要と同一率で増加したならば、我国の剰余栽培は永続的たり得たであろう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
