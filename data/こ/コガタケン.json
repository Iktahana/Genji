        "examples": {
          "standard": [
            {
              "text": "うちのマンションは規約で、チワワやトイプードルなどの小型犬のみ飼育が許可されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "小型犬用のドッグランは、体が小さなワンちゃんたちが安心して遊べる空間だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "散歩中に会った小型犬が、大きな犬に向かって勇ましく吠えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "気魄のある小型犬　ある暴風雨のあった翌日のこと、私がハシゴをかけて屋根にのぼり、ずれたカワラを直していると、腰のところに何か触れるものがあります。",
              "citation": {
                "source": "私の飼った犬",
                "author": "斎藤弘吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "シンシア嬢のフォックステリア小型犬が馬車に忍び込んでいた。",
              "citation": {
                "source": "四日闇夜",
                "author": "THE FOUR DAYS' NIGHT",
                "note": "青空文庫"
              }
            }
          ]
        }
