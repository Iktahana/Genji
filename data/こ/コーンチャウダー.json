        "examples": {
          "standard": [
            {
              "text": "シーフードとコーンチャウダーの組み合わせは、最高のコンビネーションだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は冬になると、いつも温かいコーンチャウダーを自分で作る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このレストランのコーンチャウダーは、濃厚でクリーミーな味わいが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "例の大氷柱に、ポツンと載った、オードヴル、コーンチャウダー、あとはチーフ任せで松茸飯みたいなもの、バゞロア。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーンチャウダーに、オルドヴル、スパゲティに肝、あんまり凝られるので反ってうまくない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴル、コーンチャウダー、ミニツステーキにマカロニ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
