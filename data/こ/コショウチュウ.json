        "examples": {
          "standard": [
            {
              "text": "喉が渇いていたのに、自動販売機に『故障中』の紙が貼ってあってがっかりした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、ここのトイレは今故障中みたい。隣のフロアまで行かなきゃ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "エレベーターが点検により故障中だったため、重い荷物を持って階段を上がる羽目になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "艇長の安否　重力装置故障中の五分間は、とても永かった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話が故障中では、警察も呼べない。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
