        "examples": {
          "standard": [
            {
              "text": "そのコンサートでは、壮大な混声合唱が披露された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "卒業式で、合唱部が感動的な混声合唱を歌い上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "混声合唱の練習では、パートごとの音程を正確に合わせることに集中した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "二十人ばかりの音楽サークルでは男女混声合唱の稽古最中だ。",
              "citation": {
                "source": "ドン・バス炭坑区の「労働宮」",
                "author": "――ソヴェト同盟の労働者はどんな文化設備をもっているか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "レコードはビクターにブレー指揮バッハ協会合唱団のがあり（ＪＤ六二七―三一）、コロムビアにブールモーク指揮、リヨン混声合唱団のがある（ＪＷ五〇九―一三）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは軽く軽く卓を叩いていたが、やがてそれが混声合唱になった。",
              "citation": {
                "source": "溜息の部屋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
