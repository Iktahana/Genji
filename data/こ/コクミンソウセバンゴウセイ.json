        "examples": {
          "standard": [
            {
              "text": "マイナンバーカードが導入される際、反対派はそれを「国民総背番号制」と呼んで批判した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「国民総背番号制は、行政の効率化には役立つが、プライバシー侵害の懸念もある」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔のドキュメンタリー番組で、国民総背番号制を巡る激しい反対運動の映像を見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それまで国民総背番号制の道具としかコンピューターをイメージできなかったオレも、「個人にコンピューティング・パワーを解放する」と吹き込まれ、久しぶりに興奮して「そうだそうだ」とわめいた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民一人ひとりに特定の番号を割り振り、その人物にまつわるあらゆる情報を統合的に管理しようとする国民総背番号制。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
