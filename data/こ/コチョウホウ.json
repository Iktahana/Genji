        "examples": {
          "standard": [
            {
              "text": "詩人は、感情を強調するために誇張法を多用した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の話はいつも誇張法が使われていて、どこまでが本当か分からない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "広告のキャッチコピーには、消費者の目を引くための誇張法が用いられることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」　私は決して誇張法を用みて描写してゐるのではない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいのひとりよがりの誇張法か、と鼻であしらわれるのが、何より、いやだ。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            }
          ]
        }
