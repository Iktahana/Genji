        "examples": {
          "standard": [
            {
              "text": "仏教美術において、金胎両部曼荼羅は非常に重要な位置を占めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は金胎両部の思想に深く傾倒し、その研究に生涯を捧げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "金胎両部は、密教の教義の根幹をなす概念である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "金胎両部なぞの教えになると、実際ひどい。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは全く金胎両部の霊場である。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、もう一度彼が大平峠を越して帰って行こうとするころには、気の早い一部の同門の人たちが本地垂跡の説や金胎両部の打破を叫び、すでにすでに祖先葬祭の改革に着手するのを見た。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
