        "examples": {
          "standard": [
            {
              "text": "紛争地域での人道支援を継続するためには、国際社会からの継続的な支援が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "気候変動問題への対策を怠れば、わが国は国際社会で孤立する恐れがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国際社会の一員としての責任を果たすため、積極的に平和維持活動に貢献したい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "国際社会の現実を語るすべての思想と言葉は禁止され、そういう人は治安維持法で投獄させられた。",
              "citation": {
                "source": "それらの国々でも",
                "author": "――新しい国際性を求めて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらは、平和を維持し、専制と隷従、圧迫と偏狭を地上から永遠に除去しようと努めてゐる国際社会において、名誉ある地位を占めたいと思ふ。",
              "citation": {
                "source": "日本国憲法",
                "author": "施行、昭和二二年・五・三",
                "note": "青空文庫"
              }
            },
            {
              "text": "┌──────┐　　　　│基督顕示協会│　　　　└──────┘　　　　┌──────┐　　　　│国際社会主義│　　　　└──────┘　諸君！",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "視野を国際社会にまで広げると、そこにも問題は山のようにあった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、眼の前にある今日の国際社会においてさえ、なおまだ未解決のままつねに不気味な不安のナゾとなっているからだ。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
