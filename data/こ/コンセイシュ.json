        "examples": {
          "standard": [
            {
              "text": "このカクテルは、数種類のフルーツリキュールを混ぜた混成酒だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖母は、自家製の果実酒をよく「混成酒」と呼んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "スパイスとハーブを漬け込んだ、風味豊かな混成酒を試してみて。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "混成酒ばかり飲みます、この不愉快な東京にいなければならぬ不幸な運命のおたがいに取りては、ホールほどうれしい所はないのである。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの工場からアセトンだと云って樽詰めにして出したのはみんな立派な混成酒でさあ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか皆さんは茨の実を入れた梨の濁麦酒だの、乾葡萄や黒梅の入つた混成酒を召しあがつたことがおありかな？",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "客の前へは、乾葡萄と梅の実の入つた混成酒や、大きな皿にのせた婚礼麺麭が運ばれた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
