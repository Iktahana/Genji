          "standard": [
            {
              "text": "オリンピックの開会式で、コンゴ人の選手たちが鮮やかな民族衣装を着て入場してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は日本に住むコンゴ人で、地元のサッカーチームでコーチを務めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "パリのカフェで隣り合わせたコンゴ人と、フランス語で政治について語り合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
