        "examples": {
          "standard": [
            {
              "text": "古いファイル形式のデータを新しいシステム用にコンバートする作業に時間がかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このソフトウェアを使えば、PDFファイルをWord形式に簡単にコンバートできる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大量の画像データを一括で別のフォーマットにコンバートする必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
