        "examples": {
          "standard": [
            {
              "text": "汚職が発覚し、容疑者は国外脱出を図った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くの人々が迫害を逃れて国外脱出を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政府は、国外脱出を試みる国民を厳しく取り締まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "事件後、彼女は国外脱出をすすめる同志の言葉をしりぞけて、首都にふみとどまった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼めば一人ぐらい下宿させますし、そういう事情ならポプラー地区は最適で、国外脱出希望者が露見することはありません。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
