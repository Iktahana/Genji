        "examples": {
          "standard": [
            {
              "text": "朝食には、牛乳をかけたコーンフレークをサッと食べるのがお気に入りだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、コーンフレークのおまけを集めるのが楽しみだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はダイエット中なので、甘くないコーンフレークを選んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "コーンフレークスとかシュレデッド・フィートとかいうのがそれである。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジュース二三種、オートミール、コーンフレークス、それに卵の料理が、五六種類。",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
