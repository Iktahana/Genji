    "definitions": [
      {
        "index": 1,
        "gloss": "to be of excellent workmanship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この老舗の職人は、その巧を誇る細工で多くの人々を魅了してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は自分の技術の巧を誇ることはないが、作品はそれを雄弁に語る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "美術館には、昔の匠たちが巧を誇った刀剣が展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして技巧を誇る一流の作品は前者に相応するかもしれない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて口疾さと、人の考へつかぬ作物まで利用する技巧を誇るのである。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今日ばかりは、そんな長閑な光景は見えず、貸し望遠鏡はどこかへ姿を隠し、その位置には代りあって、精巧を誇る測高器と対空射撃算定器とが、がっしりした三脚の上に支えられ、それからやや距ったところには、巨大な高射砲が金網を被り、夕暗が次第に濃くなってくる帝都の空の一角を睨んでいた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し職人は皇帝よりの御使と聞いて、切りに此處彼處を指さして其色澤の美、意匠の巧を誇る。",
              "citation": {
                "source": "懷疑思潮に付て",
                "author": "朝永三十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
