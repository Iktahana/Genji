        "examples": {
          "standard": [
            {
              "text": "チーム内で意見のコンフリクトが生じ、解決策を見つけるのに時間がかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "異なる文化背景を持つ人々が交流する中で、コンフリクトは避けられない場合がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あの二人の間、またコンフリクトしてるな。」 「お互い譲らないからねぇ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "故に近世の詩学家は罪過の語の代りに衝突「コンフリクト」の語を用ふ。",
              "citation": {
                "source": "罪過論",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想上種々なコンフリクトがあったとしても、自分のその有難さ丈は一点の汚辱も受けないのである。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
