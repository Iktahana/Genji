        "examples": {
          "standard": [
            {
              "text": "店頭に表示されている小売値段は税込価格です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人にプレゼントする品物の小売値段を調べたが、あまり予算が合わなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "以前よりも商品の小売値段が手頃になり、買いやすくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "糸菜――京菜を買ふ、一株一銭（小売値段が）とは安すぎる、何だか腹立たしくなつた、――が、煮てもうまい、漬けてもうまい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "小売値段が急騰しないうちに、という用心である。",
              "citation": {
                "source": "濁酒を恋う",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも極めて重要なレコードで、かつて日本の小売値段が十六円と言ったこともある大骨董品である。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
