        "examples": {
          "standard": [
            {
              "text": "祖父から教わった「常に謙虚であれ」という言葉を、今も深く心に刻んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "初優勝を飾ったあの瞬間のスタジアムの景色を、一生忘れないよう心に刻んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一度の失敗から学んだ手痛い教訓を心に刻み、二度と同じ過ちは繰り返さない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "其の様子を聞けば、私が言托を為た通り、何か、内儀の形代を一心に刻むと聞く、……其が成就したと言ふ昨夜ぢや。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅商人を点出して場合を特殊化した所にこの歌の面目は存し、それが深刻な印象を読者の心に刻むのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
