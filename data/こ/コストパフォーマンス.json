        "examples": {
          "standard": [
            {
              "text": "このタブレットは、低価格ながら高性能で非常にコストパフォーマンスが良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "食べ放題のランチは、育ち盛りの学生にとって最高のコストパフォーマンスだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「コスパ（コストパフォーマンス）重視で選んだ宿だったが、想像以上に豪華だった」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "コストパフォーマンスの問題さ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、値段に対する性能の比、コストパフォーマンスを考えると、迷いが出る。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
