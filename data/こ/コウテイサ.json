        "examples": {
          "standard": [
            {
              "text": "このトレイルは高低差が激しいので、体力に自信がない人は注意が必要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ここの高低差、すごいね！景色も抜群だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "建築設計では、敷地の高低差を考慮して、排水計画を立てなければなりません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "今回自分は、鉄道模型を配置するような箱庭の取材にここへとやってきたのであって、高低差を求めてやってきたのである。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を境にして左右に分かれて高低差のある、高いほうの敷地のなかの、平屋建ての家だった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の南の縁は、十メートルほどの高低差のある脇道と接していた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の海まで、かなりの高低差があった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
