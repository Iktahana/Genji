        "examples": {
          "standard": [
            {
              "text": "新製品はユーザーから高評価を得て、売り上げを伸ばしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "レストランのレビューサイトで、この店は常に高評価だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の企画書は、上司から高評価された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "なるほど氏の能力に関する僕の高評価を裏付けるものだった。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし幸運にも高評価を得られれば、次の道徳論・政治論・文芸批評に検討を進め、この『人間本性論』は完成するだろう。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな美しい館の持ち主がどんな悪党だろうが、花の熱心な愛好家なら、高評価してしまう。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
