          "standard": [
            {
              "text": "近代的な国民国家の形成には、言語や文化の統一が大きな役割を果たした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一つの国民国家としてまとまるには、共通の歴史認識が必要なんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "19世紀のヨーロッパでは、民族自決による国民国家の誕生が相次いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "来年にもあるいはあすにも、宝永四年または安政元年のような大規模な広区域地震が突発すれば、箱根のつり橋の墜落とは少しばかり桁数のちがった損害を国民国家全体が背負わされなければならないわけである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
