          "standard": [
            {
              "text": "大学のゼミで、意識の性質やクオリアについて「心の哲学」の観点から議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「心の哲学」における心身二元論の歴史を、基礎文献からじっくり学び直すことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "AIが将来的に意識を持つ可能性を考える上で、心の哲学の知見は欠かせないものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "吾人は今日に於て人心の哲学的に傾くを怪しまざる也、唯其久しく之れ飢渇せしが為めに善き物と悪しき物とを撰ばずして之を呑噬し終に不消化不健康なる思想を蔓延せしめんことを憂ふ。",
              "citation": {
                "source": "凡神的唯心的傾向に就て",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
