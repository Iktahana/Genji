    "definitions": [
      {
        "index": 1,
        "gloss": "dimness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕暮れ時の小暗がりの中で、誰かがこちらを伺っているような気がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "蔵の奥の小暗がりに古い提灯が吊るされており、少し不気味だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "障子越しの淡い光が、部屋の隅に心地よい小暗がりを作っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "……だからの」　ふと、正成はその右眼のわるい横顔を振り向けて、細殿の小暗がりを来る白い顔を待って言った。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
