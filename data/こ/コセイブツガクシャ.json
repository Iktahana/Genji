          "standard": [
            {
              "text": "古生物学者が、新たに発見された骨が新種であることを正式に発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "将来は古生物学者になって、世界中の発掘現場を飛び回るのが夢だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "現場の古生物学者たちは、刷毛を使って慎重に化石を掘り出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "現在の地球表面上に残る各種の遺跡によって、そんな事実を推定して行く地質学者や、古生物学者は皆、想像のみを事とするお伽話の作者といえようか。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これら生物学的怪物どもに関するレイクの報告は博物学者と古生物学者たちを一気に目覚めさせてしまった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
