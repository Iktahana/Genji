        "examples": {
          "standard": [
            {
              "text": "彼は一代で莫大な個人資産を築き上げ、多くの慈善団体を支援している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "離婚の際の財産分与において、結婚前から所有していた個人資産が争点になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "老後の生活を安定させるため、若いうちから計画的に個人資産を運用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "従っていかなる公共事業も政府に期待することが出来ず、そしていかなる個人資産家も、資本所有を意味する如き改良はあえてこれを行おうとはしないが、けだしこれはおそらく直ちに身の破滅の徴標となるであろうからである。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            }
          ]
        }
