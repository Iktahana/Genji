        "examples": {
          "standard": [
            {
              "text": "祖母は毎朝、亡き家族のために光明真言を唱えるのが日課だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "厄除けのために、寺院で光明真言の写経会に参加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "光明真言を唱えることで、心が落ち着き、安らぎを得られると信じられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "杖は外に置いて、釣燈籠だけは大事そうに抱えて中へ入った盲法師、光明真言の唱えのみが朗々として外に響きます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "光明真言の唱えは、それと共に一層鮮やかで冴えて響き渡ります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
