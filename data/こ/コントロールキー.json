        "examples": {
          "standard": [
            {
              "text": "コントロールキーを押しながら「S」を押すと、ファイルを保存できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "多くのショートカットキーは、コントロールキーとの組み合わせで機能する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キーボードの左下にあるコントロールキーを多用するので、指が疲れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "またカーソルキーだけを押せばカーソルは隣に移動するが、シフトキーと組み合わせればより遠くへ、コントロールキーと組み合わせればさらに遠くへ飛ぶというアイディアを提案するなど、ゲイツがインターフェイスの改良と統一に関して貢献したのも事実であると鈴木は証言する。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
