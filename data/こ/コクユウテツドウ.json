        "examples": {
          "standard": [
            {
              "text": "民営化される前の国有鉄道時代は、今よりもずっと運賃が安かったと父が言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ヨーロッパを旅行した際、歴史ある国有鉄道に乗って国境を越えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国有鉄道のロゴが入った古い機関車が、公園の隅で静かに保存されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "停車場の待合室にはどこの停車場にも掛かっているような、全国の、国有鉄道の地図が掲げられていた。",
              "citation": {
                "source": "郷愁",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国有鉄道の幹線が、二本並んで、ともに五日間も不通になったというようなことは、鉄道の歴史始まって以来のことであった。",
              "citation": {
                "source": "亡び行く国土",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国有鉄道のサービスに注文をつけたお客さんが一々鉄道省のお役人から叱られていては大変だ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
