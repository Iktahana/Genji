          "standard": [
            {
              "text": "国連憲章の第一条には、国際社会が守るべき平和と安全の維持について記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「武力の行使は原則として禁止されているんだよ」と、父は国連憲章の抜粋を見せてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "加盟国である以上、国連憲章に定められた義務を誠実に履行しなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "国連憲章は第二条第四項で、領土保全と政治的独立に対して武力をもって脅威することを禁じている。",
              "citation": {
                "source": "世界は求めている、平和を！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
