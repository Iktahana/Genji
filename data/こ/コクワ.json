    "definitions": [
      {
        "index": 1,
        "gloss": "hardy kiwi (Actinidia arguta)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山道で見つけたこくわの実は、見た目は小さいがキウイに似た甘酸っぱい味がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖母は秋になると、近所の山からこくわを採ってきて果実酒を作ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "庭の棚にこくわの蔓を這わせて、夏は日除け、秋は収穫を楽しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」「……爺ン爺い、とこくわ――おおよ。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "婿にいけば、婿にいった気にならあね」「よけいな返答をこくわ」　つけつけと小言を言わるれば口答えをするものの、省作も母の苦心を知らないほど愚かではない。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
