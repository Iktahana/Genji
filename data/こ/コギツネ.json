          "standard": [
            {
              "text": "散歩中に林の奥をのぞくと、茂みの間から可愛い子ぎつねが顔を出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "母ぎつねの後を一生懸命について歩く子ぎつねの姿に、思わず笑みがこぼれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "怪我をして動けなくなっていた子ぎつねを保護し、野生動物保護センターへ届けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」と、子ぎつねがふしぎがりました。",
              "citation": {
                "source": "村のかじやさん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、母ぎつねは、子ぎつねをつれてゆきました。",
              "citation": {
