          "standard": [
            {
              "text": "国立印刷局の見学ツアーに参加して、お札が刷り上がる工程を間近で見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新しい一万円札の偽造防止技術について、国立印刷局が詳しく解説している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国立印刷局は、日本円の他にも官報の印刷など重要な業務を担っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "国立印刷局に兵士の衛舎があった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、マレーの老市民らの最も恐ろしい思い出の一つとなって、彼らの記憶の中では、「国立印刷局の衛舎の夜襲」と題されている。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
