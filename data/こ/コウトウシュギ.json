        "examples": {
          "standard": [
            {
              "text": "彼の文学作品は、高踏主義の影響を強く受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高踏主義の作家たちは、自然や個人の内面に目を向けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は高踏主義的な思想を持ち、物質的な豊かさよりも精神的な充足を追求した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一口に云うと「高踏主義」であった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等のアカデミカルな意識が、歪曲された資本主義的ジャーナリズムに対する反抗意識から来るにしろ、或いは寧ろその歴史観的・世界観的・な一般素養の欠乏から来るにしろ、一種の高踏主義・貴族意識・に結び付いていることは争われない心事ではないかと思う。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "高踏主義・貴族主義・も一つの趣味として或いは尊重されていいかも知れぬ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
