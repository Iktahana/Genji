          "standard": [
            {
              "text": "政治家は、国民の安全で豊かな公民生活を守る責任がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害が発生した際、公民生活への影響を最小限に抑える対策が取られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公民生活の向上には、経済の安定と社会保障の充実が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この第六節で重点を置いている箇所は、「公民生活ニ於テ団結シ、相倚リ相｜扶ケ、寛容相許スノ気風ヲ作興シ」云々であるが、要は各人がお互いに平等の位置にありつつ、築き上げていく公共生活であった。",
              "citation": {
                "source": "「人間宣言」のうちそと",
                "author": "前田多門",
                "note": "青空文庫"
              }
            }
          ]
        }
