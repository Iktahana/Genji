        "examples": {
          "standard": [
            {
              "text": "アナログ信号をデジタル信号に変換するコンバーターが必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海外旅行のために、電圧コンバーターをスーツケースに入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このUSBコンバーターを使えば、古い周辺機器も最新のパソコンに接続できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これに短波の受かるコンバーターを付けるサービスを始めたところ、新聞に紹介されたことも手伝って、これがじつに繁盛した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時点で彼らの脳裏をよぎったのは、「このマシンはＮ88―ＢＡＳＩＣをそのまま載せており、Ｚ80の機械語の命令を８０８６のものに書き換えるコンバーターを使って動かしているのではないか」との疑問だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロソフトの分析によって、コンバーターを利用してそのままＮ88―ＢＡＳＩＣを走らせているのではないかとの疑いは、すぐに晴れた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＳＢトランシーバーはＤＡコンバーターにインターフェイスしたパソコンがマスターになっていて、表面に取り付けられたスイッチやツマミはマイクの操作を除いて存在理由を失っていた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
