        "examples": {
          "standard": [
            {
              "text": "言葉は通じなくても、音楽を通じて現地の人々と深い心の交流ができたと感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ネット上の文字だけのやり取りだけでなく、顔を合わせての心の交流を大切にしたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長い年月を共に過ごした老夫婦の間には、沈黙さえも心地よい心の交流の一部となっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いい意味に於て其後もわれわれの心の交流は常住新鮮であつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も、そんな事を、此の間、考へた事あつたのよ」　お互ひの心の交流のなかに、少しづつ、死の意識が薄昏い影になつて、眼底を掠めた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
