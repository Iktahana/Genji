        "examples": {
          "standard": [
            {
              "text": "雑誌のグラビアページは、写真が映えるように光沢のあるコート紙が使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このイベントのチラシは、文字だけでなく写真も多いので、発色の良いコート紙を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "年賀状は、インクジェットプリンター対応のマットなコート紙に印刷するのが一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "外泊のときは、さすがの高志も、兄らしく令子をエスコートして帰り、いっしょに寮にもどってくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちは校長先生の白く長く垂れている髯と、うすいあばたの顔を思い出すと黒いフロックコートしか思い浮ばなかった。",
              "citation": {
                "source": "藤棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
