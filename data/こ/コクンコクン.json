        "examples": {
          "standard": [
            {
              "text": "喉を鳴らしながら、彼はキンキンに冷えたビールをこくんこくんと美味そうに飲んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "赤ちゃんが母親のミルクを、一生懸命こくんこくんと音を立てて飲んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "走り終えたばかりの選手が、スポーツドリンクをこくんこくんと一気に流し込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ねんねこをひきずりながら、地面の上を四五間もこっちへ這いだし、こくんこくんと頭を上下に振りながら、ああちゃんいやよ、ああちゃんいやよと声いっぱいに泣き叫んでいた。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
