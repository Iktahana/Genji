        "examples": {
          "standard": [
            {
              "text": "鉄板焼きのカウンターで、熟練の職人が神戸肉を見事な手捌きで焼き上げてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "神戸肉の認証マークがある店は、厳しい基準をクリアした本物の味を提供している証拠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海外からの観光客も、日本に来たら一度は神戸肉を食べてみたいと口を揃えて言う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一流のまぐろというものは、最高の神戸肉や最上のうなぎを何倍か上回るほど値段の高いものであるが、食べてみれば、それだけの価値をもっていることは、ひと等しく認めるところの事実なのだから、どうにも仕方がない。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "神戸肉で、とてもいゝ肉なのだが、タレがゼロである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
