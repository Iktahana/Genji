        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い引き戸の下部に貼られた腰張りには、上品な波紋の模様があしらわれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "経年劣化で破れてしまった腰張りを補修するため、同じ質の和紙を買いに行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この腰張りの細工、当時の職人のこだわりが感じられますね」と修復士が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
