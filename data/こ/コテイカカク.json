          "standard": [
            {
              "text": "セール品を除き、このショップの全商品は固定価格で販売されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "オークション形式ではなく、固定価格で即決購入することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "原材料費が高騰しているが、契約により固定価格での納入が続く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そして数日後、ウォード氏は家の所有者を突き止め――齧歯類のような顔をした嗄れ声の小男だった――愛想顔で値段をつり上げようとする男の気勢をそぐだけの固定価格をいきなり提示して、炉額全体と絵を含むオーバーマントルを入手した。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
