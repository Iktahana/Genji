        "examples": {
          "standard": [
            {
              "text": "高校で学ぶ物理の多くは、古典力学の範疇に入る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "惑星の軌道計算には、古典力学が用いられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "量子論が登場するまで、古典力学は物理学の主流だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これの運動の解明は古典力学だけで間に合う。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然科学では Maxwell, Boltzmann の古典力学的統計操作。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがいかに量子力学が発達し、現在のような蓋然的アプローチで統計的に物と物との関係を把握するのではなく、古典力学のように必然的アプローチで一切を認識できるようになったとしても、それだけでは説明されつくせないものがある。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
