        "examples": {
          "standard": [
            {
              "text": "トーストの焦げ目が香ばしくて好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "転んで膝に大きな焦げ目を作ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "暑いアイロンをテーブルに置いてしまい、木目に焦げ目がついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "この焦げ目は衣類の一部にも及んでいた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓のない尖塔に上がる梯子には黄色い染みと焦げ目がついていたが、記者の一人が梯子を上り、落とし戸を横に動かして開け、弱々しい懐中電灯の光を不思議な悪臭のする闇に向けたとき、彼が見たのは暗黒と出入口傍に転がる不定形で雑多な屑だけだった。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
