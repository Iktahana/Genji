        "examples": {
          "standard": [
            {
              "text": "雑誌の購読料は、一年間まとめて支払うと割引が適用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "動画配信サービスの購読料が値上げされたが、内容が充実しているので継続することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今月の購読料の引き落とし、ちゃんと確認した？」と夫が妻に尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "振替郵便が来ると、入金簿へ金額、氏名、名目を記載し、もし購読料ならば購読者名簿へ購読年月日を記載し、広告掲載料ならば別の名簿へその旨書きいれる。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "購読料が切れていると、あらかじめ印刷した催促のハガキを出す。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "財産があるわけではなし、雑誌や新聞に書き散らす雑文の原稿料だって高が知れたものだし、「黎明」だって購読料月三十円ではいくらの収入にもなるまい。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この新聞の購読料は一ヶ月二十セントである。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
