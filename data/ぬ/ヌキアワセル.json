        "examples": {
          "standard": [
            {
              "text": "両国の剣士は、一触即発の状況で抜き合わせる寸前だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画のクライマックスで、主人公と悪役が抜き合わせるシーンは迫力満点だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "二人の意見が真っ向から対立し、会議室は今にも抜き合わせるような緊張感に包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "抜き合わせる間もなかったが、バッチリ柄頭で受け止めた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔名与力と謳われた二人がいかに年を取ったとは云え、刀を抜き合わせる暇もなくむざむざ削竹に咽喉を貫ぬかれ、惨殺されたということは、一面から云えば不覚ではあったが、他面彼等盗賊の群がいかに強いかということの新しい証拠ともなるのであって、有司にとっても市民にとっても恐ろしく思われたのは云うまでもない。",
              "citation": {
                "source": "赤格子九郎右衛門の娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土生仙之助、抜き合わせる隙がなく、鞘ごとかざして、はっし！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
