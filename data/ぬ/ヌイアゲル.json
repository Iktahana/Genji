        "examples": {
          "standard": [
            {
              "text": "徹夜でドレスを縫い上げ、発表会に間に合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は丁寧に生地を縫い上げ、美しいカーテンを作り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "母はいつも、私のお気に入りのぬいぐるみを縫い上げてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "前夜、久しぶりで晴ればれした顔で牀の上に起きなおって、「もう、大ぶんに快いから、きょうは一枚縫い上げるよ」　と、きかぬ気をみせて、絽縮緬の座敷着を手にとっていたが、片袖を縫いかけて、針をおいた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は、おそくなっても縫い上げるつもりでいます。",
              "citation": {
                "source": "さびしいお母さん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
