    "definitions": [
      {
        "index": 1,
        "gloss": "wiping paper (esp. for swords)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
