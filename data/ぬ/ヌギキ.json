        "examples": {
          "standard": [
            {
              "text": "子供の脱ぎ着は時間がかかるので、外出前はいつもバタバタする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試着室で、新しい服の脱ぎ着を繰り返してサイズを確かめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はスポーツの後、汗をかいた服の脱ぎ着に手間取っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "包みを解けば出でたり、ネルの単衣、柔らかき絹物の袷、白縮緬の兵児帯、雪を欺く足袋、袖広き襦袢は脱ぎ着たやすかるべく、真綿の肩ぶとんは長き病床に床ずれあらざれと願うなるべし。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『狭衣』に「みのしろも、われ脱ぎ着せん返しつと、思ひなわびそ天の羽衣」。",
              "citation": {
                "source": "蓑のこと",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぎ、もみ、つが、ひのきがや、いぬがや、あかまつ、くろまつ、やくたねごよう、こなら、かしは、かしはなら、くぬぎきり、つるまんりよう。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
