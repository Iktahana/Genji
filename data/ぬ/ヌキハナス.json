        "examples": {
          "standard": [
            {
              "text": "武士は敵を前に、素早く刀を抜き放した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画のクライマックスで、主人公が抜き放した刀の切っ先が光った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「覚悟しろ！」と彼は叫び、ギラリと刀を抜き放した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして二人とも刀を抜き放すだんになりますと、建のはにせの刀ですから、いくら力を入れても抜けようはずがありません。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツルリと短刀を抜き放すと、パッと彼は飛び下りた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "脇差坤竜をグルッと背中へまわし差して、手の、抜き放すと同時に法勝寺三郎の生き血を味わった愛剣武蔵太郎安国を、しきりにそばの、まだ映山紅を霜囲いにしてある藁へ擦りぬぐっている。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
