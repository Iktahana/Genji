        "examples": {
          "standard": [
            {
              "text": "テーブルクロスには、美しい花の縫い模様が施されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は独自の縫い模様を考案し、作品に取り入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このブラウスの繊細な縫い模様は、職人の技を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "白い縫い模様のある襟飾りを着けて、糊で固めた緑色のフワフワした上衣で骨太い体躯を包んでいるから、ちょうど、空に漂う風船へ頭と両手両足をつけたように見える。",
              "citation": {
                "source": "糸くず",
                "author": "LA FICELLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がはっきりと見たものは、暗い所ほど尚よく光る裲襠の金絲の縫い模様と小袖の箔の色とであった。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒絽の帯に、これだけは思い切て派手な縫い模様。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
