        "examples": {
          "standard": [
            {
              "text": "当社の新しいロゴマークには、持続可能な社会への願いが込められています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "街中で見かけたあのカフェのロゴマークが、どうしても思い出せない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "制服の胸元には、誇らしげに学校の伝統的なロゴマークが刺繍されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "基本はあくまで、出来合いのものを使って可能な限り早く、ＩＢＭのロゴマークの入ったパーソナルコンピューターを作ることだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがコンピューターの世界に君臨してきたＩＢＭのロゴマークを付けているにもかかわらず、ＰＣはアルテア以来の「共棲」をキーワードとした流儀を受け入れた、じつにパーソナルコンピューターらしいマシンに仕上がっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
