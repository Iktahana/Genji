    "definitions": [
      {
        "index": 1,
        "gloss": "lock",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "家を出る前に、必ずドアをロックするのを忘れないでください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は自転車に頑丈なチェーンをかけ、二重にロックした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「ちょっと待って、スーツケースのロックがうまくかからないんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "『わたし、フロックコート着る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの趣味はすべてにおいて庶民的で、儀式ばったことが嫌いなので、フロックコートなどの礼服を非常に嫌い、常に野蛮人の服と称し『なんぼ野蛮の物』と言っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれではあまり体面に関するので、夫人が是非フロックコートを新調するようにすすめたが、頑として中々きかない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上に参るの時、あなた、シルクハット、フロックコートですよ』などと、子供をだますようにして説き伏せられ、やっと礼服を新調したけれども、やはり少しも着ようとしない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈が高く顔の小さい、額がノツシリしてフロックコートのよく似合ふ、前校長の容姿が何時か彼の心を離れないものとなつてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルマン教授は胡麻塩の長髪を後ろへ撫でつけていて、いつも七つ下がりのフロックを着ていたが、講義の言語はこの先生がいちばん分りやすくて楽であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ登るには、ロッククライミング以外に手がない。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "体験としての存在様態が模様に客観化される例としては、ドイツ民族の有する一種の内的不安が不規則的な模様の形を取って、既に民族移住時代から見られ、更にゴシックおよびバロックの装飾にも顕著な形で現われている事実がある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "西鶴の人間に関する観察帰納演繹の手法を例示するものとしてはまた『織留』中の「諸国の人を見しるは伊勢」に、取付虫の寿林、ふる狸の清春という二人の歌比丘尼が、通りがかりの旅客を一見しただけですぐにその郷国や職業を見抜く、シャーロック・ホールムス的の「穿ち」をも挙げておきたい。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロックやヒュームやカントには多少の耳を借しても、ヘーゲルやフィヒテは問題にならないらしい。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この実験はその後にマロック（Arnulph Mallock）が完成し、而してレーリーの理論的の計算と一致する結果を得た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七六―七七年の冬には、やはりフルードの弟子で、また親戚であった前記のマロックを助手として液体力学の実験をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "タワーやマロックのような、自分で独立の研究の出来るような人は彼の助手としてはあまり適当でなかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからあのいつもの漆喰細工の大玄関をはいってそこにフロックコートに襟章でも付けた文部省の人々の顔に逢着するとまた一種の官庁気分といったようなものも呼び出される。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒のフロックコオトに黒のネクタイ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロックコオトに御奉公をしているのだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（フロックコオトの上着を脱いで床の上に投り出す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀、貴方はライオン・ロックの高嶺のように赤裸々な方だから正義と自己の信念を愛したのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬向きにこしらえた一ちょうらのフロックがひどく暑苦しく思われたことを思い出すことができる。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば相対性原理とはどんな事か、マルキシズムとは何か、バロック芸術とは何、ベースボールとは何、ジャズとは何、そういうことが望みのままに早分りがすれば甚だ便利であり、また時代に適応する所以であるかもしれない。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カイロ男爵だって早く上等の絹のフロックを着て明るいとこへ飛びだすがいいでしょう。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "釦の多いフロックコートを着たようである。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが済むと怪しげな名前の印度人が不作法なフロックコートを着て出て来た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのまにか獅子が立派な黒いフロックコートを着て、肩を張って立って「もうよからうな。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正何年であったか正月の三日に、国原がフロックコートで初出社をすると、左手の甲に仰山らしく繃帯をしている。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローロックのピンを捻じると、石垣へ手をやり、あと先を見計らって艇を水のなかへ押し出した。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそばへ一人の夏フロックコートを着た男が行って何か耳うちしました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "lock (in rugby)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ラグビーのロックは、スクラムの際に中心となってFWを支える重要なポジションだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は身長2メートルを超える巨体を生かして、日本代表の不動のロックとして活躍した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "試合終盤、敵陣ゴール前のラインアウトで、ロックが見事にボールをキャッチし、トライのチャンスを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
    ],
