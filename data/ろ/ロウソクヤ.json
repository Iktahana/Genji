        "examples": {
          "standard": [
            {
              "text": "京都の路地裏にある老舗の和ろうそく屋では、職人が一本一本手作業で芯に蝋を塗り重ねていく伝統的な製法を守り続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "観光客で賑わうヨーロッパの旧市街で、色とりどりの手作りキャンドルを並べた小さなろうそく屋を見つけ、お土産にいくつか購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "昔はこの町にも何軒かろうそく屋があったそうだが、電灯の普及とともに次々と店を畳んでしまったという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さればこそ、一生一度の盗みもしたんですが、それってものは、あのろうそく屋の長兵衛めがちっと気にいらねえ癖があってね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろうそく屋では、ろうそくが売れるので、おじいさんはいっしょうけんめいに朝から晩まで、ろうそくを造りますと、そばで娘は、手の痛くなるのも我慢して、赤い絵の具で絵を描いたのであります。",
              "citation": {
                "source": "赤いろうそくと人魚",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろうそく屋の年より夫婦は、神さまの罰が当たったのだといって、それぎり、ろうそく屋をやめてしまいました。",
              "citation": {
                "source": "赤いろうそくと人魚",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろうそくつくるがろうそく屋、型からひっぱいだときゃ、手にもってた。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉屋にパン屋、ろうそく屋の亭主。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こうして、モミの木は、つぎの日も、ろうそくや、おもちゃや、金の紙や、果物などで、かざってもらえるものと思って、楽しみにしていました。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "てまえは京橋｜薬研堀のろうそくや大五郎と申す者でござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇吉は、おかあさんと、毎日ここへでて、ろうそくや、マッチや、うちわなどをならべて、あきなっていました。",
              "citation": {
                "source": "新しい町",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
