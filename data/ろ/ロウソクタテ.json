        "examples": {
          "standard": [
            {
              "text": "アンティークショップの片隅で、真鍮に細かな彫刻が施された見事なろうそく立てを見つけ、思わず衝動買いしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "クリスマスの夜のディナーテーブルには、ガラス製の美しいろうそく立てが置かれ、ロマンチックな雰囲気を演出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "仏壇のろうそく立てにこびりついた溶けた蝋を、お盆の前に専用のクリーナーで綺麗に削り落とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "壁ぎわの木箱には、衣服の布がぼろぼろになってすこしばかりのこり、奥のほうの寝台にはわらがしいてあり、木製のろうそく立てもある。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家に突然、神棚にありし鈴が落ちきたり、そこに載せてあるろうそく立てが落ちきたり、その飛ぶや別に音なく、ただ落つる際に大いなる響きを発するのみである。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "はしっこいジャックはしっこいジャック、すばやいジャック、ろうそくたて一つ、ジャックがとびこした。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
