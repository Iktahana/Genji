        "examples": {
          "standard": [
            {
              "text": "彼は大学を卒業後、メーカーの人事部労務課に配属された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "給与計算や社会保険の手続きは、すべて労務課が担当している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "従業員の労働時間に関する問題が発生したため、労務課が調査に乗り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "昨今の工場では労務課がいろいろ苦心して講習会をやるが、その一つで詩吟の会だの剣舞の会だのというのがある。",
              "citation": {
                "source": "今日の生活と文化の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ブラブラするのは、もう、やめましたの」「どこへ、お送りしましょう」「郵船ビルのレーバー・セクション（労務課）へ行って、メイドでもなんでも、やってみるつもりなの」「へえ、メイドにね……それもいいが、川崎の鉱山調査研究所に、雇員の口があるよ……鉱山保安局にいる由良ってのは、あなたの叔父さんだろう。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐山　軽金属の会社の――かなり大きな製造会社ですがね、そこの労務課……学校出てからズッと……こいでも、大学出てるんですよ。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一席やってくれ」　もうだいぶん酔っている三菱の労務課長が、牀柱のところから、手をあげて叫んだ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
