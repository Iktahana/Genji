        "examples": {
          "standard": [
            {
              "text": "帰り道にあるローソンに寄って、からあげクンと缶ビールを買って帰ろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "駅前のローソンの入り口で、友達と待ち合わせをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "荷物を送るために、近くのローソンでゆうパックの伝票をもらってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ヘプジバ・ローソンなる者が一六九二年六月十日、ホーソーン判事の下、刑事上級裁判所で次のように宣誓した：「十四人の魔女と黒の男がハッチンソンさんの家の裏の森でいつも集会を開いていました。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
