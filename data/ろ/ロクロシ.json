        "examples": {
          "standard": [
            {
              "text": "町工場のベテランろくろ師は、コンマミリ単位の精度で金属部品を削り出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼はろくろ師として長年働き、数々の精密な製品を生み出してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "若い見習いが、ろくろ師の厳しい指導の下、旋盤の技術を習得しようと励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "人のいいピート一等兵は、パイ軍曹と衛兵との攻撃にあって、眼をしろくろしている。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
