        "examples": {
          "standard": [
            {
              "text": "賄賂や接待は、政治家を取り込むための古典的な籠絡手段だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は目的のためなら、どんな籠絡手段を使うことも厭わない冷徹な男だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "相手の弱みにつけ込むのは、彼の常套の籠絡手段だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "一般人民の籠絡手段　ところで一般人民もやはり自分の味方にする必要がある。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても古河にとっては青天の霹靂であったにちがいなく、従来の政府に対するような籠絡手段をもってしては到底まぬかれ得ない厳達であり、命令どおり遂行するとなれば、事業上、経済上に相当の打撃と苦痛をともなうことと推測された。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
