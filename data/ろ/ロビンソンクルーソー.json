        "examples": {
          "standard": [
            {
              "text": "彼はまるで現代のロビンソンクルーソーのように、山奥で自給自足の生活を送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "夏休みの読書感想文の課題図書に、ロビンソンクルーソーが選ばれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "子供の頃に読んだロビンソンクルーソーの物語が、私の冒険心に火をつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ロビンソンクルーソーを読んでテニソンのイノック・アーデンのように詩趣がないと云う。",
              "citation": {
                "source": "作物の批評",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれだからロビンソンクルーソーは作物にならないと云うのは歌麿の風俗画には美人があるが、ギド・レニのマグダレンは女になっておらんと主張するようなものである。",
              "citation": {
                "source": "作物の批評",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
