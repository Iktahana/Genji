        "examples": {
          "standard": [
            {
              "text": "主人公が自分探しの旅に出る、という設定はロードムービーの定番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "夏休みに見たロードムービーに影響されて、ヒッチハイクで一人旅に出たくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "このロードムービーは、登場人物たちの心の変化を、旅先の美しい風景とともに描き出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "カフカは透明な旅人の話をこの一編きりしか書かなかったが、時雨沢の方には言葉を話す自動二輪が登場し、ロードムービーとなって、連作の形を作ることに成功している。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            }
          ]
