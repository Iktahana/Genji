        "examples": {
          "standard": [
            {
              "text": "ファミコンで発売された初代「ロックマン」は、その難易度の高さとアクションの面白さで多くの子供たちを夢中にさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は「ロックマン」シリーズの全作品をクリアしており、特に好きなボスはカットマンだと語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「懐かしいな、放課後は友達の家に集まって、いつもロックマンの攻略法を話し合ってたよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "九番目の「鬼火」は、ブロックマンやタウバーに比べると、素直で嫌味がないだけに身につまされて聴かれる。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌はヒュッシュ、ゲルハルト、ブロックマン、キプニス、タウバーらのがある。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
