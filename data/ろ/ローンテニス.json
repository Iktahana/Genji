        "examples": {
          "standard": [
            {
              "text": "ウィンブルドン選手権は、伝統的な天然芝のコートで行われるローンテニスの最高峰の大会だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "イギリスの貴族たちが庭先の芝生で楽しんでいたローンテニスが、現代のテニスの原型となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "手入れの行き届いたローンテニスのコートで、白いウェアを着た選手たちが優雅にラリーを続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "夏は散歩の代りにローンテニスもやった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵画、音楽、芝居、浄瑠璃、若しくは囲碁、ピンポン、ローンテニスと同様に、単に暫く娯楽を得るための方便と見做して哲学を味ふに於ては何の妨げもない。",
              "citation": {
                "source": "芸術としての哲学",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして種々の筋肉の調和した働きというものは、練習の結果として初めて完全にできるものであることは、ベースボール、ローンテニスのごとき遊戯でも、書画、裁縫のごとき芸術でもみな大いに練習を要するということを見ても知れる。",
              "citation": {
                "source": "生物学より見たる教育",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
