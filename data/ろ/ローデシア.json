        "examples": {
          "standard": [
            {
              "text": "彼は大学の歴史の授業で、かつてアフリカ南部に存在したローデシア共和国についてレポートを書いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その古い切手帳には、ローデシアと印字された珍しい切手が大切に保管されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祖父は若い頃、鉱山の技師としてイギリス領ローデシアに数年間滞在していたことがあるそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ローデシア警察に招かれておりまして、すぐにでも南アフリカへ行くつもりです。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて青年、君についても明るい未来がローデシアで待っていると信じている。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローデシアでダイヤを発見し、一発でのし上がり、もっぱら、デビアス社との契約を指揮する為に、シティの事情通によれば、はるばる合併交渉にやってきて、二百万ポンドの現金を持参しているとか。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
