        "examples": {
          "standard": [
            {
              "text": "彼女は肩こりがひどかったので、小型のマッサージ用ローターを押し当ててコリをほぐした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "引き出しの奥から、電池が切れかかって微弱に震えるピンク色のローターを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "雑貨屋のジョークグッズコーナーに、リモコンで遠隔操作できるローターが売られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
