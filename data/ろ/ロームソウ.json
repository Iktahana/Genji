          "standard": [
            {
              "text": "掘削調査で、厚いローム層が確認された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域は、肥沃なローム層に恵まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ローム層の厚さによって、植生も変わってきます。」と地質学者は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "慎しく語ろうと気をつけている言葉の端々に関東ローム層とか、第三紀層とかいう専門語が女学校程度の智識でない口慣れた滑らかさでうっかり洩れ出すのを、私の注意が捉えずにはいなかった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見りゃあ、わかるだろ」　非常口ホールからヴェランダへ出ると、この寮を建てるためにけずられた裏山の、半分だけになった頂上が見え、むきだしの急斜面で、関東ローム層の成立ちを観察できる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
