    "definitions": [
      {
        "index": 1,
        "gloss": "caged bird",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ああ、籠鳥の身はつらいな…」と彼は冗談めかして、終わらない仕事の山を見つめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女はまるで美しい籠鳥のように、親の決めた厳格なルールの中で生きていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "籠鳥は毎日同じ景色を眺めながら、いつか自由に大空を羽ばたく日を夢見ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "籠鳥の感嗚呼青春の夢高く理想のあとにあこがれて若き血汐の躍るとき人も自在の翼あり。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
