        "examples": {
          "standard": [
            {
              "text": "昔ながらのローカル線に乗って、旅情あふれる田舎の風景を楽しんできました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このローカル線は、乗客が少なくても、地域住民の生活を支えるために運行を続けています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "廃線寸前のローカル線が、観光資源として復活するケースもあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ローカル線だから、車も小さいし、速度も遅い。",
              "citation": {
                "source": "腹のへった話",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローカル線の本数は少ないし、線路不通で大混乱しているようだった。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
