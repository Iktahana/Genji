        "examples": {
          "standard": [
            {
              "text": "職人が丁寧に蝋色漆を塗り重ねたお椀は、まるで鏡のように周囲の景色を反射していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祖父の形見の万年筆は、軸に最高級の蝋色漆が使われており、しっとりとした手触りだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "展覧会で見た漆器の飾り棚は、深みのある蝋色漆の黒と金箔のコントラストが息を呑むほど美しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "堂々たる大型で、欅の材を太々と使い、これに蝋色漆を塗ったりまた黒柿の内縁を入れたりします。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
