          "standard": [
            {
              "text": "歴史小説で、新田義貞による六波羅攻略の場面が劇的に描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "六波羅攻略は、鎌倉幕府の滅亡を決定づけた重要な戦いの一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "社会科の授業で、後醍醐天皇の倒幕計画と六波羅攻略について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "彼も急遽、近江からこれに会して、「足利と共に力を協せ、六波羅攻略の大功を仕遂げし者」　と称え、また高氏もそれを称揚して、共々、曠れの御車迎えに来ていたのだった。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "高氏の叛旗は、あざやかに、六波羅攻略には成功したが、そのためには、最愛の妻子をこの大ばくちに賭けたのであり、恐ろしい欲望だったというしかない。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
