        "examples": {
          "standard": [
            {
              "text": "その映画は、スペインのアンダルシア地方を旅するロマニーの一家の物語だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は自身のルーツであるロマニーの文化を、写真を通して世界に伝えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "祭りの広場では、ロマニーの女性たちが情熱的なフラメンコを踊っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "堂のすみにしゃがんでいる年とった土人に、「ここに祭ってあるゴッドの名はなんというか」と聞いたら上目に自分の顔をにらむようにしてただ一言「スプロマニーン」と答えた――ようであった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
