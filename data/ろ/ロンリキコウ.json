        "examples": {
          "standard": [
            {
              "text": "新しく開発された論理機構により、データ処理の速度が劇的に向上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "システムの根幹をなす論理機構に障害が発生し、全面的な復旧作業が行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "このチップは、複雑な演算を瞬時に行う独自の論理機構を備えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この生産の尖端に誘導されねばならない理由を有っている夫々の国々の論理機構は又、その尖端を出揃わせるわけで、それに交通運輸機関の著しい発達の必要がこの論理の国際性を日増しに現実的なものにして行きつつある。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しこの第二の規定は実は、ドイツ・アウフクレールングでは単に最も極端なドイツ式な形で現われたと云うまでで、広くフランスの唯物論にも共通な一つの論理機構に他ならない。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然科学の歴史的発達にもし階級性があるなら、この発達を必然ならしめた自然科学の内部的論理機構そのものに階級性がなくてはならぬ。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
