        "examples": {
          "standard": [
            {
              "text": "子供の頃、勇者になって魔王を倒すロールプレイングゲームに夢中になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "新作のオンライン・ロールプレイングゲームで、世界中のプレイヤーとパーティーを組む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "そのロールプレイングゲームは、プレイヤーの選択によって結末が変わるマルチエンディングを採用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ウォズニアックはコンピューターがテキストを画面に表示してよこし、それを見ながらユーザーがテキストを送り返して話を進めていくといった形式の、のちにロールプレイングゲームとして確立されるようなものを作りたいと考えるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
