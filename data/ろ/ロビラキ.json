        "examples": {
          "standard": [
            {
              "text": "茶道の世界では、十一月になると炉開きを行い、冬の茶の湯の準備を始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "先生の家の茶室で、親しい人たちだけが集まるささやかな炉開きの茶会が開かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "炉開きには、その年の初物の亥の子餅をいただくのが習わしだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "千鳥聴き一　炉開きの忙しい二、三日を済ますと、浜中屋の女将は、骨折り休めに、熱海に入湯に出かけた。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
