          "standard": [
            {
              "text": "古代インドでは、ヴェーダの権威を認めるか否かで、六派哲学などの様々な思想が生まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "大学でインド哲学を専攻し、特に六派哲学の中のヨーガ学派について研究している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "六派哲学は、それぞれが独自の解脱への道を説いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "支那哲学や印度六派哲学やギリシア＝ローマ期の哲学、又中世のカトリック神学、に於て見られる学問なるものは、それ自身が道徳的知恵か宗教的信条かに他ならなかった。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
