        "examples": {
          "standard": [
            {
              "text": "パリの街角で開かれていた露天市では、アンティークの食器や古本が売られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "毎週日曜日に開催される公園の露天市は、地元の人々でいつも賑わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "旅の楽しみの一つは、その土地ならではの品物が見つかる露天市をぶらぶらと歩くことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ビルにそつて右へ曲ると、いくつもの小路のなかに、地べたに店を拡げてゐる露店市が、ぎつしりと並んでゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピラミッドのやうに積み上げた蜜柑を売る店、ゴム靴屋、一ぱい五円の冷凍｜烏賊を並べてゐる店、どんな路地の中にも、さうした露店市が路上にあふれてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
