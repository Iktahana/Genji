        "examples": {
          "standard": [
            {
              "text": "数か月にわたる交渉の末、労働組合と会社側は、賃上げに関する新たな労働協約を締結した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この労働協約には、賃金や労働時間だけでなく、福利厚生に関する詳細な取り決めも含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "労働協約に違反したとして、労働組合は会社側に厳重に抗議した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "フーヴァーの資本・労働協約は、現にアメリカ国内生産の矛盾と対立とを鋭く意識させる役に立っているばかりであり、フランスの資本主義は、自動車生産の部門から恐慌の影響を示しはじめている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
