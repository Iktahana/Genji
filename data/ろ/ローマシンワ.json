          ],
          "literary": [
            {
              "text": "（１）Pluto ――ローマ神話の下界の王。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊８　ガロパード　非常にステップの急調子舞踏の一種＊９　マルスの神　ローマ神話に於ける軍神。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはやトリガーセンはホメロス風の怒りなどないし、重大事項のために湾へ飛び込んだローマ神話のマーカス・クルチウスでもない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
