        "examples": {
          "standard": [
            {
              "text": "畑で収穫したローゼルの赤い萼を使って、自家製のハイビスカスティーを淹れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "地元の直売所で、甘酸っぱいローゼルのジャムが瓶詰めで売られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ローゼルの実を塩漬けにすると、梅干しのような風味になっておにぎりにぴったりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "クローゼル・ド・モンタル氏は種々の点でクローゼル・ド・クーセルグ氏と離反した。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "――アルマン・カレル（訳者注　有名な新聞記者）はクローゼル元帥を訪問した。",
              "citation": {
