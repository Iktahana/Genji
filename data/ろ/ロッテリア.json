          "standard": [
            {
              "text": "高校生の時、学校帰りに友達とロッテリアに寄ってポテトを食べるのが日課だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ロッテリアの絶品チーズバーガーは、時々無性に食べたくなる味だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "駅前のロッテリアで、待ち合わせの時間までコーヒーを飲んで待つことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "大通りの横断歩道を渡り、大きく〈不二屋〉と書かれた看板のあるビルの地下に降りて行き、ロッテリアでエビハンバーガーとスプライトを注文する。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロッテリアを出て再び横断歩道を渡り、有楽町マリオンの方へ戻って来ると、何やら人がビルの入口のところに集まっている。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
