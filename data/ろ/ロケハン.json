          "standard": [
            {
              "text": "映画監督は、物語のイメージにぴったりの場所を見つけるため、自らロケハンに赴いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "来週から始まるドラマの撮影に先立ち、制作スタッフが入念なロケハンを行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この美しい田園風景は、ロケハン中に偶然見つけた絶好の撮影スポットだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "網棚へ小道具の入ったスーツ・ケースを載せると、灰銀のフラノのワンピースに緋裏のついた黒のモヘアのストールという、どこかのファッション・モデルのような恰好で車室を流して歩き、知った顔がないかと物色していたが、三つ目の車でロケハンにでも行くらしい楠田という助監督の一行を見つけた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
