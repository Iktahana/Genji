          "standard": [
            {
              "text": "老年学は、加齢に伴う心身の変化や社会との関わりを多角的に研究する学問だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は大学院で老年学を専攻し、高齢社会におけるコミュニティの役割について論文を書いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "市の福祉課は、老年学の知見を活かして、高齢者向けの新しいプログラムを開発した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "中年学校、老年学校を設置して中年、老年の生徒を収容し、その教授、助教授には最も現代的な模範的ボーイやガールを任命するのも一案である。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
