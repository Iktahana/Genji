        "examples": {
          "standard": [
            {
              "text": "彼はプロのロードレーサーとして、ヨーロッパの厳しいレースで戦っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "週末になると、多くのロードレーサーたちが峠道でトレーニングに励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "最新のカーボンフレームを採用したロードレーサーは、驚くほど軽い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "一速で時速一三〇キロも出てしまうロードレーサーだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルメットをかむったミーヨが、ロードレーサーにまたがった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭日の、なにもレースのないスピードウエイのコースを時間で借り切り、人気の高いあのロードレーサーの試乗をさせてもらっている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このコースをあのロードレーサーで三周できるなら、一万円くらい払ってもいいというオートバイ・クレージーはたくさんいるはずだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "何周目かに、あのロードレーサーでミーヨがまた走るのを、ぼくはバンクの下から見た。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンクのいちばん下をＷ３で重く走っているぼくを尻目に、鮮やかなオレンジ色のつなぎのミーヨが、しなやかにたくましいロードレーサーと美しく一体になり、バンクを飛び抜けていった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのロードレーサーにくらべると、カワサキのＷ３は、恋女房であるにはちがいないにしても、すくなくとも十年以上は苦楽を共にしてきた古ものに感じられてくる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
