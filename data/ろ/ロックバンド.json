        "examples": {
          "standard": [
            {
              "text": "彼は高校の文化祭で、友人たちとロックバンドを組んで初めてステージに立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "地元のライブハウスを中心に活動していた無名のロックバンドが、口コミで人気に火がついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "伝説のロックバンドの解散コンサートには、全国から何万人ものファンが詰めかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "「今日のゲストはデビューしたばかりの女性ロックバンド、サイバネティック・スキゾイドのみなさんです」　その瞬間アナウンサーをクローズアップしていたカメラから、自分たち三人に向けられた正面のカメラに切り換わったのを陽子は悟った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく女の子だけのバンドだと、アレンジができないとかプロデュースができないとか、とかく憎まれ口を叩かれるものですけど、あたしたちはすべての面で、男性のロックバンドが可能なことなら女性のロックバンドでも可能なんだってことを証明したいんですよ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日のゲストはデビューしたばかりの女性ロックバンド、サイバネティック・スキゾイドのみなさんです」　カメラが切り換わる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
