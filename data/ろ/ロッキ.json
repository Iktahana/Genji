[
  {
    "uuid": "05cd3ed7-b241-5397-abd0-4755205a3f55",
    "entry": "六輝",
    "reading": {
      "primary": "ろっき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese calendar's six labels, indicating how auspicious each day is",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "結婚式の日取りを決めるために、六輝を調べて大安の日を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "カレンダーに書かれている「仏滅」や「友引」は六輝の一種だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "六輝を気にする人もいれば、全く気にしない人もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "「ちょっ、こんなにぼろっきれを集めてさ、まるでお宝みたいに抱いて寝てるんだよ……」　こう言ってナスターシャは、例の病的な神経性の笑い声を高々と立てるのであった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずか十ルーブリか二十ルーブリくらいの品を取り出して、それをポケットへねじ込んでさ、女物のはいった長持の中でぼろっきれを引っかき回しただけなんだ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
