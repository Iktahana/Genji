        "examples": {
          "standard": [
            {
              "text": "浄水場の見学ツアーで、巨大なろ過池に水がゆっくりと染み込んでいく様子を観察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "大雨で原水が濁ったため、ろ過池の洗浄頻度を通常よりも増やす必要があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "この施設では、砂と砂利の層を使った急速ろ過池を採用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "少しどころかちっとも要領を得なかった。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
