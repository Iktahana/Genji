        "examples": {
          "standard": [
            {
              "text": "祖父の遺品を整理していたら、未現像の古いロールフィルムが何本も出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "デジタルカメラが普及する前は、旅行に行くたびに36枚撮りのロールフィルムを数本持ち歩いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "トイカメラに35mmのロールフィルムを装填し、街の風景をモノクロで撮影する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "目下ノトコロ好事ノ士ガ稀ニ用イルノミデ一般ニ普及シテイナイガ、普通ノ手札型ノロールフィルムニ印画紙ガ重ネテアルモノデ、容易ニ日本デハ手ニ入ラズ、一々アメリカカラ取リ寄セルノデアル。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
