        "examples": {
          "standard": [
            {
              "text": "暖炉の前でロッキングチェアに揺られながら読書をするのが、祖父の何よりの楽しみだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "アンティークショップで、一目惚れした美しいデザインのロッキングチェアを購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は赤ん坊を抱いてロッキングチェアに座り、静かな子守唄を歌った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "また右側の壁には少し奧によつて扉、ずつと前によつて瀬戸で疊んだストーヴ、その前に二脚の肱掛椅子と一脚のロッキングチェアとがあつてストーヴと扉の中程に小さいテーブル。",
              "citation": {
                "source": "人形の家",
                "author": "ET DUKKEHJEM",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
