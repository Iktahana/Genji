        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日のロケ弁は、地元で有名な店の特製幕の内弁当で、スタッフみんな大喜びだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "撮影の合間に、温かいロケ弁を食べながらスタッフと談笑するのが、ささやかな楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼はAD時代、毎日何十個ものロケ弁を発注するのが仕事だったと語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "バスの中へ、ロケ弁が届く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロケ弁が配られると、たちまち食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロケ弁が出たら食ひたくなり、焼きちくわ、鮭などのおかず、これを平げた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
