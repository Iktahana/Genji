          "standard": [
            {
              "text": "カウンセリングの手法として、他者の立場を演じるロールプレイングを取り入れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "リーダーシップ研修で、複雑な部署間対立を解決するロールプレイングを実施した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "実践的なコミュニケーション能力を高めるために、営業現場を模したロールプレイングを行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ウォズニアックはコンピューターがテキストを画面に表示してよこし、それを見ながらユーザーがテキストを送り返して話を進めていくといった形式の、のちにロールプレイングゲームとして確立されるようなものを作りたいと考えるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
