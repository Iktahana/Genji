        "examples": {
          "standard": [
            {
              "text": "中学の英語の授業で、初めて「ロミオとジュリエット」の有名なバルコニーの場面を読んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "敵対する家に生まれた二人の悲恋を描いた「ロミオとジュリエット」は、時代を超えて上演され続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼はオーディションでロミオ役を射止め、「ロミオとジュリエット」の舞台に立つことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "もっともロミオとジュリエットは窓から……」　と、言いかけて、白崎は赧くなっている女の顔を見て、おやっと思った。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロミオとジュリエット」にしろ、「パオロとフランチェスカ」の物語にしろ、スタンダールの「カストロの尼」にしろ。",
              "citation": {
                "source": "貞操について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロミオとジュリエット」で、ジュリエット姫は、どんなに哀憐にロミオ！",
              "citation": {
                "source": "デスデモーナのハンカチーフ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロミオとジュリエットの墓」なら二つありさうなものと思つて、捜して見ましたけれども、見つかりませんでした。",
              "citation": {
                "source": "フランスに於けるシェイクスピア",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺を見ただけでは別にどういふ感じもなかつたのですが、その胸像を見ると共に、一種厳粛な、荘厳な気持に打たれ、実際自分が「ロミオとジュリエット」の舞台の人物といふほどでもありませんが、殆んどその時代にゐて、その物語りを直接に感じてゐるやうな気がしたのでした。",
              "citation": {
                "source": "フランスに於けるシェイクスピア",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハムレット」、「ロミオとジュリエット」、「リヤ王」、「マクベス」、「オセロー」、かういふものがどんどん翻案となつてフランスの舞台に現はれました。",
              "citation": {
                "source": "フランスに於けるシェイクスピア",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかい、光ちゃん、それからね親と親とが仲が悪いと、そのためにかえって逆に子供と子供が恋愛に落ちることだってあるんだぜいつか「ロミオとジュリエット」と言うのを読んだことがあるだろう？",
              "citation": {
                "source": "詩劇　水仙と木魚",
                "author": "――一少女の歌える――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
