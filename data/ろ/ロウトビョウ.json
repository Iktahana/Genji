        "examples": {
          "standard": [
            {
              "text": "人生の終盤において、多くの人が老と病という避けがたい問題に直面する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は、長年連れ添った妻が老と病に苦しむ姿を、なすすべもなく見守ることしかできなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "仏教では、生・老・病・死を、人間が本質的に抱える四つの苦しみ「四苦」として説いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "老と病とは人生に倦みつかれた卑怯者を徐々に死の門に至らしめる平坦なる道であろう。",
              "citation": {
                "source": "正宗谷崎両氏の批評に答う",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
