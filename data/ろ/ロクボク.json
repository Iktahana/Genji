        "examples": {
          "standard": [
            {
              "text": "体育館の壁には、体操で使われる肋木が設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼はリハビリのために、毎日肋木を使ったトレーニングを行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "子供の頃、学校の肋木に登って遊んだ記憶がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "女生徒の体操の時間で、肋木につかまった生徒達が、教師の号令で、跼んだり起きたりしています。",
              "citation": {
                "source": "足の裏",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面に体操用の肋木台。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その肋木に両腕をしばりつけられて、土気色の顔の、眼をつぶり、青バナを垂らし、ヒクヒクとあえいでいる片倉友吉。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘヘ、どういうのかねえ、この――（ニヤニヤしながら肋木の方へ）人見　――あの、だいじょうぶでしょうか？",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "友吉は、縄がほどけるとクタクタと、ボロをたたんだように肋木の足もとに坐る。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛もそのうちには、もっとしりがやせ、あばら骨がろくぼくのようにあらわれ、ついには死ぬのです。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
