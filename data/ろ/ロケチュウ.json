        "examples": {
          "standard": [
            {
              "text": "「ただいまロケ中のため、この先への立ち入りはご遠慮ください」と書かれた看板が立っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "駅前で偶然、好きな俳優がロケ中なところに遭遇して、一日中幸せな気分だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼はロケ中の事故で怪我を負い、しばらくの間、撮影から離脱することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "三月十四日（日曜）　曇天のため午前のロケ中止といふことで朝十時すぎ起きて入浴食事。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "樋口と四階のクラブで話してると、「夜のロケ中止」の報に勢ついた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
