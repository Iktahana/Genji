        "examples": {
          "standard": [
            {
              "text": "1922年のローマ進軍は、イタリアの歴史における転換点となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ムッソリーニ率いる黒シャツ隊によるローマ進軍は、ファシスト政権樹立のきっかけとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ローマ進軍がなければ、その後の歴史は大きく変わっていただろう。」と歴史家は分析した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "行動の讚美はイタリーのマリネッティのように、未来派からローマ進軍へとうつりゆきますから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
