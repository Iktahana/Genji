        "examples": {
          "standard": [
            {
              "text": "観光地の陶芸体験コーナーで、ろくろ回しに挑戦して自分だけのお茶碗を作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼の趣味は陶芸で、週末は自宅の工房でろくろ回しに没頭している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ろくろ回しは、土の感触を楽しみながら集中力を高めることができる、素晴らしい活動だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      },
      {
