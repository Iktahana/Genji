        "examples": {
          "standard": [
            {
              "text": "北朝鮮を実質的に一党支配しているのは、朝鮮労働党という政党だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ブラジルの大統領選挙で、左派の労働者党の候補が僅差で勝利を収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "かつて存在したその国の労働者党は、軍事クーデターによって非合法化され解散に追い込まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「ソヴェト連邦の労働者党、即ちソヴェト連邦の共産党による政府の指導という事実は何処に現われているか？",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村の旧土地制はそれによって崩壊しつつあること、ロシアの未来は工場の労働者に基礎を置かれなければならぬということ、労働者党が必要でありそれが過去において陥ったインテリゲンツィアの矛盾をも解決するであろうこと等をプレハーノフはその論文の中で語っているのであった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            }
          ]
        }
