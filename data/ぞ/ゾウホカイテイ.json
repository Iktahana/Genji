          "standard": [
            {
              "text": "この教科書は、最新の知見を取り入れて増補改訂された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "論文の増補改訂には、かなりの時間と労力がかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "近年、インターネット上の情報をもとに書籍が増補改訂されることも多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "而して本論は即ち當時の講演を増補改訂せしものなり。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかして早く増補改訂を加えた第二版を出したいと、民俗学研究所の人々は苦慮している。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
