        "examples": {
          "standard": [
            {
              "text": "コケ植物の生活環において、造精器は精子を形成する器官である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "顕微鏡で観察すると、造精器から放出される精子の動きがよく見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "造精器と造卵器は、植物の生殖において重要な役割を担っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "併し淫念もまた或器分、即ち生殖系器の發達に伴なつて萌し來るものであり、造精器の摘出によつては殆ど亡滅するものである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし淫念もまた或る器分即ち生殖系器の発達に伴って萌し来るもので、造精器の摘出によっては殆んど滅亡するものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
