        "examples": {
          "standard": [
            {
              "text": "彼は俗離れした生活を送り、世間の喧騒から距離を置いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その芸術家は、俗離れした感性でユニークな作品を生み出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の生き方は、俗離れしていて周りの人々を驚かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "海鼠を好むといふ人は、俗離れのした其の趣をも食べるのである。",
              "citation": {
                "source": "茸の香",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗離れのした強い性格の律師で、突然、「あ、左大将はいつごろから宮様の所へ通って来ておいでになりますか」　と問うた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心の望みどほりの美しい人です――きやしやで俗離れがして。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
