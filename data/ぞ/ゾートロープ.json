        "examples": {
          "standard": [
            {
              "text": "ゾートロープは、昔のアニメーションの原理を体験できる装置だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館で、ゾートロープが動いているのを見て感動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゾートロープの中の絵が連続して動き出す様子は、見ていて飽きない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それからまた、眼底網膜の視像の持続性を利用するという点ではゾートロープやソーマトロープのようなおもちゃと似た点もあるが、しかしこれらのものと現在の映画――無声映画だけ考えても――との間の差別は単なる進化段階の差だけでなくてかなり本質的な差であると考えられる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
