        "examples": {
          "standard": [
            {
              "text": "新しい炊飯器は、象印の最新モデルを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "象印の製品はデザインも機能も優れていて、とても気に入っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠方から来た友人が、日本の象印の電気ポットをお土産に買っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "旧時代のハイカラ岸田吟香の洋品店へ、Ｓちゃんが象印の歯みがきを買いに行ったら、どう聞き違えたものか、おかしなゴム製の袋を小僧がにやにやしながら持ち出したと言って、ひどくおかしがって話したことを思い出す。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花王歯磨、ライオン象印、クラブ梅香散……ざっと算えた処で五十種以上に及ぶです。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "象印のグリーン氏にガロン薬缶五十、温め鍋二十、ベイクケトル十五、スモークドタン十枚。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジンジャーエールは、最後にはつばめの食堂車に象印のラベルのものがあつたのをおぼえてゐるが、今もなほあるかどうかは知らない。",
              "citation": {
                "source": "飲料のはなし",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
