        "examples": {
          "standard": [
            {
              "text": "国内の主要な造船会社は、国際競争力の強化に努めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの造船会社は、高度な技術力で知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "造船会社に勤める彼は、新しい船の設計に携わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "バアクレイ・カアル造船会社によって、クライド船渠で建造された。",
              "citation": {
                "source": "沈黙の水平線",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしかすると、すでにどこかの造船会社が興味を示し、羊羹クジラの製作に取りかかっているかもしれない。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき老人が、御学友なぞと言っていた造船会社のステーンセン伯爵とは、もしかすると……もしかすると、先王陛下のその秘密のお子様ではないかしら？",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯爵は、現在上院議員、クラーグ造船会社副社長として重役陣に列している。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
