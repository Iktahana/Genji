    "definitions": [
      {
        "index": 1,
        "gloss": "rectangular bugaku mask made of thick paper and white silk with facial features drawn on it",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雅楽の舞に用いられる蔵面は、独特の表情が印象的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その蔵面は、室町時代に作られたものだと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館で、貴重な蔵面が展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "梅太郎昼ねしたり、小谷耕蔵面会ス。",
              "citation": {
                "source": "坂本龍馬手記",
                "author": "イロハ丸航海日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この契機を力説するために道元は仏と仏との面授面受を説く（正法眼蔵面授）。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
