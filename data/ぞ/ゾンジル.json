        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "詳細につきましては、私どもも存じません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そのお名前は以前から存じております。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は世界の経済情勢をよく存じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "主人は所払い」「うへッ」「いかにもそれは気の毒と存じるので、内々その方の耳に入れて置く。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "何卒、御用お命じ下さいますなら、私ども幸いと存じるものでございます。",
              "citation": {
                "source": "罌粟の中",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「片扉がそっくり浮きあがるほど明るく存じる。",
              "citation": {
                "source": "津の国人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついてはこの秘密を、女王陛下に奏上したく存じるゆえ、イギリス領土内の安全通行券をもらいたいというのである。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まことに、お痛わしくは存じるが、お上の御快気次第、ここの御所をよそへお移し申しあげることになろう。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さるがゆえに、一だんと、文治武備の制はむずかしく、わけても朝廷ご自体が、直接、武士を養い、武権を統御あるなどは、事々に、乱を生じやすく、容易でないことを、御賢察あらま欲しく存じる次第にござりまする。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
