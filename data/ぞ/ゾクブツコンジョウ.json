        "examples": {
          "standard": [
            {
              "text": "彼女の行動は、俗物根性の表れだと批判された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は俗物根性から、高級品ばかりをコレクションしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "世間には、俗物根性を持った人が意外と多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私の心の中の俗物根性をいましめただけの事なのである。",
              "citation": {
                "source": "『玩具』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "漱石は、飾らない言葉で一面では日露戦争後の日本人の盲目的なヨーロッパ崇拝を罵倒し、他の一面ではヨーロッパの文物にある俗物根性を批判した。",
              "citation": {
                "source": "「迷いの末は」",
                "author": "――横光氏の「厨房日記」について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ俗物根性の奴は――あいつが女であるにしても、ええぶん殴りでもしてやるほかに手がなからう。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人種差別意識が弱い人達ですら俗物根性と模倣の影響を強く受けてしまう。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリアートに対するナショナリスティックな忠誠とブルジョワジーに対する理屈の上からの酷たらしい憎悪は、日常的な俗物根性の中に共存し得る。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
