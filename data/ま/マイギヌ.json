        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "龍神の娘に扮した役者が、きらびやかな舞衣を纏って花道から登場した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "伝説上の天女が着るという、虹色に輝く不思議な舞衣を衣装係が再現した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幻想的な照明を浴びて、舞衣の金糸が舞台上で豪華に煌めいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
