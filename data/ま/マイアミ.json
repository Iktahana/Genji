        "examples": {
          "standard": [
            {
              "text": "次の冬休みには、マイアミのビーチで日光浴を楽しみたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マイアミはフロリダ州の主要な都市であり、ヒスパニック文化の影響が強い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "豪華客船がマイアミの港を出航し、カリブ海クルーズへと向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "飛行機がマイアミに向けて頭上を飛んで行った。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "テックス・リターが商用でマイアミに向かったとき、乗っていたジェット機がハイジャックにあい、リターは、ハヴァナまでつれていかれた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この真実は、たちまち、『マイアミへいく途中でおかしなことがおこった』という歌になってしまった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
