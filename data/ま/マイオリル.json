        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "一羽の白鳥が、大きな羽を広げて優雅に湖面へと舞い降りた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幸運が突然自分の元に舞い降りてきたような、信じられない出来事だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ヘリコプターが救助隊員を乗せて、山頂の開けた場所へ静かに舞い降りる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "天使が空を舞い、神の思召により、翼が消え失せ、落下傘のように世界中の処々方々に舞い降りるのです。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、土間のその小屋の中へ舞い降りると、そこには紛れないもう一つの鳩がいるのであった。",
              "citation": {
                "source": "白い翼",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "短い午後が終わり、曇っている空の下に早い夕暮れが舞い降りるにつれ、九歳の僕は少しずつ不安になっていった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そうするが早いか、たちまち機首を下にむけて、のろ牛をおそう鷲のように、猛烈なスピードでさっとまいおりるのでありました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
