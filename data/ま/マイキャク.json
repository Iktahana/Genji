          "standard": [
            {
              "text": "伝染病の蔓延を防ぐため、殺処分された家畜は速やかに埋却処分された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "不法投棄された産業廃棄物が、私有地の森の中に埋却されているのが発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い建物を解体した際に出た廃材を、指定の場所に埋却して処理した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "好し左らば、人生は暗黒なる雲霧の中に埋却すべきものとせんか。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、私は作者として、その中に埋却されずに、幾分なりともその上に立つてゐたいと思つてゐるのである。",
              "citation": {
                "source": "作者の言葉",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            }
          ]
