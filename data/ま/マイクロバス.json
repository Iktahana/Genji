        "examples": {
          "standard": [
            {
              "text": "旅館の送迎用マイクロバスが、駅前のロータリーで宿泊客を待っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "少年サッカーチームの遠征のために、保護者の一人がマイクロバスをレンタルして運転した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この先の道は狭いので、大型バスは通れませんが、マイクロバスなら大丈夫です」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "マイクロバスを改良した右翼の自動車が軍歌のテープをボリュームいっぱいに流しながら隼人の前を通り過ぎる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰気なガードレールをくぐり、有楽町マリオンを通り過ぎると数寄屋橋のところで一台のマイクロバスが停まっていて、白髪の老人が右翼的な政治思想を熱心に辻説法している。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
