          "standard": [
            {
              "text": "日本の半導体メーカーは、長年にわたりマイクロエレクトロニクスの分野で世界をリードしてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大学の研究室で、次世代のマイクロエレクトロニクス技術を用いた超小型センサーを開発している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スマートフォンのさらなる薄型化には、マイクロエレクトロニクスの微細化プロセスが欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "例の「アラン・ケイ」の訳者である鶴岡雄二は、一九七九年に古本屋で『サイエンス』のバックナンバーを数冊買い求め、その中の一冊にあったケイの「マイクロエレクトロニクスとパーソナルコンピュータ」をたまたま読んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七七年三月号の『コンピューター』に発表した「パーソナル・ダイナミック・メディア」に続いて、アラン・ケイは同年九月号の『サイエンティフィックアメリカン』誌に、姉妹編に相当する「マイクロエレクトロニクスとパーソナルコンピューター」を発表した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
