        "examples": {
          "standard": [
            {
              "text": "昔の図書館では、貴重な文献がマイクロカードに記録されて保存されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "デジタル化が進む前、大量の文書データを省スペースで管理するためにマイクロカードが活用された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "史料編纂室の奥底から、半世紀以上前に撮影されたマイクロカードの束が見つかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "マイクロフィルムの中にとけ込んでゆく書籍、マイクロカードの中に沈んでゆく書籍は、電話連絡のインフォーメイションとともに、もはや、単独空間の図書館概念を破壊しはじめたのである。",
              "citation": {
                "source": "図書館の未来像",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
