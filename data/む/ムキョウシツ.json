        "examples": {
          "standard": [
            {
              "text": "新しく開発したオーディオ製品の音響特性を測定するため、外部の音を遮断した無響室に入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "無響室の中に一人でいると、自分の呼吸音や血流の音さえ聞こえるようで不安になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "反響が全くない無響室では、距離感が掴みにくく、独特の閉塞感を感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "無論それが閉じられてしまえば、この一劃には、吸音装置が完成して、まず残響に対しては無響室に近くなってしまうからだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
