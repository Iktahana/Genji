          "standard": [
            {
              "text": "賃上げを求める鉄道組合は、回答が得られるまで無期限ストに突入すると宣言した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "無期限ストの影響で、市内の公共交通機関が完全にストップし、市民生活に混乱が生じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "経営陣が譲歩案を提示したことで、一週間続いた無期限ストはようやく解除された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "炭労は十三、四日にわたる四十八時間ストについで、十七日から大手筋十六社二十四万人が一せいに無期限ストに突入した。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年たちは無期限ストの第一日から、アルバイトのため山を去っていた。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            }
