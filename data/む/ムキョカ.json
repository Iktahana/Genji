        "examples": {
          "standard": [
            {
              "text": "公道で無許可の看板を立てることは禁止されており、発見次第撤去される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "無許可のデモ行進が駅前で行われ、通行人の妨げになったとして警察が出動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "他人の土地に無許可で立ち入る行為は、不法侵入罪に問われる可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "無許可営業で叱られるのかもしれない。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "密輸と回避活動がナラガンセット湾を支配しており、夜陰に乗じて無許可の積荷を陸揚げするなど極ありふれた行為だった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
