        "examples": {
          "standard": [
            {
              "text": "武蔵野線は貨物列車も多く走るため、撮り鉄たちに人気の路線だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「武蔵野線って風に弱くて、すぐに遅延しちゃうのが困るよね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "西船橋から府中本町まで、武蔵野線に揺られて小旅行気分を味わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ほつかりした気になつたその帰り路、池袋停車場へ廻つて其処から出る武蔵野線の汽車に乗つてしまつた。",
              "citation": {
                "source": "渓をおもふ",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "また池袋の武蔵野線のホームのトタン屋根が、変な具合にめくれていて、車中より私は首をひねったが、これも旋風のためとわかった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいとご無沙汰しているうちに、旧武蔵野線の出口の筋向いあたりにあったあのゆうれい横丁も消えてしまって「平田屋」で焼酎一杯という気分も出しようのない変り方になったのだ。",
              "citation": {
                "source": "池袋の店",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者は、原稿の押し売りとか、ぼろ生活のための金策などの往き帰りを、旧武蔵野線を利用しているので、つい「小山珈琲店」に寄るのだが、模様変えしてからの客種の増えたことにはおどろいているのである。",
              "citation": {
                "source": "池袋の店",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
