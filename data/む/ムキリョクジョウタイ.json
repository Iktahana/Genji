        "examples": {
          "standard": [
            {
              "text": "長期の休暇から戻った彼は、しばらく無気力状態が続いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ストレスが重なり、彼女は無気力状態に陥ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プロジェクトが中断して以来、チームは完全に無気力状態だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その苦しさのうたに自分からいつか眠らされて、鈍痛的無気力状態に陥り、生活感情を合理的にもってゆける人間に対して、女同志である場合には特に、あのひとにそういう女の心持はわからないとか、苦労していないとか、苦労が足りないとか反撥する場合が多い。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
