          "standard": [
            {
              "text": "自分の無学無知を棚に上げて、専門家の意見に平然と異を唱える彼の態度は目に余る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「無学無知を恥じる必要はないが、学ぼうとしないことは罪だ」と恩師に教えられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "SNS上の無学無知な誹謗中傷が、多くの人を傷つけ、社会問題となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "無学無知な一漁夫に過ぎぬけれど酔うた時には何となく感慨の深いことを言う。",
              "citation": {
                "source": "恭三の父",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり無学無知、まるで歴史を知らないということでしょう」　城代がなにか云おうとした。",
              "citation": {
                "source": "半之助祝言",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
