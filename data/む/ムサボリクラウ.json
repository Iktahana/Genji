        "examples": {
          "standard": [
            {
              "text": "飢えた野犬が、投げられた肉の塊を貪り食らっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は一週間ぶりのまともな食事を、獣のような勢いで貪り食らった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "獲物を仕留めたハイエナたちは、血の滴る肉を貪り食らい始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この市に集うもの、すべて、むさぼりくらうこと豚のごとく、さかんなること狒狒のごとく、凡そわれに益するところあらむと願望するの情、この市に住むものたちより強きはない。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "「モコウ君、ぼくらは早くこのことを一同に報告しなければならない」　ふたりは、ラマの屍体は鳥どものむさぼりくらうにまかして、いそぎ洞へ帰った。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
