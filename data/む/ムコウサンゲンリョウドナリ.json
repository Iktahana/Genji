          "standard": [
            {
              "text": "町内会のお祭りでは、向こう三軒両隣で協力して準備を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困った時は、向こう三軒両隣の人がいつも親身になってくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい住民が来たので、向こう三軒両隣の皆で歓迎会を開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "晦日の蕎麦は、その月より翌月まで蕎麦のようにつづくことを祝し、引っ越せしときに向こう三軒両隣へ蕎麦を配送するは、近辺に縁をつづけるようにとの意なり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
