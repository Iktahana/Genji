        "examples": {
          "standard": [
            {
              "text": "鍛冶屋では、師匠の指示に合わせて向こう鎚が力強く鉄を打つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若い向こう鎚は、将来名工になることを夢見て日々修行に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝統的な鍛冶の現場では、向こう鎚の役割が非常に重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
