        "examples": {
          "standard": [
            {
              "text": "この取引における輸送費は、すべて向こう持ちでお願いしたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回のプロジェクトの費用は、一部向こう持ちで対応していただけるとのことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もちろん、夕食代は向こう持ちだよ！」と彼は笑顔で言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その運賃は高率であって、それに食費は向こう持ちであって、おまけに船員が航海中最も悩むところの性欲に対して、密航婦を積む以上、好都合なことはなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラマールの下宿代は、敷布類の洗濯代はむこうもち、一週に一度の入浴つきで一ヵ月一九五〇フランだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
