          "standard": [
            {
              "text": "英語で「go to bed」と言う際、特定のベッドを指さない場合は「bed」を無冠詞で用いる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "固有名詞には原則として冠詞をつけないが、河川や山脈の名前では無冠詞にならない場合もある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この単語が無冠詞で使われる理由について、文法書を調べてより詳しく理解を深めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、実際この作品で \"petit prince\" に付くのは定冠詞のときもあれば、不定冠詞になることもあり、また無冠詞にもなります。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
