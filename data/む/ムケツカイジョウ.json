        "examples": {
          "standard": [
            {
              "text": "敵軍は無血開城に応じ、市は破壊を免れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は交渉の末、相手に無血開城を迫った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦わずして無血開城できるなら、それに越したことはない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "要は、主人摂津守村重に会って、ここをも開城し、尼ヶ崎や花隈城をも、無血開城いたすように、よくよくご意見をいたしてみます。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ城中の者の生命と、その後の扶持だに保証して賜るなら」　と、無血開城の大事を、ほとんど一諾にひとしいことばをもって、光秀にこたえているのだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
