        "examples": {
          "standard": [
            {
              "text": "このサプリメントは、体内で不足しがちな無機塩を補うためのものです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "温泉の成分を分析したところ、多量の無機塩が含まれていることが判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "微生物の培養液には、成長に必要な無機塩をバランスよく配合する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "即ち其の昆布を携へて実験室に至り浸出液を造り粘質物を除き無機塩類及びマンニットを結晶せしめて除去したるに呈味物質は依然として残液中に存し、種々之を分離せんと試みたるも其の目的を達せず、当時他の研究に多忙の際なりしかば此の専門外の実験は一時之を中止することとせり。",
              "citation": {
                "source": "「味の素」発明の動機",
                "author": "池田菊苗",
                "note": "青空文庫"
              }
            },
            {
              "text": "無機塩類による置換はほとんど見られず、四千万年前のものであるにも拘らず内部の臓器は完全に損傷を免れていた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
