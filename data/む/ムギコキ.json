        "examples": {
          "standard": [
            {
              "text": "祖父は昔、冬の間に手作業で麦扱きをしていたと話してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "麦扱きは、収穫後の大切な作業の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "農家の庭先では、子供たちが麦扱きの手伝いをしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "此方からも麦扱きを借りたり、饂飩粉を挽いてもらったり、豌豆や里芋を売ってもらったりした。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は余の不相変ぼんやりして麦扱きをして居るのを見て、正気だと鑑定をつけたと見え、来て見て安心したと云った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
