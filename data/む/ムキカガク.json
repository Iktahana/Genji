        "examples": {
          "standard": [
            {
              "text": "将来は研究職に就きたいので、理学部で無機化学の基礎をしっかりと固めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "無機化学の実験で、色鮮やかな金属沈殿が生じる様子をレポートにまとめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最新のスマートフォンに使われている半導体技術には、無機化学の知見が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "学校を出た喜助は、老人の骨折で、理化学研究所へ入って、無機化学実験室の助手をつとめることになったのである。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はふと思いついて、本箱の奥の方に突込んであった無機化学の教科書を引張り出して、一酸化炭素の所を調べて見た。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無機化学と有機化学のあいだの壁は壊された。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようにして有機化学と無機化学の境界を取り払い動物の作る有機物質は他の物質とは根本的に違わないことを示した。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
