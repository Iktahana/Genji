    "definitions": [
      {
        "index": 1,
        "gloss": "morning drink to get rid of a hangover",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨夜飲みすぎたので、今朝は迎え酒を一杯飲んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "二日酔いには迎え酒が効くという人もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「迎え酒なんか飲んでたら、ますます悪くなるぞ！」と友人が忠告した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "実は朝起きぬけに、ソーセージを肴にして迎い酒を二、三本やったのだ。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯さえできればあとはどうでもよいと思って、家の中の落着かない雰囲気をよいことに、おれはちょっと迎い酒をやっていた。",
              "citation": {
                "source": "花ふぶき",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "周章狼狽する二人をまず先きへ防空壕へ追いやって、この時義経少しも騒がず、翌朝の迎い酒にもと残し置きたる湯呑みの酒を咄嗟にぐっと呑みほした。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時になって迎い酒のことを思い出して、上衣を着てくるついでにひっかけてくるつもりだったらしい。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
