        "examples": {
          "standard": [
            {
              "text": "無国籍の人々は、国籍を持つ人々と比べて多くの権利が制限される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦争により、多くの人々が無国籍の状態に置かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は無国籍だが、特定の国に長年住み、コミュニティに溶け込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "上海で懇意にしていた無国籍者のことを、俺は思い出す。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男を、無国籍者のくせに、実にくだらぬと俺は思う。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
