        "examples": {
          "standard": [
            {
              "text": "スマートフォンのアプリで、様々な楽器の合成音を奏でることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このゲームのBGMは、すべて合成音で構成されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "音響技師は、自然の音と合成音を組み合わせて新しいサウンドを作り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その他ジョン・ケージの偶然音楽にも興味がありますし、それから催眠音楽にも興味がありますし、つまりこれは科学的に脳に心地よい刺激を与える音楽を計算した上で曲が書けるんじゃないかって思うんですけど……それから将来的にはボコーダを積極的に取り入れて、合成音声をボーカルにしたいですねえ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の隅に置かれたオシロスコープは今のところほとんど使ったことがないが、将来的には合成音声を自分たちのサウンドに取り入れていくつもりなので、結局は楽器の仲間入りをすることになるだろう。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車する停留所名を、録音テープ合成音声が順番に告げた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
