        "examples": {
          "standard": [
            {
              "text": "強欲非道な独裁者は、自国の富を私物化した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの会社の経営者は、強欲非道なやり方で財産を築いたと噂されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の強欲非道な行いは、人々の怒りを買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "Ｔ「強欲非道の男がある」　店先で子供が縄飛びして居る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵討ということをほめ上げるために、世間は後世に俺を強欲非道の人間にしないではおかないのだ。",
              "citation": {
                "source": "吉良上野の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、しかし彼は強欲非道の男であった。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
