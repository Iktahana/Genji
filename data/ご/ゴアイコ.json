        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年にわたる皆様のご愛顧に心より感謝申し上げます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今後とも変わらぬご愛顧を賜りますようお願い申し上げます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この商品は、多くのお客様のご愛顧によりベストセラーとなりました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "日ごろご愛顧くださる伊豆守様までが詮議を禁じたうえに、そのまた禁じ方なるものが、さながら尾州家において名人の出馬するのを恐るるもののごときけはいがうかがわれましたものでしたから、身分の相違、役の低さに、しみじみとこの世がはかなく思えたのはむべなりというべきでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれから遠方へ参りますが、なにとぞ従前の通りお見捨てなくご愛顧のほどを願います。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈世のひとがみな王のご愛顧をねがったころ、わたしは二度までも王の恩顧を辱なくしたものである。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
