        "examples": {
          "standard": [
            {
              "text": "SNSには、加工された合成写真があふれており、真偽の区別が難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行の思い出に、有名観光地を背景にした合成写真を撮ってもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "捜査官は、提出された写真が合成写真ではないかという疑念を抱いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ロケットで宇宙へ行って来たと称する偽宇宙飛行士の合成写真を君は見る。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "このジョーカー・キムラなる少年は合成写真の映像によって生み出された架空の人物で、木村ソフト社のいわばマスコットである。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ彼女たちが合成写真の映像で作られた架空の存在だと分かっていても、一度あの手の擬似体験ゲームをやるとやみつきになりますよ」「でもそういった擬似体験ゲームを製作するのはいろいろ難しいんですよ」あなたは言った。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
