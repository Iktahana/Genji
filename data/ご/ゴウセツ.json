    "definitions": [
      {
        "index": 1,
        "gloss": "tremendous snowfall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
