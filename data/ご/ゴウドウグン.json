        "examples": {
          "standard": [
            {
              "text": "敵対勢力に対抗するため、数カ国の合同軍が編成された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史書には、かつての大戦で戦った合同軍の記録が残されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "合同軍による大規模な演習が始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それに日比谷の陸海軍の合同軍楽隊の演奏がもう始まるころだから、もうここを出なくちゃならない。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "城兵も、これがために勢いを盛り返して、奮戦したので、さしもの北条、武田合同軍も、ついに敗走してしまったのである。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
