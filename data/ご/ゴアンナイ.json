        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "以前、A社との会議で、彼にご案内したことがあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい取引先に、弊社の担当者をご案内しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
