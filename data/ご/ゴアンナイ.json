    "definitions": [
      {
        "index": 1,
        "gloss": "guidance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "博物館のボランティアの方が、丁寧に展示物のご案内をしてくださいました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地元の方に道をご案内いただき、無事に目的地に到着できました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新入社員向けに、社内システムのご案内資料を作成しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ほかにどこも、ご案内したいやうなところもありません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹藪のあの入口のところで、けさのやうに雪の上に俯伏していらしたら、私たちは、いつでもここへご案内いたしますわ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いよい天気でございますから、あなたご案内して差上げたら」　と、とかくに事物の歓待の方へ気を利かして行くのであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "客が足を洗ッてしまッて、まだふききらぬうち、主人は、『七番へご案内申しな！",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『六番さんのお浴湯がすんだら七番のお客さんをご案内申しな！",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の所へご案内申しあげましょう。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（さあ、それではご案内申しましょう、どれ、ちょうど私も米を磨ぎに参ります。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご案内いたしましょう」　雨はポッシャンポッシャン降っています。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ今丁度ひるのやすみでございますが、午后の課業をご案内いたします。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあではご案内を致しましょう。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はじめに第一学年をご案内いたします。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「時間がも少しですから、次の教室をご案内いたしましょう。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしがさきに立って、ご案内しますから。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまにご案内します」　そういって何故か規矩男は去勢したような笑い方をした。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃ、今度、わたくしご案内いたしましょうか。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通はお母さんへ、松坂屋から夏物売出しのご案内。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の暮、でしたかしら、奥さまが十年振りとかで、ご主人のお友達の笹島先生に、マーケットでお逢いしたとかで、うちへご案内していらしたのが、運のつきでした。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤の花の咲いているところへでもご案内しようかな」　久し振りで外出するかの女は嬉しかった。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいまここまで出てまいりましたのは、大空の神のお子さまがまもなくおくだりになると承りましたので、及ばずながら私がお道｜筋をご案内申しあげたいと存じまして、お迎えにまいりましたのでございます」とお答え申しました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の音がすこしお邪魔になるかも知れませんが、騒ぐようなお客さまはこちらへはご案内いたしませんから、お静かでございますと、番頭は言った。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手が、新子の荷物を運び入れてくれると、奥から三十ばかりの女中頭らしいのが出て来て、「いらっしゃいませ、どうぞ、お部屋をご案内したします。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、新子が云うと、「洗面所やバスは、後でご案内いたします。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつかれでなかったら、ご案内しましょう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事が終りかけた時、姉の圭子は、以前からの話の続きらしく、「私が、ご案内してもよろしいんですが、開幕前で、何となく落着けませんし、妹ならもう行きつけているんですから。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ておくべき部屋の方へご案内をお願いします。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらへ、じかにご案内を。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車をつかまえ、殿下を警察署までご案内いたしましょう。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごあんないしますわ。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのかたの　おへやへ　ごあんないしましょう。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこを　あるいている　おじょうちゃんの　にんぎょうを　かぐだけで、　あなたを　ちゃんと　ごあんないして　さしあげます。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
