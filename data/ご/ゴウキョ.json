        "examples": {
          "standard": [
            {
              "text": "彼は常に傲倨な態度で、他人の意見を聞き入れようとしない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若き頃の彼は傲倨で鼻持ちならない性格だったと、周囲は語る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の傲倨な態度の裏には、実は深い劣等感が隠されているのかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "誰にも屈したことがない、誰へも傲倨に君臨する、ましてや芸術においては無論、天下の陶器師を睥睨している。",
              "citation": {
                "source": "増長天王",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
