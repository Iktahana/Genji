        "examples": {
          "standard": [
            {
              "text": "大学のキャンパスは、サークルの勧誘ビラを配る先輩と初々しいフレッシュマンたちで賑わっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "フレッシュマン向けのオリエンテーションで、時間割の組み方や図書館の使い方を教わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "春のリーグ戦では、期待のフレッシュマンがいきなりスタメンに抜擢され活躍した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その為にフレッシュマンの意気は次第に沮喪し、元気は消耗し萎縮して終う。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らが影響をうけた源泉は、チャック・ベリーとフォア・フレッシュマン。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
