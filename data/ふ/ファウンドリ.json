        "examples": {
          "standard": [
            {
              "text": "世界的な半導体不足の影響で、大手のファウンドリはフル稼働の状態が続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自社工場を持たないチップメーカーにとって、信頼できるファウンドリの確保は死活問題だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このファウンドリは最新の微細化技術を持っており、多くの顧客から注文を受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この意味において私はワグネル・ファウンドリーの発明を心から慶賀します」「私はあなたがそう言うて喜んで下さることだと思っていました。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、來週にはファウンドリ・クロオズから、新入生が四人來る筈ですの――雪がなかつたら、今日來たでせう。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
