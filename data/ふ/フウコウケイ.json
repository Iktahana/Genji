        "examples": {
          "standard": [
            {
              "text": "屋根の上に取り付けられた風向計が、くるくると回って風向きを示している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "漁師は出航前に必ず風向計を確認し、海の状況を予測する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは、庭に設置された風向計が指す方角に興味津々だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また一方とんぼの群れが時には最も敏感な風向計風速計として使われうるであろうということも想像された。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
