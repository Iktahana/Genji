        "examples": {
          "standard": [
            {
              "text": "フレンチのコースの途中でフィンガーボールが出されたので、軽く指先をゆすいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "フィンガーボールにはレモンのスライスが浮いていて、爽やかな香りが漂っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カニ料理の後に運ばれてきたフィンガーボールで、手の汚れと匂いを落とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "古い物理書などに書いてあるとおりガラスのフィンガーボールの縁を指頭で摩擦して楽音を発せしめる場合に、指を水でぬらしておいて摩擦する事になっているが、現在の場合でも接触面が水でぬれている事が必要条件であるらしく見える。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は鶏の骨を、フィンガーボールに入れていたのだった。",
              "citation": {
                "source": "マカーガー峽谷の秘密",
                "author": "THE SECRET OF MACARGER'S GULCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィンガーボールは、レースの敷きものに乗っていて、水には、レモンが浮いていた。",
              "citation": {
                "source": "想い出",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
