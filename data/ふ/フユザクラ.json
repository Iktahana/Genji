        "examples": {
          "standard": [
            {
              "text": "寒い季節に咲く冬桜は、どこか控えめで可憐な印象を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "公園に植えられている冬桜が、ちらほらと花をつけ始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "珍しい冬桜を見に、遠くから観光客が訪れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "信越線新町駅に下車して藤岡、鬼石と過ぎ、冬桜で世に聞こえた三波川の合流点まで行けば、秩父古生層が赤裸の肌を現わして、渓流に点在する奇岩に、釣り人は眼をみはるであろう。",
              "citation": {
                "source": "雪代山女魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
