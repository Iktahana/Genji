        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祭りの装飾として、細長い吹き抜きが木から吊るされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "風になびく吹き抜きの布が、建物の外壁を飾っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "吹き抜きの形状をした飾り布が、風にはためいていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
