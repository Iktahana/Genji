        "examples": {
          "standard": [
            {
              "text": "スーパーの冷凍フーズのコーナーで、お弁当のおかずにちょうどいい唐揚げやコロッケを買い込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "このメーカーはオーガニック素材にこだわったベビーフーズを展開しており、若い母親たちから支持されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "健康志向の高まりを受け、低糖質や高タンパクを謳う機能性フーズの市場規模が年々拡大している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "原作者ミュラーのことをいろいろ調べてみたが、どんな本にも名前がでておらず、当時のイギリスのフーズ・フーにさえのっていない。",
              "citation": {
                "source": "「ザイルの三人」訳者あとがき",
                "author": "妹尾韶夫",
                "note": "青空文庫"
              }
            }
