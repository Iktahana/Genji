        "examples": {
          "standard": [
            {
              "text": "ローマ神話のファウヌスは、森と牧畜の神として崇められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代の遺跡から、ファウヌスの像が発掘された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ねえ、ギリシャ神話とローマ神話、ファウヌスってどっちに登場するんだっけ？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "手をさし伸ぶるファウヌスには美しき限の女、舞を辞むことあらじ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "9395ですから、金色の※髪をした牧童にでも、どうかして遣って来た、黒い、剛い毛のファウヌスにでも、時と場合で、ふっくりした、こっちの手足をすっかり自由にさせて遣るものですわ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファウヌスに似ていて、獣らしくはない。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、わたしの知っているもっとも極端な例の中に、まずファウヌスの妻ファトゥアがあるが、彼女は結婚して後はどんな男性にもその顔を見せなかった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
