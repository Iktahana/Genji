        "examples": {
          "standard": [
            {
              "text": "夫婦円満の秘訣は、お互いを尊重し、感謝の気持ちを忘れないことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼らの夫婦円満な様子は、周りの人々にも良い影響を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "妻は、夫婦円満のために毎日小さな努力を重ねていると言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "子供は六人あるが、夫婦円満だぞ。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦円満というのは、アナタの云うことゴモットモ、ゴモットモ。",
              "citation": {
                "source": "安吾巷談",
                "author": "天光光女史の場合",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてキチガイの関係に属するものだが、一般の夫婦円満の根柢にも教祖と信者的な持ちつ持たれつの信仰の一変形はあるかも知れない。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その六　暗い哉　東洋よ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
