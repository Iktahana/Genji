        "examples": {
          "standard": [
            {
              "text": "重要な書類は、種類ごとにきちんとファイリングされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は毎日、大量の資料のファイリング作業に追われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このオフィスでは、全ての電子データをクラウドにファイリングしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "アメリカでレコード店に入ると、大量にならんでいるレコードの名前別のファイリングのなかに、エルヴィス・プレスリーというファイルはないことが多かった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "スチール・デスクやファイリング・キャビネットはいくつもあるのに、このオフィスには、いつも、彼女しかいない。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
