        "examples": {
          "standard": [
            {
              "text": "見たい番組がなくて、彼はリモコンでやみくもにチャンネルをフリッピングしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "コマーシャルになるたびにフリッピングするのが、彼の長年の癖になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "会議中、彼は退屈しのぎにスマートフォンの画面をただフリッピングしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
