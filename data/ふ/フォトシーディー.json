        "examples": {
          "standard": [
            {
              "text": "昔撮った写真をデジタル保存するために、現像店でフォトＣＤの作成を依頼した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "引き出しの奥から、十数年前に作ったフォトＣＤが出てきたが、読み込めるか不安だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「当時はフォトＣＤが、高画質な画像保存のスタンダードだったんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
