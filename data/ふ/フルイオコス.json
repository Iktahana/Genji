        "examples": {
          "standard": [
            {
              "text": "恐怖心を必死に抑え込み、最後の勇気を奮い起こして強大な敵に立ち向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "連敗続きで落ち込んでいた選手たちを、監督の熱い言葉が再び奮い起こした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "震える手をぎゅっと握りしめ、沈黙を破るために自分の声を奮い起こす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "春部にはなんだかそれがたいへんいじらしく見え、はからずも勇気を奮い起こす縁となった。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "にんじんは勇気を奮い起こす。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらでひとつ、わしが、大和魂をふるいおこすような歌を教えるのも必要だろ。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
