        "examples": {
          "standard": [
            {
              "text": "今夜のパーティーはフォーマル（formal）な装いが求められています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、フォーマル（formal）な場で落ち着いた振る舞いをしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「フォーマル（formal）なスピーチの練習をしましょう。」と先生はクラスに提案した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "制服ひとつとっても、金糸のエンブレムがついた紺のブレザー、レジメンタル・タイ、グレイのスラックス、というフォーマルなもの、そして、ふだん学校や寮で着る、衿なし上着にオープンシャツの校服、という二種類があり、いろいろ行事のある入寮入学前後は指示が複雑で、新入生を悩ませた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月の中旬から考を定め、二人の気にさわらないようにフォーマルなインビテーションを書き、都合を問ねて置いたのである。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
