        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は友人から借りたお金を返す気がなく、そのまま踏み倒すつもりらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "バーのツケを半年も踏み倒していた客が、とうとうマスターに捕まって警察を呼ばれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "家賃を数ヶ月滞納した挙句、夜逃げして踏み倒すなんて大家さんへの裏切り行為だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
