        "examples": {
          "standard": [
            {
              "text": "冬場にドアノブを触ったときにバチッとするのは、体に溜まった負電気が一気に放電されるからだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "琥珀を布で摩擦すると、琥珀は負電気を帯びて軽い紙切れを引き寄せるようになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "落雷は、雲の下部に溜まった負電気と地上の正電気との間で起こる巨大な放電現象だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "イオンというのは電気を持った微粒子であって、正電気をもったもの即ち陽イオンと、負電気をもったもの即ち陰イオンとがある。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先ず電気は導体の表面に在るのか、または導体と接する媒介物（絶縁物）の表面に在るのか」という問題から始めて、ガラスのような物を取り、正負電気の間に置いたとして、「感応の現象があるから、電気は導体の方には無く、かえって媒介物の方にあるのだ」と書いた。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
