        "examples": {
          "standard": [
            {
              "text": "この展望台からは、風光絶佳な景色が一望できるため、多くの観光客が訪れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は風光絶佳な温泉地で休暇を過ごし、心身ともにリフレッシュした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "絵葉書のような風光絶佳な風景に、思わずため息が漏れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それにも飽き足らず歌枕の地、風光絶佳の武蔵野へ、異様の屋敷を造るとは、田沼の専横尋常でないぞ！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば氷川の森の背後にかの殺風景なる三聯隊の兵舎の聳ゆるなくんば東京市内の空地の中風光絶佳の処となすも決して過賞にあらざるべし。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
