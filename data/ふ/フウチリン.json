        "examples": {
          "standard": [
            {
              "text": "市が管理する風致林の中を散策していると、都会にいることを忘れてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "風致林の保護活動に参加し、外来種の抜き取りやゴミ拾いを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "嵐の翌朝、風致林の入り口には折れた枝が散乱し、通行止めになっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "内務省のお世話が届き過ぎて、神社合併が兎の、風致林が角のと、面倒な事だ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山林は風致林という名目を設けて保存しながら土木の官吏は予算を捻出する場合に、いつでも心なく並木の老松の伐採を計画する。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
