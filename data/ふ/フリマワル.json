        "examples": {
          "standard": [
            {
              "text": "子供たちは手をつないで輪になり、目が回るのも忘れてぐるぐると振り回って遊んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "強風にあおられて、店の古い看板が危険な音を立てて振り回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "勢いを失ったコマは、軸がぶれて不安定に振り回り、やがて倒れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "旅を終えて振り回ると、今なお続く民藝の分布に付て色々の結果を捕えることが出来る。",
              "citation": {
                "source": "地方の民藝",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
