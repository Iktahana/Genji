        "examples": {
          "standard": [
            {
              "text": "リラックスしている時には、副交感神経が優位に働き、心拍数が落ち着く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "副交感神経は、消化活動を促進し、体の回復を助ける役割がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ストレスを感じると、交感神経が活発になり、副交感神経の働きが抑えられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「――浸出性体質の人、つまり副交感神経の過敏になって居る人は、或方法で或部分を圧迫すると、迷走神経の作用で心臓の働きが止るんだそうです。",
              "citation": {
                "source": "葬送行進曲",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
