        "examples": {
          "standard": [
            {
              "text": "その映画は、家族を殺された主人公が犯人を追い詰める緊迫の復讐劇だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "シェイクスピアの「ハムレット」は、世界で最も有名な復讐劇の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "派手なアクションが売りの復讐劇だが、その裏にある悲しい人間ドラマに感動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "瓶詰めの嬰児　さて、愈々復讐劇の序幕を開く時が来た。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来ならば、老人と後家との婚礼のこと故、なるべく目立たぬ様、質素に取行うべきであったが、わしは復讐劇の最後の舞台を、思い切り華やかに効果的にする為、世間の思惑など考えず、飛び切り派出な披露宴を催した。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆、腹の中で奇妙な四つ指鉱山の話や、オランダ人を襲った復讐劇を知っていた。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
