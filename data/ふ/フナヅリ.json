          "standard": [
            {
              "text": "今週末は会社の同僚たちと船釣りを予定しているが、波が高くならないか心配だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "初めての船釣りでマダイを釣り上げ、彼は満面の笑みで写真を撮っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "酔い止め薬を飲んでから船釣りに挑んだおかげで、一日中快適に楽しめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "今年の秋はかなり度々湖水に出て公魚の船釣りをして、魚の寄りの動きも知つて居るし、末期の釣れ場迄つきとめて置いてもあつたので、勿論左程の期待はかけずに、暮も押しせまつた一日気早のスケーターに混つて氷湖上に出て見た。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            }
          ]
        }
