        "examples": {
          "standard": [
            {
              "text": "九回裏、二死満塁。フルカウントからの運命の一投が、マウンドの投手の手から力強く放たれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "粘りに粘ってフルカウントまで持ち込んだが、最後は外角低めギリギリの球に手が出ず見逃し三振に倒れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "フルカウントになると、打者も投手も一球のミスが命取りになる極限の集中状態で対峙することになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
