          "standard": [
            {
              "text": "夜間工事の現場は、複数のフラッドライトによって昼間のように明るく照らされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "サッカーのナイトゲームで、スタジアムの巨大なフラッドライトが一斉に灯った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "自宅の庭に防犯用のフラッドライトを設置したら、夜間の訪問者が減った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "灯がなくちゃあ……」　混乱する頭のなかで、管理棟屋上のフラッドライトを思いだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、新しくできた、石炭がらをまぜたコンクリートづくりの掩蔽壕のような建物で、周囲の茂みのなかで悪いことができないように、まわりにフラッドライトがたくさんある。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
