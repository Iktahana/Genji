        "examples": {
          "standard": [
            {
              "text": "若手法律家が、新たに副検事として地方検察庁に赴任した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "副検事は、検事の職務を補佐し、軽微な事件の捜査にあたる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は副検事として、市民の安全を守るために日々奮闘している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "現にハワイでは日本人が数名下院議員に当選してい、副検事長も日本人で千二百円の月俸を得ている。",
              "citation": {
                "source": "アラメダより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "検察庁よりは直ちにラヤス次席検事指揮の下に、カルバハール検事、エルナンデス副検事ら出張、一方オリベイラ予審判事一行の出動を請うとともに、管轄警察側と協力、事件の傍証を固めているからやがて加害者の自供を待って、事件の全貌が白日の下に曝け出されるのも近いことと思われる。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
