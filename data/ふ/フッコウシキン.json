        "examples": {
          "standard": [
            {
              "text": "被災地の復興資金が不足しており、政府に追加支援を求めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の会社は、地域経済を活性化させるための復興資金を調達した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ボランティア活動を通じて、私たちは少しでも復興資金の足しになればと願っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "Ｂ　　復興資金を集める相談をしてたわ。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから近畿商工会議所連合会の席上では、大蔵省当局者に向って、二千万円程政府が責任補償する一万円以上の復興資金の予算を要求している。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に欧洲戦争中に巨利を博して、その後又損をしたそうだけれど、先頃震災後母校の復興資金に一万円寄附したくらいだから、同窓中の成功者だろう。",
              "citation": {
                "source": "首席と末席",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "復興資金として五百円寄附したばかりだ。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「母校の復興資金のことで態※お出になったのですから、私、今度こそは少し纒めて寄附しなければならないと思っていますの」「ふうむ、それは宜かった」「宜しゅうございますの！",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
