        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女が発表会で着たドレスは、スカートの裾にたっぷりとあしらわれたフルフルとしたチュールのフリルが、歩くたびに揺れてとても可愛らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "アンティーク調のシルクのブラウスの首元に、フルフルの繊細なレース飾りがついていて、顔周りにとてもエレガントな印象を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "バレエの舞台衣装のスカートは、何層にも重なった薄い生地がフルフルのボリュームを出しており、ジャンプするたびに美しく広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "細い、フルフル浴衣を着て貧血になやんでいる人。",
              "citation": {
                "source": "日記",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、フルフル、ごめんだよっ！",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
