        "examples": {
          "standard": [
            {
              "text": "赤外線や紫外線は、電磁波の中でも不可視光線に分類される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "防犯カメラの夜間モードでは、不可視光線を利用して映像を撮影する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "太陽からは可視光線だけでなく、多量の不可視光線も降り注いでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "海中哨戒線は、陸にあるトーチカを、点々と海底にしずめたような恰好のものであったが、或る特殊な不可視光線によって、そこを通過する潜水艦などを捕えるような仕掛けになっていた。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "深山理学士の研究問題は、この不可視光線と呼ばれる赤外線が人間にも見える装置を作ることにあった。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
