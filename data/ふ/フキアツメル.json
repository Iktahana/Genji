        "examples": {
          "standard": [
            {
              "text": "強い風が落ち葉を吹き集め、駐車場の隅に大きな山を作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "砂漠では、風が細かい砂を吹き集め、砂丘の形を変えていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "乾燥した季節には、埃が風で吹き集められ、道路の脇に溜まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "死んだもののたましいを風が吹き集めるところにわたしのたましいもみちびかれたおお父トオカルよ河があるひらめく剣がある女が洗っている浅瀬の岸で　それを聞くと、トオカルは木のうえの最後の木の葉のように震えた。",
              "citation": {
                "source": "浅瀬に洗う女",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            }
          ]
        }
