          "standard": [
            {
              "text": "彼はソファで寝ている子猫のお腹を、指で優しくふにふにして遊んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "赤ちゃんの柔らかいほっぺたをふにふにしていると、可愛くて時間が経つのを忘れてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "リラックスするために、手の中にあるストレス解消用のジェルボールを無心でふにふにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
