        "examples": {
          "standard": [
            {
              "text": "祖父の書斎には、仏領インドシナの古い地図が額縁に入れられて飾ってある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "第二次世界大戦の開戦前夜、日本軍は仏領インドシナの南部に進駐した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "大学のゼミで、仏領インドシナにおける植民地政策の歴史について発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一つは揚子江の流れをくだり四川省の宣賓、一つはメーコン河をくだって仏領インドシナのメンヤンへ、それぞれ流れついたものがあったのです。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤヨイ号は、仏領インドシナ某地点で、多量のガソリンやオイルを積みこんでから、ふわりと空へまいあがったのであった。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、仏領インドシナのハノイか、それとも、ずっと南に下りて、サイゴンへ入るか、そのどっちかでしょうと思います。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡国は西域の汎称に用いられ、崑崙国はコーチンチャイナ（仏領インドシナ）のある国を意味し、瞻波国はコーチンチャイナの一部であった。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
