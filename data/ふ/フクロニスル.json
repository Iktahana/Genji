        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "喧嘩になったが、相手が多勢だったので、あっという間に袋にされてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の意見は少数派で、会議では他のメンバーに袋にされてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「何だと！一人で来いよ、多勢で袋にするなんて卑怯だぞ！」と彼は叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "可哀さうに、獣は、私達の着物にするために、自分の毛を育て、又私達のたべ物になるために、其の乳や肉を太らせ、そして又私達の手袋にするために、其の皮を丈夫にしてゐるのです。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼はアゼルマをしか「袋にする」ことはできなかった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
