        "examples": {
          "standard": [
            {
              "text": "人気ロックバンドのコンサートは、発売と同時に札止めとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の映画は、夕方の回がすべて札止めだそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "劇場の入り口には「札止め御礼」の貼り紙があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "座へ行くともう満員で札止め、何でも十日頃までは全部売切れの由。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "八幡クラブといふ所で夕食、食後ファン連と座談会あり、三回目も札止めの大満員だった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
