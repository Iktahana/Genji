        "examples": {
          "standard": [
            {
              "text": "敵の軍勢を山中で封じ込む作戦が成功し、勝利を収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は自分の感情を心の奥底に封じ込み、決して表に出さない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "罠を使って獲物を封じ込めるのは、原始的な狩りの方法だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "なかには郵便切手を二三枚封じ込むで、郵税だけは此方持ちにするから、書物だけ恵むで欲しいといふのがある。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "また二人の男から同時に結婚の申込を封じ込むだ手紙を受取つた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも水晶に針金を封じ込む方法はちゃんとあるので、こういう旧式な手法を墨守するのは少し馬鹿気ているという議論も出るかもしれない。",
              "citation": {
                "source": "実験室の記憶",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水晶管に針金を封じ込むことは、真空技術一般からみれば、ほんの瑣細なことである。",
              "citation": {
                "source": "実験室の記憶",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
