        "examples": {
          "standard": [
            {
              "text": "実験室では、機器から漏れる微弱な輻射線が測定に影響を及ぼす可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "宇宙飛行士は、大気圏外での強い輻射線から身を守る特別なスーツを着用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "特定の波長の輻射線を照射することで、材料の表面を硬化させる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "熱の輻射も無線電信の電波も一つの連続系の部分になってしまって光という言葉の無意味なために今では輻射線という言葉に蹴落とされてしまったのである。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、輻射線を発している諸恒星に比べて非常に低温度で、またばく大な広がりをもった暗黒な天体が多数に空間内に存在すると考える。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな極光が、ぶよぶようごく真赤な虹をあらわし、その核心からでる金色の輻射線が、氷罅のうえをキラキラっと流れてゆく。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "大気中の炭酸ガスの含有量が殖えれば、太陽の輻射線をよけいに吸収するので、地球の温度はのぼることになる。",
              "citation": {
                "source": "白い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
