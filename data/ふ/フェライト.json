        "examples": {
          "standard": [
            {
              "text": "「この鋼材、フェライト組織が綺麗に出ているから加工しやすそうだね」と職人が頷いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "フェライトは鉄の合金相の一つで、磁石の材料としても広く利用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "顕微鏡を覗くと、多角形のフェライトの結晶粒が画面いっぱいに広がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "磁石を作る素材として広く使われていたフェライトを利用したこの素子は、パラメトロン★と名付けられていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "後藤の回想によれば、高校時代からラジオ製作に凝っていた彼はアマチュアラジオ雑誌でフェライトを使ったオキサイドコアを知って興味を持ち、買い求めて遊んだ経験を持っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
