        "examples": {
          "standard": [
            {
              "text": "この村では、良質な地下水を汲み上げるために深井戸を掘った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "深井戸のポンプが故障してしまい、修理が終わるまで断水することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "深井戸から汲み上げた水は、夏でも驚くほど冷たくて美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "おぼんの季節に下町の人たちが訪ねて来ると、まづ第一に深井戸の水を汲んで砂糖水にしてお客にコツプ一杯御馳走した。",
              "citation": {
                "source": "豚肉　桃　りんご",
