        "examples": {
          "standard": [
            {
              "text": "服役囚の更生を助けるため、刑務所内では木工や印刷などの職業訓練が行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ある服役囚が執筆した手記が、社会の歪みを告発するものとして大きな反響を呼んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "刑務官は、服役囚たちが規則正しい生活を送るよう厳しく監視しつつ、心のケアも行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "悪臭芬芬たる未決檻中に身を屈める哀れな囚われ人たちだの、長期服役囚の怯えた灰色の顔だの、竹の棒で滅多打ちにされ痣だらけになった尻だの――いずれもが私に耐え難い罪の意識を押し付け憂鬱にさせた。",
              "citation": {
                "source": "象を撃つ",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
