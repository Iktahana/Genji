        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "机にこぼしたコーヒーを急いで布で拭き落とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鏡についた水垢を、専用の洗剤を使ってきれいに拭き落とす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "泥だらけになった靴を、濡れタオルで丁寧に拭き落とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "快く暖まっている大理石の腰掛けのすべすべとした肌ざわり、蒸気にむされてグッタリとしたからだ、流るる汗、汗を拭き落とす道具、そうして爽快なシャワア、いかにも気持ちが好さそうで、法華寺の浴室とは大変な違いである。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
