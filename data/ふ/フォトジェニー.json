        "examples": {
          "standard": [
            {
              "text": "映画批評において、スクリーンに映し出された被写体が放つ独特の魅力をフォトジェニーと呼ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その女優には、単なる美貌を超えた、映画的なフォトジェニーが備わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このシーンの彼女の表情には、言葉では説明できないフォトジェニーを感じるね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
