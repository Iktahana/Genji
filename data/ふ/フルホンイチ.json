        "examples": {
          "standard": [
            {
              "text": "週末に大学のキャンパスで学生主催の古本市が開催されており、そこでずっと探していた絶版の建築写真集を思わぬ安値で掘り当てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "毎年秋に河川敷で開かれる恒例の大規模な古本市には、全国から多くの読書家が空のスーツケースを引いて朝早くから集まってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "古本市の会場にずらりと並んだ段ボール箱を一つ一つホコリにまみれながら漁って、諦めかけていたミステリー小説シリーズの欠巻をようやく探し当てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "が近頃では、女房も見張りに馴れたし、亭主も段々古本市だの場末の同業を狙って、掘出しに精々出あるく。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "古本市場を見に行く。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
