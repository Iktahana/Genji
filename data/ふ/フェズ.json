        "examples": {
          "standard": [
            {
              "text": "モロッコの市場で、深紅色のフェズという帽子をお土産に買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつてのオスマン帝国では、役人たちが公的な場でフェズを着用することが義務付けられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の古い写真には、フェズを被って背筋を伸ばして座る祖父の姿が写っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自ら挙げた七人のペルシア詩人中の一人で、十四世紀に生きていたハーフェズのペシミズム溢れる抒情詩から、ゲーテは多大の影響を受けたと言われている。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも彼にしてハーフェズの創作上の先師であったオマル・ハイヤームを知っていたならば、この東方に深く憧れた詩人の『西東詩集』には、さらに色濃いオマル的な懐疑の色調が加えられたかも知れない。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェズ〔モロッコの旧都〕の王ムレイ・メレクは、先頃ポルトガル王セバスティアンと戦い、三人の王を死なせ・この大国をカスティリャの領土にし・たことによって有名なあの戦争に勝ったのであるが、ポルトガル人が武装して彼の国に攻め入った時から重い病にかかっていた。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
