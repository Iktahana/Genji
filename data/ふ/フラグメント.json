        "examples": {
          "standard": [
            {
              "text": "爆発によって飛び散ったガラスのフラグメントが、現場のあちこちに鋭く突き刺さっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "考古学チームは、遺跡から発掘された土器の小さなフラグメントを丁寧にブラシで掃除した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "パケット通信の途中でデータが大きなサイズだったため、ルーターが自動的に複数のフラグメントに分割して送信した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "六九　何人にも知られざる或人　ベンサムが「フラグメント・オン・ガヴァーンメント」の第一版を出した時、故らに匿名を用いて出版した。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "之のないものは論文でなくて論議的フラグメントに他ならない。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論フラグメントもフラグメントとしてその科学的価値は大きいのではあるが。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのクラシックのものは、どれも本物ではありますが、其々の大作家の全スケールからみれば全クフラグメントです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
