        "examples": {
          "standard": [
            {
              "text": "ヨットの帆を調整するために、マストの先端に取り付けられた風速計を注視する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "小学校の気象観測コーナーで、くるくると回る風速計をノートに記録した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「風速計が壊れているのか、こんなに風が強いのに針が動かないよ」と困惑する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "現在測候所で用いているような風速計では感度が不十分であるから、何か特別弱い風を測るに適した風速計の設計が必要になるであろうと思われた。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方とんぼの群れが時には最も敏感な風向計風速計として使われうるであろうということも想像された。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
