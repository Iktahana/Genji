        "examples": {
          "standard": [
            {
              "text": "その風景地は、四季折々の美しい景色で観光客を魅了している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末には、家族と一緒にお気に入りの風景地へピクニックに出かけるのが楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は新しい風景画のインスピレーションを得るため、有名な風景地を訪ね歩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "人里遠き山や林に市塵を避け、侘びた草庵を結んだり、或は贅沢を極めた風景地の別荘など皆此の境地に属する。",
              "citation": {
                "source": "読書八境",
                "author": "市島春城",
                "note": "青空文庫"
              }
            }
          ]
        }
