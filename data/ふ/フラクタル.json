        "examples": {
          "standard": [
            {
              "text": "ロマネスコという野菜の形は、細部が全体と同じ形を繰り返すフラクタル構造になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "海岸線の長さは測る物差しの尺度によって変わるという、フラクタル幾何学の考え方に感銘を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "プログラムで描画された雪の結晶のフラクタル図形が、モニターの画面いっぱいに広がっていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "筆者はすでに紙の上の日本語版で読んでいたが、「なんのこっちゃ」という感じでところどころに入っていたフラクタル図形の描きかけは、拡張本にもある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
