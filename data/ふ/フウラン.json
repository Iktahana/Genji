        "examples": {
          "standard": [
            {
              "text": "夏の夕暮れ、庭先に置かれた風蘭から甘く高貴な香りが漂ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は長年、希少な品種の風蘭を丹精込めて育てることを趣味にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "清楚な白い花を咲かせた風蘭が、涼やかな風に揺れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "かくして草木のあるものは、あの風蘭が岩のくぼみや樹皮の腐れに寄生するやうに、寂れはてた私の心に宿り、からからに乾いたそのふところを、葉の緑で潤ほし、花の匂で焚き燻べて、萎びかかつた私の生命に絶えず若々しい気力を与へようとしてゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹風蘭雨などはその一つだろう。",
              "citation": {
                "source": "台湾の姿態",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
