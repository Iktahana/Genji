        "examples": {
          "standard": [
            {
              "text": "火災現場に駆けつけたファイアマンたちが、猛火の中で決死の救助活動を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幼い頃からの夢だったファイアマンになるために、毎日厳しいトレーニングを続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "勇敢なファイアマンの活躍により、延焼を最小限に食い止めることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
