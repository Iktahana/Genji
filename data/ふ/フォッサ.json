        "examples": {
          "standard": [
            {
              "text": "マダガスカルの密林に生息するフォッサは、ネコのような姿をしていながらマングースに近い仲間だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "木登りが得意なフォッサは、長い尻尾でバランスを取りながら枝から枝へと飛び移る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "動物園の展示エリアで、日光浴をしているフォッサの珍しい姿を観察することができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "我々はただフォッサンの城を一つ失っただけで、それすら、さんざん敵をてこずらせた末のことであった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
