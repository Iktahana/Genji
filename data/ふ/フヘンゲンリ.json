        "examples": {
          "standard": [
            {
              "text": "物理学者は、宇宙のどこでも通用する普遍原理を探求し続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "時代や文化が違っても、人を思いやる心は人間社会における普遍原理だと言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その哲学書は、道徳的価値の根底にある普遍原理について深く考察している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで広い意味の哲学――即ち哲学的精神を有するもの――とは、すべて本質に於て主観を掲げ、何かの実在的なもの、もしくは普遍原理的なものに突入しようとする思想であって、例えばルッソオ、ゲーテ、ニイチェ、トルストイ等の詩学的人生評論の類が、みなこれに類している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
