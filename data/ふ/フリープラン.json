        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今回は団体ツアーではなく、航空券とホテルだけを予約するフリープランで旅行した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "旅行代理店は、若者向けに格安のフリープランを数多く用意している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "フリープランの旅行は、計画を立てる楽しみがある反面、すべて自己責任となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
