        "examples": {
          "standard": [
            {
              "text": "その動物は、人間に対する強い服従心を示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "訓練によって、犬は素晴らしい服従心を身につける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の服従心は、命令を絶対とする軍隊生活で培われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼の生涯に恵まれた幸福は、服従心の強い、優しい妻と娘とをもった事だった。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は旧制度に対してその本当の力を作っているもの、すなわちその宗教とか、法律とか、国家とか、国家に対する服従心とか、宮殿とか、監獄とかに決定的打撃を与えて、それを殺してしまうことをあえてしなかった。",
              "citation": {
                "source": "革命の研究",
                "author": "ピョートル・アレクセーヴィッチ・クロポトキン　Pyotr Alekseevich Kropotkin",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリストフの声に首長らしい抑揚があったので、本来の服従心が強く働いたのだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は卑しい家畜みたいに服従心によってではなく、愛によって信仰していたのである。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
