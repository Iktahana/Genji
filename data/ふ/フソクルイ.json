        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アサリやハマグリは、斧足類に分類される二枚貝の一種だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "斧足類は、左右対称の二枚の殻を持つ軟体動物である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海辺の干潟では、様々な斧足類を観察することができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "母親　えー次は斧足類。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（気分をかえて）えー斧足類は蛤に蜆に牡蠣、あさり、あげまき、帆立貝、赤貝、ばか貝。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、斧足類の動物と申しますと、蛤だの、蜆だの、あさりだの、それから赤貝やばか貝でございますの。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭足類、腹足類、斧足類などを暗記しておりますのも、道夫以上に母親が知っていれば、道夫が発奮すると思うからでございますよ。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "生餌では頭足類のタコ、イカ、斧足類の蠣、シジミ、ハマグリ、アサリなど。",
              "citation": {
                "source": "道具と餌と天候",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
