        "examples": {
          "standard": [
            {
              "text": "扶桑教は、富士山を神体とする神道の一派である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は扶桑教の熱心な信者で、毎週のように行事に参加している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "扶桑教の教義は、自然との共生を重視している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "御嶽教、扶桑教といろいろ聞いちゃおるが、お富士教ってえのはあっしも初耳なんで、今に忘れず覚えていたんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議な小娘は、しめなわをものものしげに張りめぐらしたそこの右側の扶桑教祈祷所と見える一軒へ、主従ふたりを誘うかのごとくにおどおどとはいりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "扶桑教といや、ちんちんもがもがの行者じゃねえですか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――当局は教理に不敬がありはしないか教団会計に横領がありはしないか、と見ているのであり、またひとのみち教団が宗教行政に適応するために名目上自分でその一派と名乗っている扶桑教にも検察の眼を向け始めたものである。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "大本教・ひとのみち（扶桑教にぞくす）を初めとして、天津教・島津治子教（？",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
