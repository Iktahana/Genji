        "examples": {
          "standard": [
            {
              "text": "京都の古い町屋を訪れると、美しく手入れされた粉壁が路地の両側に延々と続いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "歴史ある酒蔵の粉壁は、長年の風雪に耐えながらも白く輝き、独特の風情を醸し出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "城の改修工事で、職人たちが伝統的な技法を用いて粉壁を真っ白に塗り直した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "幹のやさしい、そこの見晴しで、ちょっと下に待つ人を見ようと思ったが、上って来た方は、紅甍と粉壁と、そればかりで夫は見えない。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに白帝城は老樹｜蓊鬱たる丘陵の上に現れて粉壁鮮明である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "清河の崔羅什という青年はまだ弱冠ながらもかねて才名があったので、これも徴されてゆく途中、日が暮れてこの墓のほとりを過ぎると、たちまちに朱門粉壁の楼台が眼のまえに現われた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに白帝城は老樹蓊欝たる丘陵の上に現れて、粉壁鮮明である。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "北方（西岸）から突き出てゐる所に人家が群つてゐて、空氣の澄明な日などには瓦甍粉壁が夕陽を浴びて白く反射してゐる。",
              "citation": {
                "source": "湖光島影",
                "author": "琵琶湖めぐり",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀杏は黄葉の頃神社仏閣の粉壁朱欄と相対して眺むる時、最も日本らしい山水を作す。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
