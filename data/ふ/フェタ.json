        "examples": {
          "standard": [
            {
              "text": "ギリシャ風サラダには、塩気の強いフェタを崩して入れるのが欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "フェタは羊や山羊の乳から作られる白いチーズで、樽の中の塩水で熟成させるのが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "トマトとキュウリ、オリーブにフェタを加え、オリーブオイルをかければ立派な一品になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "露西亜名をマリア・フェタロヴナといって今年八十二歳。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがダグマア前露女皇、いまのマリア・フェタロヴナの家で、忠臣のコザックたちに守られて晩年を送っているんだが、まぎらすことの出来ない息子や孫たちの悲惨な死が老いたたましいを覆して、彼女はすこし精神に異常をきたしているという。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「森の泉」と称する小川の附近には、パオトル・フェタン・ゴエといふ化物がゐて、或は人の姿、或は猫の姿、或は馬の姿、時によると火の玉になつて現はれる。",
              "citation": {
                "source": "ブルタアニュの伝説より",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらない数字だが一例としてあげておくと、一九六五年の一年間に、医師がアンフェタミンを処方した回数は二四〇〇万回。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
