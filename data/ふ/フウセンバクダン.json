        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "第二次世界大戦末期、日本は和紙で作った風船爆弾を偏西風に乗せてアメリカへ飛ばした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館には、当時実際に使われる予定だった風船爆弾の模型が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "風船爆弾という奇策は、当時の日本の切迫した戦況を物語っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "食糧で反枢軸国はまず敗北相をあらわしはじめるよ」◯先日Ｆ君の話によると、まだ風船爆弾はあがっているよし。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本がサクラの爆薬をもち、風船爆弾をくり出し、特攻隊を有するのに対し、アメリカはＢ29だけというわけにも行くまいではないか。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "工学部では風船爆弾を製造した実績をかわれてか、軍の要請に応じて新兵器の製作研究に総力をあげ、文科系の各学部の学生たちは多くが軍需工場へ動員されていた。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
