        "examples": {
          "standard": [
            {
              "text": "子供の頃に大好きだった絵本を大人になってから再び読むと、全く違う感想を抱いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "試験前夜、付箋がたくさん貼られた参考書の重要箇所を再び読んで確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "先生からの手紙を再び読み返し、その言葉の重みに思わず涙がこぼれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もし一度で理解することができなければ、暫らく間をおいて再び読むようにするが好い。",
              "citation": {
                "source": "如何に読書すべきか",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでだがこの薬丸にも沢山の草双紙を持っていたから、かつて私は江戸で随分見ていた草双紙を、この家で再び読むことが出来た。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「脱出」という言葉を日本の文学の上に、ふたたびよむとき、わたしたちの心には、ある思いが湧く。",
              "citation": {
                "source": "「下じき」の問題",
                "author": "――こんにちの文学への疑い――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
