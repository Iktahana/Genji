        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「先ほど頂いた資料を共有するため、関係者全員にフォワードしておきました。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大事なメールを誤って消さないように、別のバックアップ用アドレスにフォワードしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「取引先からの返信を、僕の個人用メールにもフォワードしてくれるかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
