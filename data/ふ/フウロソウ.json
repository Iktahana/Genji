        "examples": {
          "standard": [
            {
              "text": "高山植物の宝庫であるこの山道では、可憐な薄紫色の風露草があちこちに咲いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は植物図鑑を片手に、足元にひっそりと咲く風露草の種類を同定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "露に濡れた風露草の花びらが、朝日に照らされて美しく輝いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "明るい陽差しが、軒に出された風露草の植木鉢に、恵み多い光りの箭をそそいでいた。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
