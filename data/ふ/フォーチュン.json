        "examples": {
          "standard": [
            {
              "text": "宝くじ売り場で「今日のフォーチュンは私にある！」と意気込んでいる人がいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の人生は、予期せぬフォーチュンによって大きく変わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「フォーチュンを信じるかい？」と、彼は星占いの本を手に取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "十一月二十九日（月）　読売の夕刊にフォーチュン誌の大東亞戰爭開戰当時の記事と称するものが載っている。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "占星術に絡んだ記述について、知り合いの、猫と音楽を愛する占い師、フォーチュン聖（http://fortunehijiri.blog57.fc2.com/）さんに伺ってみました。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
