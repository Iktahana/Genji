        "examples": {
          "standard": [
            {
              "text": "キセル乗車をして改札を通り抜けようとした男が、駅員に呼び止められて不正乗車で摘発された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "定期券の有効期限が切れているのを知りながら使用を続けるのも、立派な不正乗車にあたる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "不正乗車が横行している区間では、抜き打ちで車内検札が行われることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "随分不正乗車があるらしくて気が立っている。",
              "citation": {
                "source": "日記",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、地方新聞は不正乗車の激増を大きく扱っていた。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不正乗車をしているのは貴方です。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうええわいや、もうなにも云うことあれへん、だが口は禍いのもとちゅことがあるよってな、これからは気いつけなはれや」　まるで不正乗車をして伴れて来られた乗客に対するどこかの私鉄の駅長みたような口ぶりであった。",
              "citation": {
                "source": "陽気な客",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
