        "examples": {
          "standard": [
            {
              "text": "経済の先行きが不透明な状況で、多くの投資家が株価の動向を不安視している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の無謀な計画を、周囲の人々は不安視する声が多かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その新たな政策は、将来的な影響について専門家から不安視されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あれきり消息もないが」　と、不安視され出した仲間があった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝は、連判に欠けるかと不安視されていた細川兄弟も着陣した。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
