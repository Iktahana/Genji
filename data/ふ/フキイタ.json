          "standard": [
            {
              "text": "古い小屋の屋根は葺き板が剥がれ落ち、雨漏りがひどかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝統的な日本家屋の屋根には、美しい木製の葺き板が使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "職人が一枚一枚手作業で葺き板を重ね、屋根を修理した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一言でいうならば、うすく割って屋根葺き板にするような、大きな素性の良い木材が、おいおいにとぼしくなってきたからである。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
