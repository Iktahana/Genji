        "examples": {
          "standard": [
            {
              "text": "製品名ではなく、その物の普通名称で呼んでください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ホッチキス」は商品名だが、普通名称としても広く使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "普通名称化すると、ブランド価値が損なわれることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "名称の教育とは、これに普通名称教育と特有名称教育の二種あり。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通名称教育とは、苗字、村名、州名等、普通名称の人を教育するの力あるをいう。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
