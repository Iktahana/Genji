    "definitions": [
      {
        "index": 1,
        "gloss": "boiled daikon (or turnip, etc.) eaten hot with miso",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "寒い冬の夜には、熱々の大根の風呂吹きに甘辛い柚子味噌をたっぷりかけて食べるのが一番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祖母が作ってくれるカブの風呂吹きは、出汁が中までしっかり染み込んでいて絶品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "居酒屋のお通しで出てきた風呂吹きが思いのほか美味しくて、思わず日本酒が進んでしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "鰹のたたき、あいなめの煮物、船で作った絹｜漉しの冷奴、大根の風呂吹き。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "変りふろふき　これからはよくどちらでも大根ふろふきが流行ります。",
              "citation": {
                "source": "十八番料理集",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからふろふき大根。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生で食うときは大根おろしにし、烹て食うときはふろふきにした。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七八貫もあろうと思う、煮しめたふろふきのような水っぽい女。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二本の脇差",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
