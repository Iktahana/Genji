          "standard": [
            {
              "text": "ブラジルを旅行した際、リオデジャネイロのフラメンゴ地区にある美しい公園を散策した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "フラメンゴは、リオデジャネイロの中でも比較的裕福な人々が住むエリアとして知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ホテルはフラメンゴのビーチのすぐそばにあり、窓から湾の景色を一望できた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
