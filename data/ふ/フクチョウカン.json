        "examples": {
          "standard": [
            {
              "text": "アメリカ国務省の副長官が来日し、両国間の協議を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "財務省副長官は、財政政策の転換について言及した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「副長官、次の会談はいつですか？」と秘書が尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "丸公値上げについては、都留副長官が、女性改造という婦人雑誌の対談会で、民報の森沢氏からつっこまれて大汗に陳弁している。",
              "citation": {
                "source": "ほうき一本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "都留副長官が恐縮のいたりとして認めている。",
              "citation": {
                "source": "ほうき一本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方には副長官といふものがある。",
              "citation": {
                "source": "板ばさみ",
                "author": "オイゲン・チリコフ　Evgenii Nikolaevich Chirikov",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
