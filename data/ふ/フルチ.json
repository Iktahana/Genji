        "examples": {
          "standard": [
            {
              "text": "転んで擦りむいた膝から古血がにじんでいたが、水で洗って消毒したらすぐに落ち着いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "産後の体調を整えるためには、体内に残った古血をしっかりと出し切ることが大切だと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "漢方の先生から、血行不良で溜まった古血を流すための煎じ薬を処方してもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "屋根裏より燻製の猿、鰐の子などが古血のように固まって垂れて居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "監房を出る時ふと眼をやると、洗面器の血潮はすでに夏の日の白い光線のなかに黒々と固まりかけてゐて、古血の臭ひが鼻先に感ぜられた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にも、凝結した古血のかたまりを絶えず吐き續けた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "監房を出る時ふと眼をやると、洗面器の血潮はすでに夏の日の白い光線のなかに黒々と固まりかけていて、古血の臭いが鼻先に感ぜられた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にも、凝結した古血のかたまりを絶えず吐き続けた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど眺めていると、煤けたうちに、古血のような大きな模様がある。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "備中の笠岡あたりでは、産後一ばんの食物は白味噌の汁にズイキを入れたもので、是をワリナと呼び、古血を下す效があると謂つて居た。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "備中の笠岡あたりでは、産後いちばんの食物は白味噌の汁にズイキを入れたもので、これをワリナと呼び、古血を下す効があるといっていた。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
