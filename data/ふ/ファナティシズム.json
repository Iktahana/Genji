        "examples": {
          "standard": [
            {
              "text": "彼の発言には、過度なファナティシズム（熱狂主義）が感じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ファナティシズム（狂信）は、しばしば対立を生む原因となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "政治的なファナティシズム（盲信）に陥らないよう注意しなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "社会では大本教の持っている異常精神的奇怪味を目してインチキといっているのかも知れないが、それならば天理教（これは公認された宗教だ）のファナティシズムにだってあることで、独り大本教だけのものではあるまい。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
