        "examples": {
          "standard": [
            {
              "text": "朝日に照らされた鳥取砂丘には、夜の間に風が描き出した美しい風紋が広がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "砂漠を旅する写真家は、刻一刻と形を変える風紋の影をカメラに収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "強い海風の影響で、海岸の砂浜には規則正しい風紋が刻まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "二｜振の斧と、一｜挺の剃刀、得物こそ違え、気象は同一、黒旋風紋床の愛吉。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面は風紋砂丘が浜辺へ延びて、雑草が乱雑に伸び、ハマカンザシに覆われている。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
