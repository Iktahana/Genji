        "examples": {
          "standard": [
            {
              "text": "病気で休学していた彼が、春から無事に復学できることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学に復学するにあたり、彼は改めて学業に専念することを誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "休学期間を経て、彼女は一回り成長して復学してきたように見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "二重橋の外に鳳輦を拝みて万歳を三呼したる後余は復学校の行列に加はらず、芝の某の館の園遊会に参らんとて行く途にて得たるは『日本』第一号なり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルウッドは出来事全般についてほとんど気違いじみた考えを持っていたのだが、次の秋に復学し続く六月に卒業した。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
