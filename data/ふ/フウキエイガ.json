    "definitions": [
      {
        "index": 1,
        "gloss": "wealth, rank, and arrogant splendor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "富貴栄華を謳歌した彼も、晩年は孤独だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くの人が富貴栄華を夢見るが、手に入れるのは難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史上、富貴栄華を極めた王朝は数多く存在した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その一門の富貴栄華は、一にこの夫人に因って代表さるると称して可い。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵画彫刻の美を感ずる人は紅塵十丈の裏にありても山林閑栖の楽を得べく、山水花鳥の美を感ずる人は貧苦困頓の間にありても富貴栄華の楽を得べし。",
              "citation": {
                "source": "病牀譫語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "先輩の尻馬に乗つて、そして先輩も及ばないほどの富貴栄華を極めて、独りで天狗になるとは恐れ入つた次第だ。",
              "citation": {
                "source": "黙々静観",
                "author": "勝海舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時に当り一意専心、物理を探究して、造化の秘密を開くは人間無上の快楽にして、王公の富貴栄華も羨むに足らず。",
              "citation": {
                "source": "人生の楽事",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
