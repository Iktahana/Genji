        "examples": {
          "standard": [
            {
              "text": "長年の悩みだった失恋の痛みを、やっと吹っ切ることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "過去の失敗を吹っ切って、彼は新たなスタートを切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「よし、もう吹っ切った！前向きに進もう」と彼女は笑顔で言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "と私は女学生の言葉でふっきるように云った。",
              "citation": {
                "source": "その頃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっきり労働者の文学として、ふっきる部分をふっきらせなければならない。",
              "citation": {
                "source": "その柵は必要か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
