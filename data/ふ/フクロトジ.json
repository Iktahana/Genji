        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "江戸時代の和本は、ほとんどが袋綴じの形式で作られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "図書館で古い書物を見ていたら、袋綴じになっているページがいくつかあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "袋綴じの技術は、紙を無駄なく使うための知恵だったと言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "即ち袋綴じであって、截口が綴る方にある、西洋の逆態である。",
              "citation": {
                "source": "書籍の風俗",
                "author": "恩地孝四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は音を立てないようにするために、西洋紙にペン字で書くことを避け、かように柔かい薄い雁皮紙を袋綴じにした小型の和装の帳面を作り、それへ毛筆の細字でしたためているのだが、さっきは私としてついぞないことに、書く方に興が乗り過ぎて、ほんの一二秒の間二階への注意を怠っていた。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
