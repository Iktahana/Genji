        "examples": {
          "standard": [
            {
              "text": "蚊が媒介するフィラリアは、犬や猫にとって深刻な病気の原因となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ペットの健康を守るため、定期的なフィラリア予防薬の投与が推奨されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "フィラリアが心臓に寄生すると、重篤な症状を引き起こすことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もう十四年も私達と生活を共にしてゐる彼は、そのうちの十年間胸にフィラリアを飼つてゐるわけなのである。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々を軌道に載せた基礎的な研究はパトリック・マンソン（1844-1922）が1879年にフィラリア病と蚊の関係で行われたものであった(3)。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
