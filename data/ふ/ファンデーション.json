        "examples": {
          "standard": [
            {
              "text": "新しいファンデーションに変えたら、肌のトーンが明るくなったと褒められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "デパートの化粧品売り場で、自分に合った色のファンデーションを選んでもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このファンデーションは、一日中崩れにくくて化粧直しの手間が省ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
