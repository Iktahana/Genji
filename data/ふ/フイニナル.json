        "examples": {
          "standard": [
            {
              "text": "台風の上陸によって、楽しみにしていた海外旅行の計画がふいになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "怪我のせいでレギュラー入りのチャンスがふいになり、彼は肩を落とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "合意寸前まで行った契約が、土壇場でのキャンセルのためふいになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "給科はふいになるし、前借した金にゃ一ケ月三分の利子つけて、元利耳をそろえて返さにゃならねえんだぜ。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして飲物の高価なことは、桑田が一ヶ月の給料などは二三度出入をしたら忽ちふいになるかと思はれるくらい。",
              "citation": {
                "source": "人妻",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど飯米もふいになるし、恭さんにもこれから逢えないとなりゃ……」「ほんとうに逢わせない気だろうかね。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの笛の音、そこから自分の心づくしがふいになるようではたまらぬ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "落としでもしたら、私の取り分二万ドルがふいになる」　グライドがうなずいた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲むと、せっかくの治療がふいになるからと厳禁されていたが、俺は酒が飲みたくて飲みたくて困った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
