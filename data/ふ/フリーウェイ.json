        "examples": {
          "standard": [
            {
              "text": "ロサンゼルスに到着し、レンタカーで片側5車線もある巨大なフリーウェイを疾走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "事故の影響でフリーウェイが完全に渋滞してしまい、空港への到着がギリギリになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "アメリカのフリーウェイは基本的に無料で通行できるが、一部の専用レーンは有料となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ダウンタウンからゴールデンゲート橋までの自動車による便をはかるため、この地区は、新設されるフリーウェイでつぶされることになっていた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにフリーウェイをとおすと、ダウンタウンからゴールデンゲート橋まで、自動車による所要時間が六分みじかくなるというのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "フリーウェイの計画は、数年前から出されていた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "周辺の人たちはフリーウェイに反対していて、一九六六年三月、フリーウェイ建設は中止にきまった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、フリーウェイをのがれるためにほかへ移転していった人たちはすでに多く、ハイト・アシュベリー地区は、そのために無人になった土地の中心だった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
