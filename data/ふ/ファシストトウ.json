        "examples": {
          "standard": [
            {
              "text": "歴史の授業で、ムッソリーニが率いたファシスト党の台頭について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ファシスト党の支持が広がった背景には、当時の社会的な不安があったとされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「教科書で見たファシスト党のシンボルマークは、とても威圧的な印象だったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "逆にユニフォームが強調される処には必ず何等かのミリタリー・システムが社会的に要求されているのであって、世界各国のファシスト党員のユニフォームは、近代風俗上特筆大書すべき現象と云わねばならぬ。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
