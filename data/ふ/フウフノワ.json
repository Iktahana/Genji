        "examples": {
          "standard": [
            {
              "text": "夫婦の和が保たれている家庭は、いつも明るい雰囲気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お互いを思いやる心が、夫婦の和を育む上で最も重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夫婦の和が乱れると、子供たちにも悪影響を与えてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "古びた金縁の中に極めて下手な油絵の老夫婦の和服姿が乾涸びたままニコニコしていた。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "忍びやかに会した客は、十内夫婦の和歌の友｜金勝千秋、論語の師伊藤｜仁斎と東涯の父子、医師の寺井｜玄渓など、ほんの八、九名であったが、手狭な一室はいっぱいになっていた。",
              "citation": {
                "source": "日本名婦伝",
                "author": "小野寺十内の妻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
