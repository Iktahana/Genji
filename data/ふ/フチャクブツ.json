        "examples": {
          "standard": [
            {
              "text": "遺跡から出土した土器の表面を顕微鏡で観察したところ、微小な有機物の付着物が確認された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "洗濯槽の裏側に溜まった黒カビなどの付着物が、洗ったばかりのタオルに黒いカスとしてついてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "歯科検診で、歯の裏側に石灰化した付着物があるのでしっかりブラッシングするよう指導された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その針のように細く巻かれた萌芽を擁護しているものが、無色透明の、弾力のある、ところてんのような、玉子の白味のような付着物である。",
              "citation": {
                "source": "洛北深泥池の蓴菜",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
