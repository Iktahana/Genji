    "definitions": [
      {
        "index": 1,
        "gloss": "to cheat (in a romantic relationship)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
