        "examples": {
          "standard": [
            {
              "text": "春の雨が静かに降りそぼつ中、濡れた庭の緑が一層鮮やかに見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "霧雨が降りそぼつ夕暮れの街を、彼は傘もささずに一人歩いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "一日中降りそぼつ雨音を聞きながら、家で静かに読書をして過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "本殿のところに腰かけてみていれば、降りそぼつ雨にうたれて、お百度をふんでいる人さえある。",
              "citation": {
                "source": "琴平",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は冷たい冬雨の降りそぼつ中をも厭わず、また田舎から京都に出て来た。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            }
          ]
        }
