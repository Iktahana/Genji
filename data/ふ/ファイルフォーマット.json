        "examples": {
          "standard": [
            {
              "text": "画像のファイルフォーマットにはJPEGやPNGなど様々な種類があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この新しいソフトウェアは、古いバージョンのファイルフォーマットに対応していません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "うーん、このデータ、どのファイルフォーマットで保存するのが最適だろう？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ベーシックで書かれたプログラムの文字列を字句単位に短縮化した、トークンと呼ばれる中間コードの仕様もまた、ファイルフォーマットと同様、十六進数でダンプして分析するしかない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "賽の河原の石積みとなった悪夢の互換ベーシック開発　Ｎ88―ＢＡＳＩＣやＮ―ＢＡＳＩＣと互換性をとるためには、中間コードとファイルフォーマットの仕様を知ることは絶対に欠かせなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニュアルに記載されている内容、ファイルのダンプから得られる中間コードとファイルフォーマットの仕様、そしてマイクロソフトベーシックがブラックボックスとしてどう動作するかの三つが、開発チームの情報源とされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
