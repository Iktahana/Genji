        "examples": {
          "standard": [
            {
              "text": "オフィスに導入した新型の複合機は、印刷速度が驚くほど速くて作業が捗る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "複合機のトナーが切れてしまったので、事務用品の担当者に補充を依頼した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「すいません、この複合機の使い方がよく分からないんですけど、教えてもらえますか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
