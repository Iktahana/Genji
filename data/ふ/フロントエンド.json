        "examples": {
          "standard": [
            {
              "text": "彼はWebサイトの見た目や操作性を作り込む、フロントエンドのエンジニアとして活躍している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ユーザーが直接触れるフロントエンドの使い勝手が、そのアプリの評価を大きく左右する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "新しいプロジェクトでは、フロントエンドの開発フレームワークにReactを採用することが決まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一太郎は日本語フロントエンド・プロセッサー（仮名を漢字に変える辞書引き担当ロボットのようなものだ）をＭＳ―ＤＯＳというプラットフォームに開き、他のアプリケーションでも使えるようにしたことで、流行りにはやった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "努力とは実にやってみるもので、ここから日本語フロントエンド・プロセッサーという卓抜な仕掛けが誕生した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
