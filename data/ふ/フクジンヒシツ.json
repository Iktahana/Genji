        "examples": {
          "standard": [
            {
              "text": "副腎皮質は、様々なホルモンを分泌して体のバランスを保つ重要な臓器だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長期的なストレスは、副腎皮質の機能に影響を与える可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "検査の結果、彼の副腎皮質に異常が見つかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（＊アドレナリンは副腎髄質ホルモンであり、アディソン病は副腎皮質機能低下である）　科学の歴史でこれらのいわゆる内分泌腺の発見以上に魅惑的な話は多分ないであろう。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は屠殺場からの副腎皮質と高速の in vitro 活性測定方法を用いた（41）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
