        "examples": {
          "standard": [
            {
              "text": "新約聖書の中で、マタイ、マルコ、ルカ、ヨハネの4人は福音史家として尊敬されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "中世の写本には、ペンを持った福音史家の姿が緻密な挿絵で描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "福音史家によって書き残された言葉を比較し、当時の社会情勢を分析する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "科学者たりし福音史家聖ルカが録したキリストのみ言葉は、はっきりと次のごとく警告なさっているではないか。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼はジャンヌの福音史家の美しい言葉を読み返した。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
