        "examples": {
          "standard": [
            {
              "text": "バイオリニストのフィドラーが、情熱的な演奏を披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あのフィドラー、指の動きが速くてすごい！」と観客が感嘆した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、民族音楽を演奏するフィドラーとして知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "『グランド・オール・オプリイ』のオープニング・ナイトは、アンクル・ジミー・トムスンというフィドラーが、六五分間、自分ひとりでヴァイオリンを弾きまくったのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜカントリー・ミュージックが選ばれたかというと、人々はオペラなどよりもアパラチア山中のフィドラーのフィドル（ヴァイオリンとは呼ばずに、フィドルと呼ぶ）を聞きたがったからであり、聞きたいものを聞かせておけば、コマーシャルにも有利だったのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
