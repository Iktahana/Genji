        "examples": {
          "standard": [
            {
              "text": "夜道を歩くときは、安全のためにフラッシュライトを持つと良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "停電したので、引き出しからフラッシュライトを探し出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このフラッシュライトは、非常に明るく、遠くまで照らすことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "頭の裡も外もフラッシュライトに取り巻かれているように一面の光の渦巻だ。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やる気がなければフラッシュライト社のサットンが飛びつきますよ」　チェイス記者が見出しをまた明かりに照らすと、グレディ主筆がうなずいた。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時ちょっとすぎ、イブニングフラッシュライト新聞が疑問に答えた。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、フラッシュライト新聞を読んでこの二例がサンタアナ号から移されたものと知っていたら、大混乱はなかっただろう。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
