    "definitions": [
      {
        "index": 1,
        "gloss": "behaving like a married couple",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼らはまだ結婚していないが、まるで夫婦気取りで振る舞っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新人の二人は、社内でいつも夫婦気取りで行動しているため、周りからひやかされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あら、また夫婦気取りで仲良くランチしてるわね！」と先輩が笑いながら言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もうこうなれば澄ましたもので、お俊と私はすっかり夫婦気取りで暮していたのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は夫婦気取りで、同じ部屋に泊ったが、それは便宜のためであって、二人の身体の関係は、長く純潔に保たれていた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三は苺にあやされて、子供が母を待つように大人しく寝ていたが、不用意な葉子の雑誌や書物や原稿の散らかったあたりに、ある時ふと一色の手紙を発見したことがあって、いつでも忙しなく葉子から呼出しをかけていることが解っているので、夫婦気取りの二人のなかは大抵想像できるのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "極言すれば、夫婦気取りでいるとも云いたいのである。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、それっきりこの半年ばかり、どの姉達にも御無沙汰してしまって、三石と夫婦気取りで、その日その日をおくっていたのだ。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦気取りというのではなく、自然にすらすらと出てくるのである。",
              "citation": {
                "source": "憑きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたし達があんまり仲がよすぎるって、そして……夫婦気取りでいるって……。",
              "citation": {
                "source": "古井戸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅だから遠慮は入らぬ純然たる夫婦気取り。",
              "citation": {
                "source": "空想としての新婚旅行",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして見ると二人は、まるっきり夫婦気取りです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "先代の愛妾お絹と福村とは夫婦気取りで暮しているそうな。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして見れば、二人は夫婦気取りで旅をしているようです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "東海道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらあの人達夫婦気取りよ」でぶのシルヴィが言った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
