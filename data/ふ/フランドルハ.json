        "examples": {
          "standard": [
            {
              "text": "フランドル派の画家たちは、光と影の巧みな表現と、細部にまでこだわった写実的な描写で知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "美術館でフェルメールの絵を見て、フランドル派の芸術の奥深さに感銘を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼はピーテル・ブリューゲルに代表されるフランドル派の絵画を研究している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "伸子は年齢二十三、四であろうけれども、どちらかと云えば弾力的な肥り方で、顔と云い体躯の線と云い、その輪廓がフランドル派の女人を髣髴とさせる。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姿がフランドル派の絵のようですね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランドルはもと自由の国たり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
