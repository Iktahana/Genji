        "examples": {
          "standard": [
            {
              "text": "最後の原稿用紙を書き終え、彼は深く息をつきながら静かに筆を置いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "定年退職を機に、長年連載していたコラムの筆を置く決意をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "小説家は完成したばかりの長編小説の推敲を終え、ようやく筆を置いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "善い悪いを抜きにし只私の愛するものへ捧げるつもりで讚美し祝して、この筆を置く。",
              "citation": {
                "source": "繊細な美の観賞と云う事について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このへんで、硬い話の筆を置くこととし、次にこの書に収めた作品についてすこしばかり作者の感想を綴らせてもらう。",
              "citation": {
                "source": "『十八時の音楽浴』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "残るは Through the Looking-Glass ですが、そちらもまた近いうちに、という希望（あるいは言質、または約束）を残して筆を置くこととします。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
