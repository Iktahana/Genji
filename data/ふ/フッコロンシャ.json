        "examples": {
          "standard": [
            {
              "text": "彼は新しい技術の導入に反対し、復古論者として批判されることもあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "復古論者は、過去の伝統や慣習を重んじ、現状維持を主張する傾向がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史上の多くの復古論者は、社会の変化に抵抗しようとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いやしくもわが今日の復古論者の言のごとくせば赫々たる維新の功業それいずくにある。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
