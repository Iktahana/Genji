        "examples": {
          "standard": [
            {
              "text": "予算案が議会で不承認となり、首長は政策の修正を余儀なくされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "提出した申請書類に不備があったため、結果は不承認となってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一部の委員による強い反対により、その議案は不承認に終わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "――人間の分際といふものの不承認。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが「出版不承認」と却下された。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "史家たちは今日も、ロシヤ政府がレザノフの計畫に承認を與へなかつた事情、また不承認を知りながら計畫をすすめ、しかも遠征出發の直前になつて、雲がくれして行衞不明となつたレザノフの曖昧な行動について、決定的な判斷を與へることが出來ないでゐる。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
