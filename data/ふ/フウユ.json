        "examples": {
          "standard": [
            {
              "text": "この寓話は、独裁政治の危うさを鋭い諷喩を交えて描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は直接的な批判を避け、諷喩を用いて上司の独善的な態度を暗にたしなめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古典文学の中には、自然の移ろいを人生の無常に見立てた諷喩が多く含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "就中、最も軽い諷喩と円転自在の名文で聞えたのが中坂まどきであって、「まどき」の名は当時の『読売新聞』の読者の間に喧伝された。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」「何をふうふうゆだっているんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
