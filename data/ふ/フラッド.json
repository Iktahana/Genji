        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "短時間に大量のアクセスが集中し、サーバーがリクエストのフラッドによってダウンしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "オンラインゲームのチャットが、意味のないメッセージのフラッドで一時的に使用不能になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "迷惑メール対策として、特定の送信元からのフラッドを自動的にブロックする設定を有効にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
