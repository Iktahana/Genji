          "standard": [
            {
              "text": "複数の建設会社が裏で落札額を調整する不正入札を行い、公正な競争を妨げた疑いがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "不正入札への関与が疑われる担当職員の自宅に、検察の家宅捜索が入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「談合による不正入札を根絶しない限り、税金の無駄遣いを防ぐことはできない。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "石炭屋一同は申合わせて談合値を決め、あらかじめ落札者を置いて、あとで割前をもらう一種の不正入札の方法をとった。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
