        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "異なる意見や文化に対する不寛容な態度は、社会に分断をもたらす原因となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の部下たちは、上司の些細なミスにも不寛容な態度に辟易していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史を学ぶことで、過去の不寛容な時代から教訓を得ることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その点を忘れていると、オレ達はおそらくコンピューターの新しい芸に対して不寛容になるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの党派もみな不寛容と狭小とにおいて負けず劣らずだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "群衆は容易に暗示によって左右され、敏感で、単純で、軽信的で、衝動的で、気まぐれで、無責任な性格を持ち、時にはたやすく不寛容、残忍、兇悪な暴徒（モッブ）にもなる。",
              "citation": {
                "source": "政治学入門",
                "author": "矢部貞治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴォルテールは無神論者、嘲笑者、革命家で、不正に不寛容な男であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までメアリは余りにも頑固、冷酷、無慈悲なので、他人の弱さや失敗に不寛容だった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
