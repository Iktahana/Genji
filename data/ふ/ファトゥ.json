        "examples": {
          "standard": [
            {
              "text": "花札（ファトゥ）は、日本の伝統的なカードゲームだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖父は、子供の頃によく花札（ファトゥ）で遊んでいたと話していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域では、お正月に家族で集まって花札（ファトゥ）を楽しむ習慣がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "第二は、ファトゥー射的場の隣だったので、終日｜拳銃の音がして、それにたえ得なかったからである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、わたしの知っているもっとも極端な例の中に、まずファウヌスの妻ファトゥアがあるが、彼女は結婚して後はどんな男性にもその顔を見せなかった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
