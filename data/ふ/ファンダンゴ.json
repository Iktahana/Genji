        "examples": {
          "standard": [
            {
              "text": "ギタリストが奏でる激しいリズムに合わせて、踊り子がファンダンゴを舞う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スペインの伝統的な舞曲であるファンダンゴは、情熱的で力強い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "酒場の喧騒の中、カスタネットを打ち鳴らすファンダンゴの調べが聞こえてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし主として至極もっともな憤激を惹き起したことは、このめかし屋の無頼漢めがこっちでファンダンゴ６をやったり、あっちで旋回運動をやったりしながら、タイムを守る７というような考えを微塵も持っていないように思われることであった。",
              "citation": {
                "source": "鐘塔の悪魔",
                "author": "THE DIVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
