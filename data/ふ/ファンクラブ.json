          "standard": [
            {
              "text": "彼女が入会しているファン倶楽部から、先行予約の案内が届いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "公式ファン倶楽部の会員限定で、特別なライブ映像が公開された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "小さな劇団だが、地元の人々によって支えられているファン倶楽部がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それどころか、一年まえには、ファンクラブに入るほど好きだったヴェンチャーズでさえ、もうあまり関心がなくなってきている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワラなんか、あ、クラブの仲間のことだけど、そいつ、高志のお母さんのファンクラブをつくるんだってさ」「あらあら、たいへんだこと。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムーンドグズ・ファンクラブの入会資格は、一九六六年以前のジョンをリアルタイムで愛したことだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
