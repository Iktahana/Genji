    "definitions": [
      {
        "index": 1,
        "gloss": "to divide in two",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は庭でとれた柿を、近所の人たちに振り分けてあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "先生は、クラスの生徒を二つのグループに振り分け、ディベートの準備をさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "遺産相続で揉めないように、弁護士が間に入って財産を子供たちに公平に振り分けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "その上職業とか勉強とかに振り分ける余力はない。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしこれまでは一台のコンピューターの上に集中して管理されていた仕事を、個別のワークステーションに振り分けることになる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＳ―ＤＯＳマシンとして成功させるためのエネルギーを、共倒れの危険を冒してＰＣ―１００に振り分ける意欲を、浜田はまったく持たなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の一人は広場の真中に青と赤の旗を神聖な象徴のごとく振り分ける分別盛りの中年者であった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「父帰る」の娘を藤田、「涼風」の役は、三益・北村に振り分ける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄金の蕋をふりわける。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
