        "examples": {
          "standard": [
            {
              "text": "昔は銭湯の風呂代も安かったが、今はかなり値上がりしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "財布を忘れてしまい、友達に風呂代を立て替えてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "毎日通うとなると、1ヶ月の風呂代も馬鹿にならない金額になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "風呂を飲んでしまつた、澄太君に申訳がない、どうでもかうでも風呂代だけは捻出して、その野風呂にはいつて貰はなければならない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "事の起りは、戦争中、燃料が不足して風呂がわかせなかったことと、銭湯が休業がちであったことが原因だが、元来が、夏になると、日に何回となく水風呂をあびて暑気を払う習慣があったのを、風呂代りに冬まで延長したのである。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
