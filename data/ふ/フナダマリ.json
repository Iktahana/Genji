    "definitions": [
      {
        "index": 1,
        "gloss": "moorage (esp. for small boats)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "港の片隅にある船だまりには、仕事を終えた小さな漁船が静かに休んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "夕日が、船だまりの水面をオレンジ色に染め、美しい光景を作り出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "子供たちは、船だまりで釣りをしたり、船から船へと飛び移ったりして遊んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "背が延び、より冒険を好む歳になると、若いウォードは時折、傾いだ家々や破れた明かり取り窓やぐらつく階段や捻れた手すりや浅黒い顔や言葉もないような悪臭がごった返したこの地区を巡りつつ、サウス・メインからサウス・ウォーターに向かって、湾を行く汽船が今なお立ち寄る船だまりを探した。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "素朴な橋から丘を登るように古びた小屋が何軒か建ち、眠るような船だまりには生簀付の釣り舟がもやってあった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェアフォードは港の途中にあり、船だまりの横通りは変な噂があった。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "船だまりの方へ行き、すぐ街灯の明かりで通りを確認し、目的地を探した。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夜中を過ぎて警部はフェアフォードの船だまり近くにいた。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "警部の経験から、船だまり近辺に泊まる輩は逃亡者が多い。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも仮住まいを船だまり近くに定めた。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
