  {
    "uuid": "3729707c-e5d9-52bf-b979-494b15da8a02",
    "entry": "焚刑",
    "reading": {
      "primary": "ふんけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "burning at the stake",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "中世ヨーロッパでは、異端者に対する罰として焚刑が執行されることがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は魔女狩りの犠牲となり、焚刑にかけられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "悪政への抗議の証として、人々は記録を焚刑にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ナチスの焚書に倣って、日比谷公園で過去の出版物を焚刑に処するそうだという噂まで製造された位いである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルイコフの名によるクラブの広間の壇上装飾は、聖書、十字架、僧冠などの赤い色電気により焚刑の光景だ。",
              "citation": {
                "source": "モスクワ印象記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、異端者や魔女を焚刑に処したときに使った種のものだ。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
