        "examples": {
          "standard": [
            {
              "text": "古語の文法書を読み、不定称の指示代名詞の使い方について理解を深めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "英語の「someone」や「anything」は、特定の人物や物を指さない不定称の代名詞だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "先生は、「だれ」「どこ」などの不定称の疑問詞を使った例文をいくつか紹介した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
