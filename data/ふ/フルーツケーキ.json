        "examples": {
          "standard": [
            {
              "text": "クリスマスの時期になると、祖母はラム酒に漬け込んだドライフルーツたっぷりのフルーツケーキを焼いてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "この洋菓子店のフルーツケーキは、生地がしっとりしていて日持ちもするのでお土産にぴったりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "紅茶のお供に、頂き物のパウンド型のフルーツケーキを一切れ切り分けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ケテルでも、クッキーを売っているが主力を注いではいない、パウンドケーキや、フルーツケーキは上等だが、ここのクッキーは、こわれやすくて、家へ持って帰れば、粉々になってしまう。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
