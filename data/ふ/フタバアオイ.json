        "examples": {
          "standard": [
            {
              "text": "京都の下鴨神社では、神紋として二葉葵の葉がデザインされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "初夏の日差しを浴びて、神社の境内にひっそりと群生する二葉葵を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "葵祭で使われる飾りに、ハート型の可愛らしい二葉葵が編み込まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "加茂の社家だつただけに本多家では二葉葵を紋所に使つてゐると、それを清康が見て、「いゝ紋ぢや、俺の家で使ふ事にしよう。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと／＼加茂の二葉葵には長い葉茎がくつ附いてゐるのだが、清康はそんな物は無益だといつて摘み切つてしまつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
