        "examples": {
          "standard": [
            {
              "text": "このスキンクリームには、保湿効果の高い扁桃油が配合されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "赤ちゃんの肌荒れに、無添加の扁桃油を薄く塗ってケアしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "アロマテラピーで、リラックス効果のある扁桃油の香りが使われることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「甘扁桃油、苦扁桃油、接骨木花水、沈降硫黄、そうして闇夜に絞り取った、売春婦の肝臓の血、それを合わせた冷罨剤、これを塗ることに致しましょう。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランクは彼の強壮剤で僕を力づけようとして僕の耳疾には扁桃油を用いてみた。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            }
          ]
        }
