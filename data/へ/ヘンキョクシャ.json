        "examples": {
          "standard": [
            {
              "text": "CDのブックレットを確認すると、作曲者とは別の人が編曲者としてクレジットされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "コンクールの課題曲は、著名な吹奏楽の編曲者によって手がけられたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "自分の作ったデモ音源をプロの編曲者に渡して、豪華なオーケストラアレンジにしてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この曲の編曲者ビュッセがパリ交響管弦団を指揮したのがコロムビアに入っているが、少し冴えない（Ｊ五二三七―八）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことはともかく、この曲の可憐な魅力は、ヘンデルのせいと言うよりは、編曲者にして演奏者なるフレッシュの手柄に帰すべきものであると思う。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありがとう、マイケル」　編曲者が、そうつけ加えた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを支えた黒人編曲者、フレッチャー・ヘンダスンのブラックさ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
