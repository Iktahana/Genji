        "examples": {
          "standard": [
            {
              "text": "テレビのバラエティ番組で、芸人たちが変てこりんな衣装を着て奇妙なダンスを踊り、スタジオは爆笑に包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼はいつも、常識では考えられないような変てこりんな理由をつけては、面倒な仕事を巧みに避けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祖母の家の蔵の奥から、用途の分からない変てこりんな形の古い農具がいくつも出てきて、歴史博物館に寄贈することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "会の話やなんか、十分語らないので、そちらで御覧になると何だか変てこりんなのでしょうね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々にとっては何が何やらまるで見当もつかぬような支那文字をべったり書いた細長い布や、派手な色の提灯や、怪奇な招牌の混合で装飾された変てこりんな建物が劇場なのである。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本杖、両杖半分ぐらいの時代で、とても変てこりんな漫画式のものだが、おかしなことに、現代日本の各ゲレンデで、この本にあるような変てこりんなシーロイファを、ちょいちょい見受ける。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その魚はじつにへんてこりんの形をしているんですよ。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、へんてこりんなおとこの子がひとり、おもいつめたようすで、ぼくのことをじっと見ていた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなのひとって、やっぱりただのへんてこりんだ、とだけ、その子は心のなかでおもいつつ、たびはつづく。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリス　すっごくへんてこりん。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こんなことを言っているうちに、ふと目についた一本の木、そこに何やらなかへと続く戸口がついていて、「まあ、へんてこりん！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とアリスは思ってね、「でも今日はみんなへんてこりん、だから入ってもまあよろしくてよ。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、へんてこりん！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とアリスは思ってね、「でも今日はみんなへんてこりん。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「すっごくへんてこりん！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　シンデレラさえやらなければ、ふたりのあたまはへんてこりんになってしまうのに。",
              "citation": {
                "source": "シンデレラ",
                "author": "CINDERELLA, OR THE LITTLE GLASS SLIPPER",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか、へんてこりんであった。",
              "citation": {
                "source": "老人と鳩",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
