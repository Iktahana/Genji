    "definitions": [
      {
        "index": 1,
        "gloss": "thank-you gift (given as thanks for a favor or for attending a funeral, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "葬儀に参列してくださった方々へ、感謝の気持ちを込めてお茶のセットを返礼品としてお渡しした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "香典返しとしてカタログギフトを返礼品に選ぶ家庭が増えているようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "結婚祝いをいただいた上司に、お酒好きだと聞いていたのでワインを返礼品として贈った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "thank-you gift (sent from a locality to a tax payer as part of the \"hometown tax\" program)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ふるさと納税の返礼品で届いた新鮮なカニを、家族みんなで鍋にして食べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "毎年、お米やお肉などの実用的な返礼品をもらえる自治体を選んで寄付している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "制度の変更により、地場産品以外の豪華すぎる返礼品は禁止されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
