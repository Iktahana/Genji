        "examples": {
          "standard": [
            {
              "text": "国境の防衛を任された辺境伯は、王家にも匹敵するほどの強大な軍事力を持っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "そのファンタジー小説の主人公は、貧しい辺境伯家の三男として転生した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "辺境伯の領地では、隣国との交易によって独自の豊かな文化が育まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ここで彼はバーデン・バーデン辺境伯の侍医となりラシュタット宮廷詰めになった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "この転機にさいしてこの王室の最後の辺境伯であったパトロンが死去した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "この感染症の動きを追っている我々にとって辺境伯の兵士がこの病気を持ち込んだのかハンガリー人やトルコ人から受け取ったかどうかはかなり興味深い。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "辺境伯の軍隊の帰郷に伴ってこの病気はヨーロッパで再び遠く広く蔓延した。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
