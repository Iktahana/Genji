        "examples": {
          "standard": [
            {
              "text": "大学の図書館で、フロイトやユングの理論も取り上げられている変態心理学の分厚い専門書を借りてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女は犯罪プロファイラーになるという夢を叶えるため、アメリカの大学へ留学して変態心理学を専攻した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "今期の選択科目である変態心理学の講義は、人間の行動の多様性を学べるとあって学生から非常に人気が高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これを笑うたのを他日に及んで笑わるるかも知れぬという訳は、変態心理学の書にしばしば見る二重人格また多数人格という例少なからず。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「変態心理学」でもあった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ頃でた本で山田吉彦氏訳のリボオ『変態心理学』というのがある。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、あなたがどうしてあんな恐ろしい罪を犯す気になったか、その心持は男の僕にはよく分らないけれど、変態心理学の書物を読むと、ヒステリィ性の婦人は、屡々自分で自分に当てて脅迫状を書き送るものだそうです。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
