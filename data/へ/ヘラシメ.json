        "examples": {
          "standard": [
            {
              "text": "セーターの袖口を細くするために、編み図に従って慎重に減らし目をする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ここで減らし目を忘れると、帽子の形が歪んでしまうわよ」と祖母に教わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "初心者向けの編み物教室で、増し目と減らし目の使い分けを基本から学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ああ　かれをして遠く遠く沖の白浪の上にかへらしめろかれにはかれの幸福がある。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人をして、再、我木曾義仲に、かへらしめよ。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ開帆の期すでにさだまりて九月二十六日琉球人祭服して寺におもむき犠牲を神に供し諳厄利亜人を加護し、つゝがなく本国へかへらしめんことをいのれり。",
              "citation": {
                "source": "南嶋を思いて",
                "author": "――伊波文学士の『古琉球』に及ぶ――",
                "note": "青空文庫"
              }
            }
          ]
        }
