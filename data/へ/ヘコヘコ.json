        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "そのプラスチック製の薄い板は、力を加えるとヘコヘコと簡単にしなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "安物のバケツは底がヘコヘコしていて、水を入れると今にも形が崩れそうだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "使い古したスニーカーの底がヘコヘコになり、歩くたびに妙な音がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "六時頃、ヘコヘコになっているところへかえって来た。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "海屋の幅『古書通信』の二月号に出ていた閑人閑語の「オキナのヘコヘコ」という条を見て、思わずほほえみました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
