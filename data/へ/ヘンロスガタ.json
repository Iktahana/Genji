        "examples": {
          "standard": [
            {
              "text": "駅前で、すげ笠に白衣という本格的な遍路姿の若者を見かけて驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "お寺の近くの売店には、杖や数珠など遍路姿に必要な道具が一式揃っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は遍路姿に着替えると、心を新たにして一番札所の門をくぐった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "御詠歌をうたって軒毎に報捨を乞う遍路姿の娘の、哀れな鈴の音が鳴ることもあった。",
              "citation": {
                "source": "溺るるもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま逢う樵夫や部落の人も、遍路姿のふたりに、何の怪しみも持たなかった。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
