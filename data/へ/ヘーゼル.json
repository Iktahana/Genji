        "examples": {
          "standard": [
            {
              "text": "庭の隅に植えたヘーゼルの木が、春になってようやく黄色い花を咲かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ヨーロッパの森を歩いていると、野生のヘーゼルの木をよく見かける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ヘーゼルの枝は弾力性があり、昔は籠を編む材料として重宝されたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ヘーゼルは我々が知っているどの病気よりも発疹チフスに似ていると信じているしヘッカーはその後の数世紀のあいだに変化した発疹チフスであるとの見解を持っている。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対してヘーゼルは古代インドで天然痘によく似た病気が流行していたことを示す数節をスシュルタから引用しパシェンは紀元前1700年にはシナに天然痘が存在したことを示すものを事実として認めている。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
