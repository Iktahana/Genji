        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "仏教では、大自在天は世界の創造と破壊を司る神とされています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヒンドゥー教のシヴァ神が、仏教に取り入れられて大自在天と呼ばれます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大自在天像は、しばしば三つの目と四本の腕を持つ姿で表現されます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いろいろと、文明は発達してゆくンだが、このシバの大自在天は、人間最大の文明だね。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドに於いては大自在天は男性の中の男性で、その精舎の中には常に天根を祀っていたほどであるが、支那を経て日本に渡来した仏教、日本民族によって敬虔に受け入れられた仏教には既にそういう観念がきれいに浄められていて、日本独自の清浄性が逆に仏教をもその清らかな面に於いてのみ許したのである。",
              "citation": {
                "source": "本邦肖像彫刻技法の推移",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大自在天王が天人六十人をひきいて現われる。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
