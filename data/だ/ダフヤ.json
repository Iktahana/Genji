        "examples": {
          "standard": [
            {
              "text": "人気アーティストのライブ会場周辺で、警察がダフ屋の取り締まりを強化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ネットオークションで高額転売をしている奴らは、現代のダフ屋と変わらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "チケットが完売だからといって、ダフ屋から買うのは法律で禁止されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いくらか大阪の地理がわかるようになったので、千日前の十円喫茶を振りだしに、一杯屋の女中、モギリ、スーベニヤの売子、ダフ屋と、じぶんでも思いだせないほどめまぐるしく名と職を変え、南の盛り場を転々と流れ歩いた。",
              "citation": {
                "source": "虹の橋",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
