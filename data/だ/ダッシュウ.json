        "examples": {
          "standard": [
            {
              "text": "冷蔵庫内の嫌な臭いを消すため、強力な脱臭剤を使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ペットを飼っている家庭では、部屋の脱臭が日課になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新車の独特の匂いを脱臭するため、窓を開けて換気した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ＭＳ―ＤＯＳの世界ではウイルスを便所の脱臭剤の商品名にしても、フランス料理の名前にしても、源氏名にしても四股名にしてもなんだっていいのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "偏執狂者は面白くないし、より偏屈なタイプのナショナリストには、一冊でもいいから何年もの時を経てもなお読む価値のある書物を書く能力のある者が皆無であるという事実には、それなりの脱臭効果がありはする。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
