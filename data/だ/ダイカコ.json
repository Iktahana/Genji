        "examples": {
          "standard": [
            {
              "text": "英語の試験で、過去のある時点よりもさらに前の出来事を表す大過去の用法を問われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "フランス語の文章を翻訳する際、大過去を日本語でどう自然に表現するか悩む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼が到着したとき、電車はすでに出発していた」という文は、大過去を使う典型例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "たまたま記代子さんが僕をたよって逃げて来た、ね、ぼくたるや、大過去のインネンはとにかくとして、さしあたって何の責任がありますか。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の方の用事は、大過去から過去となりやっと現在体となりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
