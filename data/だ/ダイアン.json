        "examples": {
          "standard": [
            {
              "text": "最初の計画が頓挫したため、私たちはすぐに代案を検討し始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は会議で、現在の問題に対するいくつかの有効な代案を提示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "もしこの方法がうまくいかなければ、代案としてBプランがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "黙りこくった浜田に、今度は西が代案を示した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本電気に対しては、取りあえずインターフェイスマネージャーをはずす代わり、視覚的な操作環境を組み込んだアプリケーションを標準で持たせるという代案を示した★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ宮は、話してわかるのならどこへでも行くといわれたが、Ｏ書記官長が、総理の身の上に万一のことでもあれば、政府に支障をきたすからと反対して、ラジオ放送の代案を持ちだした。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論当分駐満大使は関東軍司令官と同一人物である予定だから、前の理想案代案としてはまず結構かも知れない。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれに代る代案はまだ具体的にはなっていないらしい。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから明徴一派は代案を探索しておく必要があったろうと共に、明徴一派の驥尾に付して正直に走りまわっている者がいたとすれば、彼等も亦、やがておいてけぼりを食わされないように、用心すべきだったろう。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだいあんた方あ？",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
