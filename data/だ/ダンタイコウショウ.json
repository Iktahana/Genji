        "examples": {
          "standard": [
            {
              "text": "労働条件の改善を求めて、組合は会社と団体交渉を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "団体交渉は、労働者の権利を守る重要な手段だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "経営側は、従業員の代表との団体交渉に応じる義務がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "団体交渉もくそもねえや。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二八条　勤労者の団結する権利及び団体交渉その他の団体行動をする権利は、これを保障する。",
              "citation": {
                "source": "日本国憲法",
                "author": "施行、昭和二二年・五・三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二には言論、集会、結社の自由、労働者の団結権、団体交渉権、ストライキ権が憲法で保障されることになったのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "団体交渉権を制約し、クローズド・ショップを非合法にし、ストライキをおこなう前に六〇日間の冷却期間を設けなければいけないとするなど、労働者の権利を大きく制限するものだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
