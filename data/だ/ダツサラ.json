        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年会社勤めをしていたが、ついに脱サラして自分の店を開くことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "脱サラして農業を始めた彼は、都会の喧騒から離れて充実した日々を送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "脱サラ後の生活は甘くないと言うが、それでも夢を追って挑戦する人がいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ところがマイクロコンピューターの出現で、連中は哀れ絶滅と相成った）に自分達で開発したシステムを乗せて販売する業務を念頭におき、脱サラして会社を起こした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年に脱サラして、椎名尭慶は極安コンピューターの提供を目指してソードを設立した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
