        "examples": {
          "standard": [
            {
              "text": "第一養護学校では、一人ひとりの発達段階に合わせたきめ細やかな特別支援教育が行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "第一養護学校の運動会では、生徒たちが練習の成果を存分に発揮し、会場は温かい拍手に包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地域交流の一環として、地元の大学生が第一養護学校を訪れ、生徒たちと一緒に工作を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "松本は黒崎の友人でこの試みに共感していた玉城重信と玉置晴朗とともに、群馬県桐生市の桐生第一養護学校を訪ね、脳性麻痺の子供たちにとってどんな道具がふさわしいのかを探りはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "作ったのは一台きりだったが、桐生第一養護学校では、いろいろなタイミング合わせの装置と組み合わせて、子供たちが幅広く使ってくれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
