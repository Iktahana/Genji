        "examples": {
          "standard": [
            {
              "text": "中国旅行のお土産に、珍しい団茶を買ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "団茶は、保存性が高く、熟成させることで味が深まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人と一緒に、丁寧に淹れた団茶をゆっくりと味わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "煮る団茶、かき回す粉茶、淹す葉茶はそれぞれ、唐、宋、明の気分を明らかに示している。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼が団茶を用いたからであった。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "団茶はこれをあぶって嬰児の臂のごとく柔らかにし、紙袋を用いてこれをたくわう。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
