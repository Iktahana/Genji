        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "博物館の展示資料で、古代中国の貴族たちが遊んでいたという弾棋の道具を見かけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "弾棋のルールは現代では不明な点も多いが、当時は非常に人気のある娯楽だったようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史小説の中で、主人公が弾棋の勝負に負けて悔しがる場面が生き生きと描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
