        "examples": {
          "standard": [
            {
              "text": "優れたスポーツチームには、強い団体精神が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害時には、地域住民の団体精神が復興を支える力となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は団体精神を重んじるリーダーとして、部下からの信頼が厚い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "年よりは、ぜんぜん団体精神を知らんので駄目である。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――上等のお菓子でも不味そうに食べること）団体精神。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、お次ぎは団体精神の発動にうつる。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの三人が熱心に団体精神の予備行動を始めているのに、ピロちゃんだけは、ぼんやり沖のほうを眺めながら、こんなふうにつぶやく。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
