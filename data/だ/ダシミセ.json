        "examples": {
          "standard": [
            {
              "text": "縁日では、金魚すくいの出し店が子供たちで賑わっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イベント会場には様々な企業が出し店を設けて、自社製品をアピールしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「こちらの出し店では、限定グッズを販売しています！」と店員が叫んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――　と精々｜喜多八の気分を漾わせて、突出し店の硝子戸の中に飾った、五つばかり装ってある朱の盆へ、突如立って手を掛けると、娘が、まあ、と言った。",
              "citation": {
                "source": "雛がたり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ喧嘩だというと、大勢が崩れて、私たちの跳ね出し店の手欄を被り、店ぐるみ葭簀張りを打ち抜いて、どうと背後まで崩れ込んで行ったものです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "熊手を拵えて売ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本金二百円のテンプラの出し店が、ある場末の町角で始まったのでした。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの掛けてる横手の町角でも、小さい出し店の中で、腕の逞ましい、男のやうないつものかみさんが相變らず無愛措な顏をして新聞を前に列べてゐる。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
