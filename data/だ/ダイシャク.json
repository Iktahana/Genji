        "examples": {
          "standard": [
            {
              "text": "昔の日本では、長さの単位に大尺や小尺といった種類があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの建物は、設計図を見ると大尺で測られた寸法で建てられているようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大尺は、現在の物差しとは少し感覚が違うね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "大谷文學士の調査によれば（『東洋時報』第一二二號）、漢時代の一里は官尺にて我が三丁五十五間、後漢建武銅尺にて三丁五十一間に當り、唐時代の一里は小尺にて我が四丁四十二間、大尺にて四丁五十一間に當る。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            }
          ]
