        "examples": {
          "standard": [
            {
              "text": "車のダッシュボードには、速度計や燃料計など様々な情報が表示される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいソフトウェアには、システムの状態を一目で把握できる便利なダッシュボード機能が搭載されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はダッシュボードの上に、お気に入りのフィギュアを飾っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "走る自動車の後部座席から、ダッシュボードとその向こうのウィンドシールドごしに、道路をとらえたショットだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "影になっている運転席とダッシュボードのすぐ外には、強い陽ざしを照り返しているエンジン・フードがあった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞子は運転席のなかで体を横向きにし、両足をダッシュボードに上げた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "シートをうしろへいっぱいにずらし、腰を前に出してだらしなくすわりなおした僕は、ダッシュボードに裸足の両足をあげた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "マアラエア湾にも、猿がたくさんいたからなあ」　反射的に僕は両足をダッシュボードから降ろした。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "車へ戻り、ダッシュボードの時計を見た。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダッシュボードのラジオで、音楽が聞けたからだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "となりの男はダッシュボードにほうり出され、フロント・ガラスで頭を打った。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
