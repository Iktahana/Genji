        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "飛行機のエンジントラブルで、出発が遅れ、代替機が用意された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "老朽化した輸送機の代替機として、新型機が導入される予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "悪天候のため、急遽、代替機への乗り換えを案内された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
