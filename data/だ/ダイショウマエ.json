        "examples": {
          "standard": [
            {
              "text": "能舞台の中心、観客から見て最も奥まった場所を大小前と呼ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "役者が大小前に立つと、舞台全体が引き締まった印象になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大小前は、物語の重要な場面で使われることが多い位置だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "採り物・韓神についであつた大嘗歌即、大嘗会に召された短歌形式以外の物の多かつた一類が、大小前張として、神楽自体の中にも、既に大きな区画を作つて居たのである。",
              "citation": {
                "source": "和歌の発生と諸芸術との関係",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんこういうのは垣内本来の性質でなく、つまりは墾田奨励の仮装的な政策によって、これが一種の開発権の別名となって来たので、この点はやや大小前後の差こそあれ、荘園その物の発達とよく似ている。",
              "citation": {
                "source": "垣内の話",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
