        "examples": {
          "standard": [
            {
              "text": "達磨宗は、坐禅を重視する仏教の一派だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日本の多くの禅寺は、達磨宗に属している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "達磨宗の教えは、簡素な生活を推奨している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "かくて山門の衆徒は栄西を訴え、公家階級もそれに同じて達磨宗停止の令を発した。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子の定家の歌は一層拍車をかけたものだったので、人たちは禅問答の難解さにたとえて達磨宗の非難をあびせた。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
