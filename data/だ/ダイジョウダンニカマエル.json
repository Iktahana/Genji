        "examples": {
          "standard": [
            {
              "text": "稽古中、師範は「もっと堂々と大上段に構えなさい」と指導した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "剣道初心者の彼は、ぎこちないながらも必死に大上段に構えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試合の開始と同時に、二人の選手は互いに大上段に構えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
