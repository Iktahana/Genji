        "examples": {
          "standard": [
            {
              "text": "担任の先生は、男子生徒と女子生徒の意見を公平に聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "休み時間には、男子生徒たちが校庭でサッカーを楽しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この学校では、男子生徒にも家庭科の授業が必須だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "たぶん偶然に生えたか、巧妙な農夫が植えたのであろうが、一番の盗っ人である男子生徒でも、品種ぐらいは分るだろう。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "男子生徒用の更衣室でＴシャツとショート・パンツを脱いだ裕一は、通路を歩き建物の外に出た。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "学年別に男子生徒が全員参加する運動種目を、観客席の有利な位置から、邦子は双眼鏡で見た。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
