        "examples": {
          "standard": [
            {
              "text": "彼は毎日ベンチプレスを欠かさないため、服の上からでも大胸筋の厚みがよくわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「胸板を厚くしたいなら、まずは効率よく大胸筋を鍛えるトレーニングから始めよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "水泳のバタフライは、腕の力だけでなく大胸筋を大きく使うダイナミックな泳法だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "思いっきり広い肩の下に、左右の大胸筋がもっとも良く発達していた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い肩、厚い胸板、逞しく美しい腕、発達した大胸筋、そしてそれと分かちがたくひとつになっている、明らかに小ぶりな、しかしかたちのいい乳房。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
