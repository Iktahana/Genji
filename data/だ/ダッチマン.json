        "examples": {
          "standard": [
            {
              "text": "帆船の帆を張るためのロープのことを、ダッチマンと呼ぶことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔話に出てくるダッチマンは、しばしば伝説的な船乗りとして描かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、オランダ出身なので、皆から親しみを込めてダッチマンと呼ばれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一九四一年に又もやレオナルド展が世界巡業を行ったことは、不滅というよりも「さまよえるダッチマン」のオペラ式で、おおレオナルドをして安らかに眠らしめよと、シェークスピアなら科白にかくべきところでした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
