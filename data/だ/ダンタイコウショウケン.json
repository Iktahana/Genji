        "examples": {
          "standard": [
            {
              "text": "憲法には、労働者の団体交渉権が保障されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "従業員は、自らの労働条件について団体交渉権を行使できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "労働組合の主な役割の一つは、組合員の団体交渉権を代行することだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "第二には言論、集会、結社の自由、労働者の団結権、団体交渉権、ストライキ権が憲法で保障されることになったのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "団体交渉権を制約し、クローズド・ショップを非合法にし、ストライキをおこなう前に六〇日間の冷却期間を設けなければいけないとするなど、労働者の権利を大きく制限するものだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
