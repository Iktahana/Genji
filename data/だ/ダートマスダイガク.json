        "examples": {
          "standard": [
            {
              "text": "優秀な卒業生を多く輩出するダートマス大学は、世界的に有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、アメリカのアイビーリーグの一つ、ダートマス大学への進学を目指している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ダートマス大学のキャンパスは、緑豊かで美しいことで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "★一九六四年にアメリカのダートマス大学でジョン・ケメニーとトーマス・カーツによって大型コンピューターのタイム・シェアリング・システム用の会話型言語として書かれたとき、ベーシックの規模はごく小さかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六三年から六四年にかけて、ダートマス大学で開発されたベーシックは、タイムシェアリングによってユーザー一人ひとりがコンピューターと向かい合い、マシンと対話しながらプログラムを組むことを狙っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
