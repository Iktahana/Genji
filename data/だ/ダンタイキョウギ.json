          "standard": [
            {
              "text": "サッカーやバスケットボールは、代表的な団体競技である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は個人競技よりも、協力して戦う団体競技を好む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームメイトとの絆が深まるのが、団体競技の魅力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで私は陸上競技の御大などに祭りあげられて羽振りをきかしたものだが、何しろこの中学は人力車夫と新聞配達がたくさんゐるから馬鹿にマラソンが強いので、特に団体競技、駅伝競争となると人材がそろつてゐる。",
              "citation": {
                "source": "ぐうたら戦記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
