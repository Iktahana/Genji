        "examples": {
          "standard": [
            {
              "text": "昔々、この国には森の奥深くに住む大賢者がいました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は若くして人生の真理を悟り、やがて人々から大賢者と呼ばれるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "物語の主人公は、旅の途中で大賢者に出会い、助言を授かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "十五歳以後は、最早あらゆる魔術と呪文とに通じた博学の大賢者として天の下に並ぶものもない。",
              "citation": {
                "source": "セトナ皇子（仮題）",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
