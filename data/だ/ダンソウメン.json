        "examples": {
          "standard": [
            {
              "text": "地震発生時には、断層面に沿ってずれが生じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地表に出ている断層面は、観察が容易だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地質学者は、岩盤を削って断層面を詳細に調査した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "なるほど、下部は黒く、中部はやや褐色に幾段もの脈がついて、上部は黄や青の苔の、そのツンドラの断層面がそのままそっくりその中に飾られてあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロッペン鳥の懸崖、岩壁――断層面。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜻蛉や蠅でなければ行けない何物かの断層面にも似ていた。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
