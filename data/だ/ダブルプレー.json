        "examples": {
          "standard": [
            {
              "text": "ショートの華麗なグラブさばきから始まったダブルプレーで、一死満塁のピンチを切り抜けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "バッターが放った痛烈なゴロが正面を突き、あっという間にダブルプレーが成立した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ここでダブルプレーが取れれば最高だ」と、ピッチャーは低めにボールを集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "わっという喊声と共に千三は球がたしかに手塚に取られたと思った、が球は手塚の靴先にバウンドした、手塚はダブルプレーを食わして喝采を博そうとあせったのでスタートをあやまったのである、かれはバウンドした球をつかもうとしてグローブの上ではね返した、ふたたび拾おうとしたとき二塁手と衝突して倒れた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
