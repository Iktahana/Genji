        "examples": {
          "standard": [
            {
              "text": "複雑なシステムを理解するために、エンジニアは詳細なダイアグラムを作成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プレゼンテーションでは、視覚的に分かりやすいように大きなダイアグラムがスクリーンに映し出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はホワイトボードに、問題解決のためのフローダイアグラムを手際よく描いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ウィスタフカ、或ものはスタティーチェスキー〔統計〕の材料が古く或画は一寸 1905 年時代のハイカラー（つまりワフタンゴフ）があるが、アボルトについてのダイアグラム随分面白かった。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大判の四角い本で、頁をひらくと、革命前のロシアの石油、石炭、鉄などの生産と文化の状態が、当時それらの経営に君臨していた外国資本と、ひどい労働者小舎に住んで働いていたロシア労働者の対照的な姿とを描き出しながら石油櫓の数、石炭の山の大小のダイアグラムで示されている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
