        "examples": {
          "standard": [
            {
              "text": "そのアイコンをダブルクリックしてアプリケーションを起動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ファイルを開くには、マウスでダブルクリックしてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "なかなかダブルクリックがうまくいかず、イライラした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ダブルクリックでネットスケープが起動されて、そのままその場所に連れていってくれる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピンをもらった人は、ダブルクリックで該当のページにジャンプできる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ためしにダブルクリックしてみる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "インターネットに接続してあるという条件は付くが、注釈のダブルクリックでブラウザーが立ち上がり、世界への扉が開いて、宛先のページが画面上に呼び出される。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
