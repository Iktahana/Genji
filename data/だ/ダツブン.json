          "standard": [
            {
              "text": "古い文献の写本を読み進めていたが、肝心な結末の部分に脱文があり、話の筋が追えなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「メールの本文に脱文があって、待ち合わせの時間がどこにも書いてないんだけど…」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "引用元を確認したところ、私の書き写した文章には三行ほどの脱文があることが判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「当著」は初めわたくしは当地著の脱文かと以為つたが、その重出するを見るに、到著の誤であらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
