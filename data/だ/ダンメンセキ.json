        "examples": {
          "standard": [
            {
              "text": "電線の断面積が小さいと、許容電流が低くなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このパイプの断面積を計算して、流れる水の量を求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "航空機の翼の断面積は、揚力に大きく影響する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "すなわち、一、軍船を沈めるのには、すべからく船底に断面積大なる穴をうがつべし。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って接合部切口における断面積も算出されるわけだから、これらの数値によって不要なる贅肉は揉み出して切開除去されるのだ。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
