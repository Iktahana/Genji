        "examples": {
          "standard": [
            {
              "text": "歴史の教科書で、ヒトラー率いるナチス・ドイツが「第３帝国」と称していたことを学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "第３帝国の野望は、世界を巻き込む大戦を引き起こした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画では、第３帝国時代の緊迫した社会情勢が克明に描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "［『第三帝国』第三九号、一九一五年五月五日］",
              "citation": {
                "source": "感想の断片",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日々々どうしていゝかわからないやうな日ばかりです　暫く第三帝国も拝見しませんが如何ですか。",
              "citation": {
                "source": "消息",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "――八月十八日―孤月様―野枝［『第三帝国』第五〇号、一九一五年九月一日］",
              "citation": {
                "source": "消息",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "序の中の霊と肉の調和、自愛と他愛の最もよき折合、イブセンの第三帝国を建設すべく□□努力して居ると云う事を明かに知り得た。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "イブセンの第三帝国の所で、キアルケガアルドが真理は主観であると云う事を云って居たとあるがそれには同意しかねるのである。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三帝国に於てイブセンも亦超人を持ったのではないか。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はツァラツストラを説きブランドを叫び、超人をいい第三帝国を語った。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
