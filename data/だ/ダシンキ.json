        "examples": {
          "standard": [
            {
              "text": "医学生は、打診器を使って患者の膝蓋腱反射を検査する練習をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神経内科の診察では、医師が打診器で全身の反射をチェックすることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この打診器は、持ちやすく、正確な打診がしやすいように設計されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "殿「ウム、夫は検熱器と云ふものだ、是が聴診器、是が打診器と云ふものだ。",
              "citation": {
                "source": "華族のお医者",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿「いや斯ういふ処に病は多くあるものだからな、是から一つ打診器で肺部を叩いて見てやらう。",
              "citation": {
                "source": "華族のお医者",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
