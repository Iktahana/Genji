    "definitions": [
      {
        "index": 1,
        "gloss": "fall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "試合中に相手選手がダウンして、レフェリーがカウントを始めた。「1、2、3…」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然の雷に驚き、彼は足元がもつれてダウンしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "プロレスラーが必殺技を受け、ついにマットにダウンした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「何、ダウン、兄さんはダウンとトランプはしないことにしたぞ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ダウンとは、先生が「ン」の字を「ウン」と発音したことによつて、「オミヤノダンダン」と読本にあるのを「ダウンダウン」と読んでから私がつけたニックネームだつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ダウンと書いてダン、と読むんぢやい。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴賢はうまうまとひっかけられて猛撃を喰い、忽ちノックダウンされたのも仕方がなかったと言うべきである。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ポーツダウン丘陵の砦で司令官をやっているフリーボディ少佐です。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、「青空文庫からファイルをダウンロードして自分のディスクに収め読む利用者の方たちも、作者を賛える記念碑に石を積む人」であると添えた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのトッテン師匠の高座が一九九〇年六月十三日、新百合ケ丘のアシスト本部でかかると聞いたものだから、日本一のウイルス男たるこのオレは、システム・ダウン寸前の老骨にむち打って、小金持ちの蝟集する川崎市麻生区の新興高級住宅地へと馳せ参じたのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここのところウイルスだウイルスだと騒ぎまくっていたオレは、ついにシステム・ダウンして病院にほうり込まれる羽目となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダウンサイジングと呼ばれる戦場でメインフレームは誰に破れたのか　父と母はもはや、永続的に共同生活を維持していく状態にないと初めて知らされたのは、オレが小学校四年生の時だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう気づくか気づかぬかのうちに、オレの口からは「ダウンサイジングと言っても、大型は誰に負けたのか、という話なんだと思うんですよ」と、分かったような分からないような言葉が垂れ流されていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一九九〇年を前後して、ダウンサイジングという話になる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがダウンサイジングと呼ばれるものの本質だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダウンサイジングの戦場での最終的な勝者は、まだ誕生していないのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダウンサイジングと書かれた白旗を掲げてメインフレームの陣地から両手を上げて出てきた連中は、彼らの流儀と彼らの文化を再び、マイクロコンピューター上に築こうとしている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このキャンパスは、そこらじゅうアップダウンばかりで、平らな地面というのはグラウンドと野球場、そして舗装されたテニスコートや、バスケットコートなど、数えるほどしかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は二階に飛んで帰り、マドラスチェックのボタンダウンのシャツと、淡いブルーのコットンパンツ、そして、チェックのベルトをバッグに突っこんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、全力疾走」８そこは灯もずっと華やかで心配ごとも気がかりも、みんな忘れられるだから、でかけようダウンタウンにいれば、すべてが素晴らしいほかに、こんな場所などあるわけがないあらゆることがあなたを待っている〈ダウンタウン〉ペトゥラ・クラーク　ふたりは、ピカデリーのまえで車からおろしてもらった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "短い髪に合わせたのか、男物のような、チェックのボタンダウンのシャツを着ている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、これを四分、八分と倍テンポにしていき、こんどは、四分、二分というぐあいに、スロウダウンする。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像のなかの慶一の視線は、いきなり先生の胸に合ってしまい、あわててティルトダウンして、乱れ籠におかれた、汗のしみついた下着に固定する。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "柾生も、薄いクリーム色のボタンダウンに、淡いブルーのコットンパンツというすがたで、慶一ひとり、赤や黄色のめだつ、マドラスチェックのボタンダウンでは、まるで、ふたりの刑事につかまった、チンピラのようだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わかんないよ、日本の会社はメチャクチャだから」「ヤードバーズの〈オーヴァー・アンダー・サイドウェイズ・ダウン〉だの、スタンデルズの〈ダーティー・ウォーター〉だの、騒々しい曲ばっかじゃねえか」　三日後に、ワラがアメリカへ帰る。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐屋みたいに早起きする義理はないんだ」　うっかりすると見落としそうな、かすかなストライプの入ったボタンダウンを着て、その胸にはスクールタイがぶらさがっていたのは、五人の度肝を抜いた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パパ、カムダウン、サッパー、イズ、レディ』と三人の子供が上り段のところから、声を揃えて案内するのが例でした。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
