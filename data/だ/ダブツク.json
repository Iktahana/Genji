        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "飲みかけのペットボトルをバッグに入れたら、歩くたびに中身がだぶついて落ち着かない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "洗濯機の中で水がだぶついている音を聞きながら、終わるのを待っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "胃の中に大量の水分がだぶついている感じがして、走るのが辛い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
