        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "30代を過ぎてから代謝が落ち、脇腹の肉がだぶついてきたのが悩みだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "厳しいトレーニングを辞めた途端、全身の筋肉が脂肪に変わってだぶつき始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ブルドッグのように顔の皮がだぶついている犬は、愛嬌があって可愛らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
