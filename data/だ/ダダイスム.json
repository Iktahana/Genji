        "examples": {
          "standard": [
            {
              "text": "ダダイスムは、芸術の常識を覆す革命的な運動だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はダダイスムに深く傾倒し、その理論を研究した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "うわー、ダダイスムって、かなり過激な芸術運動だったんだね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ダダイスムも表現主義も、無意味に「人間よ、人間よ」と人埃の中に見失った母を求める子どものように叫びつづけたのである。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "表現派、ダダイスムの地盤はそれである。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダダイスムは漸次其の勢力を拡大しつゝある。",
              "citation": {
                "source": "演劇一般講話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
