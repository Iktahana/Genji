        "examples": {
          "standard": [
            {
              "text": "寝坊した友人のために代返を頼まれたが、声が似ていないので断った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "代返が教授に見つかってしまい、頼んだ方も頼まれた方も大目玉を食らった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最近の大学ではICカードで出席を取るので、代返は物理的に難しくなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "道後へ、理髪入浴、藤君居に寄つて米代返金、債荷一つ果してほつとする。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはゆる「代返」なる習慣には、たまに眼をつぶることはあつても、この種の手の込んだ、或は合法的かもしれぬが、一方、教師として黙認すべからざる学生の協同謀議に対して、なんらかの手を打つべきではないかと、彼は考へた。",
              "citation": {
                "source": "計算は計算",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
