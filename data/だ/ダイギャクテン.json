        "examples": {
          "standard": [
            {
              "text": "最終回の裏、二死満塁からの代打逆転サヨナラホームランで、劇的な大逆転勝利を飾った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「倒産寸前だった町工場が、新発明一つで大逆転を収めるなんて、まるで映画みたいな話だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "選挙速報の画面で、劣勢だった候補者の得票が急増し、深夜に大逆転が起きた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
