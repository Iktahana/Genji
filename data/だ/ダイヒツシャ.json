        "examples": {
          "standard": [
            {
              "text": "歴史上の偉人の中には、個人的な手紙を代筆者に書かせた者も少なくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は忙しい作家の代筆者として、原稿の清書を手伝っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高齢になり、文字を書くのが難しくなった祖父は、代筆者に日記をつけてもらっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もっとも彼は、その代筆者を多分お鶴だろうと想像していた。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、代筆者の柾木少年丈けが、いつまでも、クヨクヨと、甲斐なく打捨てられた恋文のことを、思いつづけていたのである。",
              "citation": {
                "source": "蟲",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
