          "standard": [
            {
              "text": "超音波検査で、ダグラス窩に少量の腹水が溜まっていることが分かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "内診の際、ダグラス窩に圧痛を感じる場合は炎症の可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子宮と直腸の間にあるダグラス窩は、解剖学的に非常に重要な部位だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、蘭子は赤ちゃんの時代｜已に「ダグラスか然らざれば仕立屋銀次」の思想を植えつけられていた。",
              "citation": {
                "source": "江川蘭子",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
