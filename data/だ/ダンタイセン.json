        "examples": {
          "standard": [
            {
              "text": "剣道の大会では、個人戦だけでなく団体戦も行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回のオリンピックでは、体操の団体戦が注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "団体戦では、一人ひとりの実力はもちろん、チーム全体の戦略も重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "武田信玄も、上杉謙信も、その軍隊の編制に於て、統率に於て、団体戦法に於て、用兵に於て、戦国の群雄をはるかに凌駕して居り、つまり我国に於ける戦術の開祖と云うべきものである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "謙信と信玄とは、軍の編成と統率、団体戦法と用兵に於て、戦国時代の群雄をはるかに凌駕してゐて、我が国に於ける戦術の開祖とも云ふべきである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
