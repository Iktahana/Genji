        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "息子の進学先は、伝統ある男子校に決まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "男子校の文化祭は、女子校とはまた違った盛り上がりを見せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は男子校で培った友情を一生大切にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もっとも、そうなると、また県教委がさわぎだして、男子校にもどすようなハメにならんともかぎらないがね」「そんなことになったら、タイヘンだ」　口をつぐんでいるつもりだった慶一が、思わず驚きの声をあげた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私立の名門男子校のレイクサイドスクールは、一九六八年春、いち早くコンピューター教育に取り組むことを決めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
