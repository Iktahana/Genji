        "examples": {
          "standard": [
            {
              "text": "走行中にタイヤのナットが緩んで脱輪し、あわや大惨事になるところだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「大型トラックの脱輪事故が相次いでいるので、運行前の点検を徹底してください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "左前輪が脱輪したまま無理に走ったせいで、路面に深い傷跡が残ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
