        "examples": {
          "standard": [
            {
              "text": "南国の海岸線に沿って整然と並ぶダイオウヤシの並木が、観光客を出迎える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ダイオウヤシの高く伸びた幹の先に広がる緑の葉が、強い日差しを遮ってくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "植物園の温室で、ひときわ存在感を放つダイオウヤシの威容に見惚れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大きさはわが四国くらいの島で、熱帯の海に近いから、海岸の砂浜には、大王椰子の樹が、緑の葉をひろげている。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王椰子の葉がざわざわとゆれて、遠くの方で、かすかに、海鳴の音がしている。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
