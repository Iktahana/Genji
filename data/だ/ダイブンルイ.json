        "examples": {
          "standard": [
            {
              "text": "図書室の本は、まず歴史や科学といった大分類に基づいて並べられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アンケートの結果を整理するために、回答をいくつかの大分類に分けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家計簿の項目を「固定費」と「変動費」の大分類で管理し始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "幾つかの柱の上には書物の大分類と小分類を示す大型の記号があった。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆはフェル博士の分類、Ｍはマーリニの分類を意味し、Ａ・Ｂはそれぞれの大分類、１・２などはそれぞれの小分類の項目番号をあらわす。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
