        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "退職後、彼は世界を旅する第二の人生を始めました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は第二の人生で、画家になるという夢を追求することを決意しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多くの人々は、退職後の第二の人生に、新しい趣味や冒険に満ちた人生を期待しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "二人さへゐなければ、富岡はおせいと自由に第二の人生を歩み出せるやうな気がした。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと自分から招いた過失であるとはいえ、私たちは第二の人生を、光の褪せた晦冥の中から踏み出さねばならなくなったのです。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二の人生といふやうなものだ。",
              "citation": {
                "source": "教祖の文学",
                "author": "――小林秀雄論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二の人生というようなものだ。",
              "citation": {
                "source": "教祖の文学",
                "author": "――小林秀雄論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろわれは藝術を第二の人生と見たりき。",
              "citation": {
                "source": "藤村詩抄",
                "author": "島崎藤村自選",
                "note": "青空文庫"
              }
            },
            {
              "text": "云はゞ藝術は第二の人生である。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
