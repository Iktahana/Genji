        "examples": {
          "standard": [
            {
              "text": "物語は、彼と彼女という第３人称で語られることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "論文では、客観性を保つために第３人称の表現を用いるのが一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供向けの絵本は、主人公を「ぼく」や「わたし」とする第１人称が多いが、これは第３人称で書かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "』と口では第三人称の地位に居るやうな調子で云うた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、小畑の視点を中心にした第三人称で書くことに決めたのではなかろうか。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
