        "examples": {
          "standard": [
            {
              "text": "この工場は、日本のものづくりにおける代表例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その遺跡は、古代文明の代表例として世界遺産に登録されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の成功は、努力が報われる代表例として語られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "テキストデータを利用する代表例とも言えるのは、本の音訳と朗読だろう。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィレットが同意しているのは、この種のものはウォードが不完全な塩類から呼び起こした実体の代表例であり、奴隷ないしは祭儀のために保管していたのに違いないという点のみである。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィル・スペクターとザ・ビーチボーイズが、その代表例だろう。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
