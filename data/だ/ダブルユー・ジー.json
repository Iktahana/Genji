        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新製品開発のためのWGが発足し、各部門から精鋭が集められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "次回のWGでは、具体的なプロトタイプのデザイン案について議論する予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "WGのリーダーとして、メンバーの意見を取りまとめながらプロジェクトを進行させる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
