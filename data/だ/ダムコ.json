        "examples": {
          "standard": [
            {
              "text": "ダム湖の水位が低下し、周辺の農業用水に影響が出ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夏の観光シーズンには、ダム湖でのボート遊びが人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このダム湖、とても綺麗で静かだね。リラックスできる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "水はまんまんとして、そのダムに堰かれて湛え、橋梁の連灯はまだ白く玻璃球のみ光って、丘陵の上、また水辺に反照する鮮明なる洋風建築、このダムこそ東洋一の壮観だとせられる。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "美和子は、それと気づくと、芝居気たっぷりに、「マダムここへおかけにならない？",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年たちは、ダムこわしの機械人間の行方を早くつきとめて取りおさえないと、これから先、たいへんな事件が起こるであろうと心配しているのだった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
