        "examples": {
          "standard": [
            {
              "text": "赤ちゃんが大のほうをしたので、おむつを替える時間だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公園の芝生に犬の大のほうが落ちていて、注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "朝、健康な大のほうが出ると一日が気持ち良く始まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "大のほうへ吹いています。",
              "citation": {
                "source": "手紙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、肝腎な武大のほうでは、一こう真にうける風がないのだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くずれかかった、赤い石がきのうえには、つたがふかくおいしげって、ろだいのほうへ、ひと葉ひと葉、はいあがっています。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
