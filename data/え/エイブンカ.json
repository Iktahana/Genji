          ],
          "literary": [
            {
              "text": "そこで愈英文科を志望学科と定めた。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝大の英文科に、四年前にはいったのだけれども、まだ卒業しない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいち僕には、一高英文科に入学できる自信がない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中秋の或る快晴の日の午後、景子は友人の某大学英文科の助教授宮坂を案内して彼がしきりに逢いたがって居た此の国の文学者ジョン・ガルスワーシー邸を訪ねて行った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと僕の家にいたのだが、外国語学校の英文科を苦学して出ると、語学の先生になったところで莫迦莫迦しい、漢法医になるというんだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "英文科を選んだといふのは、単に自分の英語の習慣に媚を呈したに過ぎなかつた。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　床柱に頭をもたせかけて泰然と腕組をしてゐる村木光夫が、まはりを見廻しながら、「大滝の妹さんの登志子さん――さつきも言つた通り、登志子さんは来年からは女子大の英文科に入つて、ゆくゆくは作家にならうといふ志望を抱いてゐる人で……」　と重々しい口調で呟いだ。",
              "citation": {
                "source": "海路",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、或る私立大学の英文科に籍を置いてゐたが、英語の小説すら原書では読めなかつた。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "英文科を選んだといふのは、單に自分の英語の習慣に媚を呈したに過ぎなかつた。",
              "citation": {
                "source": "文學的自叙傳",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺か――」　と私も自分の名前を続けて「俺は、英文科の一年だよ。",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなり裕福な商家であったが、次男坊で肌合の変っていた三四郎は、Ｗ大学の英文科を卒えると、教師になって軽々諸国行脚の途についた。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彌生は專門學校の英文科を左傾がかつたことを云つて自分から退學したのであるが、この頃ではけろりとしてしまつて「ねえ、このぐらひの家に住むとなれば、何うしたつて着物から先きに一と通りはそろえてなくては、あたし表へ出るのも耻しいのよ。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吾は其家の総領で、今年大学の英文科を三年に進んだ。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "總領の信吾は、今年大學の英文科を三年に進んだ。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "籍を置いてゐた私立大学の文学部で、彼は英文科に属してゐることに気付いて「英文学！",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "物知らず６・28東京日日（夕）　京都大学の英文科のある学生が、なにがし教授のお伴をして、四条の南座に忠臣蔵の通し狂言を見たことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「原君、御紹介しましょう」と相川は青木の方を指して、「青木君――大学の英文科に居られる」「ああ、貴方が青木さんですか。",
              "citation": {
                "source": "並木",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし語学に趣味があるようなら、早稲田の英文科でもやったらどうだろう。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川さんは、大学の制服の膝をきちんと座布団の上に坐って――確にあれは制服だったが、でも、大学を一体芥川さんは何年に出られたのかと思って、今、年譜を調べて見たら、大正五年七月英文科を卒業とある。",
              "citation": {
                "source": "田端の坂",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学校がすんで、目白の日本女子大の英文科の予科に一学期ほどいて、やめた後だったと思う。",
              "citation": {
                "source": "時代と人々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本女子大学の英文科予科に一学期ほどいたことがある。",
              "citation": {
                "source": "女の学校",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一部の乙組即ち英文科の生徒なりき。",
              "citation": {
                "source": "恒藤恭氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この部屋の先住の英文科の帝大生が壁にナイフで落書をしている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ学生で帝大の英文科に籍を置いてゐる。",
              "citation": {
                "source": "愛する人達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桃ちゃん、これ読むといい」　そういってイリーンというひとの書いた書物の歴史とか時計の歴史とかいう本を貸すのも順助であったし、英文科にいる桃子の学校でつかう本をみて、「やっぱり先生ってものは自分が習ったような本をよますもんだな。",
              "citation": {
                "source": "夜の若葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等は二人ともこの七月に大学の英文科を卒業していた。",
              "citation": {
                "source": "海のほとり",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "松岡は我々三人が英文科に籍を置いてゐるのにも関らず、独り哲学科へはいつてゐた。",
              "citation": {
                "source": "あの頃の自分の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "専門家にならない限り、婦人にとって、文学は情操を養うのを主眼とすると、女子大の英文科の先生も説かれていたし、私も女学校で、生徒達にそう説いた。",
              "citation": {
                "source": "新妻の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "学業の出来がよいので、そのまま芝田さんの家に居続けて、女子大学の英文科まで卒えました。",
              "citation": {
                "source": "白い朝",
                "author": "――「正夫の童話」――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
