          ],
          "literary": [
            {
              "text": "暮から東京裁判はＡ級被告東條英機の公判に入った。",
              "citation": {
                "source": "砂糖・健忘症",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に今日の新聞はＡ級の容疑者が十九名釈放されたと伝えています。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばＡ級の戦争犯罪者、つまり世界の人類に向って罪を犯した人が数人処刑されたとしても、ファシズムが残り、底が残っていればそれはなんの意味もありません。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のファシストとして大活躍をした反動者を含む二十人の戦犯人がＡ級戦犯被告としてとりのぞかれた事実も耳目をあつめた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東條の家族が、「父は生きたのです」といった十二月二十三日の次の日、わたしたちはＡ級戦犯容疑者十七名が釈放された記事と写真とをみました。",
              "citation": {
                "source": "ファシズムは生きている",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのＡ級が大部分、役人にいわせれば禁止Ａ級に入れられていた。",
              "citation": {
                "source": "ある回想から",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お隣りは絞首刑でね」　Ａ級戦犯の判決のことなのだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のいた部屋は、Ａ級戦犯のＯ氏が発病直後送られた部屋で、発病直後は兇暴でこのガラス部屋は不向きであったから、松沢へ送られたそうである。",
              "citation": {
                "source": "精神病覚え書",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかへ、升田はＡ級筆頭で、自他ともに許す次期名人の候補であつた。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "名人戦といへば死生を賭けたやうなものでもあるし、覚醒剤の必要な対局は、Ａ級棋士で年に十回、挑戦試合が五回、それだけしかないのである。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "升田をキッカケに新人雲の如く起って、西に升田を叩きつぶす大山あれば、東に木村を破って名人位を奪う塚田あり、Ａ級の十名中には、旧人の名を見ることができない。",
              "citation": {
                "source": "戦後新人論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲はＡ級選手で二十三歳。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はＢ級から一躍とびあがってＡ級の上位三者をなぎ倒して挑戦者になったが、その落付きと年間のめざましい戦績から、世間の大半は彼の勝利、大山次期名人を疑わなかったようである。",
              "citation": {
                "source": "九段",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの若者は古狸でも三四年は寝込むようなきびしい悪評の中で、冷静に、動揺することなく、またしても順位戦に好成績をあげ、わずかに木村との最後の挑戦者決定戦に敗れたが、Ａ級順位戦では彼が第一等であったように記憶する。",
              "citation": {
                "source": "九段",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の年もＡ級優勝、挑戦者となり、はじめ二敗、つづく二局を二勝して二対二にもちこみ、第五局目モミヂの対局に於て、「ぼくの勝ちですよ」　言々句々に再びウヌボレが現れていたのはモミヂの女中たちすら指摘するところである。",
              "citation": {
                "source": "九段",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に近ごろ流行の、硝子囲いに材料を山と盛り、お客さんいらっしゃいと待ちかまえているような大多数の店は、Ａ級寿司屋とはいい難い。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがため、店内に居並ぶ客種は普通の寿司屋にみるように、Ａ級、Ｂ級、Ｃ級と混合していないのが特色である。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ級にあらずんばＢ級といった具合で、夜となく昼となく、すさまじい勢いで繁盛この上もない。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一節第一日の第十二レースＡ級予選で、実力第一の武田選手が消えるという噂がとんでいた。",
              "citation": {
                "source": "光を覆うものなし",
                "author": "――競輪不正事件――",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに会社常雇のＡ級かんかん虫が船具部であるといってもよい。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あいつはたすかったんだな、あいつは）　それは麻痺性痴呆の病名をもって、Ａ級戦犯の法廷から除外された男であった。",
              "citation": {
                "source": "黄色い日日",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりＡ級というわけなのだろう。",
              "citation": {
                "source": "安い頭",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
