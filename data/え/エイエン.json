          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "宇宙の広大さを考えると、人間の時間は永遠の一瞬に過ぎない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "結婚式で、二人は永遠の愛を誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この美しい景色は、まるで永遠の時を刻んでいるかのようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この友情は永遠だよ！」と彼は力強く言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "失われた文明には、永遠の謎が秘められていると信じられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "さあれ日は過ぎ月は逝き、なれ等血もなく涙なく、よくぞ鬩めげる数千年、さても殺生はての死の、よくぞ好きなる、おゝ永遠の闘争よ、おゝ恩怨の同胞よ！",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎたる彈くひと萩原朔太郎ぎたる彈く、ぎたる彈く、ひとりしおもへば、たそがれは音なくあゆみ、石造の都會、またその上を走る汽車、電車のたぐひ、それら音なくして過ぎゆくごとし、わが愛のごときも永遠の歩行をやめず、ゆくもかへるも、やさしくなみだにうるみ、ひとびとの瞳は街路にとぢらる。",
              "citation": {
                "source": "ぎたる彈くひと",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めからボヘミアンであったヘルンは、晩年においてもなおボヘミアンであり、永遠に故郷を持たない浦島だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（實際に言つて、詩人は精神の永遠的な少年である。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠の詩人宿命生涯を貫く萩原朔太郎　僕は少年の時、島崎藤村氏と薄田泣菫氏の詩を愛讀した。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠にパンセは言葉にたよる他、仕方ないものなのか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かせがねばならぬ」といふ意識は芸術と永遠に交らない、つまり互ひに弾き合ふ所のことだ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体芸術家が、実生活人に比べて永遠追慕の情の強い所に成立つのであつてみれば、実生活の空気に反撥的である場合にのみ芸術家の生活は弾力的であるのである。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠は汝が眼の裡に微笑むでゐた……此の世を去つた炬火、空にて再びともれよ！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら科學智識や文化の進歩と關係なく、子供の兒童心理そのものは、常に永遠に不變であるから。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん本質的に言うならば、芭蕉のポエジイにもまた、真の永遠的の若さがある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの恋人は、過去にも実在した如く、現在にも実在し、時間と空間の彼岸において、永遠に悩ましく、恋しく、追懐深く慕われるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のこうした俳句は、現実の恋の実感でなくして、要するに彼のフィロソヒイとセンチメントが、永遠に思慕し郷愁したところの、青春の日の悩みを包む感傷であり、心の求める実在の家郷への、リリックな咏嘆であったのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鮓は、時間の沈滞する底の方で、静かに、冷たく、永遠の瞑想に耽っているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前途は遠く永遠であり、日は空に薄曇っていた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠の漂泊者である芭蕉が、雪近い冬の空を、鳴き叫んで飛び交いながら、町を指して羽ばたき行く鴉を見て、心に思ったことは、一つの「絶叫」に似た悲哀であったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉と同じく、魂の家郷を持たなかった永遠の漂泊者、悲しい独逸の詩人ニイチェは歌っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者は「永遠の漂泊者」であり、何所に宿るべき家郷も持たない。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら尚、人間は永遠に先祖の記憶を遺伝して居る。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢幻的な間に合わせの仮象を放逐して永遠な実在の中核を把握したと思われる事でなければならない。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちにおれは之を遺産とし、永遠の領地として贈つてやる。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "津村は天國へ行つたにきまつてゐるし、私は死んでも他のところへ行くのだから、もう永遠に津村の顏を見る事が出來まい。",
              "citation": {
                "source": "郷愁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう永遠に帰らないことを思つて　　酷白な嘆息するのも幾たびであらう……私の青春はもはや堅い血管となり、　　その中を曼珠沙華と夕陽とがゆきすぎる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなやの間ではあるが、消えてはまた生まれ、あちらと思えばこちら、連続と隠顕と、ひととき眼を忙失させるけれども、なお眼を放たないなら、眺め入るものに有限の意識を泡にして、何か永遠に通じさすところがある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして話の途絶えた間、北海の浪の音を聞いていると、私はこの老婦人と一緒に永遠に四郎を待つ気持になれた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他に一分も心を寄せ合はなかつた相愛の男女が、三年目の再会後、間もなく永遠の破綻を来らしめました。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女も男と同じように働き、学び、考える時代となり、尚上述の条件を男子側より否定されるならば、永遠に、女性の生命は内面の不平を堪えて男子を羨み続けるでありましょう。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真当の恋というものの本質も標準も私が必ず知って居るというわけではないけれど、とにかくより執拗なより永遠的なものということですの。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠に動きつつ永遠に交わらざる平行線は、二元性の最も純粋なる視覚的客観化である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
