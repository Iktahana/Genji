          ],
          "literary": [
            {
              "text": "風雪の威力の下、鱗甲のある枝幹を四方にのべて、地上に偃臥する特性を持つ。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖の上になってるので、利根川は勿論中川までもかすかに見え、武蔵一えんが見渡される。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "また物体の磨滅の現象からも、目に見えぬ微小部分が存するゆえんが引証されている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ神の正義を伝えんが為に茲に来た。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんのほうは、子供とは、まったく、えんがなくなってしまいました。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "透通いて見えん事は無けれどもよ……障子越は目に雲霧じゃ、覗くにはっきりとよう見えんがいの。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "影も形も見えんがな」　夜逃げでもしたのではないかという顔で、訊くと、「声はすれども、姿は見えぬ、ほんにお前は屁のような……」　〆団治はうたうように言って、「――今日はお午の夜店やさかい、そこイ行ったはんネやろ」「さよか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君はあんまり品行方正とは言えんが、とにかく出来るから推薦したのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋のあいだに小さな穴があるのは不自然だとも思えんが。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、いゝぶえんが來たど』　といつた。",
              "citation": {
                "source": "鮎釣に過した夏休み",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国婦人が住んでいてね、私なんぞにゃ朗々としか聞えんが、およそ目には見えんで、各自はその黒髪の毛筋の数ほど、この天地の間に、天女が操る、不可思議な蜘蛛の巣ぐらいはありましょう、恋の糸に、心の情が触れる時、音に出づるかと思うような、微妙な声で、裏若いのが唱う。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自己の野心を満足せんが為めに、即ち彼の衷にあって表現を求めている愛に、粗雑な、見当違いな満足を与えんが為めに、愛国とか、自由とか、国威の宣揚とかいう心にもない旗印をかかげ、彼の奇妙な牽引力と、物質的報酬とを以て、彼には無縁な民衆を煽動する。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに天下かつてこの事なきを見れば、この料理天職説も畢竟は男子の得手勝手より婦人に塗りつけたるものにして、婦人は男子の意を迎えんがため、もしくは知らず知らず男子の意を受けて、ついに自らしか言うに至りたるものなるべし。",
              "citation": {
                "source": "婦人の天職",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えんがいないのだ。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんともいえんが、Ｓ国の爆撃機が行動を起したのかもしれない。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはここに真志屋五郎作と石塚重兵衛とを数えんがために、芸術批評家の目を立てた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は専門じゃないから判っ切り云えんがな、娘さんは飛んでもないことを仕出かしとる、立派に妊娠していられたものを堕胎剤を飲んでいるらしいて。",
              "citation": {
                "source": "反逆",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とんと良く聞えんが！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大きな声じゃ言えんがね、それは造作なくやれるんだよ」とその女は、炉の側で小さな声で母に話し始めたのだった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は戸が強くガタン／＼と鳴り出すと、怯えたやうに、「如何ん、無えんが、やあたい。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "要吉は、ある年、近所へ避暑にきていた大学生たちが、自分の家のえんがわへ腰をかけて、一｜粒よりの水蜜桃をむしゃむしゃと、まるで馬が道ばたの草をでもたべるようにたべちらすのを見た時の、うらやましい驚きをいつまでも忘れることができませんでした。",
              "citation": {
                "source": "水菓子屋の要吉",
                "author": "木内高音",
                "note": "青空文庫"
              }
            },
            {
              "text": "えんがわに腰をかけていると、昨日の雨でしめっていた庭にかげろうがまっています。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸した金を返えしもせず、人を殺そうとするなんて、阿呆らしくてものが云えんがな」「ものが云えなければ黙ってろ。",
              "citation": {
                "source": "罠に掛った人",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判所は、被告に適当の保護を与えんがために、猫の飼主に命じて開廷日には猫を戸外に出さないという保証状を出させてもらいたい。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって誤解のなきことを欲するが、われに思想あり、この思想を世に伝えんがために早くわれを殺せといわんばかりに、めざましきを好む演劇的な挙動を恣にして、態と反動を招いて、かえってはなばなしく斃れることを望むのが宜いと言うのではない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "光にむかふは神の許をえんが爲なり四六―四八〔望みの極〕神〔熄む〕願ひの必ず成るを信じて靜心にかへれるをいふ五二―五四〔高き光〕神の光。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「学校の職員や生徒に過失のあるのは、みんな自分の寡徳の致すところで、何か事件がある度に、自分はよくこれで校長が勤まるとひそかに慚愧の念に堪えんが、不幸にして今回もまたかかる騒動を引き起したのは、深く諸君に向って謝罪しなければならん。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある一種の意識連続を自由に得んがために（選択の区域に出来得るだけの余裕を与えんがために）あらかじめ意識の範囲を広くすると云う意味にほかならんのであります。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
