        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "戦士たちは、永遠の眠りにつく前に祖国のために戦った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "静かな夜、森の奥で動物たちは永遠の眠りにつく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は安らかに、まるで永遠の眠りについたかのように見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "死の佇んでいる玉座をそこは人知れぬひそやかな都市霞なる西方の深い窪地にあり善人悪人聖人極悪人みな永遠の眠りについている。",
              "citation": {
                "source": "ポオ異界詩集",
                "author": "エドガー・Ａ・ポオ　Edger A. Poe",
                "note": "青空文庫"
              }
            },
            {
              "text": "多年の賢明な治世の後にハイムダルがある冬の日に永遠の眠りについたときに、始めに彼を人間界に載せてきた小船が海岸で見出された。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "城砦を囲んで永遠の眠りに沈んだやうな森が、二人を呑んでしまつたのだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "哥薩克魂がその由緒正しい五体から飛び去り、唇は蒼ざめて、彼は永遠の眠りについたのである。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうその時すでに彼は、これまで多くの哥薩克どもが永遠の眠りに就いたあの同じ冷たい死の床に横たはつてゐたのぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、いよいよ年齢をとれば、大量の睡眠が必要となり、すなわち永遠の眠りにつくというわけじゃ」「御教訓、ありがたいことでございます」　老師は照れかくしに、つまらん講義を始める。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "木々の葉はそよりともせず、朝蝉が鳴いていて、はるか下の方から聞こえてくる海の単調な鈍いざわめきが、われわれ人間の行手に待ち受けている安息、永遠の眠りを物語るのだった。",
              "citation": {
                "source": "犬を連れた奥さん",
                "author": "DAMA S SOBACHKOI",
                "note": "青空文庫"
              }
            },
            {
              "text": "転身異相画　その法外先生が永遠の眠りにつく時、枕辺の大次郎と千浪の手に、痩せ細った手を持ち添えて握らせ合い、「改めて許す。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼が自然を恋い慕うたのは、この永遠の眠りのためではなかった。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "静子よ卿に佳き永遠の眠りあれ。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七五〇年七月二十八日、十三人の子供達に囲まれて、晩年盲目になったバッハは、安らかな永遠の眠りに入ったのである。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には昏睡、精神を永遠の眠りの中に投じ、おのずからまなこはふさがり首はうなだる。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
