          "literary": [
            {
              "text": "」「英雄色を好むさ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に家康も英雄色を好むの古則に漏るる能はじ。",
              "citation": {
                "source": "大久保湖州",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「英雄色を好む」の言を口実として色にふけるものあり、「君子は貧を楽しむ」の言を口実として貧に安んずるものあり、これみな大なる過失なり。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "英雄色を好むも、色を好むもの必ずしも英雄ならず、君子貧を楽しむも、貧に安んずるもの必ずしも君子ならず。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
