          ],
          "literary": [
            {
              "text": "一、話し手のエートス（性格）による証明。",
              "citation": {
                "source": "解釈学と修辞学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで話し手は言葉の技術によって自己のエートスに対する相手の信を作り出すように努める。",
              "citation": {
                "source": "解釈学と修辞学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは各人のパトス、またエートスによって規定され、性格的なものである。",
              "citation": {
                "source": "解釈学と修辞学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "かようにパトスないしエートスに基づくものとして修辞学は表現的である。",
              "citation": {
                "source": "解釈学と修辞学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学のエートス（精神）であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
