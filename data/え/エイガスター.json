        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "かつての映画スターも、今ではすっかり白髪のおじいさんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ハリウッドの映画スターが来日し、空港はファンでごった返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃の夢は、映画スターになってスクリーンで活躍することだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は瞬く間に映画スターの座に上り詰めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "近頃は日本人の顔がだんだんに西洋人に似てくるようで、銀座などを歩いているとあちらの映画スターに似たような顔つきをした男女を見かけることも珍しくないがただ髪の毛だけは、当り前のことだが皆申し合せたように真黒である。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず現代でいちばん実用的な描写法としては世界的に知れ渡った映画スターなどのいろいろなタイプを借りて記載するのが近道であろうかと思われる。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さながらに映画スターの私室然たる到れり尽せりの部屋だ。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "展示する服より、じぶんの器量をヒケラかそうという、映画スター気取りのモデルは、たくさんだって……着ているものの枠のなかにキチンとおさまって、デザインや生地の美しさを生かしてくれるような、すぐれた感覚をもったひとだけを集めたい意向なの……あなたにうってつけの話だと思って、推薦しておいたわ。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐれた美しさや才気のある娘は、映画スターやギブスンガール（米国の美術家ギブスンの描いた、理想的なアメリカ女）の典型でなくても、一種の無冠の女王になれる。",
              "citation": {
                "source": "ブラウン神父の醜聞",
                "author": "THE SCANDAL OF FATHER BROWN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは映画スターの悪態をならべ立てて、ロマンスは大きらいだとおつしやる。",
              "citation": {
                "source": "ブラウン神父の醜聞",
                "author": "THE SCANDAL OF FATHER BROWN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは映画スターが五回目の結婚をするのは、ロマンスに迷つたからだというお考えですか？",
              "citation": {
                "source": "ブラウン神父の醜聞",
                "author": "THE SCANDAL OF FATHER BROWN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのレヴィウの舞台からは、すでに何人か映画スターやレコード歌手などが巣立っていて、その劇場はスター養成所だとさえ言われているところだ。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸万の説明によると、外国語の華訳には、原語の意味を中国語で現わしたものもあるが（たとえば映画スターが「明星」、トーキーが「声片」）、原音をそのまま漢字の音に当てはめたのがあって、「威士忌」や「飛力脱」がそれだと言って、「重野が上海に来てるらしい」　当て字のことなど、丸万にはさして興味がないようだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "十数人のアメリカ兵をひとりで相手にして、姉はまるで映画スターのようだった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画スターを専門に撮っていた優秀な写真家たちが、技術を駆使してものにした写真だから、彼女たちの脚線が美しいのは当然だろう。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画スターになれそうなほどだ。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「映画スターです」　と、彼は言った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画スターみたいな人だ」　思案する、という言葉がぴったり来るような表情で、島村はしばらく考えた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私としては、まるで映画スターのような気持ちで、この写真ぜんぶにサインをしたくなるわ」　そう言って夏子は笑い、「今日も写真機を持ってるのね」　と言った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、映画スターになるまで」「取材しなくてはいけない」「すでにかなり知ってるよ」　もし書くとして、日比谷優子についての文章のなかに、ふたたび冬彦は高木節子を感じることになるのだろうか、とヨシオは思った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑色のクレパスを選んだ優子は、色紙の天地を一杯に使って、まさに映画スターのサインをした。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
