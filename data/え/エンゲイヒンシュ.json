        "examples": {
          "standard": [
            {
              "text": "このバラは、新しく開発された園芸品種で、病気に強いのが特徴です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "来年のコンテストに向けて、珍しい園芸品種のチューリップを育てています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "農家さんは、それぞれの気候に最適な園芸品種を選ぶのに苦労しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最新の園芸品種カタログには、驚くほど多様な植物が紹介されていました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それ等の地獄を縁づけている丘陵には、地獄の煙のなびきかかるところに、岩石をはうようにして、葉のこまかい、園芸品種としても名高い雲仙つつじが、一面にはびこっていて、上の方へのぼるに従い、山つつじ、瑶珞つつじが、赤松の間に茂っている。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
