        "examples": {
          "standard": [
            {
              "text": "「えんえん、おもちゃ壊しちゃった！」と子供が泣き出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "赤ちゃんが「えんえん」と大声で泣いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「また宿題忘れたの？」「えんえん、ごめんなさい…」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "麥萩原朔太郎麥はさ青に延び行けり遠き畑の田作りの白き襦袢にえんえんと眞晝の光ふりそそぐ九月はじめの旅立ちに汽車の窓より眺むれば麥の青きに驚きて疲れし心が泣き出せり",
              "citation": {
                "source": "麥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘がバルセロナの古い歴史を呼びさますようにえんえんと鳴る。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "えんえんたる鐵路の涯へ、汽車が走つて行くのである。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、令弟は気息えんえんとして、今にも呼吸を引きとろうとしているところであった。",
              "citation": {
                "source": "屋根の上の黒猫",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かさかささして、えんえんえん、という形なの、泣かないばかりですわ。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も此の栗の木を前にして、真赤なえんえんたる天鵝絨の坂があり、坂の上には丘があり、麦畠があり、麦畠には麦が穂をそろへて揺れたり光つたりする清明な小景があつた事も読者よ記憶せよ。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇后も、それといっしょに、えんえんと燃えあがる火の中に飛びこんでおしまいになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の心には、もう嫉妬の焔が、えんえんと燃えながらも、言葉だけは、いよいよ丁寧に、「そうですか。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀河系の渦状分肢のさらに外縁に孤立する太陽の惑星、テルミナスにこもった三万人の研究者が、何世代にも渡ってえんえんと刊行し続けたというあの事典の存在は、アダムスの頭にもありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は、大きな意思を構成する膨大なアトムの一個なんだな」　悲鳴を上げる視神経をなだめてえんえんとサーフィンを続けていたある夜、私の胸に、ふとそんな思いが芽生えました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりの山々は、いつもえんえんと起伏する山でありながら、さて若し私が大男であつて不図疳癪を起して掴みあげようと腕を鳴しても、掴みどころに迷ふであらう特に際立つた峰も見あたらぬ眠むたげな色合でぐるりと村を取り巻いてゐた。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽室のなかでは、五人のスネア・ドラマーが、音楽学校の女打楽器奏者の大声に合わせて、ほんもののスネア・ドラムではなく、板にゴムシートを貼りつけた練習台を相手に、「フラ打ち」の練習をえんえん一時間もつづけていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志は、「うさぎ屋がユニオンの支店になる日」という物語を、大船との往復のあいだ、えんえんと話しつづけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつが近頃、八郎丸のお妙坊を手込めにしようとたくらんで……」　と聞きかけた時私の口腔からは、えんえんたる焔が吐き出たと思はれた。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "行手の霜枯れた畑の彼方には斑らな雪を戴いた山々が、碧く澄み透つた空の裾に圧し潰されたやうに低くなだらかにえんえんと連なつてゐた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ僕は、大きな意思を構成する膨大な数のアトムの一個なんだな」　そんな感慨がわき上がってきたのは、リンクをたどって、パーソナルコンピューターの歴史をめぐるネットサーフィンをえんえんと続けていた夜だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "報道陣は軽井沢に殺到し、テレビ各局はえんえんと現場の模様を中継し続けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "えんえんと続く話し合いが始まった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先には、どんな夢想家にも思い描くことのできなかったほどの、おびただしいドミノの列がえんえんと連なっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこのすり合わせの作業が、えんえんと難航することになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてコンピューターへの着手に断を下し、えんえんと悪戦苦闘を続けるこの事業にそれでも確信を抱き続けてきた小林は、無言のまま、一つ大きくうなずいて石井の言葉を受けとめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八〇年九月二十八日、ビル・ゲイツとポール・アレン、そして日本市場へのベーシックの売り込みを大成功させてマイクロソフトの副社長の肩書きを得ていたアスキーの西和彦は、ＩＢＭのマシンを中心に絡まり合った問題を解くために、えんえんと論議を続けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初は三〇分という話になっていたビル・ゲイツとの話し合いは、えんえん三時間★に及んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "えんえんたる無駄話が深夜に及ぶと、高校生であること、大学に進むこと、果ては生きることの意味への問いかけといった空恐ろしいテーマすら浮上した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コイルをはずしては巻きを調整し、もう一度取り付けては画像をチェックする作業がえんえんと続いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが印刷の工程でミスが生じると、えんえんと入力したプログラムは結局動かず、失意の読者は往々にして昼夜を問わずに電話で問い合わせを入れて、書き手を悩ませた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当にすぐれたソフトウエアを生み出すためには、高い能力を持った人間が、集中した作業をえんえんと積み重ねていかざるをえなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもこうした事態がこのまま進んでいけば、ちっぽけコンピューターは、新しく生まれてくるマシンに合わせてえんえんと手直しの作業を続けるか、特定の機種だけを相手にして自ら市場を制限するか、それともＯＥＭへの転向でも試みる以外なくなるとピットマンは考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発の手順をたずねられ、「自分たちで書いたプログラムを、手作りの八ビットマシンでえんえん走らせて作った」と答えると、「是非上司に会ってほしい」と逆に求められた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
