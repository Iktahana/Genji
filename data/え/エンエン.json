      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "endlessly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会議は延々と続き、結論が出る気配がない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は昨日の出来事を延々と話し続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高速道路が延々と続く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "敵の出で来るを恐れては勿々軍はなるまじ、その上に延々とせば、横山｜終に攻落さるべし。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "延々後をつけ回して機会をうかがえばいいのです。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち戸外に猛る野分と本の綾とが解け合うようで、雨の飛沫も延々うねる波濤としか思われない。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼等幾多の犠牲的青年によって、遂に成功するに至った延々何百｜哩の鉄道は、長蛇の如く野を走り、山を貫き、昨日までの蛮地は、かくして国富と変ったのであります」　重役の娘と、何時の間にか紳士のようになった工夫が相抱くところで幕だった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姉の八重が、一つ違いの十八で、新一郎との間に結納が取り交わされるばかりになっているのであるが、世間が騒しいので、そのまま延々になっているのだ。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹木のない乳褐色の山々が延々と暁の両岸に連っているきりだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "林檎の花の下を蛇行しているセーヌ河は、古城の銃眼を高く一方に聳えさせ、延々と巴里に向って流れている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらとあちらのその間に、まだ誰も見たことのない美しい国境がひとり延々と続いているのだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが延々になつてゐたのは、今までは男手としては駒平一人であり、季節の仕事に次から次へと追はれて、その時を得なかつたためであつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥つた男は以前御用雑誌の記者をしてゐる頃、加藤男の計らひで支那視察に出掛ける事になり、しこたま旅費も貰つて、そのなかから流行のフロツクコートも一着｜拵へたが、出発間際になつて風邪を引込んで、延々になつてゐるうち、つい沙汰止みになつてしまつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい声では言へないが、余り延々にしておくと、さういふ女でも、いつの間にか側目を振る事を覚えるものだから。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど、私の心に遺っているおつやさんという人は延々と育ち、非常に美しい皮膚を持ち、軟い花のような人であったのだ。",
              "citation": {
                "source": "追想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの言葉を聞いた時は、まことに延々するほど嬉しく思いました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "馬専門の彫刻家のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは巾三尺ほどの延々たる露路で、何世紀にも決して日光のあたることはないらしかった。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、わたしという一人の作家が、ここに書いて来たあれやこれやの思いにかられて、延々たる長篇の、辛うじてその中途へまで辿りついたとき、二つの肩はずっしりとした明日からの仕事の重さを感じているばかりであるのは、当然ではないだろうか。",
              "citation": {
                "source": "「道標」を書き終えて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖の左手には、黛をグッとひきのばしたように、蘇提が延々と続いていた。",
              "citation": {
                "source": "西湖の屍人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな延々と、自然のまゝの姿で生きていられる世界もある。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月末には迎いに行く事になっていたが、丁度刑事に踏み込まれたりして、迎いに行くのが延々になり、子供にこんな有様を見せたりするのは面白くなかったし、幸い子供も帰りたがらないので、その儘預け切りになっているのだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを黄金の杖で繋ぎ、向かい合って延々と立っているのが、女方術師の華子である。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ両刀を投げ出して了ったら却って延々とするかもしれない。",
              "citation": {
                "source": "稚子法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思わなければならない程、延々と長く引かれている。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「延々と三千キロに近いあの大城壁です。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原の中に逆もぎつきの木柵（針金つき）が延々と連って居る。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は神の御恵に浴し得た霊の輝きだとか何とか云って居たけれ共、主婦や老人は延々としたお久美さんの体を頼もしそうに眺めながら、「好い娘さんになりましたねえ。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッハッハ」　と、自分だけ逆上しなかったようなことを云っているが、なんと石川淳は菅原をひきつれ、十分ぐらいで到着できる来ノ宮駅へも、二十分ぐらいで到着できる熱海駅へも向わずに、ただヤミクモに風下へのがれ、延々二里の闇路を走って、多賀まで落ちのびたのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟達の技たる残虐行為を延々聞かされて誇りを持てる者などいません。",
              "citation": {
                "source": "日本の全ての方々へ",
                "author": "マハトマ・ガンジー　Mahatma Gandhi",
                "note": "青空文庫"
              }
            },
            {
              "text": "延々長蛇の如き入場者の列。",
              "citation": {
                "source": "喧嘩上手",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士額、地蔵眉、墨を塗ったのではあるまいかと、疑われるほどに濃い睫毛で、下眼瞼を色づけたまま、閉ざされている切長の眼、延々とした高い鼻、蒼褪め窶れてはいたけれど、なお処女としての美しさを持った、そういう顔が猿轡で、口を蔽われているのであった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平家は、北の山際から南の海の遠浅まで、大石を積み上げ、大木を伐って逆茂木を延々と連ねた上に、海が深いので、ここに大船を並べて楯とした。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りには頼朝からの土産物が、延々と続いた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "meandering",
        "register": "standard",
