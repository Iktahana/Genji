[
  {
    "uuid": "3f66770e-9629-5ddc-89de-ff9106f7565d",
    "entry": "延々",
    "reading": {
      "primary": "えんえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞-と",
