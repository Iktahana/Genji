        "examples": {
          "standard": [
            {
              "text": "古い建物の「営繕」は、計画的に進める必要があります。劣化が進む前に手を打っておきましょう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域では、歴史的建造物の「営繕」を手がける専門業者に依頼するのが一般的です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地元の町内会では、公園の遊具の「営繕」費用を募っています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝統建築の「営繕」には、特殊な技術と材料が求められます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "矛盾のようであるが、父の係りは営繕課であった。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿衛子の父は彦根藩主井伊家の臣で小沢一政といい陸軍の営繕部に勤務していた。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿衛子の父は彦根藩主井伊家の臣で小沢一政といい、陸軍の営繕部に勤務していた。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学を出たばかりで勤めた文部省の営繕課をやめたいばかりに、若い旧藩主のお伴のような立場でイギリスへ行った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作事奉行は建築営繕のいっさいを管掌する、城館、寺社の修復、表座敷から台所に至る諸｜什器調度の修繕、掃除、検査など、事務は複雑多岐にわたっているが、主馬は職を継いで一年と経たぬうちに、その適任であることを証拠だてた。",
              "citation": {
                "source": "山椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
