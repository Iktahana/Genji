    "definitions": [
      {
        "index": 1,
        "gloss": "evacuating to the homes of one's relatives in the countryside in wartime",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "戦争中は、多くの子供たちが地方の縁故者の元へ縁故疎開した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母は子供の頃、空襲を避けるために親戚の家に縁故疎開したと話していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "縁故疎開先の生活は慣れないことばかりで、辛い思いもしたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "当時の記録によると、縁故疎開で地方に移った家族は数万世帯に上る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "聴けば他アやんは頼っていく縁故先が無いわけでもなかったが、縁故疎開も集団疎開もしようとせず、一家四人、焼け残った防空壕の中で生活しているのである。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁故疎開をショーレイしている。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
