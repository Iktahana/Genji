        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の演奏は若かりし頃の勢いに加え、円熟した深みを増している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "旬を迎えた果物は、まさに円熟の極みで、甘みが口いっぱいに広がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の経験を経て、彼のリーダーシップは円熟の域に達した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "文楽は学生時代にいちど見たきりで、ほとんど十年振りだったものですから、れいの栄三、文五郎たちが、その十年間に於いて、さらに驚嘆すべき程の円熟を芸の上に加えたであろうと大いに期待して出かけたわけですが、拝見するに少しも違っていない。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また渋味は、自然界にあっては不熟の味である場合が多いが、精神界にあってはしばしば円熟した趣味である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦はその晩年、その思想いよいよ円熟するに従て全く菜食主義者ではなかったようである。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばだね」　と、小田は新しい煙草に火をつけて、「――林檎は実が円熟して地に落ちる時が一番うまいんだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三巻　この巻には、井伏さんの所謂円熟の、悠々たる筆致の作品三つを集めてみた。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽は午後の円熟した光を一雫のおしみもなく、その旺溢した黄金色の全幅にそそぎかけている。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして少し気の狂った病的な円熟が中年の美女のいろ艶を一層凄艶にして居た。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は武田さんの小説家としての円熟を感じた。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて無上の面目を施した翁は四月六日東京出立、同二十七日無事帰県したが、この時の上京を前後として翁の芸風が漸く円熟期に入ったものではないかと思われる理由がある。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理にそんな声を出しているとしか思えぬ、しわがれた悩ましい声は、なにもかも知りつくしたような円熟した女の底の深さを囁いて、佐古の好奇心を刺戟した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢野は嫉妬の素振りも見せぬほど円熟していた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人形つかひ」では、現代の娘とは似ても似つかぬ内気な娘が、そつと覗きこんでゐるし「花ざかり」では婚期の円熟した娘であらうが、尚母親の後にしがみついて、美しい羞恥を示してゐる、さういふ情景や、情趣は現代では全く見ることが不可能である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "その思想と伎倆の最も円熟した時、後代に捧ぐべき代表的傑作として、ハムレットを捕えたシェクスピアは、人の心の裏表を見知る詩人としての資格を立派に成就した人である。",
              "citation": {
                "source": "二つの道",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同の物腰態度は稍円熟の境に達して、脚どりと云ひ、咳払ひの具合と云ひ、道往く人に出遇つた時の、何気ない挨拶を交して素知らぬ風を装ふ話振りと云ひ、凡そもう何処にも怯えた気色のない堂々たるロビンフツドの徒党であつた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の家を出て他所へ「往く」その時のこころもちと、わが家へ「還る」その気もち、真理を求めて往くそのすがたと、真理を把み得て還るその姿、若々しい青年の釈尊と、円熟した晩年の釈尊、私はこの『華厳経』と『法華経』を手にするたびに、いつもそうした感じをまざまざと味わうのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "円熟した内面生活の全幅がこの期間に披瀝されたと思う。",
              "citation": {
                "source": "漱石の「行人」について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、このことは、小林秀雄氏が何処かで云っているように、単に既成作家、評論家が今の調子をつづけて円熟し、ものわかりよくなった結果として、年齢とともに期待し得るというような実質を意味するものではないと思う。",
              "citation": {
                "source": "文学の大衆化論について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古伽藍と剥げた額、化銀杏と動かぬ松、錯落と列ぶ石塔――死したる人の名を彫む死したる石塔と、花のような佳人とが融和して一団の気と流れて円熟｜無礙の一種の感動を余の神経に伝えたのである。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水晶幻想」時代には近代のブルジョア・インテリゲンチアらしく、科学知識への興味を自慰的に示していた川端康成は、次第に円熟し、東洋人らしくなり、仏典をいじり、霊の輝きへの信仰によって高められ、微妙な美の創造者になったかのようである。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも年とともに円熟することでしょう。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "野枝さんの場合におけるが如き蕪雑にして不自然なものではなく、僕の思想や感情がようやく円熟しかけてきてからの恋愛なのだから、遙かに高貴でもあり純一でもある。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当な年で円熟しているというばかりでもない。",
              "citation": {
                "source": "『暦』とその作者",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この遺歌集の最後の二首は、また氏の最後のものらしく円熟した透明な名残りをとどめている。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "円熟しないまゝで途方に暮れて、そこらを引つかきまはしてゐるのさ……。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歎くが如く喜ぶが如く甚だ単純でない所が晶子さんの開拓した明治抒情詩の新境地であるが、それ許りではない、この歌は調子もよくそつもなくこの時代の作としてはよく出来て居て、円熟した後年の風が既に見えてゐる。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌の如きは勿論近年の円熟した高雅な調べから見れば大したものではないが晶子さん以前には誰も示し得なかつた「張り」を示してゐる。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
