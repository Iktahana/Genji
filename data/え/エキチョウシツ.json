        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "切符を紛失したことを告げると、改札横の駅長室へ案内された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「失礼します」緊張しながら駅長室のドアを叩き、一日体験の挨拶をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "駅長室の壁には、開通当時の古い写真や歴代の記念切符が飾られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私は駅長室へ往って汽車のことをしらべた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラタール氏は駅長室に案内された。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがカラタール氏が駅長室から出て行ったのと、ほとんど入替に、ホレース・ムーアと名のる一見軍人風の紳士が慌ててそこへ入って来た。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ちに彼は、数名の部下を督励して本屋の駅長室へ馳けつけて行った。",
              "citation": {
                "source": "気狂い機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体駅長さんはその土地、土地のいろいろな状況に通じた人であって、駅に下車するといつも駅長室で私はそれぞれの駅長さんに逢って、いろいろと案内してもらうのであった。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、やがて汽車が着くと、人々はみんな駅長室の方へ行きだした。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "こなひだも荷物を送出すのに儂はいきなり駅長室へ掛合に行つた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の中折に黒マントの日に焼けた男がタッタ一人駅長室の前に立っている。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本刀を吊して出入する将校達のいからした肩、興奮した眼の光、昨日新しく大連本社から急派されたと云ふ鉄道部員達のただならぬ動作、それに私達の休憩した駅長室は臨時軍司令部にさへなつてゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い間通っているものと見えて、駅長とは特別懇意でよく駅長室へ来ては巻煙草を燻べながら、高らかに外国語のことなどを語り合うているのを聞いた。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車が停車しない前に、専務車掌の倉内銀次郎はヒラリとプラットホームに飛び降り、駅長室に馳けこむなり、医者と警視庁とに電話をかけた。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は身仕度をして立ちあがる、駅長殿ものそのそあとから山を下りる、発車は午後二時四十分、それまで閑そうな駅長室に、煙草をふかしながら座りこむ。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅長室の前まで来ると、その扉に中隊長室と書いた紙片が貼りつけてあった。",
              "citation": {
                "source": "群集",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――駅長室につれこむ。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっしょに来るべきはずでつい乗り後れた東洋城の電報を汽車中で受け取って、その意のごとくに御殿場で一時間ほど待ち合せていた間に、余は不用になった一枚の切符代を割り戻して貰うために、駅長室へ這入って行った。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今頃は、東京駅の駅長室で、輸血かなんかやられてるだらう」「もうたくさんよ……」　と、彼女は、つひに顔をそむけた。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――駅長室つていふのは何処かしら？",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "人波をかき分けて、彼女は駅長室へ飛びこむ。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "スミ、お若の見詰めてゐる方を見ると、駅長室らしい所に刑事と青年が居るのが硝子戸越しに見える。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お若と駅長室の二人とをキヨロキヨロ見くらべてゐる旅商人。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅商人「いえさ、あれがよ」　スミ、駅長室を見る。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その声に、駅長室を見詰めてゐた土方がお若を見る。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りがけ、駅に寄ると、駅長室にきて話をしていきなさいという。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言って、すぐ駅長室の方に行ったが、間もなくまたやって来て、待合室をぶらぶらしながら、時計ばかり見ていた。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はちょっと困ったような顔をして俊亮の方を見たが、そのまま、その男といっしょに駅長室の方に行った。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "改札がはじまった頃、朝倉先生はやっと駅長室から帰って来た。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい、よんどころのないことで駅長室に行っていたものですから、ごあいさつがおくれまして。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅長が一通の電報を手にして、駅長室から出て来、あわただしく憲兵の方へ進んでいった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見定めると、私は大急ぎで、Ｍ駅へと引返し（半里の山路ですからそれには十分三十分以上を費しました）そこの駅長室へ這入って行って「大変です」とさも慌てた調子で叫んだものです。",
              "citation": {
                "source": "赤い部屋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
