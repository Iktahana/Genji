        "examples": {
          "standard": [
            {
              "text": "その女性はえんじ色のドレスを着て優雅に見えた。",
              "source": "幻辞"
            },
            {
              "text": "えんじ色は深みのある赤で、格式高いイメージを与える。",
              "source": "幻辞"
            },
            {
              "text": "このえんじ色の帯は帯締めになっています。",
              "source": "幻辞"
            },
            {
              "text": "冬の着物にはえんじ色が似合うという。",
              "source": "幻辞"
            },
            {
              "text": "えんじ色のカーペットが敷かれたホールは格調高かった。",
              "source": "幻辞"
            },
            {
              "text": "この染料はえんじ色に染めるのに最適だ。",
              "source": "幻辞"
            },
            {
              "text": "えんじ色の傘が雨の日の街を彩っている。",
              "source": "幻辞"
            },
            {
              "text": "その本のカバーはえんじ色で高級感があった。",
              "source": "幻辞"
            },
            {
              "text": "えんじ色は伝統的な日本の色合いとされている。",
              "source": "幻辞"
            },
            {
              "text": "襟のえんじ色の刺繍が目を引いていた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ニュウグランド・ホテルの前を通って、陽の眩ゆい草原の道を真直ぐに進みながら、小さい兄妹はえんじ色にうれた野苺を見つけて、わざと草深い中を歩きながら両手にあまるほど苺を摘んだ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、えんじ色と紺色のその風呂敷が、先生に似つかわしくないものだ、と思っていた。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "えんじ色、よく御似合いだわ」　仁科たか子は狼狽した。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古道具屋の店先に立ちどまった二人の人影、「叔父さん、あの人形にして下さいな、まあなんて可愛いんでしょう」　と言うのは、直ぐそばの百貨店の窓飾の中から飛出したような、可愛らしい女の子です、浅いえんじ色の外套に同じ色の帽子、いかにも健康らしい、身体中にバネが入っているよう。",
              "citation": {
                "source": "眠り人形",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく柱によりかかっていた素子は、やがて隣の部屋へゆき、きれいな、えんじ色にすきとおったパイプにたばこをつけ、それをくゆらしながら自分の机に向った。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "えんじ色のパーカー51のデミ・サイズに、ブルー・ブラックのインキを彼は使った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "片方の防波堤の突端には、濃いえんじ色の煉瓦でつくった、小さな夢のような灯台が立っている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
