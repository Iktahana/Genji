          "literary": [
            {
              "text": "ニコニコと親切な米人のエアガールが外套を預る。",
              "citation": {
                "source": "新春・日本の空を飛ぶ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キャプテンもエアガールも、親切。",
              "citation": {
                "source": "新春・日本の空を飛ぶ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "カクテル・パーテーがはじまる、エアガールがニコニコと往復多忙である。",
              "citation": {
                "source": "新春・日本の空を飛ぶ",
