        "examples": {
          "standard": [
            {
              "text": "子供の頃、窓の外を眺めながら、いつかエアガールになりたいと思っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お飲み物はいかがですか？」とエアガールが笑顔で尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ベテランのエアガールは、どんな状況でも冷静に対応する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔の映画では、エアガールが制服を着て活躍するシーンがよく描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ニコニコと親切な米人のエアガールが外套を預る。",
              "citation": {
                "source": "新春・日本の空を飛ぶ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キャプテンもエアガールも、親切。",
              "citation": {
                "source": "新春・日本の空を飛ぶ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "カクテル・パーテーがはじまる、エアガールがニコニコと往復多忙である。",
              "citation": {
                "source": "新春・日本の空を飛ぶ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
