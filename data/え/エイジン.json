        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ロンドンに住む友人は、生粋の英人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は旅行で訪れたロンドンで、親切な英人家族と交流した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その小説は、19世紀の英人生々しい様子を生き生きと描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "倫敦で始て興行せられた時、英人にも丸で分からなかったのです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから谷へおりる途中に、小さなタヴァンといったような家の前を通ったら、後ろから一人追っかけて来て、お前は日本人ではないかとききますから、そうだと答えたら、私は英人でウェストンというものだが、日本には八年間もいてあらゆる高山へ登り、富士へは六回登ったことがあると話しました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英人はホースナッツ・ツリーといっている。",
              "citation": {
                "source": "マロニエの花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮肉好きの英人の見物は羊皮製の顔に血の気を浮べて頷き合ふ。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "入學早々、ブルウル氏といふ英人の教師が、What is Real Happiness? といふことについて生徒へその所信を書くやう命じたのである。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "入学早々、ブルウル氏という英人の教師が、What is Real Happiness? ということについて生徒へその所信を書くように命じたのである。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかに旧劇場で案内係をして居た一人の娘の親が英人の娘として米人の使用人に変ることは英国の不節操であると同時に米国への屈従であると云って断然許さなかった。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ曾つて英人なる宣教師某と相携へて花を艶陽の中ばに観る。",
              "citation": {
                "source": "漫言一則",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら実際的の国民なる英人に取りては、兎ても花の下に終日浮かれぞめくの興を貪ることは覚束なしと。",
              "citation": {
                "source": "漫言一則",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎに牧師がメソポタミヤから受取つたのは、或英人の病院の医者がよこしたもので、はッと思つたとほり、つまり、ウ※ルターの死去のしらせでした。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二週間前に、丁度一人のアラビア人の婦人が、その夫だといふ英人の一患者を、当病院につれて来ました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は、アピアの一英人の言葉である。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、マオリ人に英人と同等の政治上の権力を与え、土人代議士の選出を認めた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ギボンと云はれても、私にはあの浩瀚なローマ衰亡史の著者しか思ひ當らないのだが、よく聞くと、パラオでは相當に名の聞えたインテリ混血兒（英人と土民との）で、獨領時代に民俗學者クレエマア教授が調査に來てゐた間も、ずつと通譯として使はれてゐた男だといふ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ギボンといわれても、私にはあの浩瀚なローマ衰亡史の著者しか思い当らないのだが、よく聞くと、パラオでは相当に名の聞えたインテリ混血児（英人と土民との）で、独領時代に民俗学者クレエマア教授が調査に来ていた間も、ずっと通訳として使われていた男だという。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜から乗って来た英人のＣがオランダの女優のいちばん若く美しいのと踊っていた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　昭和九年の秋英人スコットの乗った飛行機が英国と濠州メルボルンとの間をたった七十一時間で飛び渡った。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馭者の語るを聞けば、この英人は伊太利に來てより十日あまりなるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等は凝息して行くほどに、一英人の導者と共に歸り來るに逢ひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠、汝等の間に英人ありやと問ふに、われ、無しと答ふれば、一聲｜畜生と叫びて過ぎぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡目八目で言いたいままの放語と思えど、久しく本邦に在留せし英人が、木戸、後藤諸氏草創の難に思い比べて、禁ぜんとして禁じ得ざる激語と見えたり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "英人リチャード・コックス『江戸日本日記』一六二二年（元和八年）二月二十一日の条、コックス江戸にあり芝居に之く途上オランダ館に入り肥後か肥前の王に邂逅す、武勇な若い人で年々五十万石を領す、今蘭人に事え居る僕一人、先にかの王に事えた縁によりオランダ館を訪ねたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーナーヴォン卿その株を睹由来を聴いて、英人なら謝恩のためこの樹を保存すべきに葡人はこれを伐った、所｜異れば品異るも甚だし、以後ここの人がどんな難に遇うを見ても我は救わじ、救うて御礼に殺されちゃ詰まらぬと評したとある。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍動の西南區に英人を妻とし棲み、子有りと也」と有り。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れ英人の理想を謳ひしもの、而して提督ネルソンは最も善く此理想を代表せし人なり、彼はシヱクスピヤの如き宇宙的人物にあらず、彼にクロムウエルの如き深遠なる宗教的観念ありしを見ず、彼は忠実なる英国の子供にして彼の単一の目的は英国の利益と栄光とにありき、偉大なる彼は特別に英国人の専有物なり。",
              "citation": {
                "source": "ネルソン伝に序す",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョン・バンヤンの作たる The Life and Death of Mr. Badman（悪人氏の生死）は、ある意味において『天路歴程』以上の傑作であると思われるが、英人自身は余りこの書を貴まないのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "英人の女教師が、イギリスにお帰りの時、十九の私にこうおっしゃったのを覚えています。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ノ國防上朝鮮ヲ獨立セシメズト云フコトハ、英人ガ印度ヲ獨立セシメズ又亞佛利加植民地ヲ獨立セシメズト云フコトトハ全ク別事ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度又ハ亞佛利加ノ住民ガ全然英人ト人種ヲ異ニセルニ對シテ、日鮮人ハ古來ノ混血融合ノミナラズ同一人種中ノ最モ近キ異民族ナル點ニ於テ屬邦タルベカラズ又植民地タルベカラズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
