        "examples": {
          "standard": [
            {
              "text": "ユーロが導入される以前、EC加盟国の間ではエキューという共通の計算単位が使われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おじいちゃんの古い教科書に『エキュー』って書いてあるけど、これ昔のお金なの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "当時の経済ニュースでは、ドルや円に対するエキューの交換レートが日々報じられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "馬と馬車とをいっしょにすれば百エキュー（訳者注　五百フランに当る）の価はあったのである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は年に五十エキュー（二百五十フラン）で、三つの室と、籬で囲まれ井戸のついてる一つの庭を得たのである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "千エキュー（五千フラン）なら申し分ありませんが。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
