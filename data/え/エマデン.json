        "examples": {
          "standard": [
            {
              "text": "その神社の境内には、立派な絵馬殿が建てられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雨が降ってきたので、絵馬殿の下で小休止した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多くの参拝者が絵馬殿に願い事を書いた絵馬を奉納していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "絵馬殿の軒下には、色とりどりの絵馬がずらりと並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "丑寅神社の絵馬殿を建てるために境内の樹を伐ったのが、境界の不明のために、そうした事になったのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには舞殿があり絵馬殿があり回廊があるか。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
