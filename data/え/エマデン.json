          "literary": [
            {
              "text": "丑寅神社の絵馬殿を建てるために境内の樹を伐ったのが、境界の不明のために、そうした事になったのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには舞殿があり絵馬殿があり回廊があるか。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            }
