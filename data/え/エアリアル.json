        "examples": {
          "standard": [
            {
              "text": "冬季オリンピックで、フリースタイルスキーのエアリアル競技を観戦しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "女子選手が、見事な宙返り技を披露して観客を魅了しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの高難易度のエアリアルジャンプ、よく成功させたな！」と、解説者が興奮気味に叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "デロレーンのウィリアムは失神して、ゆがんで、彼女が彼の傷を擦りむくように、次に侍女に彼女は言った、彼は完全で健康になるだろうと、（iii編, xxiii.）　ドライデン（1631-1700）の「あらし」（V, 1）でエアリアル（空気の精）は言っている。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
        }
