[
  {
    "uuid": "1d312b52-fdcb-5d21-a940-4e59fae8de46",
    "entry": "延引",
    "reading": {
      "primary": "えんいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "delay",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "システムトラブルのため、ウェブサイトのリニューアル公開が数日延引することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "悪天候によるダイヤの乱れで、到着便が大幅に延引し、利用客は困惑した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の病気療養のため、プロジェクトの最終プレゼンテーションが来週に延引された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "仕事を一段落させてから、ゆっくりお礼やらお詫びやらを申し上げようと思って、きょうまで延引してしまいました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、九月の学期が始まる頃になっても、僕は上京を延引しなければならないことになった。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾たびか延引を申立てゝ、今まで打過ぎしは何たることぢや。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用うけたまはりて已に半年、未熟ながらも腕限り根かぎりに、夜晝となく打ちましても、意にかなふほどのもの一つも無く、更に打ち替へ作り替へて、心ならずも延引に延引をかさねましたる次第、なにとぞお察しくださりませ。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎　この上は唯だ延引とのみでは相濟むまい。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父衛侯の返辞は単なる遁辞で、実は、以前厄介になった晋国が煙たさ故の・故意の延引なのだから、欺されぬように、との使である。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父衞侯の返辭は單なる遁辭で、實は、以前厄介になつた晉國が煙たさ故の・故意の延引なのだから、欺されぬやうに、との使である。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御用人の御子息はその後御催促には見えませんか」「はい」「どうも思うように出来ないので甚だ延引、なんとも申し訳がありません」と、澹山は小鬢をかいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "申し訳のない延引と澹山があやまるように云うのを聴きながら、伝兵衛は少し考えていたらしいが、やがてやはり小声で云い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの事情に妨げられて、今まで身請けを延引していたのであったが、こうなると知ったらば半年まえに思い切って身請けをしてしまった方が優しであった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は逢って懇意になって置きたいと思っていたんだが、いろいろ野暮な用があったので、きょうまで延引してまことに済まなかった。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついそのままに延引していたが、親の子煩悩が仇となって、あたら花盛りをやみやみと過ごさするもまた本意でない。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、攻撃の令は容易に下らないのみか、御所の使番が三騎、白馬を飛ばして、諸陣の間を駆け回りながら、「義直、頼宣の両卿を、とりかわせ給うにより、先手｜軍を始めることしばらく延引し、馬をば一、二町も退け、人々馬より下り、槍を手にし重ねての命を待つべし」と、触れ渡った。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "事情は外にもあったでしょうが、重なる原因は、宿の小さい娘が眼病を煩っていましたのを気の毒に思って、早く病院に入れて治療するようにと親に頼みましたが、宿の主人は唯はいはいとばかり云って延引していましたので『珍らしい不人情者、親の心ありません』と云って、大層怒ってそこを出たのでした。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが面体を後のかたみに残さんと、さきにその方を召し出し、頼家に似せたる面を作れと、絵姿までも遣わしておいたるに、日を経るも出来せず、幾たびか延引を申し立てて、今まで打ち過ぎしは何たることじゃ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用うけたまわりてすでに半年、未熟ながらも腕限り根かぎりに、夜昼となく打ちましても、意にかなうほどのもの一つもなく、さらに打ち替え作り替えて、心ならずも延引に延引をかさねましたる次第、なにとぞお察しくださりませ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎　この上はただ延引とのみで相済むまい。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって判決の先例がないので、奉行所でもその処分に苦しんで、その七月まで落着延引しているうちに、賊は七月八日に牢死した。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "月日は能く覚えていないが、今年になってから、同君が出版延引した言訳を、金城朝永君を通して私に伝言した後約一時間にして、執務中急死されたとの悲報に接した時、少からず驚かされた。",
              "citation": {
                "source": "「古琉球」改版に際して",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は忠通にもかねてその下心があったのであるが、自分の傍を手放すのが惜しさに、自然｜延引して今日まで打ち過ぎていたのである。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は忠通にもかねてその下心があったのであるが、自分の傍を手放すのが惜しさに、自然延引して今日まで打ち過ぎていたのである。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速お悔みに出る筈でございましたが、かぜを引いて小半月も寝込んでしまいまして、ついつい延引いたしました」　用意して来た線香の箱に香奠の紙包みを添えて出すと、女房は嬉しそうに、気の毒そうに受け取って、これも丁寧に礼を述べた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そのため、シンガポールの市場が恐慌し、材木が停止し、嫁探しまで延引しなければならぬ結果になろうとは――。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……午後、延引の手紙を二通認めて、またポストまで。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は明日はと思いながら、つい延引になってしまった。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
