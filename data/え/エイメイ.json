    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fame",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "若くして異例の出世を遂げた彼は、政界にその英名を轟かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「君の英名はかねがね伺っております。お会いできて光栄です」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一代で巨大財閥を築き上げた創業者の英名は、今なお色褪せることがない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "家康は海道一の弓取として英名伝播して居り、且秀吉よりは其位置が政宗に近かったから、政宗もおよそ其様子合を合点して居たことだろう。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "猴の今一つの英名エープは、梵名カピから出たギリシア名ケフォス、ラテン名ケブス等のケをエと訛って生じたとも、また古英語で猴をアパ、これ蘭名アープ、古ドイツ名アフォ等と斉しく猴の鳴き声より出たともいう。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に支那訳経の飛狸、著翅狸はコルゴの英名フライイング・キャット、飛猫に合う。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "英名ファウルは独語フォーゲル、デンマーク語フューグルと等しくもと鳥の義だったが、今はシー・ファウル、ウォーターファウル（海鳥、水鳥）等の複名のほか、単にファウルといえば雌雄鶏を兼称する事となりいる（『大英百科全書』十巻七六〇頁）。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏語で雌雄鶏を併称してプール、雛はプーレ、これより出た英名パシルトリーは肉食採卵のため飼った鳥類の総称で鶏、七面鳥、鵝、家鴨、皆その内だ（同二二巻二一三頁）、伊語で雄鶏をガロ、雌鶏をガリナ、西語で雄ガヨ、雌ガイナ、露語で雄ペツーフ、雌クリツァなど欧州では雌雄別名が多い。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムシトリナデシコ、英名キャッチ・フライ（蝿取）、その茎に粘液を出し蝿がとまると脱さぬ。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "この凱旋の将軍、英名｜嚇々たる偉人を拝見するために飛び上がるのは滑稽ではあるまい。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "後人｜碑を建て之に銘するは其心｜素より其の英名を不朽に傳へんとするにあり。",
              "citation": {
                "source": "人生終に奈何",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの新春から故グレエ子爵の『二十五年回想記』と『フアロドン雑講』を読んでゐるが、この大戦中の英名外相がその政治的活躍の背景として様々な楽しみ乃至趣味を有つてゐたのに驚く。",
              "citation": {
                "source": "趣味としての読書",
                "author": "平田禿木",
                "note": "青空文庫"
              }
            },
            {
              "text": "半世英名絶衆芬、老余凋落没奇勲、拿翁一夢当年跡、空作極南孤島雲。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし牛込の兵二郎はあまりにも有名で、平次もその英名を聴かないわけに行きません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "笛吹兵二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大蘇芳年の傑作「英名二十八人衆句」は斯うして出来上りました。",
              "citation": {
                "source": "芳年写生帖",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くも胸裏に煩ひて思に惱むアキリュウス、　15その傍に走り來て英名しるき＊ネスト，ルの子は熱涙を流しつつ彼に凶變告げて曰ふ、『ああ無慘なり！",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "曹操の英名は、同時に、四方へ鳴りひびいた。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "曠世の英名をあげて、同時に一代の大計をさだめる今を、むなしく逸してはいけません。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご辺も近来｜赫々と英名を成す。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "English name (of a plant, animal, organization, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この高山植物の英名は『エーデルワイス』だが、和名では『ウスユキソウ』と呼ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ねえ、この魚の英名ってなんて言うか知ってる？ 調べてみようよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "論文を執筆する際は、標準的な和名に併記して正確な英名を用いる必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、そのカクテルの名前、日本語だと分かりにくいけど英名を聞くと納得だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
    ],
