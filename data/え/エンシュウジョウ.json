        "examples": {
          "standard": [
            {
              "text": "山道を抜けると、目の前に広大な自衛隊の演習場が姿を現した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "演習場の入り口には「立ち入り禁止」の看板と頑丈なゲートが設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「明日は演習場で実射訓練があるから、周辺の登山道は通れないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "演習場の周囲を囲うフェンス沿いに、マニアたちがカメラを構えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "試作が出来上った岡部式の地下戦車第二号は、前回と同じく、某県下の演習場へ引出された。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人も知るように、教育の統制は日本に於ては極めて厳正であって、中でも小学校（乃至中学校）は模範的な統制演習場となっている。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争は弾道学、化学、行政、激しい運動、長距離大量殺戮、の演習場である。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
