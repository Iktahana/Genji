        "examples": {
          "standard": [
            {
              "text": "「このマニュアル、英日翻訳が不自然で全然意味が分からないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大学で英日通訳の講義を受け、情報の取捨選択の難しさを痛感した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は英日両言語に精通しており、国際会議のコーディネーターとして活躍している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "今朝も聞きましたが、横須賀軍港付近において、わが水兵が日本の少年の手によって殺害された大事件から、英日両国の間は急に悪くなり、いつどんな事が起るかもしれない様子だというではありませんか。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺めると独英日が別々に陣をとっている。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八六三年の日本輸出入総額のわずか二％しか占めてないフランスが英日関係危しとの報によってすぐさま（六三年太陽暦二月）軍艦を日本に向って出動させたのは、焼のまわったボナパルト政権のわるあがきによったのである。",
              "citation": {
                "source": "尊攘戦略史",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "同日午後七時、在英日本人およそ七、八十名、一同相会し、はるかに天皇陛下の万歳を祝し奉り、日本食の祝宴を開く。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
