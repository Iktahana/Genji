          ],
          "literary": [
            {
              "text": "エレベーターに初めて乗つたのも、その夏である。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイルランド人の経営しているホテル・グランド・オリエンタルは夜が更けるにしたがって人力車と馬車が交錯して万国旗の前でとまると各国の夜の女がボーイの腕に抱かれて、昇降するたびにアイオニアの音曲を奏するエレベーターに吸われていった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　エレベーター　百貨店のひどく込み合う時刻に、第一階の昇降機入り口におおぜい詰めかけて待っている。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、同じような考え方からすれば、結局ナポレオンも、レーニンも、ムソリニも、ヒトラーも、やはり一種のエレベーターのようなものかもしれないのである。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然その日の夕飯の膳で私たちはエレベーターの話をしていた。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六階から下りて、四階で沢山のお客がエレベーターに鮨詰めに入つてきたが、不幸な事に彼の二重マントが込み合ふ客の体に揉みあげられて、マントの袖がめくりあがり、其処から燦然として立像が現れた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗客は混乱に陥り、エレベーターの底を、ナポレオンの立像はゴロゴロと音をたてゝ走りまはり、人々の足がそれに触れると、人々は恐怖の叫びをあげて踏みつけながら、他人の足の間へ、この不快な迷惑な盗品を移さうとした。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "掏摸と監視人との格闘と乗客の苦しさうな叫びをのせて、エレベーター・ガールの気転は、監視人が完全に掏摸を捕へてからでなければドアを開けることをしなかつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、京子が大手町で降り、今井商事株式会社のあるビルディングに入り、そのエレベーターで胸を躍らせながら吊り上げられていたとき、すぐそれと並んだもう一つのエレベーターで、村川が倭文子と会うために、胸を躍らせながら吊り下げられていたのを、夢にも知らなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "五階で、エレベーターを降りると、そこにある図面で、今井商事会社の所在はすぐわかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エレベーターで、おすれ違いになったのでしょう。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "時、金、生活、享楽――即ち物資文明の産物たる東京のバラック、イルミネーション、エレベーター、店頭装飾、そのようなものの間を駈けめぐる電車、自転車、荷車、汽車、オートバイの響は砂煙を上げ、天地に轟きつつ、まだ気の弱い、生れ立ての職業婦人たちの神経を戦かした。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇岩突兀として聳つその頂上に近代のホテルを建て、更に岸石層の縦穴をくりぬき、しんしんとエレベーターで旅客を運ぶ計画ださうである。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレベーター、タクシー、無線、飛行機、その他これに類似する機械文明を構成するエレメントは、現代人の生活の中へ、しっかりと織り込まれてしまった。",
              "citation": {
                "source": "探偵小説の世界的流行",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、死体を発見した二人の証人がエレベーターの入口で行き違ったという男の行方を捜索すること、紛失した鞄の行方を捜すことなどもぜひとも必要ですね。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのエレベーターの入口で擦れ違った男ね。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもよく思い出せないんです」　二人はこんな会話を交わしながら、エレベーターで五階へ上がっていった。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "四階の空室というのは、エレベーターを降りたすぐ右側にある二十七号室だった。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「将校マントの男というのは、昨日あなたがたがエレベーターの出口で行き違った男らしいですね。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか、昨日も四階からエレベーターに乗ったはずでしたね」「あっ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、止ると、加藤は念入りに、音もなくエレベーターの扉を開けて、村瀬を促し出すと、自分はまた静かに降つて行つた。",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "不図昇つて行くエレベーターの中に記憶の鮮かな冬子の外套姿らしいのを見たので慌てゝ村瀬は階段を駆け登つた。",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら私は、九十人乗り、六十馬力、東洋一の大エレベーター――それほどのものを、乙女の身で、いとも朗らかに、（三十分宛の交代だから、別段疲れることもなく、寧ろ他の受持よりも愉快であるさうだ。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十馬力の大エレベーターは樫田の会社が拵へたのである。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、先程から質問の具合が何うも尋常ではないと思つてゐたんだが、お前も、昇つたり降りたりのエレベーター病にとり憑かれてゐるんぢやないか。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君、屋上へ行こう」　もう開店時間に間もないと見えて、どの売場でも何時の間にか出勤した大勢の店員や売子達が、商品の上に覆われた白｜更紗のシートを畳んだり、新しい商品を運んだりして忙しく立働いているのを、エレベーターの中から見渡しつつ間もなく私達は屋上へ出た。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エレベーターを降して頂戴な。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また荷物を携えている来訪者は、係員にエレベーターの下降を乞うのであった。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑車に綱を垂らし、綱に木製の箱を結び、これを釣籠仕掛で、部屋の中から人力で捲きあげるエレベーターである。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
