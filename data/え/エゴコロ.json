[
  {
    "uuid": "e012528d-191c-59ed-8d5f-be611a47a57e",
    "entry": "絵心",
    "reading": {
      "primary": "えごころ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "artistic taste",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「わあ、このスケッチ、色の使い方がすごくおしゃれ！やっぱり君は絵心があるね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "デザインのセンスはいいんだけど、肝心の絵心が致命的に欠けていて、ラフ画が誰にも伝わらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "美術館で名画を鑑賞しているうちに、自分の中にも眠っていた絵心が刺激されるのを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女の描くイラストには、技術を超えた独特の絵心が宿っていて、見る人を惹きつける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "けれども、このロココ料理には、よほど絵心が必要だ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵心のある北田は画をひきうつして売ることもある。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小児の時から見習いで絵心があったので、ノオトブックへ鉛筆で、まず、その最初の眉間割を描いたのがはじまりで。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵心の深かった夫人は、早速筆をとって窓の影そのままを一気に墨に染めた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵心のないものに彫りはできないのであるから、絵筆絵の具に不思議はないが、束にしておいてある扇子がいかにも不審なのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼつぼつ散点している家を見ると、絵のかけない人間にでもちょっと絵心がおこるものであるが、ホームズは、家屋が孤立しているということ、孤立した家屋は犯罪に適するということを考えるのである。",
              "citation": {
                "source": "ホオムズの探偵法",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は初めにわたしを医師にしようという考えであったそうであるが、友人の医師の忠告で思い止まって、更にわたしを画家にしようと考えたが、何分にもわたしに絵心がないので、それもまたやめてしまって、ただ何がなしに小学から中学へ通わせて置いたのである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ではガスタンクも原爆名所の一つになってしまったがあのタンクがはじめて空に聳〔え〕立った頃は、子供の絵心を大きく煽った。",
              "citation": {
                "source": "広島の牧歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋になって病気もやや薄らぐ、今日は心持が善いという日、ふと机の上に活けてある秋海棠を見て居ると、何となく絵心が浮んで来たので、急に絵の具を出させて判紙｜展べて、いきなり秋海棠を写生した。",
              "citation": {
                "source": "画",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんのケーテがまた絵心をもっていた。",
              "citation": {
                "source": "ケーテ・コルヴィッツの画業",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "年をとった女に歌心、絵心、それでなければ信心がある方がいいこと等。",
              "citation": {
                "source": "金色の秋の暮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "義兄は絵心があったから、自分で模写したものなどもあった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵心のあった血統　私の絵の素質がどこからきたのかと言われれば、母方からと言えましょう。",
              "citation": {
                "source": "わが母を語る",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "母も絵心のある人でした。",
              "citation": {
                "source": "わが母を語る",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがちょっと絵心でもあるくらいのＭ君ですから、やはり芸術家の潔癖な心得だけは、心の片隅に持っていますから、勧めたくもない保険など他人へ強いてみたりする下等な行いはいかにも出来難いのでありました。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が私に絵心をつぎ込んだかと流行語で問うたなら、近松｜門左衛門がそうさせたといえば足りるであろう。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "その医者が、ちょっと竹に雀ぐらいの絵心はあった。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "この看板屋が又、絵心があるといふのか、袋小路のどん底の傾いて化け物の現れさうな碁席であつたが、白塗りに赤字でぬき、華車な書体で、美術倶楽部と間違へさうな看板だつた。",
              "citation": {
                "source": "古都",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　鍋井の『絵心』パラパラとみる。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはなにかといへば、たった一人の絵心のある小学校の先生が、なぜ、この小さな町の美観を左右するやうな装飾塔の製作に協力を求められなかったのか、といふ不審と不満とである。",
              "citation": {
                "source": "北海道の性格",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに自分でいうのも変だが、私は別に図を描く事を習ったわけではないが、生来絵心があって、自分で写生なども出来る。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれにも習わぬまったくの我流だが、あの幼かったころの絵心が復活したようで、なんとなく楽しい。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅ひとつになって圓朝は、この間内から貼りかえたいろいろさまざまの障子のような小障子のようなものへ、河岸の景色を、藪畳を、廓を、大広間を、侘住居を、野遠見を、浪幕を、かつて習い覚えた絵心をたよりに、次から次へと描き上げていった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分絵心も何も持ち合わせない私の力では、何のとりとめたお話もできないのが、大へんに残念でございます。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は絵心なんか薬にしたくもないんだからね」「しかし君には断れないぜ。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のように不器用で絵心がないと来ていれば何うも仕様があるまい」「兎に角しっかりやってくれ給え。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪子はふと、母もなく我執の父の下に育つて、情のしこつた弟息子の親への甘えごころが、兄へかうも変つた形を採つて現はれるのではないかと気がついた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "desire to paint",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅先の美しい夕焼けを眺めていたら、十数年ぶりに絵心がムズムズと湧いてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "道具を一式買い揃えたまでは良かったが、いざとなると絵心が全く起きなくて放置している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おっ、珍しい。急に絵心が出たの？」と、スケッチブックを広げた僕を見て妻が笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日々の忙しさに追われ、ゆっくりキャンバスに向かうような絵心はどこかへ消え去ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
