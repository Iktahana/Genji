          ],
          "literary": [
            {
              "text": "もう閻魔帳を取り出しましたな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう社会を困らせるようになって、その筋の閻魔帳に割り込む。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はは、いつもの閻魔帳が出ましたね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はは、あなたの閻魔帳がもう出る頃だと思っていましたよ」　老人は婆やを呼んでランプをつけさせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "円味を帯びた柔かな声で流暢にリーダーを読み了った先生は、黒い閻魔帳をひらいて、鉛筆でそっと名列の上をさぐっている。",
              "citation": {
                "source": "冬日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、正直、氣どりなしに、あなたの閻魔帳の黒丸に値する「わかりません」を以て應ずる外はありません。",
              "citation": {
                "source": "好惡の論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生方の閻魔帳に記されたぼくの氏名には、赤い△印がついたのである。",
              "citation": {
                "source": "私の青年時代",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雲霧閻魔帳」週刊朝日・新春号。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
