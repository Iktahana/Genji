    "definitions": [
      {
        "index": 1,
        "gloss": "management information system",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "当社の売上データを統合管理するために、新しいＭＩＳの導入を決定しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ＭＩＳから出力された週次レポートを見て、生産ラインのボトルネックを特定できた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "顧客からの問い合わせ履歴をＭＩＳで管理することで、よりパーソナライズされたサービス提供が可能になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そりゃこのオレも、大組織の運営効率を高めるＭＩＳ部門のエリートにでも収まっているのなら、システム本位で物事を考えるかも知れない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "不況も加わってＭＩＳ部門に予算圧縮の圧力がかかり、メインフレーム中心のメーカーは従来のスタイルは通らないと白旗を上げた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレが何をほざこうと、あんたたちはＭＩＳ予算の分捕り合いに血道を上げるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＩＳＳ・イングリード！",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはＭＩＳＳ・キャゼリンを御存知なかったのですか？",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＩＳＳ・キャゼリンはすなわちその時にジャヴェリと応接間で話をしていたあの美装の貴婦人なのであった。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が万平ホテルで逢った時がＭＩＳＳ・キャゼリンが日本へ来て初めての太子訪問の時。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まったく今ではＭＩＳＳ・キャゼリンの心は殿下のことで一杯なのでしょう。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし殿下にさえその気がおありになるのならば、かえってＭＩＳＳ・キャゼリンとでも御結婚になることが対英関係上にも殿下御一身上にも好都合ではないかと思われるのですが、肝心の殿下が、身震いするほど厭い抜いておられるのですからてんで問題にはならないのです。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体以上のような事柄が思案にあまったこの人々をして私のところへ頼みに来させたわけなのであったが、「もしその場合殿下御自身のお気持でキャゼリン嬢とでも仰言せられたようでしたら、私共の方では即刻ＭＩＳＳ・キャゼリンに働いてもらうことにするつもりですから！",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私には事情はよくもわかりませんが、昨晩カパディア氏から聞くところによれば、もしＭＩＳＳ・キャゼリンが引き受けさえすれば、そしてあなたさえ米国留学を御変更になってもっと日本にいたいと仰せになれば、大使館は条件付きで許可すると言っているそうではありませんか。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえＭＩＳＳ・キャゼリンはお嫌いでも一時の手段としてでもここをなんとか切り抜けてもう少し御滞在になるわけにはゆきませんか？",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＩＳＳ・キャゼリンから聞いたと言って！",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＭＩＳＳ・キャゼリンはそう考えているでしょう……それは大使館があの人にそう思わせているからです。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
