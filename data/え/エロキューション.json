        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の政治家としての成功は、優れたエロキューション能力によるところが大きい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アナウンスメントスクールでは、正確なエロキューションを学ぶことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女のエロキューションは完璧で、聞く人を惹きつける力があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "左翼劇の特徴だった呶号的エロキューションや、集団的演出法が、そのまま時局劇に採り入れられて、しかもそれが、その限りでは少しも不自然ではない。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "時にはエロキューションのやうな稽古もやつた。",
              "citation": {
                "source": "蓑田先生",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○俳優のほとんど残らずは、彼が自身のいかなる演技中にも決して示さないようなすぐれたアクションや、魅力的な表情や、味の深いエロキューションを日常の生活の中に豊富に持っているものである。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえどんなにリアルな舞台でももしも我々が映画に対するとまったく同一の態度でこれを見るならば、そこには自然なエロキューションなどは一つもないのに驚くだろう。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "○エロキューションの指導に関しても前二項とほぼ同様のことがいえる。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "言いかえれば、舞台の上でのエロキューションは頭に入れないで、単に、読む上の調子と云うものだけを重んじている。",
              "citation": {
                "source": "戯曲を書く私の心持",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の考えによれば――」　桃川燕之助は、咳一咳と云った調子で、少し古風なエロキューションで続けました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "第四次元の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蘭さんなるものは、そのもぬけの殻に向って、しきりにエロキューションの挑発を試みていらっしゃったに相違ない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蘭殿はいい気持で、もぬけの殻に向ってエロキューションを試みて、試み疲れてうとうとして、つい寝過ごし、枕一つを抱えて国越え――という時刻になっているに相違ない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "エロキューションを、充分みてやる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "新派の古老、僕のガラマサどんのエロキューションのモデル、大東鬼城が死んだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
