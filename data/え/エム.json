  {
    "uuid": "86a3e9cc-0475-5807-85b3-d18809899bfa",
    "entry": "Ｍ",
    "reading": {
      "primary": "エム",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "M",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の名前のイニシャルはMだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このTシャツのサイズはMでちょうどいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "M字開脚は柔軟性が要求されるポーズだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私は、その手紙の差出人のＭ・Ｔという男のひとを知っております。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ三十通ほどの手紙、全部がそのＭ・Ｔさんからのお手紙だったのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも手紙のおもてには、Ｍ・Ｔさんのお名前は書かれておりませぬ。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、そのＭ・Ｔという人は、用心深く、妹からお友達の名前をたくさん聞いて置いて、つぎつぎとその数ある名前を用いて手紙を寄こしていたのでございましょう。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹の苦しみを見かねて、私が、これから毎日、Ｍ・Ｔの筆蹟を真似て、妹の死ぬる日まで、手紙を書き、下手な和歌を、苦心してつくり、それから晩の六時には、こっそり塀の外へ出て、口笛吹こうと思っていたのです。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｊ・Ｍ・マリイという人は、ヨーロッパの一流の思想家の由であるが、その「キリスト伝」には、こと新しい発見も無い。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　私と同級生で特待生のＭが私の内に十二指腸で入院した。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆が、殊に祖母が私にＭと遊べと言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｍなんて、兎に角今の中学校なんかが猫のやうな善良さで押し通せる奴つたら、延膸が大脳の割合に発達してゐないで、大脳が一通り悪い意味のエゴイスチックな発達をした奴だ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな太平楽を言ふといで、今にＭさんは偉いもの、あんたは豆腐売になる。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は母や私の間の気色を見ると、「また何か何か、Ｍさんとでも遊んどれば文句はないぢやあないか。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と偶然父もＭのことを持ち出した。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝もＭのおつ父さんに会つたがね、あれはお前が入学当時の成績のことを思つて、あなたのお子さんはよくお出来でつて挨拶をしたが私は冷汗が出た。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｍはお前の成績の悪いことをおつ父さんに話さないのだらうか。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやＭの性質では案外そんなことを言はないかも知れませんよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｍが話さないでもおつ父さんが訊く。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その電柱の辺に、学生時代のクラスメートＴＭの家がある。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十年前にはよくＴＭと一緒に本郷、神田、下谷と連立って歩いた。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＭの家の前が加賀様の盲長屋である。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ・Ｋといふ人が、その前の頁に書いてゐます。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんないい人が、どうして死んだのだらう、と追悼記の一ばん前の頁をひらいて見ると、そこに、學院長Ｋ・Ｍといふ人の弔詞が在ります。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんど改造社から、井伏さんの作品集が出版せられるさうだが、それに就いて何か書け、と改造社のＭ君に言はれて、私は、たいへん困つたのである。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "事實、Ｍ君は、たいへんの苦勞をして私の家を搜し當て、汗を拭きながら、「何か一つ、井伏さんに就いて。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもＭ君は、遠路わざわざやつて來られて、私に書けと言ふのである。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ君の濶達な人徳も、私に斷る事を不可能にさせた一因らしいのである。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｊ・Ｍ・マリイといふ人は、ヨーロツパの一流の思想家の由であるが、その「キリスト傳」には、こと新しい發見も無い。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　Ａでも、Ｍでも、私でも、借家争議といふ事になると、いつも、このＮ君を留守番に頼んで、闘つてもらふのが常であつた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ署の高等係中村は、もう、蚊帳の外に腰を下して、扇子をバタバタ初めていた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時まで、三時から君を待ったが、来ないから、僕はＭ署へ持って行かれることにする。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
