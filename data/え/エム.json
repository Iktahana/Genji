[
  {
    "uuid": "309942da-3752-574c-8ba9-17dc65cc7386",
    "entry": "笑む",
    "reading": {
      "primary": "えむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to smile",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "赤ちゃんがこちらを見て、にこっと笑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は、懐かしい思い出に浸りながら静かに笑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "厳しい練習の末、コーチは選手たちの成長を見て満足げに笑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「チエツ、またこのまづい字か……」といふ程の意味で、それでもその文字がいかにもその女らしいことには、私は何時でも微笑むのである。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠は汝が眼の裡に微笑むでゐた……此の世を去つた炬火、空にて再びともれよ！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして狸は、ああ世の中なんて甘いもんだとほくそ笑む。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言つて、お婆さんは意地惡さうに微笑む。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又五六間行って三次ほくそ笑む。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしまがじろッと侍の方を凄い眼で睨んで、　独りほくそ笑む。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし二人は、兎をうつ時のように、微笑むような心持で、楽々と発射する訳には行かなかった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いま、ちらりと微笑むやうな、口元を漏るゝ歯は、白き卯の花の花片であつた。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――此方に斜くらゐな横顔で、鼻筋がスツとして、微笑むだやうな白歯が見えた。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて冥途とやらへ行って、いや、そこでもだまって微笑むのみ、誰にも言うな。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにわれは思う、女もし恋の光をその顔に受けて微笑む時は花のごとく輝く天津乙女とも見ゆれど、かの恋の光をその背にして逃げ惑うさまは世にこれほど醜きものあらじと、貴嬢はいかが思いたもうや。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁はただ微笑むのみ、何の言葉もなく青年を打ちまもりつ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて遠く高く微笑むやうな青空の一片が望まれた。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕭条たる秋風に鎗を立てて微笑む鹿之助の顔が眼に泛ぶのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　表に夫人の打微笑む、目も眉も鮮麗に、人丈に暗の中に描かれて、黒髪の輪郭が、細く円髷を劃って明い。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　というと、艶やかな歯でニヤリと笑む。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "上で見詰めたなり、何にも言わず、微笑むらしいお孝の唇、紅をさしたように美しい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人は黙って微笑むのみ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、むら雲一重、薄衣の晴れたように、嬉しそうに打微笑む、月の眉の気高さよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――小児らの中に出づ）まあ、いいお児ね、媛神様のお庭の掃除をして、どんなにお喜びだか知れません――姉さん……（寂く微笑む）あの、小母さんがね、ほんの心ばかりの御褒美をあげましょう。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　勇美子はこういって、猶予って四辺を見たが、手をその頬の辺へ齎らして唇を指に触れて、嫣然として微笑むと斉しく、指環を抜き取った。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とさりげなく打頬笑む。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と何やらつかぬことを言って、為方なしにお雪は微笑む。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "濡れた手を間近な柳の幹にかけて半身を出した、お品は與吉を見て微笑むだ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、ね、柳ちやん――柳ちやん――」　うつとりと、目を開いて、ハヤ色の褪せた唇に微笑むで頷いた。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とすくすくと鬚の生えた、山猫のような口を突出し、対手の耳に囁くと、伝九と呼ばれた一｜人は、歪めて聞いていた面に、もっての外な、ニヤリと笑む。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と火箸を取って品よく微笑む。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "齲齒笑は思はせぶりにて、微笑む時毎に齲齒の痛みに弱々と打顰む色を交へたるを云ふ。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "晃、お百合と二人、晃は、竜頭に頬杖つき、お百合は下に、水に裳をひいて、うしろに反らして手を支き、打仰いで、熟と顔を見合せ莞爾と笑む。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "河村の華著な肉体と美しい外貌さえむごたらしく閉ざされた。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
