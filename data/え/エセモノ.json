          ],
          "literary": [
            {
              "text": "それを、さうはせずに、一度引くり返して見た勇気には感心するが、そのため、すつかり、似非者になつて了つた。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "くそ勉強して、窮屈をしのんで、そんな似非者のお仲間入りは真っ平だ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――世の名利を、あさましいなどといって、隠者めかしておるその類の似非者は、世間往々あるものだ」　と、俊基は手きびしい。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "一　松島の松をそだてゝ見どすれば、松にからするちたのえせもの※○ちたは蔦。",
              "citation": {
                "source": "遠野物語",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
