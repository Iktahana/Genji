[
  {
    "uuid": "e5577210-5b7e-54d4-8374-76702ea697e6",
    "entry": "栄養不良",
    "reading": {
      "primary": "えいようふりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
