[
  {
    "uuid": "c167f320-517c-5f23-8164-9f10ffd80da9",
    "entry": "ええ加減",
    "reading": {
      "primary": "ええかげん",
      "alternatives": [
        "えーかげん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "irresponsible",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "部長は部下のええ加減な仕事ぶりに怒り、やり直しを命じた。",
              "source": "幻辞"
            },
            {
              "text": "いつもええ加減に宿題をやっている生徒は、成績が上がらない。",
              "source": "幻辞"
            },
            {
              "text": "企業のええ加減な安全管理体制は、労災を引き起こしてしまった。",
              "source": "幻辞"
            },
            {
              "text": "医者の診断がええ加減だと患者の不信感につながる。",
              "source": "幻辞"
            },
            {
              "text": "プロジェクト管理をええ加減にやると、納期に間に合わなくなる。",
              "source": "幻辞"
            },
            {
              "text": "子どもの教育にええ加減な親の姿勢は、後々問題を生じさせる。",
              "source": "幻辞"
            },
            {
              "text": "食材の管理がええ加減だと、食中毒の危険が高まる。",
              "source": "幻辞"
            },
            {
              "text": "この温泉はええ加減な温度で、リラックスするのに最適だ。",
              "source": "幻辞"
            },
            {
              "text": "お風呂のお湯がちょうどええ加減な温かさで、気持ちがいい。",
              "source": "幻辞"
            },
            {
              "text": "朝日が当たるここの環境はええ加減で、オフィスワークに向いている。",
              "source": "幻辞"
            },
            {
              "text": "会議の時間はええ加減に設定しないと、社員の効率が落ちる。",
              "source": "幻辞"
            },
            {
              "text": "指導方法がええ加減では、スポーツの上達が難しい。",
              "source": "幻辞"
            },
            {
              "text": "法律の解釈をええ加減にしてはいけない。",
              "source": "幻辞"
            },
            {
              "text": "音楽の練習にええ加減な態度では、演技レベルが向上しない。",
              "source": "幻辞"
            },
            {
              "text": "建築工事の品質管理がええ加減だと、建物の安全性が危ぶまれる。",
              "source": "幻辞"
            },
            {
              "text": "ここまでの進捗はええ加減なペースで、目標達成は難しそうだ。",
              "source": "幻辞"
            },
            {
              "text": "薬の用量をええ加減に決めると、治療効果が期待できない。",
              "source": "幻辞"
            },
            {
              "text": "顧客サービスにここまでのええ加減な対応をしては、クレームが増える。",
              "source": "幻辞"
            },
            {
              "text": "このスープはええ加減な塩加減で、とても美味しい。",
              "source": "幻辞"
            },
            {
              "text": "提案書の内容がええ加減だと、クライアントから信頼されない。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「早合点もええ加減にしろ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お祖父ちゃんももうええ歳や、ええ加減に隠居しなはれ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ加減におしやす」　長い体を持て余して、窮屈そうにゴロンゴロン寝ていた痩せぎすの女が、チマ子の笑い声に眉をひそめた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ加減、こったら腐りかけた臭いでもすべよ」　赤い臼のような頭をした漁夫が、一升｜瓶そのままで、酒を端のかけた茶碗に注いで、鯣をムシャムシャやりながら飲んでいた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴の事だからええ加減に聞いて、ろくに分っていない癖に、よしよし分ったなどと言って生呑込にしてしまう。",
              "citation": {
                "source": "正岡子規",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは僕の方がええ加減に合わして居ったので、それも苦痛なら止めたのだが、苦痛でもなかったから、まあ出来ていた。",
              "citation": {
                "source": "正岡子規",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ加減するだよ、ええ加減に。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜のお玉さんなんぞと違うて、モウええ加減な婆さんじゃからのう。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎晩十時すぎ、くたくたになって皆が帰ってくると、起るとから寝るまで白いエプロン姿の幾子が上り口に娘たちを出迎え、「大きに御苦労さま」と挨拶し、「さあさあ、お湯がええ加減ですよ」と云った。",
              "citation": {
                "source": "だるまや百貨店",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、ええ加減に離せ。",
              "citation": {
                "source": "不沈軍艦の見本",
                "author": "――金博士シリーズ・10――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ええ加減出発した方がましだよ。",
              "citation": {
                "source": "蕎麦の花の頃",
                "author": "李孝石",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼は、「ええ加減に止めるべし、な、豊坊。",
              "citation": {
                "source": "風に乗って来るコロポックル",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ぞ宿題あるのんやろ」「綴方があるねん」「そんなら遊ぶのんええ加減にして、書いときなさいや、帰ってから見たげるよってに」「姉ちゃん、こいちゃん、行ってらっしゃい」そう云って玄関まで送って来た悦子は、スリッパアのまま土間へ降りて、敷石の上を跳びながら門の際まで二人の叔母の跡を追って出た。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――電話ええ加減にして早よいらっしゃいて」「乗ってよか、雪姉ちゃん」と、妙子は扉に手をかけながら云ったが、そう云う礼儀は正しく守ることにしている雪子が、「待ってよう」と云ったきり応じないので、自分も仕方なく車の前に止った。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――いとせめて花見ごろもに花びらを　　　秘めておかまし春のなごりに二十「あんた、ええ加減にしときなさい、そない一遍に精出したら、しんどおまっせ」「そうかて、やり出したら止められへん。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫の方では私の性質に合わすように努めてるのんですやろけど、それがほんまに気持がぴちっと合うのんでのうて、こっちを子供扱いにして、ええ加減にあやしてるように思われますのんで、そういう態度が癪に触って仕方あれしません。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもやったら私が少しだだ捏ねたら、「しょうのない奴ッちゃなあ」いうて、ええ加減にあきらめてしまいますのんに、イヤにねちねち追窮して「うそついてもあかん、僕ちゃあんと清に聞いてるねん」いうて、絵エ書くためでないのん分ってる、一体何してるのんか、はっきり説明してみいいいます。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私よっぽど「誰に見られても男の人が附いて来るのんが一番わるい、三人だけやったらどないでも言訳立つよって、あんたええ加減に帰んなさい。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も番頭さんには事情を明かしたんやのうて、ただ必要な薬品だけもろて、それをええ加減に調合したのんで、間違うてたんかどうか、よんべ俄かにお腹痛なり出して、お医者さん呼んでる間にえらい出血した。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船場の店の出店やいうてもええし、あての家でいかなんだら、ええ加減な名アいうといたらえやないかいな」いいなさるのんです。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩御飯ごろまで遊んでると、「ええ加減に帰ってけえへんか」いうて夫からかかって来ることもある、――いう工合で、ほんまにお梅どん巧いこと考えてくれた思てましてん。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいでええ加減たった頃に、「実は今さっき奥様お見えになりまして、うっかりしてる間アにえらい事になりまして、……」とお梅どんから知らしてやる、この計略で時間計算してみましたら、家の者ら気イ付くまでに一時間半か二時間はかかる。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悦子が寝られへんよって、ええ加減にしなさい、あんまり精出したら肩凝らすで」「ふん、………今日じゅうに仕上げよう思うててんけど、………」「明日にしいな、そない稼がんかてええやないか」「うふふ」と、妙子は鼻の奥で笑って、「実はちょっとお金の欲しいことがあるねん」「お金ならあたしに云いなさい。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしは、仕事が好きじゃし、なんでも、ええ加減にすますことは嫌いじゃから、どんなつまらん仕事でも、一所懸命、やった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "親方の守りなんか、ええ加減で切りあげて、引きずって帰りゃ、ええのに……）　と、もっぱら、罪を親方になすりつけて、永田杢次を恨んだ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "（金さんも、あまり抗わずに、ええ加減にしとけばええのに……）　正しいと信じたことには、火が降って来ても、矢玉が飛んで来ても、避けようとしない親友の気質をよく知っていながら、新之助は、その融通のきかなさが、腹立たしくもあるのであった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えすいとる、味方か敵か、わかりゃせん」「選挙は水物――というけんど、ほんとに、ええ加減なもんじゃ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どっちへでもいい、ええかげんで連れてって呉れよ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、村の人びとは、かねやたいこを鳴らして、山や谷をさがして歩き、ついに、泉谷の泉の中で、ももひきを頭にかむってがつがつふるえながら、「これはええ湯じゃ、ええかげんじゃ」といっている一文商いやを見つけ出すことができたのでありました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええかげんで、早よ、やめんもんじゃけえ」　キヌは、もう、青くなっている。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
