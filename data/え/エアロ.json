        "examples": {
          "standard": [
            {
              "text": "毎朝、近所のスタジオでエアロのクラスに参加している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "音楽に合わせて体を動かすエアロは、ストレス解消にもってこいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最近、新しいエアロのプログラムが導入されて、会員の間で人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "地下にはスポーツ・ジムの一部分として、長距離を泳ぐ人たちや水中エアロビクスのためのプールがあった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は夕べ戻って来たばかりだが、今朝シティでばったりエアロン・フィリップスに会ったぜ」「まさか」「本当だ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エアロン・フィリップスだ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "天運が導いたか、はたまた偶然の一致か」第七章　過去　エアロン・フィリップスは顔に笑みらしきものを浮かべて立っていた。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがエアロン・フィリップスは狡猾な悪魔だし、昔の経験で稼ぎのうまみも知っている。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ、ある程度エアロン・フィリップスと連携しているから、悪事をたくらめば、察知できるかもしれない。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂を駆け下りていると、エアロン・フィリップスにばったり出会った。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　エアロン・フィリップスの顔が輝いた。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかで居場所を得たのがエアロン・フィリップスだ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも絶えず僕の相棒エアロン・フィリップスと接触していました。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたと衝突した南アフリカで、フィールデンはエアロン・フィリップスと組んでいたとか。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "知れば不安になるだろうが、妙な風にエアロン・フィリップスが本件に絡んでいる。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん南アフリカでの相棒がエアロン・フィリップスだと教えたと思う。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "エアロン・フィリップスを知っているかと訊く必要はあるまい、やぶ蛇だろうから。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "コプリは何回か事情聴取されたあと、仲間と裁判にかけられることになり、エアロン・フィリップスが被告人に対し、決定的な有罪証拠を突きつけた。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
