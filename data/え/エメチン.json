          ],
          "literary": [
            {
              "text": "それはエメチンといふ薬か、ヤトレンといふ薬か、どちらでもよいのださうです。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あみいばあ赤痢の特効薬、エメチン又はヤトレンといふのです。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし見つかつたらエメチンでもヤトレンでも、どちらでもよいから、至急お願ひしたいのです。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            }
          ]
        }
