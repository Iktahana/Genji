          ],
          "literary": [
            {
              "text": "射干にも似、菖蒲にも似たる葉のさま、燕子花に似たる花のかたち、取り出でゝ云ふべきものにもあらねど、さて捨てがたき風情あり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　土地の故参で年上でも、花菖蒲、燕子花、同じ流れの色である。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこン処は梅林で、上の山が桜の名所で、その下に桃谷というのがあって、谷間の小流には、菖蒲、燕子花が一杯咲く。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御歯黒蜻蛉が、鉄漿つけた女房の、微な夢の影らしく、ひらひらと一つ、葉ばかりの燕子花を伝って飛ぶのが、このあたりの御殿女中の逍遥した昔の幻を、寂しく描いて、都を出た日、遠く来た旅を思わせる。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の一隅、幽欝な鉛製の八つ橋の角々に、王朝時代の情熱を想はせる燕子花。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風情は一段で、汀には、所々、丈の低い燕子花の、紫の花に交つて、あち此方に又一｜輪づゝ、言交はしたやうに、白い花が交つて咲く……　あの中島は、簇つた卯の花で雪を被いで居るのです。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――柳の奧に、葉を掛けて、小さな葭簀張の茶店が見えて、横が街道、すぐに水田で、水田のへりの流にも、はら／＼燕子花が咲いて居ます。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度私の居た汀に、朽木のやうに成つて、沼に沈んで、裂目に燕子花の影が映し、破れた底を中空の雲の往來する小舟の形が見えました。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこン処は梅林で上の山が桜の名所で、其下に桃谷といふのがあつて、谷間の小流には、菖浦、燕子花が一杯咲く。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "某が刀は違棚の下なる刀掛に掛けあり、手近なる所には何物も無之故、折しも五月の事なれば、燕子花を活けありたる唐金の花瓶を掴みて受留め、飛びしざりて刀を取り、抜合せ、ただ一打に相役を討果たし候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕子あり曲折飛躍、試に其間にす。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "八畳のあつさりした室の一方は床になつて、草書の大字を書いた軸がかゝり、その前の置き花生けには燕子花のやうな草花がさしてあつた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御歯黒蜻蛉が、鉄漿つけた女房の、微な夢の影らしく、ひら／＼と一つ、葉ばかりの燕子花を伝つて飛ぶのが、此のあたり御殿女中の逍遙した昔の幻を、寂しく描いて、都を出た日、遠く来た旅を思はせる。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕子花さく八橋も、渡れば渡る渡りがね、そこへ後から追って来た、業平朝臣の狩衣や、オーイ、オーイと呼びかける」　一向意味がわからない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花はまだ季節が早いのか、燕子花や、赤い蝿取り草ぐらいしか咲いていない。",
              "citation": {
                "source": "浅間山麓",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽春二三月　　楊柳斉作花春風一夜入閨闥　楊花飄蕩落南家含情出戸脚無力　拾得楊花涙沾臆秋去春来双燕子　願銜楊花入　※裏　灯の下に横坐りになりながら、白花を恋した霊太后の詩を読んでいると、つくづく旅が恋しくなってきた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽春二三月　　　楊柳斉作花春風一夜入閨闥　楊花飄蕩落南家含情出戸脚無力　拾得楊花涙沾臆秋去春来双燕子　願銜楊花入※裏裏」はママ］　灯の下に横座りになりながら、白花を恋した霊太后の詩を読んでいると、つくづく旅が恋いしくなった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の詩的恋愛は未だに燕子花のやうに匂やかである。",
              "citation": {
                "source": "西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "保吉はばら銭を探りながら、「たけくらべ」、乙鳥口の風呂敷包み、燕子花、両国、鏑木清方、――その外いろいろのものを思ひ出した。",
              "citation": {
                "source": "あばばばば",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾斜地の砂に「たんぽぽ」や野生の「あやめ」が乱れて咲いてゐるのを見て、良人が支那名を問ふと、青年駅夫は「あやめ」を「燕子翼」（エンヅ井）、「たんぽぽ」を「婆婆丁」（ホホチン）と教へてくれた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あやめ」の花を形容して「燕子花」と云ふのは古代からの雅名で、日本にも知られてゐるが、「燕子翼」即ち燕の羽と云ふ方言は初めて聞くのであつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "広沢や一輪見ゆる燕子花　　　　　　　　蒼※涼しさや牛も根笹に繋がれて　　　　　　同若竹の葉につく月の光かな　　　　　　　同五月雨や忘れて居りし淡路嶋　　　　　　同　持って来る者が京は尋常です。",
              "citation": {
                "source": "俳句上の京と江戸",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川が一筋流れていて、燕子花の花が咲いていた。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、小枝は手を延ばしたが、長目に燕子花の花を折った。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "※メッカの礼拝堂に信者らの祈る時、帳の奥におわす御像の脚に捧げまつらん日の本の燕子花を。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんなも燕子花を取るがよいよ」　――すると侍女達も手を延ばして、各自燕子花を折った。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後庭には藤が咲きかけてい、池の畔の燕子花も、紫の蕾を破ろうとしていた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは初夏のことでありまして、河の両岸には名に高い、燕子花の花が咲いていました。",
              "citation": {
                "source": "真間の手古奈",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君がそんな猫冠りだとは思えんしね。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで×××の△△連隊から河までが十八町、そこから河向一里のあいだのお見送りが、隊の規則になっておるんでござえんして、士官さんが十八人おつき下さる。",
              "citation": {
                "source": "躯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
