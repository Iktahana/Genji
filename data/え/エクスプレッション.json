          "standard": [
            {
              "text": "彼女の表情（エクスプレッション）は、言葉にならない感情を雄弁に物語っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「そのアイデアを、もっと分かりやすいエクスプレッションで説明してくれませんか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この詩には、作者の深い孤独感のエクスプレッションが込められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "スレザークやヒュッシュやゲルハルトに比べると、エクスプレッションに乏しく、この歌の持っている魅力――あのシューベルトと仲のよかったショバアを、最初の一度で牽きつけたという不思議な魅力――に乏しい。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
