        "examples": {
          "standard": [
            {
              "text": "出張先のホテルで、毎朝ロビーに置かれた英字紙を読んで情報を集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国際情勢を知るために、彼は定期的に英字紙を購読している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カフェのテラスで英字紙を広げ、ゆっくりと朝食をとるのが休日の習慣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "僕は機密のことなんか一切しらぬのだが、講演会などで英字紙にあるようなことを話すのを、物知らぬ連中が「祕密」と考えて、そう報告するのだろう。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日の英字紙は第一面四段抜きで、この記事をのせ、「ランドル歴史的な実験に成功」と大見出しをかかげている。",
              "citation": {
                "source": "立春の卵",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
