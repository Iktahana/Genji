        "examples": {
          "standard": [
            {
              "text": "分詞構文の使い方でつまずいてしまい、もう一度英文法の参考書を読み返している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女の英語は流暢だが、細かい英文法のミスが目立つのが惜しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「英文法なんてパズルみたいなものだよ」と、塾の講師は笑いながら言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "“Hurrah!”「…………」　私も、脚を震はせて石欄に凭り、脚下の怒濤を見降ろしたのであるが――なるほどね、そんな言葉は、初歩英文法の Iterjection の項にだけ引かれる非実際的な模範語かとばかり思つてゐたんだが……なるほどね、云ふんだね、こんな場合に――Hurrah ……。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな迷信を信じよう、私は、彼女に依つて英文法の実地研究をしたことを、今だに面白く思ひつゞける……。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はあの英文法の Subjunctive といふ奴を頻りに考へさされます。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だが、僕はできるだけ気を鎮めるために、毎日きめて英文法の本を読んだ。",
              "citation": {
                "source": "飢ゑ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｅ氏という二十二、三にしか見えない教師は英文法の講義しながら、「僕の言っていることにどれだけ信用がおけるかは疑問である。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田先生から教へられたのは英文法と英文和譯、譯の教科書はアチック・フィロソファーとイナックアーデンとであつた。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "家で英文法でも見てゐた方がよかつた。",
              "citation": {
                "source": "受驗生の手記",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾何代数英文法に頭を悩まして以来二十有余年、皆四十面をさげている。",
              "citation": {
                "source": "母校復興",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
