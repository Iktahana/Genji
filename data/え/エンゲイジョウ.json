    "definitions": [
      {
        "index": 1,
        "gloss": "entertainment hall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「街角の小さな演芸場では、毎晩のように若手芸人が腕を磨いている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「地域のお祭りで、子供向けの演芸場が特設され、大変賑わっていた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「昔は、こうした演芸場から多くのスターが生まれていたものだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「その演芸場は、地元の文化を支える大切な場所となっている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "華族紳士連の発起にて、高等演芸場の目的にて建築されたるものなるが、のちには劇場同様となれり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわりを見ると、食堂の客はとっくに演芸場の方へ戻ってしまい、あからさまに照り下すシャンデリヤの下にはテーブルの白布の上に花差しの花がぬい／＼と眼立って立っているだけになっています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "教会は彼らにとって誠に楽しい倶楽部、ないし演芸場である。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝国ホテルの演芸場へ、お義理に引き受けた切符、日頃の交際の手前、ちょっとだけは顔出しをしなければならなかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は、驚いて階下に降りると、女中を促して、自動車の用意をさせて、帝国ホテル演芸場へと急がせた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "圭子達の今度の公演の場所は、帝国ホテルの演芸場であった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」美和子は、雀躍りして演芸場からは近い、ホテルのグリルへ駈けつけりた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の演芸場へたどりつくと、そこでは未だ花々しく戯曲「村道」の舞台ごしらへの最中で、未だ未だ宵のくちのやうな活気を呈してゐた。",
              "citation": {
                "source": "春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩、五月に入ってから、村川は京子と倭文子との三人で、帝国ホテルの演芸場へ、赤色ロシアを亡命している美しい女流ピアニストのコンサートを聴きに行ったことがある。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり売れすぎて演芸場にはいりきれない恐れはないかと聞くと、少しはあると言う。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪を引いたんだ」「演芸場があまり暑すぎて、明るすぎて、そうして外へ出ると、急に寒すぎて、暗すぎるからだ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "倶楽部の演芸場にも「世が世ならば」の群集があふれて、赤を呪う白の人々と、支那政府の眼をくぐって白の動きを見守る赤の密偵と、赤系と白系が縒りまざってまるで理髪屋の標柱のような哈爾賓の社会相が、ここにそのままの縮図を見せているのだった。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師、床屋、売店、庭園、演芸場、その他日常生活に必要なすべてがこのなかに完備していて、年老いた人達は一歩もそとへ出ないで済む。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では神楽坂演芸場の方が唯一の落語の定席となったらしい。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り売れ過ぎて演芸場に這入り切れない恐れはないかと聞くと、少しは有ると云ふ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪を引いたんだ」「演芸場があまり暑過ぎて、明る過ぎて、さうして外へ出ると、急に寒過ぎて、暗過ぎるからだ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、大地震の翌年、たしか大正十三年の十月か十一月かに、新劇協会の人々の手で帝国ホテルの演芸場で上演されたのが、私の処女上演であつた。",
              "citation": {
                "source": "「チロルの秋」上演当時の思ひ出",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も代表的なものはいうまでもなく築地小劇場の旗挙げであるが、その傍らで、いくぶん違つた道を進もうとしたいくつかの小さなグループの一つに、新劇協会という劇団があり、当時、帝国ホテル演芸場と呼ばれていたささやかなホールで、細々と公演をつづけていた。",
              "citation": {
                "source": "岩田豊雄と私",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "話がごつちやになりさうだから――日本の新劇協会が、帝国ホテル演芸場と云ふ仮劇場で、『桜の園』を上演した。",
              "citation": {
                "source": "『桜の園』の思ひ出と印象",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "また口絵の圓朝像は上野鈴本演芸場喫煙室内に掲げられているもの。",
              "citation": {
                "source": "小説　圓朝　あとがき",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳水亭はその後、勝岡演芸場となって晩年の若水美登里などの安芝居の定席となり、のち東宝系の映画小屋となってしまったが、電車道に沿って二階いっぱいに客席のある寂しい小屋だった。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、近所の牛込亭や神楽坂演芸場の落語家たち（ついこの間まで彼自身もその仲間だった）の独演会のやり口を口を極めて罵り、自分のような、この、こうしたやり方こそがほんとうの独演会なのだとまず気焔を上げた。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "さんぬる十日の大雪の夜は、浪花節の木村某、はなしかの柳家なにがしらとお成道なる祇園演芸場へ出演せしが席への途次今年の干支なる羊或は雪達磨の形せる狸に破れ傘あしらひたるなど、いと巨いなる雪人形をみいでたり。",
              "citation": {
                "source": "滝野川貧寒",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二階下の演芸場には小芝居の施設があつて、都桜水、有田松太郎、井田寒三、藤井弥之助、坂田半五郎、中村鶴若、市川かほる、高山吉雄、嵐璃昇などと呼ぶ所謂緞帳役者が出演してゐた。",
              "citation": {
                "source": "異版　浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら小亀はげ亀梅坊主など私の終生尊敬脱帽してゐる名流諸芸人たちは、最早そのころ十二階演芸場の出演者ではなくなつてゐて、私はこの高塔下の娯楽場へ杖曳くことがなくなつてゐたからである。",
              "citation": {
                "source": "異版　浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもみな、大阪演芸場出演中に、浪花釣友会の連中に連れて行っていただくのだが、前の晩、夜席を打ち出してから、南海難波駅を発ち、南淡輪乗りかえで多奈川へ着く。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口はある演芸場と共通になっていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴風雨の中で物凄く燃えた、一時間余り燃えておちた、演伎館という演芸場が火元である。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、カリバッドに専用演芸場まで持っている身だから。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が僕をあすこの演芸場へ引ぱって行ったのだ」「そうそう。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
