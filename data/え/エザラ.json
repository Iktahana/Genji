        "examples": {
          "standard": [
            {
              "text": "画家は、絵皿の上に絵の具を数色絞り出し、混ぜ合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "水彩絵の具を使うときは、プラスチック製の絵皿が便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、太陽の光を反射するような鮮やかな色を絵皿に並べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "絵皿に載せた絵の具は、乾かないうちに使い切る必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
