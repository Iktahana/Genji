    "definitions": [
      {
        "index": 1,
        "gloss": "decorative plate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母は、美しい風景が描かれた絵皿を壁に飾っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このアンティークの絵皿は、一点ものらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "旅行先で買った絵皿は、我が家の食卓を華やかにしてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "棚には、記念に集めた絵皿がずらりと並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、彼は少しは気になるところもあると見えて、根津美術館にあるような絵皿は、職人に皿を拵えさせておいて、それをちょっと栂指で押しているのです。",
              "citation": {
                "source": "私の作陶体験は先人をかく観る",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの絵皿は有名なだけあって、なかなかうまいものです。",
              "citation": {
                "source": "私の作陶体験は先人をかく観る",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年）色絵祥瑞写古九谷皿　陶器好きのみなさん、この絵皿をごらんください。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは紛れもない古九谷色絵皿です。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾山の作品の欠点とも言うべきものを挙げれば、凡そ以上の如きものであるが、しかし、ここに紹介する木工風の絵皿は、むしろ異例に属すべきものであって、明らかに乾山自身が土いじりをしていると見られるものである。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年の中に幾度か爛たる雲の見えざらん。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人もしその倨傲なるを憎みて、些の米銭を与えざらむか、乞食僧は敢て意となさず、決してまた餓えむともせず。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち陽に遼東を征するを令して、徐凱をして備えざらしめ、天津より直沽に至り、俄に河に沿いて南下するを令す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "方孝孺に語りたまわく、燕王は孝康皇帝｜同産の弟なり、朕の叔父なり、吾他日｜宗廟神霊に見えざらんやと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "逝きても猶逝かぬその偉いなる心はとこしへに偉霊を仰ぐ心に絶えざらむ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るもの聞くものに哀怨の嘆き絶えざらば何をよすがに生を保たむ。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この事においては我れ正し、わが舌に不義あらんや、わが口悪しき物を弁えざらんや」とは彼の友に答えし最後の語である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくヨブは人間の弱く、はかなく、汚れおる事を説きし後「その日既に定まり、その月の数汝により、汝これが区域を立てて越えざらしめ給うなれば、これに目を離して安息を得させ、これをして傭人のその日を楽しむが如くならしめ給え」と訴えている。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口の上框ともいうべきところに、いと大なる石を横たえわたして崩れ潰えざらしめんとしたる如きは、むかしの人もなかなかに巧みありというべし。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「年を経てなど越えざらん逢坂の関」という古歌を口ずさんでいる源氏の美音に若い女房たちは酔ったような気持ちになっていた。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛うじて面を擡げ得たりし貫一は、一時に発せる全身の疼通に、精神｜漸く乱れて、屡ば前後を覚えざらんとす。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでその直接の貸主と謂ふのは何処の誰ですか」　満枝は彼の遽に捩向きて膝の前むをさへ覚えざらんとするを見て、歪むる口角に笑を忍びつ、「貴方は実に現金でゐらつしやるのね。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペッチグリウ博士続けていわく、予かつて高等哺乳動物の心室と心耳の動作を精測したき事あって一疋の猴の躯を嚢に入れてひっ掻かるるを防ぎ、これにクロロホルムを施すに猴あたかも予の目的を洞察せるごとく、悲しみ気遣いながら抵抗せず、予の為す任に順いしは転た予をして惻隠の情に堪えざらしめた。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "数月かくし続けて主人一族を餓えざらしめた。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんじいかに奇矯の言をなして婦人の天職を皆無に帰せしめんと欲するも、妊娠、分娩、育児のことに至っては、ついにこれを婦人の天職にあらずと言うをえざらんと。",
              "citation": {
                "source": "婦人の天職",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の身体の上に、僕の遭ったような危害の加えざらんことを。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お軽は、この哀しい今の身に、琴など……と思ったのであるが、お別れの一曲と所望されては、それを断わりもならず、それでは拙い一手を――と言って、秘愛の琴をとり出し、松風を十三絃の上に起こし、さて、何を弾じようかと思案した末、内蔵助の私かなる壮行を祝して、（七尺の屏風も躍らばよも踰えざらん。",
              "citation": {
                "source": "軽女",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾羅の袂も曳かばなどか絶えざらん）　と歌って、絃の音にそれを託したのである。",
              "citation": {
                "source": "軽女",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "（七尺の屏風も躍らばよも踰えざらん）　の一句は、内蔵助には、（吉良家の屏風高さ幾尺ぞ）　と、響いたことであろう……と。",
              "citation": {
                "source": "軽女",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀しみを胸に抱きながら、七尺の屏風も躍らばよも踰えざらん、と歌い弾じたお軽の奥ゆかしい心根。",
              "citation": {
                "source": "軽女",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは君が想像の自由にまかせて、簾のこなたに見えざらんこそ却々に興は深かり……と誰やらが口調をそのまま、われらと同じ趣の人々に心づけまいらせておく。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も抽斎をして不平に堪えざらしめたのは、栄玄が庶子｜苫を遇することの甚だ薄かったことである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに我等は右の肩を縁にむけ、山を※ること常の如くにせざるをえざらむ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "かしこにありてわが目をまばゆうし我に見るをえざらしめたる一の光の中にかくいふ聲す　五八―六〇またいふ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "もゝとせ千歳秋去らば樂土は實となるべしや人と人との爭に我世の惱絶えざらば花たが爲めの薫りぞや星たが爲めの光ぞや。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
