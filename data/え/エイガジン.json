    "definitions": [
      {
        "index": 1,
        "gloss": "cineast",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は生粋の映画人であり、生涯を映画制作に捧げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画人が集まるバーで、新しい企画の話が持ち上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔からの映画人たちは、今の映画界の変化に戸惑いを隠せない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は若いながらも、すでにベテランの映画人から一目置かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "日本映画人がかつてソビエト露国から俳諧的モンタージュの逆輸入を企て一時それに熱中したのはすでに周知の事実なのである。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画人が映画を見るのが何の道楽だ。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画人が映画を見、映画を作るのは仕事だ。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画人としてもドイツ人はやはり「あたまが悪く」て、その結果として物事を理屈で押して行く。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと、どうもアメリカの映画人のほうがよほど進んでいるといわれても弁明のしようがないようである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア崇拝の映画人が神様のようにかつぎ上げているかのエイゼンシュテインが、日本固有芸術の中にモンタージュの真諦を発見して驚嘆すると同時に、日本の映画にはそれがないと言っているのは皮肉である。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん営利を主とする会社の営業方針に縛られた映画人に前衛映画のような高踏的な製作をしいるのは無理であろうが、その縛繩の許す自由の範囲内でせめてスターンバーグや、ルービッチや、ルネ・クレールの程度においてオリジナルな日本映画を作ることができないはずはない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説家としての私の愚見も、あるいは、ひょっとしたら、ひとりの勇敢な映画人に依って支持せられるというような奇蹟が無いものでもあるまい。",
              "citation": {
                "source": "芸術ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育映画の制作を通して、普段なら目に見えないものを映像で捉えるという仕事に携わってきた萩野さんは、技術の可能性を信じるタイプの映画人でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人こそ、その人の名こそ、日本映画史にふたたび拭うべからざる汚点を残したものとして、日本に映画のあるかぎり、日本に映画人のあるかぎり、永く呪わるべきであろう。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分一個の不安もさることながら、それよりもまず、失業群としての、大勢の映画人の姿が、黒い集団となつてぐんと胸にきた。",
              "citation": {
                "source": "思い",
                "author": "――情報局の映画新体制案について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを説明するために、まず順序として、私と自由映画人集団との関係を明らかにする必要を感じる。",
              "citation": {
                "source": "戦争責任者の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは自由映画人集団発起人の某氏から同連盟への加盟を勧誘するため、送られたものであるが、その文面に現われたかぎりでは、同連盟の目的は「文化運動」という漠然たる言葉で説明されていた以外、具体的な記述はほとんど何一つなされていなかつた。",
              "citation": {
                "source": "戦争責任者の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「前略、小生は先般自由映画人集団加入の御勧誘を受けた際、形式的には小生の名前を御利用になることを承諾いたしました。",
              "citation": {
                "source": "戦争責任者の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それは、御勧誘の書面に自由映画人連盟の目的が単なる文化運動とのみしるされてあつたからであつて、昨今うけたまわるような尖鋭な実際運動であることがわかつていたら、また別答のしかたがあつたと思います。",
              "citation": {
                "source": "戦争責任者の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき第一回の撮影に大失敗し、そのあと突然ふってわいたすばらしい恐竜洞の光景をつかまえ、今こそすばらしい機会だ、思う存分フィルムへとってしまえと、二人の映画人は夢中になっているのだった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画人といふ「現代的タイプ」を捉へて、一見新しくもなささうな「心理」の解剖を試みてゐるのだが、生活描写にも相当の観察があり、殊に、「心理の襞」に食ひ入る執拗さに至つては、聊か日本人離れがしてゐるくらゐで、ここが戯曲家として、今後、伊賀山君の独自性を示し得る点であらう。",
              "citation": {
                "source": "伊賀山精三君の『騒音』",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャップリンが何々に三年もかかった、百万ドル映画だ、そういうことが宣伝の文句だけにとどまらず、日本の映画人が本当に信仰している。",
              "citation": {
                "source": "不思議な機構",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一東宝にとどまらず、日本の映画製作の機構には多くのムダがあり、迷信があり、しかもそれが映画人にはほとんど反省されておらない。",
              "citation": {
                "source": "不思議な機構",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれが芝居をやつてる者には勉強になるし、それから日本の映画人なんかもさういふ点で注意してもらひたいなア。",
              "citation": {
                "source": "対話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三の優秀な映画人についてそのことを確かめ得る機会もありました。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人の者は、わずか五万円の出資のもとに前の二つの映画を完成し、一九三二年（昭和七年）十月九日（日曜）午前十時、大阪朝日会館において、同日午後一時半より京都日之出会館において、学者、映画人の前で発表会をおこなった。",
              "citation": {
                "source": "色彩映画の思い出",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年ぐらい前の話で、ひところの出版景気に、目先が早くて行動的な映画人で出版や雑誌発行をやった人も相当いたようだが、映画雑誌か娯楽雑誌が普通で、Ｙ氏のように、綜合雑誌めいたものは例外だろう。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度官営労働組合を造るように、映画人の協会、役者興行主の協会、漫才師の協会、其の他其の他が出来る。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年――いや昨年の今ごろの映画人や映画界が何をしていたかをチョットでも想起するならば、思い半ばに過ぎるものがあるのである！",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三芳　かくのごとくなってきた情勢の中で、われわれは、われわれ映画人が、かつて犯していた罪悪が、いかに兇悪なものであったということを、今さらながら、いな！",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして映画人のスキャンダルをあさり、それを種に金儲けをすることを考えた。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "警部も克彦も、ウィスキーのグラスを重ね、だんだん酔が廻るにつれて、猥談も出るという調子で、あけみも映画人だから、少々の猥談に辟易するたちでもなく、三人とも心から、春のように笑い興じたものである。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ近処の英百合子の家へ、清川虹子と寄り、親子丼をとって貰って食べる、映画人の生活の一面、この家にあらはれてゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
