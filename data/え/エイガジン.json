[
  {
    "uuid": "10c95724-3408-5ee5-a630-5a63d6106c31",
    "entry": "映画人",
    "reading": {
      "primary": "えいがじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
