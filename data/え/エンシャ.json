    "definitions": [
      {
        "index": 1,
        "gloss": "long shot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "監督は、広大な草原の孤独感を強調するために、あえて人物を遠写で捉える手法を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ここのシーンは遠写で撮るから、エキストラの配置をもっとバラつかせて！」と助監督の怒号が飛ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "映画の冒頭、都会の喧騒を遠写で映し出すことで、物語のスケールの大きさを予感させる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私は山口成一君が新宿の三越から撮った望遠写真を貰いましたので、自分でスケッチしながら較べて見ますと、どうも襞の工合が大分不分明の所があることに気が付きました。",
              "citation": {
                "source": "望岳都東京",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
