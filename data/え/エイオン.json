        "examples": {
          "standard": [
            {
              "text": "「先生、この楽譜のファの音に#がついているのは、どういう意味ですか？ 嬰音（えいおん）ですか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この曲のメロディラインは、嬰音を多用していて少し難易度が高いね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ピアノの練習で、嬰音と変音（♭）の指の動きに慣れるのが大変だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "時にある調子が嬰音にされ、時に同じところが半音下る。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
