[
  {
    "uuid": "b281c252-357e-5616-a9e4-c85877da7190",
    "entry": "永続的",
    "reading": {
      "primary": "えいぞくてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
