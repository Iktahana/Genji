[
  {
    "uuid": "5593201e-559b-538d-b07d-f2b44ab74fde",
    "entry": "駅頭",
    "reading": {
      "primary": "えきとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "station area",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎朝、駅頭でボランティアが募金活動を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政治家が駅頭に立ち、通行人に政策を訴えかけていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "待ち合わせは、駅頭の時計台の下にしよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "町中の雰囲気や、駅頭の雰囲気と、子供たちの生活の本拠の家の中の雰囲気とが、何か違つたものを感じたのであらう。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅頭の混乱　××着（×××荷物駅）×町を行進する。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜半近く、又、行軍縦隊や、自動車や、鍋釜をかついだ大行李の人夫等が、駅頭に着いた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅頭まで見送りに来た頭山満先生が、父の遺骨を安置した車の前に立ちながら、見栄も何も構わずに涙をダクダクと流していられるのを見た時に、私は顔を上げ得なかった。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日の新聞を見ますと、『東京駅頭の喜劇』などと云う二段ヌキの表題で、昨夜の光景を面白く書き立ててありました。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京駅頭で、滑稽な喜劇がタチアナ姫の名に於て、行われて居た時にも、姫はトボリスクの修道院の暗い一室に暗澹たるその日その日を暮して居たのでした。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "男性達が、銘々いろ／＼な別辞を返している裡に、汽車は見る／＼駅頭を離れてしまった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "男性達が、銘々いろ／＼な別辞を返してゐる裡に、汽車は見る／＼駅頭を離れてしまつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "市役所前から名古屋駅頭まで、断続しつゝある偉観は、大した自慢にはならぬが、それ自身として、すばらしいものである。",
              "citation": {
                "source": "名古屋スケツチ",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "石山駅頭の歓送風景、小学生の万歳々々を聞いて涙ぐましく。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ頃にやはり新聞が、青少年男女の産業戦士の病気になる率が急騰していることを報じていたことは、その上野駅頭の大群集の写真との対照で、今なお生々しく私たちの感銘に刻まれていると思う。",
              "citation": {
                "source": "列のこころ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野の駅頭に密集した産業戦士たちの盆帰りの写真は、一方でその記事をよんでいる一般の人々の胸に、どんな感想をもって迫っただろうか。",
              "citation": {
                "source": "若きいのちを",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "門司風景を点綴するには朝鮮服の朝鮮人の悠然たる姿を添へなければならない、西洋人のすつきりした姿乃至どつしりした姿も、――そして下関駅頭の屋台店（飲食店に限る）、門司海岸の果実売子を忘れてはならない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はただ新宿に映画を見た時、眼つきが怪しいとの理由で、駅頭に張っていた特高に掴まった。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "而し結局、自分を犠牲にすればそのひとたちの家族が幸福になると確信できた、二十四歳のぼくの単純な虚栄、或いは偽善的な人間信頼から、ぼくはそのひとに近くの駅頭で、「さようなら」をいった。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も言った通り、芙江は小さな村ではあったが、何しろそれは本線の停車場を控えたところなので、たびたび通過するいわゆる名士や高官連の送迎に、小学生や憲兵はもちろん、村の有志、さては女どもまでも飛び出して来て、駅頭に整列する半ば義務的なものを負わされていた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅頭は相変らず混雑していた。",
              "citation": {
                "source": "愛の為めに",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "処で、汽車の着く、梅田の駅頭も、その非文化的な上に於て、木津川よりも賑やかという以外に何物もない。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "哈爾賓駅頭、弔伊藤博文公遭難遣迹少年曽侍浪滄閣。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ・Ｐの駅頭にトランクが開かれてから、実に四日目の午後である。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻の孤独な姿を、薄暗い夜の閑散な駅頭に彼は初めて見たやうな気がし出したのだ。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は前後四五人の女中を、こうして駅頭へ迎えたけれども、私がそれと目印を見破ってモシモシと話しかけると、ハイ、そうです、などゝ返事をする娘のいたタメシがない。",
              "citation": {
                "source": "無毛談",
                "author": "――横山泰三にさゝぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "品川駅頭を出発して東海道を下っていった出征兵員一行の消息は、いつの間にか、全く不明になってしまった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはその年も押しつまって、きょう一日の年の暮だというその日の朝、大阪駅頭に珍しく多数の警察官を交えた見送りをうけつつ、東京行の超特急列車「かもめ」号の二等室で出発しようとする一組の新夫婦があった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "はははは」　両国駅頭で、大江山課長と禿頭問答をやった新田先生は、急になんだか和やかな気持になった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服に日の丸の旗を斜にかけ、深刻な顔付で敬礼して駅頭にたった兄へ、私は肉親への愛情のきずなを感じた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
