[
  {
    "uuid": "5216e35b-7af3-5b53-a633-831fbd87de41",
    "entry": "栄耀栄華",
    "reading": {
      "primary": "えいようえいが",
      "alternatives": [
        "えようえいが"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wealth, prosperity, and arrogant splendor (splendour)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その王国の物語は、かつての栄耀栄華と、その後の没落について語り継がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は一代で富を築き、栄耀栄華をほしいままにしたが、晩年は孤独だったという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "豪華絢爛な衣装、きらびやかな宝石、まさに栄耀栄華の極みといった光景だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歴史上の多くの権力者が、栄耀栄華の影で、民衆の苦しみを見過ごしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "派手なパーティーや贅沢な暮らしに溺れ、栄耀栄華に酔いしれる日々だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "栄耀栄華をきはめたもんだ。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体を売って栄耀栄華さ、それが浅ましいと云うんじゃないか。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思えばもう少し池上をあやなし返し、また自分の背負い荷になっている葛岡の生活も保証させ自分も楽々と栄耀栄華に飽こうかなど思う捨鉢な慾も出て参ります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つたないこの身に余り過ぎました栄耀栄華。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄耀栄華をしたくなるものです。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所の豪傑儕、座敷方の僭上、栄耀栄華に憤を発し、しゃ討て、緋縮緬小褄の前を奪取れとて、竈将軍が押取った柄杓の采配、火吹竹の貝を吹いて、鍋釜の鎧武者が、のんのんのんのんと押出したとある……板の間ヶ原や、古戦場。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "クララは第一の世界に生い立って栄耀栄華を極むべき身分にあった。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……妹はこの数年間の嫂の変貌振りを、――それは戦争のためあらゆる困苦を強いられて来た自分と比較して、――戦争によって栄耀栄華をほしいままにして来たものの姿として、そしてこの訳のわからない今度の失踪も、更年期の生理的現象だろうかと、何かもの恐しげに語るのであった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "……妹はこの数年間の嫂の変貌振りを、――それは戦争のためあらゆる困苦を強ひられて来た自分と比較して、――戦争によつて栄耀栄華をほしいままにして来たものの姿として、そしてこの訳のわからない今度の失踪も、更年期の生理的現象だらうかと、何かもの恐ろしげに語るのであつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまな栄耀栄華の幻影が後から後からと頭にちらついた。",
              "citation": {
                "source": "幻想",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は何ひとつ不足のない栄耀栄華な生活を未来に夢見ていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち……李太白が玄宗皇帝の淫蕩と、栄耀栄華に媚び諛った詩を作って、御寵愛を蒙ったお蔭で、天下の大詩人となったのを見た呉青秀は、よろしい。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてソンナ連中の遺産を一人で掻き集めて栄耀栄華にふけりながら、よく、尻尾を押えられずに来られたもんだなあ、お前は……』……まあ怖い……そんなことがホントに出来るのかしら……。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見れば人間と云うものは、いくら栄耀栄華をしても、果ないものだと思ったのです。",
              "citation": {
                "source": "仙人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、自分も種を蒔いて栄耀栄華に遊ばうと……前なる畠五六町一夜のうちに掘り返し、日頃たしなみたる謡・乱舞の諸道具残らず、畠へ持ちはこび……残らず畠へ蒔かせたり。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの方の御思召は、決してそのやうに御自分ばかり、栄耀栄華をなさらうと申すのではございません。",
              "citation": {
                "source": "地獄変",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「茂太郎」「あ、お前は……」「お前こそ、どうしてこんなところに来てるんだい、両国橋にいれば、ああして人気の上に祭り上げられて、栄耀栄華が尽せるのに、なんだってこんな山ん中へ逃げて来ているんだい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄耀栄華の味を知つたもの故芝居も着物もさして珍らしくは思はぬはずなり。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭焼は賤の中にも賤の業とは云いながら、都の華奢な浮世の手ぶりに慣れ慣れて、栄耀栄華に飽きの来た人々には、そこにまた一種のなつかしみを感ぜしむるものがあったのである。",
              "citation": {
                "source": "炭焼長者譚",
                "author": "系図の仮托と民族の改良",
                "note": "青空文庫"
              }
            },
            {
              "text": "……浪速の豪商淀屋辰五郎、百万にも余る巨富を積み、栄耀栄華を極めたが、元禄年間｜官のお咎めを受け、家財一切を没収されたこと、汝といえども伝え聞いていよう。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよそうなら忍び込み、奪い取って一｜釜起こし、もうその後は足を洗い、あの米八でも側へ引き付け、大尽ぐらし栄耀栄華、ううん、こいつあ途方もねえ、偉い幸運にぶつかるかもしれねえ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　その時こそ運命が――解いた人の運命が、俄然とばかり一変し、栄耀栄華を尽くすことが出来、至極の歓楽を享けることが出来る！",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……宮様討ち取り三日のうちに、六千貫の黄金を手に入れ、車の庄の主となり……栄耀栄華！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京へ行って栄耀栄華に暮すが最上の分別さ、ということであった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その八　時計館の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "平家一門の栄耀栄華の陰には、敗戦の不運に泣く源氏の将兵があり、又、天皇と上皇は、互にけんせいし合いながら、政権をねらうという、不穏な空気が時代を支配していた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのぬすっとも、これだけの金、うぬが栄耀栄華に使おうと言うんじゃねえ、何十という人の命が助かるのだ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついさっきまで王様王様で栄耀栄華を極めていたが、それも僅か半日の夢。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あり相も無いことだが」　栄耀栄華が好きで、浮氣で、贅澤で、男から男へ飛石のやうに渡つて歩く女は、どう間違つても自殺などはしさうもありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "用心棒",
                "note": "青空文庫"
              }
            },
            {
              "text": "個々の場合についてその可否を決すべきであって、ただ夫婦共稼ぎが決して恥ずべき事でなくして、却って人形の様な不生産的な花嫁や、栄耀栄華を目的とする様な虚栄心の強い女子を数めようと思うのである。",
              "citation": {
                "source": "夫婦共稼ぎと女子の学問",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "片棒担いでくれ、栄耀栄華は思いのままだ、俺は国王陛下の弟だ、と年中大口｜叩いてたのは、どこの誰だい！",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
