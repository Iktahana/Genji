        "examples": {
          "standard": [
            {
              "text": "コンサートのチケットが取れたので、友人と駅前広場で待ち合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末には、駅前広場でフリーマーケットが開催されることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "酔っ払いが駅前広場のベンチで寝ているのをよく見かける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "新宿駅前広場は、城北地区の解散場であったが、そちらの行進の先頭を切ったのは簡易保険局の女子職員で、この間モスクワのメーデーと写真に紹介されたとおり、奇麗な花束を一人一人が抱えて行進した。",
              "citation": {
                "source": "メーデーに歌う",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花巻駅の駅前広場にはいつでもマムシの黒焼を屋台で売っている。",
              "citation": {
                "source": "山の秋",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんのちらり、ほらり駅前広場へ散ってゆく人々にまじって、伸子と蜂谷良作とは、国際学生会館からの人たちと落ち合う約束になっているホテルへ行った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤煉瓦の荘重な東京駅、中央郵便局、聳えたつ丸ノ内ビルディング、その他の宏壮華麗な建築物の列、はるかに望まれる宮城、コンクリートで堅められた駅前広場、走る電車、自動車、人力車――大都会の美しい玄関を、感歎して眺めた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
