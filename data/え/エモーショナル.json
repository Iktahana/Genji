        "examples": {
          "standard": [
            {
              "text": "その映画のラストシーンは、とてもエモーショナルで感動的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はエモーショナルなスピーチで聴衆の心を掴んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの歌手の歌声は、聴く人の心に深く響くエモーショナルな魅力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女はエモーショナルな性格で、喜びも悲しみもストレートに表現する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "感激的というのはこんな有様で情緒的教育でありましたから一般の人の生活状態も、エモーショナルで努力主義でありました。",
              "citation": {
                "source": "教育と文芸",
                "author": "――明治四十四年六月十八日長野県会議事院において――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマンチシズムの芸術は情緒的エモーショナルで人をして偉く大きく思わせるし、ナチュラリズムの芸術は理智的で、正直に実際を思わしめる。",
              "citation": {
                "source": "教育と文芸",
                "author": "――明治四十四年六月十八日長野県会議事院において――",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は、悲劇的な愛のほうが聞く人にとってエモーショナルな衝撃力がより大きいために離婚がうたわれたのだが、現代では意味がすこしちがってくる。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
