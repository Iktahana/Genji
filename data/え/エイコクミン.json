[
  {
    "uuid": "fcdc1d5c-fdec-5816-a858-a2d18b84d791",
    "entry": "英国民",
    "reading": {
      "primary": "えいこくみん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
