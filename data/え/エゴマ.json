        "examples": {
          "standard": [
            {
              "text": "朝食には、荏胡麻油をかけたサラダが定番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "健康に良いと聞いて、最近は荏胡麻を料理に取り入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母が作る郷土料理には、すりつぶした荏胡麻が欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "荏胡麻のプチプチとした食感がアクセントになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "荏胡麻の實を臼に入れて搗き締木にかけて油を搾つた殘りを、やはりその多くの産地では子供が貰つて喜んで食べた。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "荏胡麻の実を臼に入れて搗き締木にかけて油を搾った残りを、やはりその多くの産地では子供が貰って喜んで食べた。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「粉板」と呼ぶのは鉛粉を主とし、これに「えごま」の油と膠とを交ぜ板に塗ってあるからである。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人たちには、自分にもったいをつけ箔をつけるように、我々の心をとらえごまかすように、教えよう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
