        "examples": {
          "standard": [
            {
              "text": "この地域には、歴史的な価値のある営造物が数多く残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "都市計画では、景観に配慮した営造物の建設が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ダムや橋なども、広義には営造物と言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしお城が偉大さを印象すると主張することは、封建時代を呼び返そうとすることでもなければ、また、封建時代的な営造物を新しく作るように要求することでもない。",
              "citation": {
                "source": "城",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "城のごときモニュメンタルな営造物は一層そうである。",
              "citation": {
                "source": "城",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "営造物の名前の多くは、長い木片に書かれる。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
