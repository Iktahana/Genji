          ],
          "literary": [
            {
              "text": "そこで、明王に特別謁見の間を、お角さんは、次の間というよりも、奥書院の廊下に立って待受けておりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そこはもう謁見の間だ。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一歩謁見の間に通るや否や、託されたエセックスの手紙など、持ってこなかった自分の運勢に感謝した。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "謁見の間いッぱい、ゆゆしい顔が居ながれていた。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
