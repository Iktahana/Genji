          ],
          "literary": [
            {
              "text": "私の作品は、どう考えたって、映画化も劇化もされる余地が無い。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず最初の小説及び戯曲の映画化私感。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説（若しくは戯曲）の映画化に際して僕は（ひとは知ら無い。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、往々にしてその作者が、自作の映画化を企図して書いていると思いなされる場合があるからだ。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、映画化を意図して書かれた作家の作品を読んで、それに盛られた内容と、映画作家の持つそれと、はたしてどれだけの懸隔があるかを疑わざるを得ない場合が多いのだ。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、文芸家の作品を映画化することになった場合、「原作のままで行ってほしい」と言われる場合がある。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　居酒屋　ゾラの「居酒屋」を映画化したものだそうである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、おかしいことに大映、東宝からも同じように「清楚」の映画化の話があり、「清楚」は映画化にならないという私の考えは間違っていたらしかった。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　連句の映画化ということについては、自分はこれまでに幾度もいろいろな場所で所見を述べたことがある。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スティーブン・スピルバーグによって映画化された、マイクル・クライトンの『ジュラシック・パーク』と、ルーイス・キャロルのアリス物を集めてたっぷり注釈を付けた『ザ・コンプリート・アノテェイティッド・アリス』です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために映画化にあたっては、テレンス・マンという代役を立てざるを得なかったということだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクル・クライトンの Jurassic Park は日本語版がベスト・セラーとなったばかりで、スピルバーグによる映画化も決定している。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く飛んでゐる飛行機を映画化すために、飛行機を固定さしてをいて、背後の雲を早く移動させるといふ映画のトリックを想ひ出したらいゝ、自然の真を衝くためには、嘘をつくことをゆるされるといふ場合はさうした場合を言ふのであらう、そこにも桂月氏の曲者的なところがある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちで前の三つは既に映画化され、ウィリヤム・パウエルの主演で、三つとも日本へ輸入された。",
              "citation": {
                "source": "ヴアン・ダインの作風",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと探偵小説の映画化は、困難であると見えて、シャーロック・ホームズ物にしても、ルパン物にしても、かつて成功したためしがない。",
              "citation": {
                "source": "ヴアン・ダインの作風",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもヴァン・ダインの作品の映画化は、どれも大して成功とは思われなかった。",
              "citation": {
                "source": "ヴアン・ダインの作風",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、映画会社が、引きつづき彼の作品を三つまで映画化したということは、彼の人気がどれほど異常であるかを知るに足る。",
              "citation": {
                "source": "ヴアン・ダインの作風",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "東宝系は三船敏郎の『奇巌城の冒険』で、これは現代国語の宿題になった、『走れメロス』を映画化したものだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵小説の映画化が失敗しているのは、余談だが皆そのためだ。",
              "citation": {
                "source": "ヂユパンの癖とヴァンスの癖",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近日本映画の優秀作品として「若い人」「路傍の石」「冬の宿」「鶯」その他長篇小説のいくつかが映画化され日本としての高い水準を示したものとされた。",
              "citation": {
                "source": "観る人・観せられる人",
                "author": "――観客の問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学の作品を映画化して行こうとする製作者の心持のうちにある現実への真面目な要求はよくわかるところがある。",
              "citation": {
                "source": "観る人・観せられる人",
                "author": "――観客の問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、例えば文芸映画についても、文学作品そのものへの鑑賞が無規準ななりの或る好評に招きよせられて映画化し、その映画化によって、じかに文学作品をよこよりもっとうわすべりな受けいれかたをひろめるという結果も生じ易い。",
              "citation": {
                "source": "観る人・観せられる人",
                "author": "――観客の問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "文芸作品が映画化されてゆくことは一見相互的な活況のようであるが、その実微妙な本質の部分で、却って今日の文化の消極の面が働いているかもしれないのである。",
              "citation": {
                "source": "観る人・観せられる人",
                "author": "――観客の問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "委員制によってつくられた作品で、日本の小学校がどのように児童の衛生、学習のために注意を払っているかということを映画化したものであると説明された。",
              "citation": {
                "source": "映画の語る現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レンブラントの生涯を映画化した「描かれた人生」では、一人の芸術家が二様の動機で二人のそれぞれ性格の違う女に違った感情の内容で結ばれて行くところが、じみではあるが効果を持って描かれていた。",
              "citation": {
                "source": "映画の恋愛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころの私はレーニングラードにいて、「ソヴキノ」試写室で世界的映画監督プドフキンによって映画化されたゴーリキイの「母」を見たりしたところである。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも資本主義国の支配者たちは映画化された「母」の輸入を許可することが出来ないだけ、強力な何ものかがあるのである。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野蛮人の学校」では、ナチス治下の教育が、どんなにドイツの少年たちを毒しているかをあからさまにしたもので、映画化され、世界に深甚な影響をあたえた。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
