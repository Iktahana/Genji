        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「なんという美しさだろう！」 その言葉は純粋な詠嘆だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の演説は、聴衆の感動を呼び、「ブラボー！」という大きな詠嘆に包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "A: 「見て、あの虹！」\nB: 「うわー！すごい！」「本当に、言葉を失うほどの詠嘆だね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "藝術としての詩が、すべての歴史的發展の最後に於て、究極するところのイデアは、所詮ポエヂイの最も單純なる原質的實體、即ち詩的情熱の素朴純粹なる詠嘆に存するのである。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　かうした理窟はとにかく、この詩集に收めた少數の詩は、すくなくとも著者にとつては、純粹にパツショネートな詠嘆詩であり、詩的情熱の最も純一の興奮だけを、素朴直截に表出した。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしたことがこの作一體に、生活からのものでない、描寫からの――文學からの詠嘆を與へてゐる。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、首を左右にふりながら少し舌の滑動の怪しくなった口調で繰り返し繰り返し詠嘆する。",
              "citation": {
                "source": "思い出草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今になって考えてみると、かなり数奇の生涯を体験した政客であり同時に南画家であり漢詩人であった義兄春田居士がこの芭蕉の句を酔いに乗じて詠嘆していたのはあながちに子供らを笑わせるだけの目的ではなかったであろうという気もするのである。",
              "citation": {
                "source": "思い出草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かな」は詠嘆の意を含む終止符であるから普通の意味でも切れる切れ字には相違ないが、また一方では、もう一度繰り返して初五字を呼び出す力をもっている。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新時代の敍情詩は、單なる「純情の素朴な詠嘆」でなく、また「觀念の平面的なる敍述」でもなく、實に驚くべき複雜なる叡智的の内容と表現とを示すに至つた。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この詩風に文語體を試みたのは、いささか心に激するところがあつて、語調の烈しきを欲したのと、一にはそれが、詠嘆的の純情詩であつたからである。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）しかしながら共に純情風のものであり、詠嘆的文語調の詩である故に、あはせて一册の本にまとめた。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇蹟金銀　祈祷晶玉　海底詠嘆　海上光明　しんしんたる浪路のうへ、祈れば我が手につながれ、あきらかに珊瑚の母體は昇天す。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ感情が理智を慴伏する刹那にのみ詠嘆と祈祷はあり。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙の甘くして混濁せるものを詠嘆と呼び、涙の苦くして透純せるものを感傷と呼ぶ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詠嘆もまた幼年期の感傷と言ふを得べし、而して短歌の生命は詠嘆を出でず、格調に捉はるれば也。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼兒の眞實を嘲笑するものは必ず衒學の徒なり、萬葉集の詠嘆は單純なれども千載の後その光を失ふことなし。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」少年は、私の拒否を無視して、どんぶりを片手に持ったまま、ひとりで詠嘆の言葉を発し、うっとりした眼つきをして見せた。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思慮ある作家に取つては、文學は最早單なる遊戲や詠嘆や忘我の國ではなくなつた。",
              "citation": {
                "source": "硝子窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "新人の悲哀は古い詠嘆の絃にのぼせて象徴の世界を観照すべくあまりに複雑であり、深刻であり、而かも而かも傷ましいほど痛烈である、わが友よ、古い楽器の悲哀を知れ。",
              "citation": {
                "source": "桐の花とカステラ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "新人の悲哀は古い詠嘆の絃にのぼせて象徴の世界を観照すべくあまりに複雑であり深刻であり而かも而かも傷ましいほど痛烈である、わが友よ、古い器楽の悲哀を知れ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は時としてその繊細な平安朝の詠嘆、乃至は純情の雅びやかなる啜り泣き、若くは都鳥の哀怨調に同じ麗らかな心の共鳴を見出す事はある、而しなほ苦い近代の芸術にはまだその上に堪へがたいセンジユアルな日光の触覚と渋い神経の瞬きとを必要とする。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕切れの詠嘆詞なんて、詠嘆的な余りに詠嘆的で、昭和の文芸調とは云ひ難い。",
              "citation": {
                "source": "月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フーム、鉄工産業の労働者は頼もしいね」と、波田は詠嘆的にいった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで……」　と彼は、不図酔から醒めて、稍はにかんだかのやうな口調で、「夜中など、たつたひとりで自分の稍気に入つた作品を写して眺めてゐると、未だ見たこともない恋人と……」と云ひかけて、彼は、「やあ失敬――調子に乗り過ぎて、すつかり詠嘆的になり過ぎてしまつた。",
              "citation": {
                "source": "塚越の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして細く詠嘆的な声で、「波がおだやかだね。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者の芸術的情緒も、概して詠嘆的且つ詩人的である。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "和歌は詠嘆的でなければならない性質を持つてゐる。",
              "citation": {
                "source": "黒猫",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて詠嘆とか意志とかいふことを目的としてゐないやうな形がある。",
              "citation": {
                "source": "黒猫",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と弁士が轍の軋るやうな詠嘆的なイヽ声色で叫んだ時、見物人はひとりも拍手しなかつたが、自分は突然ホロリとした。",
              "citation": {
                "source": "若い作家と蠅",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
