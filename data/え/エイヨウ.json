[
  {
    "uuid": "f32ded1c-c129-5fb4-add8-7390a307ffa5",
    "entry": "栄耀",
    "reading": {
      "primary": "えいよう",
      "alternatives": [
        "えよう"
      ],
      "is_heteronym": false
    },
    "grammar": {
