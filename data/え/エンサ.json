[
  {
    "uuid": "49b9dcf0-cf3f-5f1c-b11b-6d144826e7fe",
    "entry": "怨嗟",
    "reading": {
      "primary": "えんさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
