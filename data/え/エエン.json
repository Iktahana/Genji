          ],
          "literary": [
            {
              "text": "鐘を撞かん事になってみる日になってみると、いたしてから、その、鐘を撞くための君はですな、名は権助と云うかどうかは分からんですが、ええん！",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "安来千軒えええん…う…う　それから「江差追分」「八木節」「博多節」などに変って行ったが、青｜羅紗の凸凹の台の上にレコードはへたばりへたばりキイキイ声で旋廻した。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、熟と耳を澄ますと、少時して、「ええん。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんにおめえもお品さんに死ならつたのが不運だつけのさな、そんだがおめえ長命したゞけええんだよ」婆さん等は口々に慰めつゝいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてまたきょうはやけにそう足がはええんだろうな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎足がはええんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなりゃもう気もたってくるが、足もまたはええんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺した一｜張羅が生きてかえるとなると気がつええんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっとと買ってけえって、お重に詰めて、あしたの朝ははええんだからな、いつでも役にたつようにしたくしておきな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝ははええんだから道草食うなといったじゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんなもあの江戸錦を洗ってみるお考えだったんでがしょう」「そうだよ」「なら、だんなのほうがひと足はええんだから、こっちへ玉をさらったらどうですか」「まあそう鳴るなよ、鳴るなよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうしたら、ええんだ！",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり威張ったことを云わねえ方がええんだで。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それこそ本當にめしも喰へねええんた事始まるべよ。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　姉のお恵が、物差しで自分の背中をかきながら、――「その端なくなってしまえば、ええんだ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺、模範青年になってる方がええんだべ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手人を磔にして、御威光を見せれば、ええんじゃ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母ア、黙っとりゃええんじゃ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "南のが引き取りゃそれでええんじゃ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな碌でもない奴は、人目につかん処で死にさらしゃええんじゃ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、みんなちょっくら行って来ようか……」「ええんだよ、親方、もう時間がねえから」「ふふふ、ふふふ、じゃ、よすとしよう。",
              "citation": {
                "source": "親方コブセ",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "「魚が、こぎゃん、えっと、えっと、釣れたんどう、一｜尾やろうか、何がええんな」「ちぬご」「ちぬごか、あぎゃんもんがええんか」　家の中は誰もいなかった。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事を手伝いせえすれあ、ええんだ」「許して……許して下さあい。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナカナカ君は頭がええんだな」「……そ……そんな訳じゃないですが……それから事件当夜の二時頃に主人の部屋に居た呉羽嬢の行動に関する秘密……」「……あ……そいつはドウモ当てにならんよ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして海底大陸とわが人類との間をむすぶ月下氷人のような役割さええんじていたのだ。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええん、うえん、うえん、うえん、うおん、うおん、うおんといふ号泣が益々高く鳴り出してゐた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「仕事のあるうちがええんだ。",
              "citation": {
                "source": "土地",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
