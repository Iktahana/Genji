        "examples": {
          "standard": [
            {
              "text": "彼から贈られたエンゲージリングは、シンプルだけど存在感がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "結婚式の準備で、まずは二人でエンゲージリングを見に行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サプライズプロポーズで、ポケットからエンゲージリングを取り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "左の手はしょっちゅう洋袴のポケットへ入れていましたが、胸のハンカチを取出すとき、案外白い大きい手の無名指にエンゲージリングの黄ろい細金がきらりと光ったのを覚えています。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……左の薬指に華奢なダイヤ入りと、エンゲージリングを一ツずつ……。",
              "citation": {
                "source": "涙のアリバイ",
                "author": "――手先表情映画――",
                "note": "青空文庫"
              }
            }
          ]
        }
