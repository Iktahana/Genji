        "examples": {
          "standard": [
            {
              "text": "彼女はイメージチェンジのために、美容院でロングのエクステをつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このエクステは、人毛なのでとても自然に見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "エクステの手入れは少し大変だけど、色々なヘアスタイルを楽しめるのが魅力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ねぇ、そのエクステ、どこのお店でやったの？すごく似合ってる！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ソリエはその現象を、神経病の一種のオートスコピー・エクステルヌと云っている。",
              "citation": {
                "source": "奇怪な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "道に出ると、「もう大丈夫」　やれやれといったように金原は足をゆるめ、「ここは所轄がちがうんだ」　この道路はエクステンション・ロードと言って、道路だけが共同租界に属しているから、ナイト・クラブとは所轄の警察がちがう。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
