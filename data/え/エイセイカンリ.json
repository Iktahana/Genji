          "standard": [
            {
              "text": "工場の衛生管理体制が評価され、国際的な認証を取得した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "食品加工業においては、徹底した衛生管理が信頼の基盤となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "我々は、施設の衛生管理を強化するため、新たなマニュアルを作成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "さらに衛生管理を厳しくすることによって臣民の福祉を世話するのが絶対主義国家オーストリアの政策の一部になった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争、革命、のように公衆衛生管理の微妙な機構を覆すどんな事件でも激しい流行病を再発させ流行は政治上の境界とは無関係に広がることになる。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
