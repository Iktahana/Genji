          "literary": [
            {
              "text": "「僕は着物きかえるから……」　間もなくお豊がわざわざ買っておいたらしい近所の海老せんべいと茶道具とをもって、あがって来た。",
              "citation": {
                "source": "聟",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、会費三百円ね」　と、山崎がかっぱえびせんの袋を芝にトスした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "通知表もらったら、笑ってばかりもいられんだろう」　といって、えびせんをひとつ、口に放りこんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "かっぱえびせんぐらいじゃ、とりもどせない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
