    "definitions": [
      {
        "index": 1,
        "gloss": "minidisc",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「昔作ったMDを久しぶりに再生したら、当時の思い出が鮮明に蘇ってきた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「CDからMDにダビングする作業って、当時は当たり前の日課だったよね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「実家の引き出しから、タイトルを手書きしたMDが山ほど出てきたよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "『ホームコンピューター』の虚妄を現実に変えるＡＭＤ３８６互換チップの宣戦布告『Ｔｈｅ　ＣＯＭＰＵＴＥＲ』から「Ｗｉｎｄｏｗｓ３・０は流行るか」という、いまさらなにをとぼけているかといいたくなる座談会のお座敷がかかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁を突き崩した反逆者の名は、ＡＭＤ（アドバンスト・マイクロ・デバイシズ）である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "チップ界の松田聖子とでも言えばいいのかな、とにかくはでなエピソードだらけのサンダース率いるＡＭＤは、これまで思わず大笑いの奇抜な広告や超特大クリスマス・パーティなんぞで話題を集めてきたが、基本戦略は地味にセカンド・ソースにおいてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが一九七六年にインテルと広範な技術の交換契約を交わしていたＡＭＤは、３８６の市場独占の打破を狙ってセカンド・ソース戦略を攻撃的なものへと一変させた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年間有効なこの契約（その後さらに十年間延長したことで、ＡＭＤは一九九五年までこれが継続すると主張する）によって、ＡＭＤは３８６のマイクロコードをコピーして互換チップを製造し得るとし、インテルの独占を打破すると宣言したのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この３８６殴り込み戦略で腹を決めたＡＭＤは、互換チップの方向づけを、処理速度の向上と低消費電力化に定めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九九一年三月、ＡＭＤは初の３８６互換チップ、Ａｍ３８６ＤＸ―40とＡｍ３８６ＤＸＬ―40の量産出荷を開始した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてＤＸＬとＬのついた側は、ＡＭＤがもう一つの柱とすえる低消費電力という特長を備えていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにＡＭＤは３８６互換製品のライン・ナップを拡充していった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方インテルは先ず、３８６という名称は自社の登録商標でＡＭＤに使用権はないと裁判で訴えたが、三月これを退ける判決が下った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにインテルはコピーしたマイクロコードの製品への組み込みの可否を巡ってＡＭＤと法廷で争っているが、同様の権利が８０２８７コプロセッサーの訴訟で認められた経緯から見れば、今後予定される裁定でＡＭＤの３８６互換チップが法的お墨付きを得る可能性は高い。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "システム屋にとってみれば、ＡＭＤのチップを使ったはいいが後から特許侵害となってインテルの機嫌を損ねたのでは大事になるゆえに、互換チップの採用の件はこれまで一切水面下に潜ってきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが先頭を切ってＡＭＤチップの採用に踏み切ったＡＳＴリサーチに続いて、一九九一年の十月二十一日から開催されるコムデックスでは、新たな３８６互換チップ採用の声が上がるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにＡＭＤは、従来五ボルトで動作してきたマイクロコンピューターの電源電圧を三・三ボルトに落とす新しい提案を、コムデックスにぶつけてくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに３８６の独占が崩れた後にくるものは、より速くより電力を食わないチップをより安く提供する、インテルとＡＭＤのマッチ・レースである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがインテルとＡＭＤの競争を通じて加速する低消費電力化を巡る技術開発は、すぐにデスクトップ・マシンにも生かされるぞ！",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点を確認したうえで、ＡＭＤとインテルの企業間抗争に関しこの原稿で言葉が足りていない点、不正確な点を正したい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七六年に交わした広範な技術の交換契約によって、インテルの開発したマイクロコードを利用する権利を与えられていると判断したＡＭＤは、これを利用してまず数値演算用の８０２８７の互換コプロセッサーを開発し、販売する方針を固めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この訴訟が決着を見る前に、ＡＭＤは同年六月、互換製品の販売を開始した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでインテルはすでに提訴済みの著作権侵害訴訟に加えて、ＡＭＤの互換製品の販売を中止させる訴えを裁判所に求めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを受けて八月、連邦地方裁判所のウィリアム・イングラム判事はＡＭＤに対し、インテルの著作権を告知すること、製品が８０２８７と同等、又は完全な互換性があると表示すること、同社がインテルから特許の使用許可を得ていると謳うことを禁止する命令を下した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、この三点を控えればＡＭＤは８０２８７互換製品を販売できると認められたと考えた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この判断に基づきこの原稿では、「インテルはコピーしたマイクロコードの製品への組み込みの可否を巡ってＡＭＤと法廷で争っているが、同様の権利が８０２８７コプロセッサーの訴訟で認められた経緯から見れば、今後予定される裁定でＡＭＤの３８６互換チップが法的お墨付きを得る可能性は高い」と書いた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一九九二年五月になって本筋の著作権侵害の訴訟に対し、連邦地裁陪審は「ＡＭＤが８０２８７互換コプロセッサーにインテルのマイクロコードを利用したのは不法である」との判断を下した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＭＤはすでに発売済みの３８６互換プロセッサーと一九九二年夏にサンプル出荷の開始を予定していた４８６互換プロセッサーにも、インテルのマイクロコードを使用していた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＭＤがすっきりインテルの独占を打破してくれるだろうとのオレの読みも、これによって揺らぐ事になった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＭＤのＸ８６互換への挑戦は、その後チップス＆テクノロジーズ、サイリックス、テキサス・インスツルメンツといった追随者を生み、競争相手の出現によってインテルは製品の大幅な値下げを迫られた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
