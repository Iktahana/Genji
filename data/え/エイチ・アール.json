        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "衆議院（House of Representatives）の解散総選挙が近づいている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この法案は、まず衆議院（HR）で審議されることになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「衆議院議員（HR）の質問時間が限られているから、簡潔に話してほしい」と議長が促した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多くの国民が、衆議院（HR）の動向を注視している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
