    "definitions": [
      {
        "index": 1,
        "gloss": "eternal life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "多くの宗教では、死後の永遠の生命が説かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "不老不死の薬は、永遠の生命を求める人間の永遠の夢だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その古代の物語には、永遠の生命を持つとされる存在が登場する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "SF小説では、永遠の生命を得るための技術開発が描かれることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "永遠の生命を思はせるね。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠の生命を思わせるね。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、やや後世になって、いろいろ仏教学者が出まして、釈尊はどうして有限の人間として、かの永遠の生命を捉えられたのだろう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、氏は信仰を得て「永遠の生命」に対する希望を持つ様になりました。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "大罪大悪の消ゆるは此奥にあり、大仁大善の発するは此奥にあり、秘事秘密の天に通ずるは此奥にあり、沈黙無言の大雄弁も此奥にあり、然り、永遠の生命の存するもこの奥にあり、かの説明し得べからずと言はれたる人生の一端の、説明せらるゝもこの奥にこそ。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして我らキリストの救に浴して永遠の生命を信ずる者は、ヨブのこの詰問に対しては永生の真理を以てこれに答うるを最上の途とする。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち「神はその所作にかかる忠誠なる魂を決して棄てず、たとい一時彼を苦しむることあるも、しかして彼の生命断たるることあるも、神は復活の恵を以て彼を起し永遠の生命を彼に与えて彼をして最後のかつ永久の勝利を獲しむ」と答えるのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が縦令凡てを施し与えようとも永遠の生命を失っていたらそれが何になる。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙への同化、永遠の生命への同化、これより他に、私達の行く道はない。",
              "citation": {
                "source": "大阪で",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠の生命につゞいてゐるか、何うか。",
              "citation": {
                "source": "大阪で",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つはいずれも緑雨自身の不得意とする作で、人の褒めるのが癪に触るといって喰って掛ったものであるが、緑雨が自ら得意とする『かくれんぼ』や『門三味線』よりは確に永遠の生命がある。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちは医学の進歩によって永遠の生命と若さとを保証されている。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四講　永遠の生命舎利子。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己の永遠の生命を信ずる者は、「不生不滅」です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "生死を達観して、人生永遠の生命に目覚めることが、なんといってもいちばん大切です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "独特の軍事学なき国民は永遠の生命なし」との意見を聞き、伊藤公使の脳裡に深い印象を与えているらしい。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は若し、心臓が停止したとき、直ちに人工心臓に置きかえて、外部からエネルギーを与えて、喞筒の作用を起さしめ、血液を全身に送ったならば、死んだ人をも再び助けることが出来、なお、場合によっては永遠の生命を保持せしめることが出来るだろうと考えたのです。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "133酒をのめ、それこそ永遠の生命だ、また青春の唯一の効果だ。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリストという男は永遠の生命に触れれば泉のごとく尽きずと言ったそうだが、なるほど泉のごとく尽きないことは真理だ。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠の生命六一―六三【しざりぬ】驚き惑ひて。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "三一―三三我は即ち最も切に語るを求むるさまなりし魂にむかひ、あたかも願ひ深きに過ぎて心亂るゝ人の如く、いひけるは　三四―三六あゝ生得の幸ある靈よ、味はゝずして知るによしなき甘さをば、永遠の生命の光によりて味ふ者よ　三七―三九汝の名と汝等の状態とを告げてわが心をたらはせよ、さらば我悦ばむ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私は万里征人未だ還らずといったような感懐よりも、流血の土中から咲き出た一本の芥子の花に永遠の生命の美しさを見て、自然の偉大さを思い、同時に人間の愚かさを感じないわけにはいかなかった。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一日医書を繙き、「若返り法と永遠の生命」の項について研究した。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "“臓器や四肢を取替えることによって見掛けの若返りは達せらるるも、脳細胞の老衰は如何ともすべからず、結局永遠の生命を獲得することは不可能である”　私は失望を禁じ得なかったが、そのうちに不図気のついたことは、この医書はかなり版が古いことである。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、呪詞・唱詞系統のものが、永遠の生命を保つ事になるのである。",
              "citation": {
                "source": "古代に於ける言語伝承の推移",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反してモスコオ芸術座は、チェホフによつて、永遠の生命を見出したと云へます。",
              "citation": {
                "source": "演劇一般講話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想の種子のなかに永遠の生命が籠められている。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、私たちの現世の生命は短くて、いつ死ぬか分からないが、もし不信仰の罰をまぬかれて、信仰の酬いとして来世における永遠の生命を把握しようとするならば、今後すみやかに悔い改めて神に帰依し、努めて悪をなさず、善をおこなおうと心がけなければならない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ヴィール夫人の亡霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の旧作の中に言へることあり、曰く「怖れ惑ふ事なかれ、我等が苦痛は一時のものなり、我等が永遠の生命は何物と雖、奪ふ事能はざるべし」と。",
              "citation": {
                "source": "トルストイ伯",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
