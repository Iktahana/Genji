[
  {
    "uuid": "862958b0-0f52-5d89-9f7a-85ddea459e72",
    "entry": "栄誉ある",
    "reading": {
      "primary": "えいよある",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
