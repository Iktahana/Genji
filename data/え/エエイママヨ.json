        "examples": {
          "standard": [
            {
              "text": "失敗を恐れて躊躇していた彼だが、最終的には「ええいままよ」と決断した。",
              "source": "幻辞"
            },
            {
              "text": "反対されてばかりいたが、彼女は「ええいままよ」と自分の道を進むことにした。",
              "source": "幻辞"
            },
            {
              "text": "何度も挑戦に失敗した後、彼は「ええいままよ」と全力で最後の試みに挑んだ。",
              "source": "幻辞"
            },
            {
              "text": "賛否両論あるプロジェクトだったが、リーダーは「ええいままよ」と決行を指示した。",
              "source": "幻辞"
            },
            {
              "text": "周囲からの反対意見に耳を傾けながらも、彼は「ええいままよ」と現地に赴いた。",
              "source": "幻辞"
            },
            {
              "text": "結果がどうなるか分からなかったが、「ええいままよ」と進学を決めた。",
              "source": "幻辞"
            },
            {
              "text": "失敗するかもしれないという懸念を払拭するため、彼は「ええいままよ」とつぶやいた。",
              "source": "幻辞"
            },
            {
              "text": "上司の指示に不安を感じたものの、部下たちは「ええいままよ」と業務を進めた。",
              "source": "幻辞"
            },
            {
              "text": "評判が悪い店だったが、食べてみようと「ええいままよ」と入店した。",
              "source": "幻辞"
            },
            {
              "text": "危険を覚悟で、登山家は「ええいままよ」とエベレスト登頂に挑んだ。",
              "source": "幻辞"
            },
            {
              "text": "社会的な立場を失う可能性があったが、「ええいままよ」と異議を唱えた。",
              "source": "幻辞"
            },
            {
              "text": "成功の見込みが薄かったが、スタートアップの創業者は「ええいままよ」と事業を開始した。",
              "source": "幻辞"
            },
            {
              "text": "老後の安定を捨てて、彼は「ええいままよ」と転職を決めた。",
              "source": "幻辞"
            },
            {
              "text": "家族の反対を押し切って、彼女は「ええいままよ」と留学に踏み出した。",
              "source": "幻辞"
            },
            {
              "text": "多額の借金を抱えながらも、彼は「ええいままよ」と夢に向かって進んだ。",
              "source": "幻辞"
            },
            {
              "text": "不確実な将来を前にして、若者たちは「ええいままよ」と新しい挑戦に身を投じた。",
              "source": "幻辞"
            },
            {
              "text": "批判を受けることを覚悟で、活動家は「ええいままよ」と声を上げた。",
              "source": "幻辞"
            },
            {
              "text": "経済的な困窮を覚悟で、芸術家は「ええいままよ」と創作活動を続けた。",
              "source": "幻辞"
            },
            {
              "text": "自分の信念に基づいて、彼は「ええいままよ」と約束を守ることを決めた。",
              "source": "幻辞"
            },
            {
              "text": "人生を賭けた決断の瞬間、主人公は心の中で「ええいままよ」とつぶやいた。",
              "source": "幻辞"
            }
