        "examples": {
          "standard": [
            {
              "text": "著名な映画評論家が、今日のテレビ番組に出演する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の辛辣な批評は、一部の映画評論家から反感を買っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画評論家を目指して、日々多くの映画を鑑賞している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この映画は、多くの映画評論家から高い評価を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さらに『キングコング』には副音声で、映画評論家によるシーンごとの解説が加えらています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当時の日本映画に、ひょっとしたらちらっとでも描かれていないだろうか、などと私が思いつきを言いまして、後藤さんは映画評論家に聞いて調べたりしたようです。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
