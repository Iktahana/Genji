    "definitions": [
      {
        "index": 1,
        "gloss": "magneto-optical disk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「昔のデジカメ写真、MOディスクに保存したままだけど、もう読み取れるドライブが家にないや。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「128MBのMOを初めて買ったときは、こんなに大容量のデータを持ち運べるのかと感動した記憶がある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「デザイン事務所の倉庫を整理していたら、当時の納品データが入ったMOが大量に出てきた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "『ＭＯＰ』と言う雑誌を買ってくると、「インタラクティブ・マルチメディアの可能性」と題したインタビュー原稿がエキスパンドブックに仕立てられ、付録のフロッピーディスクに入っていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＥＭＯより　街に住む人々に、時候のかはりめをいちはやく知らせるものは街樹である。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞穴のようにうつろな胸、睫毛のない眼、汚点だらけの肌、派手なＫＩＭＯＮＯ、羅物の下着、前だけ隠すための無花果の葉の形の小エプロン――そんなものが瞥見される。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には、この満目のＫＩＭＯＮＯです。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＯＮ・ＰＡＲＩＳ！",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗濯物が全艦を飾って、ここにも鰯をやくけむりが大演習の煙幕のようにＭＯＭＯと罩めわたっていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＯＳＰＳ（モスクワ地方職業組合ソヴェト）劇場の教育部に指導されてメキメキ発達した。",
              "citation": {
                "source": "ソヴェト「劇場労働青年」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＫ―80の記憶装置には、値段の安く電力を食わないＭＯＳ型のＬＳＩを使うことになったが、これがまったく静電気に弱い。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかでも笑い出したのは、ＭＯＳ型ＬＳＩの取り扱い注意である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚異的能力を持つにもかかわらず、ＭＯＳ型ＬＳＩは、静電気に弱い。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方三菱電機は沖電気と組んでＣＯＳＭＯＳシリーズを、日本電気は東芝と組んでＡＣＯＳシリーズを、それぞれＩＢＭ非互換で開発することとなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "横河電気の求める高い性能レベルを達成するために、ＮチャンネルＭＯＳと呼ばれる高速で動作するタイプの半導体の採用が決まっていたことも、浜田にとっては好都合だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで半導体セクションに強く働きかけ、制御回路もＮチャンネルＭＯＳの技術を使ってＬＳＩにまとめてもらうことにした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本電気の半導体事業グループのＣ―ＭＯＳ部門とバイポーラ部門に加え、富士通にも製造を依頼。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔ＭＥＭＯ〕第十八拡中以後の言論抑圧と討論の禁止、研究会禁止、はなはだしかった。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔ＭＥＭＯ〕　宮の秘密主義は（私に対する）甚しすぎる。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔十二月の―ＭＥＭＯ―の欄に〕　宮九州行きのためにつくった夜具木綿しき二枚、木綿かけ一枚、めいせんかけ一枚（きれこちら綿だけ）夜着（裏、わた買）総二〇、八五〇円也、びっくり敗亡。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＴ．ＭＯＲＩＴＺ――眼をつぶって心描して下さい。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "隼人は二階に上がって二時間ほど店の中でねばり、よく考えた末ＮチャネルＭＯＳ型トランジスタとダイナミックＲＡＭを買った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "エム・オー・エス・ペー・エス劇場がどんなによい上演目録をもってたとしてもそうちょいちょいは行けないではないか。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エム・オー・エス・ペー・エス劇場では二日の晩に「憤怒」を上演した。",
              "citation": {
                "source": "インターナショナルとともに",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エム・オー・エス・ペー・エスの「憤怒」も集団農場の組織を主題としたものだ。",
              "citation": {
                "source": "インターナショナルとともに",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エム・オー・エス・ペー・エス劇場の「憤怒」はカターエフの誤謬を清算している。",
              "citation": {
                "source": "インターナショナルとともに",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、モスクワの「エム・オー・エス・ペー・エス」劇場（モスクワ地方職業組合ソヴェトの劇場）に上演され、非常に大衆によろこばれた。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
