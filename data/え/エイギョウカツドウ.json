        "examples": {
          "standard": [
            {
              "text": "海外市場での営業活動を強化するため、新しいチームを立ち上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コロナ禍で、対面での営業活動が難しくなり、オンラインでのアプローチを模索した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "競合他社は、積極的に地域密着型の営業活動を展開している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このイベントは、新たな顧客開拓に向けた重要な営業活動の一環だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この年の暮れ、三菱電機はこのマシンをマルチ16と名付け、翌年一月から営業活動を開始して四月からの出荷に備えることを明らかにした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一方で松本は、各社のマシンにＣＰ／Ｍを採用してもらうよう、ＯＥＭの営業活動にも取り組んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、小売はどうでもいい風で、ほんとの営業活動は横須賀支店の方にあった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
