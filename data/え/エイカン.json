          ],
          "literary": [
            {
              "text": "一八六五年の正月に彼は遂に Senior Wrangler の栄冠を獲た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、また一方、この同じ心理がたとえば戦時における祖国愛と敵愾心とによって善導されればそれによって国難を救い戦勝の栄冠を獲得せしめることにもなるであろう。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シガー一本をできるだけゆっくり時間をかけて吸うという競技で優勝の栄冠を獲たのはドイツ人何某であった。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして物理学者としての最高の栄冠が自然にこの東洋学者の頭上を飾ることになってしまった。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は邁往突進、全力を尽し、必死となつて戦勝の栄冠を奪取せり。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "勾当は、ただちにその中山という人の宿を訪れて草々語らい、その琴の構造、わが発明と少しも違うところ無きを知り、かえって喜び、貴下は一日はやく註文したるものなれば、とて琴の発明の栄冠を、手軽く中山氏に譲ってやった。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭の幸福は、或いは人生の最高の目標であり、栄冠であろう。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の最高の栄冠は、美しい臨終以外のものではないと思った。",
              "citation": {
                "source": "散華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きて行きたいひとは、どんな事をしても、必ず強く生き抜くべきであり、それは見事で、人間の栄冠とでもいうものも、きっとその辺にあるのでしょうが、しかし、死ぬことだって、罪では無いと思うんです。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか兄らの生活が最後の栄冠に至らん事を神に祈る」　こんな文句が断片的に葉子の心にしみて行った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして大成会の券番設置運動に対して最後の栄冠を与えた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて｜Ｍ大尉は第一等の栄冠を得て、予定通りわが日本のために万丈の気炎をはきました。",
              "citation": {
                "source": "国際射的大競技",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに、それまでの僕という人間は修身教科書の結晶のような男で、そうした栄冠を担う資格は充分あるものと他人からも謂われ、自分としても、強い自信をもっていたのであった。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、その当否はともかくとして、我国の、新女優の先駆者としては、此後どれほどの名女優が出ようとも、川上貞奴に先覚者の栄冠はさずけなければなるまい。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方に米国で催された国際オリンピック競技では、さしもに列国が歯を立て得なかった水上の強豪、米国の覇権を、名もない日本の小｜河童連の手でタタキ落させ、何の苦もなく世界の水上王国の栄冠を奪い取らせるなぞ、胸の空くような痛快な波紋を高々と、近代史上に蹴上げている。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く“心臓盗難男の恋の鞘当て”曰く“奇賊烏啼も登場の今様四角恋愛合戦”また曰く“無心臓男の恋の栄冠”と。",
              "citation": {
                "source": "心臓盗難",
                "author": "烏啼天駆シリーズ・２",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは並びなき法華経の護持者としての栄冠が彼を待っていることを門弟、檀那、帰依の大衆は信じて疑わず、声をうち揃えて、南無妙法蓮華経を高らかに唱題したのであった。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで老聖者はコラムに言ってやった、カアルはもうすでに聖者になって、殉教者の栄冠は確かなことであるということと、それから北の方の大きな島国の、女王スカァアの支配するミスト島へ青年をやったらばよいだろうということも親切にすすめたのであった。",
              "citation": {
                "source": "精",
                "author": "CATHAL OF THE WOOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は別に陶器作家を以て世に名を成すのが目的ではありませんから、現代作家を凌駕し排撃して、その栄冠を自己一人にかち得ようとするようなケチな了見を有っているものではありません。",
              "citation": {
                "source": "近作鉢の会に一言",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "角帽をかむる日まで、レントゲン技術員として勉強していた教室、ああ、一緒に入学試験を受け、同じく角帽の栄冠を得た親友｜蛸ちゃんはどうなったろう。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「打ち首に会うか火あぶりにされるか、海の中にほうりこまれるか、いずれにしても、固く神の教えを信じて動かなかったならば、必ず天国の栄冠を賜わるのだ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "優勝の幸運がそのいづれの手に落ち、いづれの村が今日の栄冠を獲得するか、もはや、天のみがこれを命ずると言ひたいのである。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれがうまく栄冠を担えれば彼にとっては、年来の宿望に向って第一歩をふみ出すことになるのです。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A DOG OF FLANDERS",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の瞬間まで信仰する者が栄冠を得るのです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "早軍の泉谷君二ストライクの後、憤然カツと飛ばした熱球砂を噛んで外野に飛び、遂に貴重なる一点を獲得し、茲に早軍は見事三回競技に勝利の栄冠を得たのである。",
              "citation": {
                "source": "野球界奇怪事　早慶紛爭囘顧録",
                "author": "吉岡信敬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分のてきせつな、しかも典雅の栄冠をいただいた言葉のゆえに、多くの人々が自分を往来で見知っていて、うやうやしく自分をながめる、ということを考えた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるい残された女性も、落された組も、さいごの栄冠をさして、なお緊張と夢みる眸を失っていないのである。",
              "citation": {
                "source": "押入れ随筆",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは愛情もなく無恥粗暴な態度で、本当の愛の栄冠となるべき行為から、いきなりことを始めるのだ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "えいかん頑老「……兄者。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
