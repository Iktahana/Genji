          ],
          "literary": [
            {
              "text": "勿論利休は不世出の英霊漢である。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうすると、水は星露の気を承けて、液体中の英霊を散らさないと、彼は信じて居た。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂埋没さるること無き英霊底の漢である。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、定基は父祖の功により、早く蔵人に擢でられ、尋で二十何歳かで三河守に任ぜられたが、然様いう家柄の中に出来た人なので、もとより文学に通じ詞章を善くし、又是れ一箇の英霊底の丈夫であった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "正に毒草を変じて薬となし、糞土を烹て醍醐をなす底の怪手腕と称すべしで、謡曲の教外別伝の極地、声色の境界を超越した、玄中の玄曲を識得した英霊漢というべしである。",
              "citation": {
                "source": "謡曲黒白談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "英霊の資質を持つ者は、耕・漁・工・商皆能く出来て、多能多芸、太宰を感心させた舜帝や孔先生の様なことは不思議でも何でもない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "高野の英霊塔９・７（夕）　工学博士田辺｜朔郎氏は、軍人軍属のためには靖国神社を始め、色々の鎮魂の道具があるのに、学者や芸術家にはそんな設備が少しも無いのは国家として国民として片手落な次第だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけは是非何とかしなければといふので近々高野山に素晴しく大きな英霊塔を建立する考へださうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へは結構だが、自体学者や芸術家などいふ連中には旋毛の曲つたのが多いから、英霊塔を建てたからといつて、その儘成仏はしなからう。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは驀地に進み了して曠如と吾家に帰り来りたる英霊漢である。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教よりもっと古い信仰である神道の神社では、神官と人々が、かつて天皇のために戦って死んだ英霊に、また戦の神々に祈りを捧げていた。",
              "citation": {
                "source": "男子の本懐",
                "author": "A WISH FULFILLED",
                "note": "青空文庫"
              }
            },
            {
              "text": "意宇という地区の神社まで行軍したのですが、そこには英霊が祀ってありました。",
              "citation": {
                "source": "男子の本懐",
                "author": "A WISH FULFILLED",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、得難きは当年のル・メルキウルに、象徴主義の大旆を樹てしが如き英霊底の漢一ダアスのみ。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一月十三日）　　　　　嘲魔　一かどの英霊を持つた人々の中には、二つの自己が住む事がある。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ云ふ英霊漢の筆に成つた画は、何百円と雖も高い事はない。",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念館を観たあとで白玉山に登る者は、誰も悲惨な戦役の犠牲となつた将士弐万七百の英霊の前に、おのづから頭下り涙の落つるを禁じ得ないであらう。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もダンヌンツィオは十五の時に詩集を出したとか、池大雅は五つの時に書を善くしたとか言ふやうに、古来の英霊漢は創作の上にさへ、天成の才能を発揮してゐます。",
              "citation": {
                "source": "文芸鑑賞講座",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この故に古来の英霊漢は鑑賞上の訓練を受けた上にも更に又訓練を重ねようとしました。",
              "citation": {
                "source": "文芸鑑賞講座",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く他に私心はござらぬ――諸君のために某計るに、東照神君の英霊の在す駿州久能山に籠もられるこそ策の上なるものと存ぜられ申す。",
              "citation": {
                "source": "開運の鼓",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民士気の昂揚は今や、政治的にも喫緊事とされてゐるが、百千の名士の愛国的訓話は、一回の「地理の書」の朗読に如かぬことは云ふまでもなく、靖国の英霊を迎ふるわれら国民の至情に対し、如何なる高官の弔辞も、数行の「おんたまを故山に迎ふ」る詩片より荘厳にして感動的な印象を与へ得ないのである。",
              "citation": {
                "source": "「詩歌の午後」について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより、旧部下たる志岐上等兵の英霊を親しく慰めんとの御志でありますが、序でをもつて、少佐殿は、われわれ一同に、志岐上等兵の鬼神を泣かしむる華々しい最期を、直接この眼をもつてご覧になつたまゝ、つぶさに語り聴かせてもよいといふお思召しであります。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "靖国神社の神殿の前へひざまずいて、清作さんは、低く頭をたれたときには、すでに討死して護国の英霊となった、戦友の気高い面影がありありと眼前にうかんできて、熱い涙が玉砂利の上にあふれ落ちるのを禁じえませんでした。",
              "citation": {
                "source": "村へ帰った傷兵",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして英霊は永久に生きていて、自分たちを見守っていてくださるのだ。",
              "citation": {
                "source": "夕焼けがうすれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "辰一は「殉国英霊の家」と、立て札のしてある家の前を通るたびに、目に熱い涙をためて、丁寧に頭を下げました。",
              "citation": {
                "source": "とびよ鳴け",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "無用の戰死者を増すのを避くるためには結構なことだとして、その発表の仕方が「神霊の加護」「アッツ島玉碎部隊英霊の加護」など、例によって奇々怪々、国民を愚弄するかと腹だたしい。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "「英霊何個」　十一月の十一日にマニラに帰り着いた。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々なことをいったあげく、「この中に英霊を持っている人があったら、何個あるか、その数を届けて下さい」といって立去った。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「名前を知っていますか」「Ａ大尉といいます」「あなたはＡ大尉が、たった今、英霊何個といったのを聞きましたか」「ああ、そういえば、そんなことをいっていましたね」……。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに不注意とはいえ、英霊を何個と呼ぶ大尉、それを変だとも無礼だとも思わぬ人達。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            }
          ]
        }
