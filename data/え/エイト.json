        "examples": {
          "standard": [
            {
              "text": "ボートレースの「エイト」は、8人の漕ぎ手と1人の舵手で構成される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "大学のボート部には、エイト艇が何艇かあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "決勝戦では、ライバルチームの「エイト」が圧倒的なスピードを見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
