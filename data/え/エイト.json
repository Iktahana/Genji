        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この箱には、ボールがエイト個入っています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "時計の文字盤には、ローマ数字でエイト（VIII）が刻まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "毎週エイト回、ジムに通っています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そのレコード止してくれない」聴き手の方の青年はウエイトレスがまたかけはじめた「キャラバン」の方を向いてそう言った。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "厭だと思い出すととても堪らない」　黙ってウエイトレスは蓄音器をとめた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生をもう二つ」　話し手の方の青年は馴染のウエイトレスをぶっきら棒な客から救ってやるというような表情で、彼女の方を振り返った。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはは入って来ると同時にウエイトレスの方へ色っぽい眼つきを送りながら青年達の横のテーブルへ坐った。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ポーリンさんにシマノフさん、いらっしゃい」　ウエイトレスの顔は彼らを迎える大仰な表情でにわかに生き生きし出した。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日は女優、今日はウエイトレス、明日は女学生、明後日は交換嬢と、到る処に手を握り締め涙を流して、「あなたは僕の未来の妻です」　と身をふるわせ得る鳥打帽……。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "短い指の女給が、綺麗な指をしているという他のウエイトレスを伴って戻って来た。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、いま帰って行かれたあの若いお客さんから得た知識に依ると、何でもこのダンスは、四五年前に日本へ伝ったもので、普通に、シックス・エイトって言われているそうだ。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄に例がないのでクリエイトするより仕方ありません。",
              "citation": {
                "source": "農場開放顛末",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄妙きわまりなき東洋日本の縮図―― It is SAKURA; yes sir, just off Charing Cross !『ナンバ・エイト、定食スリイ！",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "安い代わり動作速度の遅いメモリーを使おうとする際には、ＣＰＵにウエイトと呼ばれる待ちの状態を意図的にはさんでタイミングを合わせる手法が使われることがある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時としては高速の８０８６―２を使おうとすれば、使用できるメモリーとのバランスをとるためにウエイトをかける手が常識的には考えられたが、クロック周波数を七Ｍヘルツに抑える代わり、ウエイトのかからない構造が工夫された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自らもハードウエアに手を染めてきた三人のハッカーは、ＣＰＵにウエイトをかけないために巧妙にタイミングをとった設計やカラーのグラフィックスを高速処理するプレーン構造を目の当たりにして、ＰＣ―１００に向けてアプリケーションを書く意欲をいっそうかき立てられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼく達、ボオトの場景が最後を飾り、観ていれば、撮影された覚えもある荒川放水路、蘆の茂みも、川面の漣も、すべて強烈な斜陽の逆光線に、輝いているなかを、エイト・オアス・シェルの影画が、キラキラする水を鋭く切り、凄まじい速さで、進んでゆくのでした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "……實はそこにひとりの可哀らしいウエイトレスが居て、その人を僕はひそかに好きになつた。",
              "citation": {
                "source": "パイプについての雜談",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、芝生の向うから、いつのまにか彼女がもう一人のウエイトレスと現はれ、何か小聲に話しながら、僕等に近づいてくるのを見る。",
              "citation": {
                "source": "不器用な天使",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕を見て珍らしさうに笑ひかける見知つたウエイトレスの顏のいくつかが、僕の探してゐるものから僕の眼を遮る。",
              "citation": {
                "source": "不器用な天使",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "別の夜、一人のウエイトレスが僕に言ふ。",
              "citation": {
                "source": "不器用な天使",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はウエイトレスを呼ぶ。",
              "citation": {
                "source": "不器用な天使",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に、他のウエイトレスもまた僕のところに來ようとする。",
              "citation": {
                "source": "不器用な天使",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから自動車は彼女を乘せて、半※轉をしながら走り出し、一分後には、午後なので殆ど客の入つてゐない、そしてウエイトレスの姿だけのちらと見えるシヤノアルの前を通り過ぎる。",
              "citation": {
                "source": "不器用な天使",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあまりに超越的な、むしろデヴィエイトした道のように思われるから。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "買いたいと思うかどうかは別問題として、何らかの方法で、各人の鑑賞度にウエイトをつけることが出来れば、その平均値をもって、美的価値を測る尺度とすることが出来そうである。",
              "citation": {
                "source": "小林秀雄と美",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことをいっても、実は言葉の遊戯に過ぎないので、そういうウエイトをつけるとなったら、抽象的なものしかない。",
              "citation": {
                "source": "小林秀雄と美",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼女が若し望むならば、田沢の会社で適当な地位を与へるか、或は、彼のプライヴエイトの秘書にしてもいゝがどうだといふのであつた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "グロウスタア、シチュエイト、コヴェントリ、ウェスト・グリニチ、及びイクシタの五都市の人口は、西紀一七四八年には五、〇三三であり、西紀一七五五年には六、九八六であった。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそのビルの一階にある喫茶店のウエイトレスをしていた。",
              "citation": {
                "source": "トンボの死",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
