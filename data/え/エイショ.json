[
  {
    "uuid": "e3fbdb98-91ce-5d76-b49f-123dcf7ef6ee",
    "entry": "営所",
    "reading": {
      "primary": "えいしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
