    },
    "definitions": [
      {
        "index": 1,
        "gloss": "barracks",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "軍隊は新しい営所へ移動し、再編成を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "部隊は演習のため、一時的に現地の営所に駐屯した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "退役軍人の多くは、かつて自分が所属していた営所での生活を懐かしく語る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「のろくさと、営所に居るように油を取ってはいけない！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中武芝の従兵等は丁度経基の営所を囲んだやうになつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "経基は仲悪くして敵の如き思ひをなしてゐる武芝の従兵等が自分の営所を囲んだのを見て、たゞちに逃れ去つてしまつて、将門の言によりて武芝興世王等が和して自分一人を殺さうとするのであると合点した。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうもゆう方、君が来て呉れるというハガキを見てから、それをほところに入れたまま、ぶらぶら営所の近所まで散歩して見たんやけど、琵琶湖のふちを歩いとる方がどれほど愉快か知れん。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが後の玄洋社の前身であったが、天下の形勢を憂慮する余り、近所界隈の畑や鶏舎を荒し、犬猫の影を絶ち、営所の堀の蟇を捕って来て、臓腑を往来に撒布するなぞ、乱暴狼藉到らざるなく、健児社の連中といえば、大人でも首を縮める程の無敵な勢力を持っていたものであった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはふと営所らしい建物の前へ来た。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、その営所を囲む木柵に多くの男女が集っていた。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワトソンは木柵に身を寄せながら営所の中を覗き込んだ。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……近藤殿の以前の隊長、芹沢鴨殿でさえ――尤もこれは、何者に殺されたか不明ということにはなっているが、真実は、土方殿が、近藤先生の命令によって、壬生の営所で、深夜寝首を掻かれたくらいで。",
              "citation": {
                "source": "甲州鎮撫隊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天主の松の上をふわふわ飛んで営所のなかへ落ちた。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "急にわれわれの粗末な営所へ武装した兵士の一隊がやって来ました。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "料亭幸楽も午前十時ごろ若い将校から多量の酒と弁当の注文をうけたが、ここもあるいはかれらの宿営所として占領されるかもしれない。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "で元の営所からこんどの営所へ行くには、パリーを通らなければなりません。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "営所へ、柴田方の大物ふたりまでが、捕虜となって曳かれて来た。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "姿が見えなければ、来いといって、呼べばよいのに、人のよい信雄は、着くやいな、みずから家康の営所へ行って、取るものも取りあえず駈けつけて来たことなど語って、「筑前の兵力は、ここだけでも八万余。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃また、如意村の郷士で石黒善九郎という者が、信雄の営所へ、密告に来た。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "……後刻、成政どのを、御営所まで、お曳きつれ下さるように」　と、伝達して戻った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おそろしい男だ……」　今さらのように、成政は、秀吉の真を知った心地に打たれながら、営所を退がって、前田家の陣所の前を、悄々と、退がって来た。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "勅使は、聖旨を体して、曹操の営所へおもむいた。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦えば戦うほど、両雄とも精気を加えるほどなので、双方の陣営にある将士はみな酔えるが如く手に汗をにぎっていたが、猛戦百余合をかぞえた頃、突然、蜀の陣で金鼓を鳴らすと、それを機に、魏のほうでも引揚げの鼓を叩き、の営所へ引き退いた。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲達は営所に帰るやいなすぐ左右の者を派してその部将を床几の前に求めた。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまのごとき広言を吠ざくなら、鶯谷（義貞の陣営所）へ来て吠ざくがいい」「さあ、歩け歩け」　と、軒ばをはなれ、さらに若侍の肩を、も一つ強く突こうとした。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴ヶ岡の元神官屋敷そのままの営所で、まだ新田の館というものを、他に新築しようとしてもいなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、頼尚はその晩、尊氏の営所へ、わざと鮮魚や野鳥の一ト籠を献上に持って出て、「十二｜刻（一昼夜）の御別行（服喪）だけでも、このさい過分至極なのに、もしお体にでもさわっては一大事ですし、また、陣中どことなく銷沈のていにもござります。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
