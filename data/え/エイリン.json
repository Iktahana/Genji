    },
    "definitions": [
      {
        "index": 1,
        "gloss": "forest management",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "持続可能な営林は、森林資源を次世代に引き継ぐために不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域では、古くから計画的な営林が行われてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "営林技術の進歩により、木材の生産効率が向上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "昨日わざわざ森栖校長先生が俺の役所（営林所）に訪ねて来られて、お前が承知してくれさえすれば、先方では願ったり叶ったりだと言っている。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大森林の下を通って海抜四一三二尺もある峠へ登った、鳥取営林署、氷ノ山国有林の立札がある。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石けんの会社に勤めを持つてゐると云つたが、もう一度、富岡には、農林省へ戻つて貰つて、何処でもいゝ地方の山の中の営林署へでも行つて貰ひたかつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は、高池町の林業試験場へ行くよりも、南の果ての孤島である、屋久島の営林署へ行きたかつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高池町の林業試験場が、気がむかなければ、同じ、和歌山の伊都郡九度山町の、高野営林署にも、君の行くポストはあると、その友人は勧めてくれた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人は、屋久島は、営林署だけで保つてゐるやうな島だが、人情は純朴で、一ヶ月は雨の降りつゞいてゐる島だが、覚悟が出来るかいと笑つて云つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そこの営林署に口があるンでね、五六年、あるひは一生、そこへ行つて、山の中で暮すつもりだ……」　ゆき子は、富岡の肩を抱き締めて泣いた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋久島の営林署に電報を打ち、ハガキを買つて、富岡は松井田の両親へあてて、鹿児島まで来て、船を待つてゐる音信を書いた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は、屋久島の営林署へ勤めを持つて、赴任して行く途中なのだと云ひ、暫く仏印の林野局に軍属で行つてゐたのだと話した。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者は、富岡が、営林署へ勤めを持つと聞いて、急に好意をましたらしく、自分も、昔は、北海道帝大へ行くつもりだつたと、少年の頃の理想を話したりした。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこには、営林署関係の医者が、山の中にゐる筈ですがね。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろは、営林署の方で、何日おきかに、電気を供給してゐるやうですね……。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂地に、四五人の人が、はしけを出迎へてゐたが、その中の二人は、営林署の人で、富岡を迎へに出てゐる人達である。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ゆき子を濡れた外套ごと抱きかゝへて降ろしてやると、営林署の出迎への人は、富岡のところへ、さくさくと砂をきしませて走つて来た。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "船着場で、営林署の迎へのものに、「奥さん」と云はれて、富岡は、その時、ふつと、官吏生活を長く続けてゐる、健康な家族を思ひ出した。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は営林署へ行き、赴任の挨拶をした。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関車の後には、四｜輛ばかりの無蓋トロッコが連結して、その四台のトロッコには、米俵や、野菜や、郵便や、塩叺が積み込まれて、山へ行く営林署の樵夫が五六人、寒さうに俵に腰をかけてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋久島の、営林署の管轄になつてゐる土地は、二万ヘクタール位であつたが、すべて官有林であつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は、営林署の事務室に飛び込んで、ストーブにあたつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この路をそんな恰好で通るのは近くにある営林区署の役人か発電所の技手ぐらゐのものだつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかで、「営林署だ」といふ声が聞えた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋を渡ると、そこは営林区署出張所の材木置場で、その向ふに稍小高い山を背負つて出張所の建物が立つてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼倉の一件も、営林署の消防演習のことも、開業のはじめに彼が空想してゐたところのもの、あの町の人の心をしつかりと捉み、信頼させるといつた野心の点から云へば、巧まずしてその効果を果すものだと見做していゝ筈であつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尺五上が秋田営林署で千五百円で出しとる。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その検査官はアルサスの営林大区へ栄転して、間もなくそこで死にました。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣橋で南股を渡ると其処に営林署の建物があって、登山者は入山許可証を差出すことになっている、この許可証は出発の時に山木で渡して呉れる。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは青森県営林局ならびに同県下営林署の人々と同行のときであった。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "資料を入手する暇はないが、同窓の友で旭川の営林局長をつとめていた人の話では、そうである。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道の森林資源は、八五％が国有林で、営林局の管轄下にある。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
