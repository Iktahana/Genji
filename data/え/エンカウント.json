        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あ、やべっ！ はぐれメタルにエンカウントした！ 逃げられる前にさっさと倒さないと」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このエリアは敵とのエンカウント率が異常に高くて、なかなか目的地にたどり着けない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "シンボルエンカウント方式を採用しているため、背後から近づけば不意打ちを狙うことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ダンジョンの最深部で、予想外の強敵とエンカウントしてパーティが半壊してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
