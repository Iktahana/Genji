[
  {
    "uuid": "c8a90ef6-0561-5df7-b62f-13954ef75ad2",
    "entry": "沿岸",
    "reading": {
      "primary": "えんがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
