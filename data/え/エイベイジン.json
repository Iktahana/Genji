        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このパブには、いつも英米人の観光客が多く訪れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国際会議では、様々な国の代表者に交じって多くの英米人が議論に参加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "英米人のユーモアのセンスには、共通する部分と異なる部分がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "英米人ノ持續セントスル國際的特權ノタメニ宣傳サレツツアル平和主義非軍國主義ガ、其ノ特權ヲ打破センガ爲メニ存スル日本ノ軍備及ビ戰鬪的精神ニ對スル非難トシテ輸入サレツツアル内容皆無ノ文化運動。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "予、大学予備門で習うた誰か英米人の読本にも類話があったが忘れしまった。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、二等は主として英米人。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "田辺太一に啓発せられて英学に志し、中浜万次郎、西吉十郎等を師とし、次で英米人に親炙し、文久中仏米二国に遊んだ。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人が、有色国民、殊に同種同文の隣邦民に対してすら、甚だ尊大であるのに、白色人種、殊に英米人の人も無げな振舞ひに対し、飽くまで幇間的態度を示すのは、誠に笑止千万である。",
              "citation": {
                "source": "左団次一行",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "又 Basic の讀書用として英米人に親しみ深い更に250個の熟語（これも850語を組合せて出來たもの）が The Basic Words に**印を附して示してある。",
              "citation": {
                "source": "ベーシック英語",
                "author": "高田力",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に Basic を知ることは、英米人にとつても英文の意味を徹底的に解釋する上に有效なる一つの助けとなるものである、１と言つてゐる。",
              "citation": {
                "source": "ベーシック英語",
                "author": "高田力",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、英語ならば「英米人のやうに」書ける、喋れるといふことが、英語学習の理想であつた。",
              "citation": {
                "source": "外国語教育",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより文法や語彙の正確なのに越したことはないが、飽くまで、「自分のもの」をそれで伝へる工夫をすべきであつて、英米人風の云ひ廻し――つまりイディオムなどといふふうなものは、日本人が無理に使ふのは不見識だといふことである。",
              "citation": {
                "source": "外国語教育",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテル・モーイはオーベルホーフェンの高台にある、水をへだててニーセンが、水際の私達の宿から見るよりは、遥かに高く仰がれる、室や設備もずっとととのって立派だが、御客の殆んど全部は英米人、いささか窮窟な感じがする、居心地に至っては、パンションで一日六フランの、シェーナウには遂に及ばない。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の教科書はナショナルリーダーを用ひてゐたといふことだから、今日の女学校と変りはないが、教師の多くは英米人で、西洋史、日本史のほかに英米史を特に教えたものださうな。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "英米人の夏帽子には麦藁多しと、五、六年前帰朝者の語る所なり今は知らず。",
              "citation": {
                "source": "洋服論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞けば鮎沢君の部下が左翼で引張られ、その証人として横浜の警察に呼ばれたが、同君が英米人と交渉があったとか、国際労働支局長だったとか、こんなことから過去一年半ぐらい注意されていたからだという。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はつぎの卷において、長崎に渡來した「電胎法」による活字を、逆に日本から上海へ逐うてゆき、英米人の「漢字活字の創始」をも、支那、ビルマ、印度における彼等の侵入の歴史のうちに見てゆきたいと考へてゐる。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "英米人の前には「ジヤパン」と稱し、佛人に逢へば「ジヤポン」と唱へ、獨人に對しては「ヤパン」といふは何たる陋態ぞや。",
              "citation": {
                "source": "國語尊重",
                "author": "伊東忠太",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは自分がアフリカのニグロについて何も知らなかったせいでもあるが、また同時に英米人の祖先たちがアフリカに対して何をなしたかを知らなかったせいでもある。",
              "citation": {
                "source": "アフリカの文化",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "英米人はよく、｜整えられた結婚と愛の結婚ということをいう。",
              "citation": {
                "source": "この頃の皇太子殿下",
                "author": "小泉信三",
                "note": "青空文庫"
              }
            },
            {
              "text": "東都明治学園卒業後英米人に英語を教授すること数年云々とあった。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「英米人に英語を教えるくらいなら、余程英語の出来る先生に相違ない」　と早合点をしてしまった。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然控え目になって遠慮勝ちに話すから分が悪い」「成程」「英米人と日本人が英語で話しているところを見給え。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日露戦争は、英米人が、こぞって日本に同情し、日本を支援し、ポーツマスの講和条約は、米人ルーズベルトの斡旋で成立したのであった。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
