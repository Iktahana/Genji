[
  {
    "uuid": "e4b947d7-9810-555c-a271-f272ada1dfe8",
    "entry": "円周",
    "reading": {
      "primary": "えんしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
