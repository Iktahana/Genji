    },
    "definitions": [
      {
        "index": 1,
        "gloss": "circumference",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「この木の幹、円周を測ったら3メートルはありそうだよ」と測量テープを回す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "数学の時間、コンパスを使って描いた円の円周を求める公式を何度も解かされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ランニングコースの円周がちょうど400メートルなので、ペース配分を計算しやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "直径百メートルもあるかと思う円周の上を走って行くその円の中心と思う辺りを注意して見るとなるほどそこに一羽の鳥が蹲っている。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから数十里の裾野を、曲馬の馬が、同じ円周を駆けめぐるように、廻って見たまえ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで吾人は、先ず詩の円周する外輪を描き得たわけだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは伊太利フロレンスの美術館の半円周の褐色の嵌め壁を背景にして立つてゐた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は円周の広々とした、深さも巨大な、漏斗の内側の表面に、まるで魔法にでもかかったように、なかほどにかかっているように見え、その漏斗のまったくなめらかな面は、眼が眩むほどぐるぐるまわっていなかったなら、そしてまた、満月の光を反射して閃くもの凄い輝きを発していなかったら、黒檀とも見まがうほどでした。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりはいま、その円周と、十六角形の一辺とのあいだにいる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "上半分には、円周の内側に沿って、大きく「ＫＷＴＳ」とあり、中心の金色の小さな円の左側には “Side A” 右側には “45 RPM” 下には、まず “TAKASHI” とあり、その下に “You Baby” と金糸で縫いとってある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、円内の下には、円周に沿って、「１９６６―１９９１」という文字が加えられている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "円の面が定まれば、その円周に沿うて竹簀が下ろされる。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "航空部隊の一部は、全艦隊の外二キロメートルの円周にそい、はるかな高度をとって、ぐるぐる旋回し、夜暗とはいいながら不意打の敵に対する警戒を怠らなかった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、詳しいことは何も知らなかつたが、彼は、さんざんに頭をしぼつた上句「山桜」とかといふ馬にあらん限りの投票を尽したところが、向きが定まらないうちにスタートを切られて、遂々終りまで半円周近くも棄てられ続けだつたといふのだつた。",
              "citation": {
                "source": "競馬の日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は拡がる彼の意志の円周を、動乱する街路の底から感じた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はいつでも、お前の寝ている寝台から綱をつけられていて、その綱の画く円周の中で廻っているより仕方がない。",
              "citation": {
                "source": "春は馬車に乗って",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルデア人が円周を三六〇度に分けたのは畢竟ここから起ったことである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルデア人が地球大円周の長さの測定を行ったらしいと思われることがある。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "この見積りに従えば、地球の大円周の長さは四三八〇〇キロメートルになるが、これは実にほとんど正しいのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つの数量の比は一対六・四二で、すなわち、円の半径と円周との長さの比、一対六・二八よりも約二パーセント強だけ小さい。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことからして、スミスは、金字塔の高さと周囲との比をもって円の半径と円周との比を表わそうとしたものであるということを、十分な根拠らしいものなしに結論している。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "エラトステネス（Eratosthenes 紀元前二七五―一九四年）はアレキサンドリアで、夏至と冬至の正午における太陽の高度を測定し、それを基にして南北回帰線間の距離が地球大円周の八三分の一一に当るということを算定した（この値は実際より約一パーセント強だけ大きい）。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二ヶ所の距離を、駱駝を連れた隊商の旅行日数から推定し、それによって地球の円周を二五万スタディア（四二〇〇〇キロメートル）と算定した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、これは人類がその中で出口なしに廻転しているところの円周ではなくて、そこでは各々の後から来る円周が先行する円周よりも広汎であるところの螺旋である。",
              "citation": {
                "source": "ベリンスキーの眼力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何十年もかけて円周率を追いかけた中世や近世の数学者の労には敬意を表するにしても、その人生は魅力的とは思えない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、落着くところは、矢張り『円周率』であった。",
              "citation": {
                "source": "脳波操縦士",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "πなどという字は、円周率を表わす時以外に、一向使った憶えがないのであった。",
              "citation": {
                "source": "脳波操縦士",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても『円周率』とは、何を意味しているのであろう、3.14 ……という無理数であるπは、何んな意志表示なのであろう。",
              "citation": {
                "source": "脳波操縦士",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、仕方なしに、東京から、数日を費して、円周率に関する書籍を取り寄せて見た。",
              "citation": {
                "source": "脳波操縦士",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、後ろの方で立ち上った東野は、「円周率は三コンマの何んとかじゃ割り切れんわい。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき、東野さんがドームにいたんだが、人民戦線の駆り出しが通ったときに、円周率は三コンマの一四じゃ割り切れんぞ、用心をせいと呶鳴っていたな。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
