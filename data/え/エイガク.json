    "definitions": [
      {
        "index": 1,
        "gloss": "study of the English language as a means to acquire Western knowledge (esp. after the end of Japan's period of isolation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "幕末から明治初期にかけて、福澤諭吉は英学を学ぶことで西洋文明を日本に紹介した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "当時の知識人たちは、英学を通して世界の動きを理解しようと努めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この旧家には、明治時代の英学書が数多く保存されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一八七五年八月、ブリストルの大英学術協会に出席中に郷里から電報で呼びかえされた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八二年サザンプトンにおける大英学術協会では Section A の座長をつとめた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八四年カナダのモントリオルで大英学術協会が開かれたときにレーリーが会長に選ばれた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに増補された交流に関する章の一節は、十年ほど前に大英学術協会に提出したものであるが、その時どうした訳か出した論文原稿に著者の名が抜けていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校を了えて後は一年ばかり中学校を修めたが、それも廃めて英学を修める傍、菊地松軒という先生に就て漢学を修めました。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーヴィングの「スケッチブック」が英学生の間に流行していたのもそのころであったと思う。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る英学塾の女生徒が、Ｌという発音を正確に発音したいばかりに、タングシチュウを一週二回ずつの割合いで食べているという話も亦、この例である。",
              "citation": {
                "source": "女人訓戒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほう、すると英学者だ、そのお酌では恐縮です、が超恐縮で、光栄です。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉の圭子は相不変女子大に通い、新子は津田英学塾に通っていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子は、英学塾の寄宿舎などで、お友達の誰とやっても、なかなか負けなかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃から、文学への熱望甚しく、再び今村力三郎氏に寄食し、国民英学会、国漢文研究所、日本大学などを転々して、比較的文学の道に直接とする学科の聴講に努めた。",
              "citation": {
                "source": "簡略自伝",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "知人英学士会員ブーランゼー方で見たはインド洋産七、八フィートあった、熊野で時々取るを予自ら飼い試みるにブーランゼー始め西人の説に誤謬多し、そのうち一論を出し吹き飛ばしてくれよう。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、午後からは、以前の如く麹町の某英学塾に通い、時雄も小石川の社に通った。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後英学を初めてからは、悪足掻もまた一段で、襦袢がシャツになれば唐人髷も束髪に化け、ハンケチで咽喉を緊め、鬱陶しいを耐えて眼鏡を掛け、独よがりの人笑わせ、天晴一個のキャッキャとなり済ました。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日英学でも遣らせようと言うには他に好い学校が無いんですもの。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして日本女子大学と英学塾とは早速大学に昇格するための運動を開始した。",
              "citation": {
                "source": "女の手帖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に津田英学塾を設立した津田梅子が、六つの歳に岩倉具視の一行とアメリカへ留学（明治四年）したり上流婦人でも男に劣らない一般教育の基礎を持つ時代があった。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巖本真理のおばあさんは明治初期の婦人英学者若松賤子である。",
              "citation": {
                "source": "手づくりながら",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが駐屯して来た軍隊は、その学校の表門にかけてある看板が、生意気だ、今頃英学塾というような敵性語を教える看板を麗々しくかけておくのは国賊だと、その看板をはずして前の溝川へ投げ込んでしまった。",
              "citation": {
                "source": "結集",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "英学出の彼はあの名高い学問のある坊さんに就いて精しいことは知らなかった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が英学を修め始めた時はまだ父は生きていて、非常に心配した手紙をくれたが、あの父の心持も思い当った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "文部省は新しい教育をしようとしているかも知れませんが、東京女子大にしろ、津田英学塾にしろ、学生達の生活はみじめなものです。",
              "citation": {
                "source": "若人の要求",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は英学塾を出てまだ間もなく、赤い帯をしめた一人の眼の大きい娘であった神近市子。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田英学塾を卒業してのち、社会問題の研究に進んでいた彼女は、当時まだ山川均との結婚前で、『番紅花』にカアペンタアの翻訳などをのせたりもしている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "田辺太一に啓発せられて英学に志し、中浜万次郎、西吉十郎等を師とし、次で英米人に親炙し、文久中仏米二国に遊んだ。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなったら、再び頂天立地の自由の身となって、随意に英学を研究しよう。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私立静岡英学校の教頭になったからである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "英学校の職は故の如くである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "静岡を去るに臨んで、渋江塾を閉じ、英学校、英華学校、文武館三校の教職を辞した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言うと、何だか自分も英学をかじッて人格が高尚かというに、そうではない。",
              "citation": {
                "source": "人格の養成",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
