          ],
          "literary": [
            {
              "text": "皆の腰かけている平土間の座席におられるものと思いこんで行ったら、その横を通りすぎて、計らずも数人の人の並んでいる演台の上へ案内されてしまった。",
              "citation": {
                "source": "打あけ話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時話していた人のその日の記念日のわけを説明する講演が終ったら、演台の下にひかえている音楽隊が高らかに、あっちの国歌になっている歌の一節を奏した。",
              "citation": {
                "source": "打あけ話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤本が演台に立った。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて、最初「人間」に発表し、更に、文芸家協会編纂の創作集に収録された第一稿は、今後、上演台本として用ひないことにしたいばかりでなく、いかなる目的にしろ、これを再び活字にすることは絶対にないやうにしてほしい。",
              "citation": {
                "source": "「道遠からん」あとがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "○場内やや喧噪、間で演台の上にある水を一人が貰ったら、空になる迄一人ずつ皆がのんだ。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版・ラジオ・キネマ・演台（舞台及び演壇）、博覧設備（展覧会・博覧会・ショーウィンドー・スカイサイン・アドバルーン等々）など＊。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "同席の愛国者にそそのかされて演台に上がった暴君サクソン人の行商人はズバズバこう言ったそうだ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "演台に立つマーサ・ストーナリーは青いニットのウールと真珠のネックレスを纏っていた。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼女は演台を譲った。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "演台に戻ったマーサは誉れの名前を読み上げた。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オイ、来いというのにどうして来ねえんだい！",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その悪済ましが気に喰わねえんだい。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その悪済ましが気に喰はねえんだい。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、どうもしねえ、そン畜生を渡せてえんだい。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何がふにおちねえんだい」「でもね――」「なんだよ」「あれほどのだいそれたまねをしたっていうのに、なんだってまた尾州さまは、おらのだんなに手入れすんなとおっしゃったんだろうね」「ちぇッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "要吉の仕事の第一は、毎朝、まっさきに起きて、表の重たい雨戸をくりあけると、年上の番頭さんを手伝って、店さきへもちだしたえんだいの上に、いろんなくだものを、きれいに、かざりたてることでした。",
              "citation": {
                "source": "水菓子屋の要吉",
                "author": "木内高音",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い込んだが最後之助、どんな事でもやり通そうという窩人の娘にゃ向かねえね」「ふん、どうして向かねえんだい？",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様はよくもまア、大正の今日に大塩平八郎なんて奴を冥途から呼び返して来やがったなア、俺はな、貴様の顔を見るさえも癪にさわって仕方がねえんだい！",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、お前もお役人なら、なんだって働かねえんだい、なんだって勤めに出ねえんだい？",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
