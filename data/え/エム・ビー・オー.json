        "examples": {
          "standard": [
            {
              "text": "わが社ではＭＢＯを導入しているため、期初に設定した目標の達成度がそのままボーナスの額に直結する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今度のＭＢＯ面談で、上司にどんな目標を提示すればいいか分からなくて胃が痛いよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "形骸化したＭＢＯに陥らないよう、部下との定期的な面談を通じて進捗を確認し、必要に応じて目標を修正する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
