        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ターゲットをレーダーに捉え、システムが完全にエンゲージしたことを確認する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カメラのフォーカスが被写体にエンゲージし、シャッターチャンスを逃さない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「こちら、敵機団をエンゲージしました。直ちに追撃に移ります」と通信が入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "クラッチがしっかりエンゲージしていないと、ギアボックスに過度な負担がかかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
