        "examples": {
          "standard": [
            {
              "text": "リビングには、家族みんなで映画を見るための大型液晶テレビがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最近の液晶テレビは、画質が非常に鮮明で、まるで現実を見ているかのようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供部屋に、ゲーム専用の小型液晶テレビを置いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "店舗のセールで、型落ちの液晶テレビをお得に購入できた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "エスカレーターに乗ってテレビ売場の四階で降りしばらくぶらぶらと歩き回っていたが、ポケット液晶テレビばかりを陳列した棚のところでふと立ち止まり、財布を取り出してまだ十分余裕があることを確かめた上でカシオのＴＶ―３６０を買うことに決めた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
