        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "そのプロジェクトは、英仏両国の共同出資で進められています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "両国間の文化交流を促進するため、英仏共同のフェスティバルが開催される予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その新しい航空機は、英仏の技術を結集して開発された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "外交官たちは、英仏関係のさらなる深化について協議しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
