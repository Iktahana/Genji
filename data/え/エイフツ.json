    "definitions": [
      {
        "index": 1,
        "gloss": "Britain and France",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "現在、英仏はEU離脱後の新たな関係構築に注力しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "第二次世界大戦中、英仏の連携は枢要でした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "英仏間の貿易協定に関するニュースは、多くのビジネス関係者の注目を集めました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今週末、サッカーの試合で英仏代表が激突する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "英仏海峡の難避者を満載した船の上で、過去の傷ましい事件が私の記億を新たにするのでした。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、私が棄てられた情人の頭文字Ｅを以て、新婚の夜は、妾の横顔英仏海峡に描いて敬礼すること。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "日清戦争に際して、背後の労働者階級と貧農がどんな風であったかは、この「愛弟通信」から求められ得ないが、国際的な関係の現れとしての北支那海に於ける英仏独露の軍艦の浮游が報じられてある。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は軍国主義を標榜する独逸が、何の位の程度に於て聯合国を打ち破り得るか、又｜何れ程根強くそれらに抵抗し得るかを興味に充ちた眼で見詰めるよりは、遥により鋭い神経を働かせつつ、独逸に因つて代表された軍国主義が、多年｜英仏に於て培養された個人の自由を破壊し去るだらうかを観望してゐるのである。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は独逸によつて今日迄｜鼓吹された軍国的精神が、其敵国たる英仏に多大の影響を与へた事を優に認めると同時に、此時代錯誤的精神が、自由と平和を愛する彼等に斯く多大の影響を与へた事を悲しむものである。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "英仏の評論家は現在の戦争を単に当面の事実としてばかり眺めてゐないのみならず、又それを政治上の問題としてばかり考へてゐないのみならず、其背後に必ず或思想家なり学者なりの言説を大いなる因子として数へたがつてゐる傾向に見える。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "只在来の名前に英仏人が新らしい意義を付けた丈である。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗天使太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）箸｜：ルビの付く文字列の始まりを特定する記号（例）英仏｜婉曲に拒否す。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、白蘭の和平調停を、英仏｜婉曲に拒否す。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此のハイキング・クラブは英仏伊独等の青年男女を会員とする国際的クラブで、本部がロンドンに在り、各国の主都に支部があって、本部から毎月会員の消息や感想や注意を集めて月刊雑誌に載せ、各会員に配布して居る。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャネットは英仏語がどちらも下手です。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イリデ叔母様とジャネットと私達二人一緒になってお店の商品を片っぱしから英仏独で呼び合いました。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "憲法の調査起草に率先して当つたのは、伊藤博文であるが、その主旨とするところは、英仏流の憲法ではなく、わが国体を基礎とする「日本の憲法」であつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　エチオピア事件でほとんど毎日毎夕の新聞に伊国首相や、エ国皇帝、それから国際聯盟の英仏代表イーデン、ラバールの肖像が出る。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィリップ氏曰く、竜の英仏名ドラゴンは、ギリシアにドラコン、ラテンのドラコより出で、ギリシアのドラコマイ（視る）に因んで、竜眼の鋭きに取るごとしと。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはオランダ板の英訳かまたまるで別書か目下英仏の博識連へ問い合せ中だ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『続開巻一笑』四に、吃りに鶏の声を出さしむべく賭して穀一把を見せ、これは何ぞと問うと、穀々と答えたとあれば支那も英仏同前だ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから英仏語ともに未通女の後見として、群聚や公会に趣く老婦をシャパロンと呼ぶ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大英百科全書』に、英仏その他で政党や軍士が古く形色各別のコッケイドを佩びた事、並びに欧州諸邦の王家それぞれコッケイドの色を異にした例を多く挙げいる。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他各国大学又は図書館協会或は学会等、及びクワーリッチ、ヒールセマン等英仏独蘭の稀覯書肆から出版した各種の稀覯書目録（欧羅巴の稀覯書肆の特別刊行の書目は細密なる分類を施こし且往々解題を加え或はファクシミルを挿入する故書史学者の参考として最も珍重すべきものである。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他各国大学又は図書館協会或は学会等、及びクワーリッチ、ヒールセマン等英仏独蘭の稀覯書肆から出版した各種の稀覯書目録欧羅巴の稀覯書肆の特別刊行の書目は細密なる分類を施こし且往々解題を加え或はファクシミルを挿入する故書史学者の参考として最も珍重すべきものである。",
              "citation": {
                "source": "灰燼十万巻",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "藩に学あり、英仏両語を教授す。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦敗国｜独逸の新武器が――火焔放射器や、高熱砲や、磁気水雷や、落下傘部隊等が、かつての戦勝国、英仏その他を現に支配しているのだから。",
              "citation": {
                "source": "独逸の範とすべき点",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トドハンタアといへば、名高い数学者で、加之に語学の達人で、希臘、羅甸はいふに及ばず、英仏独伊露の現代語から、ヘブリウ、アラビヤ、ペルシヤ、サンスクリツトの東洋語にも通じてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "英仏の感情は恐らく極めて不良となったことと考えられます。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "英仏間には十一月三日仮平和条約なり、さすがのマリア・テレジヤも遂に屈服、一七六三年二月十五日フーベルスブルグの講和成立、大王は初めてシュレージエンの領有を確実にしたのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "真に仏国に決戦を強いんとするならばサンカンタン附近を突破し、英仏軍を中断して運動戦に導き、敵主力を破る事が戦略上最も有利とする事は云うまでもない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにルーデンドルフは当時の独軍は既にかくの如き運動性を欠くと判断し、英軍を撃破して英仏海峡沿岸を占領するのが敵の抵抗を断念せしむる公算が大きいから、フランデルン攻勢は戦略上有利と主張したのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月攻勢の目標は英軍を撃破して英仏海峡に突進するにあった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局彼は英仏海峡にも達し得ず、大規模の運動戦にも転じ得ず、かえって新しき占領地区の左翼方面に不安を来たしたのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
