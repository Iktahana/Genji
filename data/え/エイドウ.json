        "examples": {
          "standard": [
            {
              "text": "ゲル電気泳動の結果、DNAの断片が予想通りの位置まで移動していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「サンプルの泳動速度が遅いのは、電圧の設定が間違っているからかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "電気泳動槽の蓋を閉め、青い色素が移動していくのをじっと見守った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "第三は墨汁の電気泳動の実験であって、墨の粒子の電気的性質を調べられたものである。",
              "citation": {
                "source": "硯と墨",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも　一休さんと　したしく　して　いる、みえいどうという　おうぎやの　ろうじんふうふが、ある日　とつぜん　一休さんを　たずねてきて、「一休さん、ながく　おつきあい　いただきましたが、このたび　わけあって　みせを　やめ、くにに　かえる　ことになりました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうじゃな　みえいどうさん、わしを　おまえさんがたの　ようしに　して　くださらんか。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、いうと、つぎのあさ　はやく　のこのこと、みえいどうに　でかけて　いって、「みえいどうさん、ふでと　すずりを　かして　ください。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとで、一休さんは　とだなから　かみを　なんまいも　だして　つぎたし、「一休は　今日から　みえいどうの　ようしに　なりました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一休さんは、「みえいどうさん、はい　おかね。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "みえいどうさんは　しゃっきんを　はらっただけでなく、それからは　ゆたかに　くらすことが　できました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
