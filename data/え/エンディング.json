          "literary": [
            {
              "text": "エンディングがあんまりじゃん」　このアルバムに対する慶一の不満は、その点に尽きた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンディング・テーマだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは喫茶店向きの曲で、その莫迦げたところが気に入って、エンディング・テーマにしたものだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ということは、さっき、エンディングだけ聴こえた曲は〈イン・マイ・ルーム〉か。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギターがエンディングのリフを弾いている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンディングのところから放送に入ったらしく、曲はすぐに終わってしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なんでも、慶一さんの好きなもので」　管理棟のかげから出て、ステージが見える場所にくると、ちょうどエンディングで、拍手がわき起こり、深紅の蝶ネクタイをして、今夜のＭＣをやっているワラが、ワイアレスマイクごと手を叩きながら、中央に歩みでるところだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "レコードがフェイドアウトしている曲をやると、いつもエンディングで悩むことになる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ずしも彼の小説はハッピー・エンディングとは限らない。",
              "citation": {
                "source": "ヂユパンの癖とヴァンスの癖",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲数枝の最後の演技はすごい当りだったが、人生の舞台にはエンディングという都合のいい幕切れはないので、終末はひどくごたごたした。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうなるのかまだぼくにもよくわからないけれど、すくなくともハッピー・エンディングではないね」「どうして？",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、フェイク・エンディングなんか使って」「あの歌だけ、題名がまだないんですよ」　ディレクターが、うれしそうに笑いながら、言った。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "うたいおえ、バックの演奏がエンディングに入ると、それにかさねてナミは、けらけらと笑った。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッピイ・エンディング。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
