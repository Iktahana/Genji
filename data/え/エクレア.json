        "examples": {
          "standard": [
            {
              "text": "「わあ！このエクレア、中のカスタードが溢れそうなくらい詰まってて最高！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仕事帰りにふらっと立ち寄ったコンビニで、自分へのご褒美にチョコたっぷりのエクレアを買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ねえ、エクレアを綺麗に食べるのって意外と難しいよね。どうしてもクリームが横から出ちゃう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お土産にいただいた老舗洋菓子店のエクレアは、皮の香ばしさとビターなチョコの相性が抜群だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お疲れ様！差し入れのエクレアだよ。糖分補給して、午後の会議も乗り切ろう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "辰弥が茶箪笥をあけてみると、ふちの欠けた洋皿に、エクレアのような菓子が二つのせてあった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
