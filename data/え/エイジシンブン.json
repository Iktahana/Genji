          ],
          "literary": [
            {
              "text": "（ヘルン自身には、英字新聞しか読めなかったから。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "店をイルミネーションで飾るでもなし、英字新聞の大陸版へ広告を出すでもなし、表の構えは普通に塗った木目の板で囲い、ただ内側だけ気持よくこしらえてしとやかに客を待つといった風だ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "股引、腹掛、脚絆に草鞋ばき、ねじ鉢巻きの者もいて、焼けだされたような薄汚い不気味な恰好で上陸した姿を見て、白人や比律賓人は何かぎょっとし、比人労働組合は同志を糾合して排斥運動をはじめ、英字新聞も日清戦争の勇士が比律賓占領に上陸したと書き立てた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "股引、腹掛、脚絆に草鞋ばき、ねじ鉢巻の者もいて、焼けだされたような薄汚い不気味な恰好で上陸した姿を見て、白人や比律賓人は何かぎょっとし、比人労働組合は同志を糾合して排斥運動をはじめ、英字新聞も書きたてた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達が Monte Carlo へ着いた翌日、水曜日の巴里英字新聞だいり・まいる紙大陸版「リヴイラで何が起ってるか・起ってないか」欄の人事往来にこう出ていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の日本人民は英字新聞『ニッポン・タイムズ』や、もし事情が許すならば『スターズ・アンド・ストライプス』などを併読しなければ自分の国の事情についても充分に知ることは出来ない。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "給仕の少年に導かれて検閲課の室に入ると、柿のやうに頭の尖がんだ掛員は私に椅子をすゝめて置いて、質素な鉄縁眼鏡に英字新聞を摺りつけたまゝ、発禁の理由は風俗｜紊乱のかどであることを告げて、極めて横柄な事務的の口調で忠告めいたことを言ひ渡した。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か、――部屋の中には女のほかにも、丹前を羽織った男が一人、ずっと離れた畳の上に、英字新聞をひろげたまま、長々と腹這いになっている。",
              "citation": {
                "source": "母",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもやはり英字新聞の通信員だと称してゐたが、男振りに似合はない、人の悪るさうな人間だつた。",
              "citation": {
                "source": "南京の基督",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしまいにはヤングがよくポケットに入れて持って来る英字新聞が、すこうしずつ読めるようになったから豪いでしょう。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　英字新聞には黄瓜を包め。",
              "citation": {
                "source": "軽井沢で",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等敵の捕虜は、やがて殺害せられ、その肉は村童仲間へ食料として分配されたと、信用すべき當時の英字新聞は傳へて居る（Ball; Things Chinese. p. 128）。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝の英字新聞で、僕の事を｜畏敬すべき――と云いましたっけね。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸になった彼女は花束の代りに英字新聞のしごいたのを持ち、ちょっと両足を組み合せたまま、頸を傾けているポオズをしていた。",
              "citation": {
                "source": "夢",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "改正条約案の中、外人関係の訴訟には外人法官を加へて法廷を組織する云々の事が英字新聞に掲載された。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼は衣食する上にはある英字新聞の記者を勤めているのだった。",
              "citation": {
                "source": "彼　第二",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その塵芥車がやっと私の背後を通り過ぎたらしいので何気なくちらりとそれへ目をやると、その箱車のなかには、鑵詰の鑵やら、唐もろこしの皮やら、英字新聞の黄ばんだのやら、草花の枯れたのやらが、一種汚らしい美しさで、ぎっしりと詰まっていた。",
              "citation": {
                "source": "美しい村",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルのテラスにはいつも外国人たちが英字新聞を読んだり、チェスをしていた。",
              "citation": {
                "source": "麦藁帽子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "東征｜先鋒兼｜鎮撫総督らの進出する模様は、先年横浜に発行されたタイムス、またはヘラルドの英字新聞を通しても外人の間には報道されていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　食堂に下りて、西洋人の家族と独身の若者共とが互に談笑する中のテエブルに、自分ばかりは黙つて食事をすまし、広間の長椅子に凭れて其の辺に置いてある上海や香港やマニラあたりの英字新聞を物珍らしく拾ひ読みした後、早く寝てしまつた。",
              "citation": {
                "source": "海洋の旅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルのテラスにはいつも外國人たちが英字新聞を讀んだり、チエスをしてゐた。",
              "citation": {
                "source": "麥藁帽子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし雑誌『改造』に寄せた「光化門」（本書所載）に関する一文は、意外にも忽ちに反響を呼び、東京の英字新聞には直ちに英訳が掲載され、京城の『東亜日報』（朝鮮語新聞）には諺文に依る翻訳が出た。",
              "citation": {
                "source": "四十年の回想",
                "author": "『民藝四十年』を読んで",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　主として外国人のために編輯されている英字新聞が、プラウダと同じ内容をもっているとは思えなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのカフェーの一隅で、伸子は途中で買った英字新聞をひろげた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウンテル・デン・リンデンは外国人の通行安全とあるのが、いかにもウィーンの英字新聞らしかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーン発行の英字新聞だけを読んでいる伸子と素子とにとって、それらすべてのことがらしいとしかつかめなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その英字新聞は五月三日のベルリン市の状況を報道するのに、何より先に外国人はウンテル・デン・リンデンを全く安全に通行することができる、と書いたような性質の新聞であった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンブルグにジェネストがおこりかかっていることも、調査委員会が組織されたことも、その英字新聞は、直接ベルリンのメーデー事件に関係したことではないように、まるでそれぞれが独立したニュースであるかのように同じ頁のあっちこっちにばら撒いてあるのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その記事を伸子たちはウィーンにいたとき、偶然買った英字新聞の上でよんだ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那側による東支鉄道の回収について、パリの英字新聞「デイリー・メイル」は冷静に事実を報道しているだけだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
