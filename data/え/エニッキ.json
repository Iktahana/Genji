          "literary": [
            {
              "text": "絵日記に三六度なんて書いたことなかったもの」　ワラは足もとの袋をゴソゴソやって、なにかさがしている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の為めには、古い新しい写生帖が懐かしい絵日記となつて居る。",
              "citation": {
                "source": "写生帖の思ひ出",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の絵日記の一番古いのは十三位の幼い頃から始まつてゐる。",
              "citation": {
                "source": "写生帖の思ひ出",
                "author": "上村松園",
                "note": "青空文庫"
              }
            }
          ]
        }
