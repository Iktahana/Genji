        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "調理前の手洗いは、衛生上の観点から最も基本的な習慣です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この施設は、衛生上の観点から、床材に抗菌性のあるものを選定しました。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "密閉された空間では、換気を十分に行うことが衛生上の観点から重要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "家庭でのペットの飼育も、衛生上の観点から、清潔を保つための配慮が必要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
