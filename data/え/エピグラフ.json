          "literary": [
            {
              "text": "以下に、エピグラフとして引用した楽曲の作者を列記する。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "エピグラフとした曲は、物語中の引用の時点で、すでに本国でリリースずみのものにかぎっている（一曲だけ例外はあるが）。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作のエピグラフに、「オセロー」の中の文句を書き入れてゐるくらゐです。",
              "citation": {
                "source": "フランスに於けるシェイクスピア",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分の作品のエピグラフに、かつて愛誦していた「絵なき絵本」の一章を抜萃していたのである。",
              "citation": {
                "source": "風貌",
                "author": "――太宰治のこと",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
