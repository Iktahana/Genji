        "examples": {
          "standard": [
            {
              "text": "栄養神経は、組織への栄養供給を調整し、その機能維持に重要な役割を果たす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この疾患は、特定の栄養神経の機能障害によって引き起こされると考えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "研究では、損傷した栄養神経の再生を促す新たな治療法が模索されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "脱肉は勿論乾性即ち神経癩の証拠で、これは栄養神経が破壊される結果筋肉が萎縮するのを云ふのであるが、乾性のひどいのになると体が乾瓢のやうになつて、少しも形容ではなく骨と皮ばかりになる。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
