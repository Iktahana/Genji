          "literary": [
            {
              "text": "日々の馴れとて、わたくしは、われと黒髪をよもぎに撒き散らし、簪に野茨を挟む術も、焚火の燠を河泥に混ぜて顔を隈かき絵取る術も、わざとらしいものには思わなくなりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
