          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "劇場の巨大なエクランに映画のロゴが映し出された瞬間、観客席から歓声が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この映画館のエクラン、湾曲していて没入感がすごいな」「映像もすごく鮮明に見えるね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "映画が終わり、エクランにエンドロールが流れ始めると、ようやく館内の緊張感が解けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ズブコヴィ・エクランと云うようなものだ。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "集団的制作者と、集団的観衆とは、只一つの人間群像であるにもかかわらず、歴史的時間は、未来への「問の記号」として、白いエクランを、その両者の隙虚の中にさし入れるのである。",
              "citation": {
                "source": "生きている空間",
                "author": "――映画空間論への序曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆そのものの、歴史の中に、自らを切断する、「切断空間」として、カットが、その白いエクランの前に答の試みをなすのである。",
              "citation": {
                "source": "生きている空間",
                "author": "――映画空間論への序曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "エクランにおいてもまた異なった意味でそうである。",
              "citation": {
                "source": "芸術の人間学的考察",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "存在と実存在との隔たりの隙虚に画布ならびにエクランはしずかにすべり入るとも考えられる。",
              "citation": {
                "source": "芸術の人間学的考察",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは白い画布ならびにエクランは一つの疑問記号である。",
              "citation": {
                "source": "芸術の人間学的考察",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意味でエクランは集団の性格が集団の内面を顧みる一つの切断面として意味をもつとも思われる。",
              "citation": {
                "source": "芸術の人間学的考察",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が取つた席はエクランとはひどく斜めの位置にあつた。",
              "citation": {
                "source": "青いポアン",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か古ぼけた曲馬団の悲劇がエクランを流れてゐた。",
              "citation": {
                "source": "青いポアン",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "道化役の白い衣裳が不恰好に歪んで吊されたやうにエクランの中心を横切つたりした。",
              "citation": {
                "source": "青いポアン",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白ぼけた光がある時はエクラン一ぱいに膨らみ、客席の人の顔を鈍く照し出すのだつた。",
              "citation": {
                "source": "青いポアン",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "エクランでは銀色に溶け入るやうな脚をした一人の踊子が、乱れた食卓の上で前｜屈みに佇んで、不思議に複雑な笑ひを漏した。",
              "citation": {
                "source": "青いポアン",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士は登山家でもあるらしく、グラン・コルニエやエクランに登ったというような話をした。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
