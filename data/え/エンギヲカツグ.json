          ],
          "literary": [
            {
              "text": "詳しくみると、親父はよく都合の悪いときにばかり縁起を担ぐのであった。",
              "citation": {
                "source": "縁起に就いて",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "白馬岳の代馬（えと文）　午年の縁起を担ぐのではないが、一つ変った馬をひき出して見たい。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに本当のことを云えば、どうせ今度の縁談も巧くは行くまいと云ったような、捨て鉢的気分が最初にあったので、そんな縁起を担ぐ必要を感じていなかったのでもあった。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "兜町の連中は兎角縁起を担ぐ。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前途があって、大なり小なり運命論者であるような人の多くに似て縁起を担ぐ人間であった彼は、自分が良き道にとどまっている根気へのご褒美を幸運な時期に天から与えられることを望んだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
