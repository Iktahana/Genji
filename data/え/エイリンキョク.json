        "examples": {
          "standard": [
            {
              "text": "森林伐採の許可申請は、最寄りの営林局で行う必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "営林局は、地域の森林保全計画の策定を担っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その地域に新たに建設される製材工場について、営林局に問い合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それは青森県営林局ならびに同県下営林署の人々と同行のときであった。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "資料を入手する暇はないが、同窓の友で旭川の営林局長をつとめていた人の話では、そうである。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道の森林資源は、八五％が国有林で、営林局の管轄下にある。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その営林局が、収入予算の金額を増すために、伐採に専念して、植林を閑却しているためであると、この勧告書はいっている。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
