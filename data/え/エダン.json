          "literary": [
            {
              "text": "五年前に輪をかけたことがオッぱじまろうてえ段どりで、私は永の奉公の奉公じまいという三日前に、旦那の云いつけで、一々案内状を持ってまわって来ましたんで。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十　冷笑鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところが御めえいざってえ段になると奴め最後っ屁をこきゃがった。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいこもちみたいなグナグナな、あんた、バックボンとか言ったな、あちらさんの前でもこちらさんの前でも、ただもうペコペコこいてるだけで、へえ、ひっこしのねえ段ではないんだから。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「柳吉つぁんの口添えだんねん」　と、得意そうに種吉は君枝に語った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "景気のいい親方がいっしょになって、おっかねえだんながじきじきにお出ましなんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」「達磨さんのにらめっこじゃあるめえし、震えているめくらあんまを相手に、気のきかねえだんまりを始めて　何がおもしれえんですかい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じれってえだんなじゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「な、辰、おっかねえだんなの眼力じゃねえかい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかのところじゃ慈悲ぶけえだんなだが、いつもこの手ばかりゃ、ほんとに伝六泣かせですよ」　いいつつも、屈強なのをそろえてそこに来たのをみると、ゆうぜんとうち乗りながら、名人がこともなげにいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "しようのねえだんなだな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ともかくこいつをはええところ抱きとっておくんなせえよ」「受け取るはいいが、なんだってまた、おれがこれを受け取らなくちゃならねえんだ」「じれってえだんなだな、捨て子はこの子がひとりじゃねんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "稼えだんだ」「版下か」「はんははんだが、字が違うやつよ。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヨイショヨイショ、……ヨイショヨイショ……」　水夫の掛け声は勇ましいが、それさえだんだん弱って来た。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええと……へえ、仕事が無えだんかえ！",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭で私は、今朝から又暖かい飯にありついたわけ、斯うなるとけえだん話も滿更ぢやありませんね」「誰もお前の朝飯のことなんか訊いてやしないよ――それで叔母さんの話は皆んなか」「まだ／＼話は一と晩つゞきましたよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "飛ぶ若衆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きれえだんなあ……　何ちゅう可愛げえんだべ、俺ら……」　高い山から眺める下界の景色は、ほんとに綺麗である。",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地方では、そんなに馬の値段がいいのか」「いいえだんな、山賊村が近けえンですよ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
