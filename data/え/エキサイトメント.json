        "examples": {
          "standard": [
            {
              "text": "子どもたちは動物園での初めての体験に、隠しきれないエキサイトメントを全身で表現していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "開演前の舞台裏には、出演者たちの緊張と期待に満ちたエキサイトメントが充満していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゴールが決まった瞬間、スタジアムは爆発的なエキサイトメントに沸き返った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "探偵小説は読者に驚異を与える、恐怖を与える、何らかの強烈なエキサイトメントを与えるということを第一の主眼としなければならぬ。",
              "citation": {
                "source": "「陰獣」その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あの時分の家具を買うエキサイトメント！",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
