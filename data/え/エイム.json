        "examples": {
          "standard": [
            {
              "text": "「うわ、今のヘッドショット！？ エイムが神がかってるな……」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "初心者向けの練習モードで、まずは動く標的にエイムを合わせる練習から始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「感度設定を少し下げてから、格段にエイムが安定するようになったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "FPSで上位ランクを目指すなら、反射神経だけでなく正確なエイムが不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "STAR７・26サンデー毎日　ジエイムス・エム・バリイ氏といへば聞えた劇作家の一人ですが、ある日、某劇場でその脚本の舞台稽古があるといふので、仲のいい友達の一人と連れだつて、それを見に出かけました。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二次大戦後、ＮＡＳＡの前身の航空宇宙諮問委員会（ＮＡＣＡ）エイムズ研究所で風洞の研究に携わったエンゲルバートはやがて、人類の多くを進歩させるような意義のあるはでな仕事につきたいと、若者らしい野心を抱くようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
