          ],
          "literary": [
            {
              "text": "○三月十六日、清元延寿翁死す、七十三歳。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸末期より明治にわたれる清元の名人にて、最初は四代目延寿太夫という。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼学者の渋江抽斎、書家の市河米庵、ないし狂歌師仲間の六朶園荒井雅重、家元仲間の三世清元延寿太夫等と同じく、虎列拉に冒されたのかも知れない。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是が四世清元延寿太夫である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下手人は判らずじまいで、いつか沙汰やみになってしまいましたが、文政八年の夏から秋へかけて再びそれが流行り出して、初代の清元延寿太夫も堀江町の和国橋の際で、駕籠の外から突かれて死にました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は戌年の人に限って突くのだという説もあったが、かの延寿太夫は酉年の生まれで戌年ではなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし『淵鑑類函』四三二、後漢王延寿王孫賦、既に酔い眠った猴を縛り帰って庭厩に繋ぐとあれば、郭璞に始まったとは大啌だ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢の焦延寿の『易林』に巽鶏と為すとあれば、そんけいは巽鶏だ、圭の字音に拠って蛙をケイと読み損じて、巽の方の三足の蛙と誤伝したのである。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰徳延寿　むかし真州の大商人が商売物を船に積んで、杭州へ行った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴婦人と音曲５・22（夕）　大阪美術｜倶楽部で催された故｜清元順三の追悼会に、家元｜延寿太夫が順三との幼馴染を懐ひ出して、病後の窶れにも拘らず、遙々下阪して来たのは美しい情誼であつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "延寿太夫はその席上で、『角田川』を語つた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "先代の延寿は道楽といふ道楽を仕尽して、とどの果には舌切情死までしようとした。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも東京人某は、己が上位に置かれているにもかかわらず、「この教授法では延寿太夫が最優等生になる」と罵った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "延寿王院（神宮寺といふ）に入りて菅公真蹟を拝観す。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "矩之の兄源之助は、清元延寿太夫である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "延寿太夫は初代が文政八年中村座よりの帰途に、乗物町和国橋で人に殺された岡本吉五郎、二代が吉五郎の子｜巳三次郎、後に所謂名人太兵衛、三代が安政四年に地震に遭つて死んだ町田繁次郎、四代が矩之の兄源之助である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の延寿太夫は五代目である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "清元お葉は名人｜太兵衛の娘で、ただに清元節の名人で、夫｜延寿太夫を引立て、養子延寿太夫を薫陶したばかりでなく、彼女も忘れてならない一人である。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "-------------------------------------------------------　　　　　　　一　この話の中に活躍する延寿国資と、金剛兵衛盛高の二銘刀は東京の愛剣家、杉山其日庵氏の秘蔵となって現存している。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでその謝礼とあって今年の春の事、薩州から内密に大島の塙代の家へ船を廻して、莫大もない金銀と、延寿国資の銘刀と、薩摩焼御紋入りのギヤマンのお茶器なんどいう大層な物を、御使者の手から直々に塙代与九郎へ賜わったという話な……御存じじゃろうが」「存じませいでか。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "違うたもんじゃ違うたもんじゃとギヤマン茶碗や、延寿の刀や、姉妹の妾を見せびらかして吹聴致しているので皆、顔を背向けている。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手には薩州から拝領の延寿国資の大刀……右手には最愛の孫、与一｜昌純の手首をシッカリと握って、居丈高の片膝を立てていた。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはッ……」　ギリギリと眼を釣り上げた昌秋は左手に提げた延寿国資の大刀をガラリと畳の上に取落した。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "坐ったまま延寿国資の大刀を引寄せて、悪鬼のように全身をわななかせた。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文句も父様｜母様が言い聞かせたか」　延寿国資を静かに傍に差し置いた昌秋は、涙を払って坐り直した。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつら巻をかけた優な面ざしでも、さすがに「勘当場」の延寿のつくりで仆れた梅幸は、一代濃艶の印象を、一挙に寂しくしたと惜しまれたものだのに、この女形の不運は、歌舞妓役者だけに、一しほ侘しい。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「画家の毛延寿を利用したのよ。",
              "citation": {
                "source": "沙漠の美姫",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、青山へまわってから延寿春で御飯をたべる。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『モロー彗星対策相談所』とか、『延寿相談所』などという珍妙な看板が、どこの都会にも、十や十五はあらわれた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "千枝太郎はもとの一人になって、えんじゅの青い影の下に立っていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
