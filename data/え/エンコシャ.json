        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "災害時には、まず縁故者の安否確認を優先すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の葬儀には、多くの縁故者が遠方から駆けつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このイベントは、地域の縁故者を中心に開催される予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社では、縁故者の割引制度があるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "すでに時代おくれで、多少滑稽な存在であるような老大家か、そうでなければ政府が国民の模範として押し立てることの出来ないような若い思想の縁故者である。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "身辺のことについても、縁故者として東畑精一氏の名前を挙げただけで、誰の名前も告げなかった由である。",
              "citation": {
                "source": "三木清を憶う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その客は、市木さんの亡妻の縁故者で、土居というひとだった。",
              "citation": {
                "source": "絶縁体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女に身寄りの者はなく、楊さんだけがなにかの縁故者だという。",
              "citation": {
                "source": "秦の出発",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "千枝子は未亡人の縁故者だったので、洋介のことは前から知っていたが、親しく接するのは初めてだった。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし指定の宿屋、合宿所というようなものはなく、縁故者や後援者のところへ宿をとり、支給される宿泊料は不足するということはない。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "死後これを九分して各方面に分割したが、親族縁故者に爭議があつて、漸く五年を經て、賞金授與が行われた。",
              "citation": {
                "source": "ノーベル小傳とノーベル賞",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、戦争が済んだため、幸いまだ鋳潰されていなかったため返却され、それを再び先生の墓の傍に従前通りに復元が出来たので、われわれ弟子どもや縁故者関係者などが銅像を中心に集まって、焼き芋をかじりながら追憶の会を開こうという催しが企てられていた。",
              "citation": {
                "source": "「人間宣言」のうちそと",
                "author": "前田多門",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、脚色上仮想人物の点出も云う迄もなく、主人公が近世の人物であり、現存縁故者もあるべく思われるので、敢て、お断りいたしておく次第です。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はすぐ役所向きへ訴人いたすように、万一、縁故者が情にからんでかくまい立てすると同罪であるぞ」　一枚の人相書を渡して、先を急ぐように、またバラバラと引ッ返して行く。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
