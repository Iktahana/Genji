        "examples": {
          "standard": [
            {
              "text": "彼はちょっとエキセントリックな服装をしているが、その才能は誰もが認めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その芸術家の作品は、エキセントリックな発想と斬新な技法で知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「え、そんなことするの？！」と、彼女のエキセントリックな行動に皆が驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この古い時計は、エキセントリックなデザインだが、正確に時を刻み続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その女の歴史の切ない必然を見ることをしない男たちは自分らの不明を反省するより浅はかな理想の幻影にエキセントリックなまでに殉じようとした彼女らをあざける。",
              "citation": {
                "source": "『静かなる愛』と『諸国の天女』",
                "author": "――竹内てるよ氏と永瀬清子氏の詩集――",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十日（火曜）　気がゆるんだような、がったり落ちがしたようで、よるは長く寝たにもかかわらず、頭は止すまらなかったので、妙にエキセントリックになって居る。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして作家の努力は即ち神経、感情のエキセントリックな者であって嘗て人間の達しなかった眼に見えなかった感情、人の達しない境に入るところに在ると思うのである。",
              "citation": {
                "source": "絶望より生ずる文芸",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "エキセントリックな方だ、とは思っていました。",
              "citation": {
                "source": "最初の印象",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
