            }
          ],
          "literary": [
            {
              "text": "外国の絵入り雑誌などによくそれの三色写真などがある。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近着の雑誌リリュストラシオン（３）に「黙示録に現われたる飛行機と科学戦」と題する珍奇な絵入りの読み物がある。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "表三の面上段に、絵入りの続きもののあるのを、ぼんやりと彳んで見ると、さきの運びは分らないが、ちょうど思合った若い男女が、山に茸狩をする場面である。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵入りの読本を歌舞伎に仕組んだのはこれが始まりであると云うのをみても、いかに「自来也物語」が流行したかを想像することが出来る。",
              "citation": {
                "source": "自来也の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして外国映画や絵入り雑誌の挿し絵で見る欧米列強の飛行隊の壮観を思い浮かべ、一方ではまたわが国の海軍飛行機のあまりにも頻繁な墜落事故の記録を胸算用でかぞえながら、なんとなく暗い気持ちにいざなわれるのであった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファンのグループの活動も活発で、解説書や絵入りのイラスト版なども出ています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる単語を一々美しい絵入りで説明したものをまず送っておけという説もあった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人雑誌が「子供の育てかた」だのやれ「姙婦の衛生」だのときれいな絵入りで書き立てているのも可笑しいようなものだ。",
              "citation": {
                "source": "今にわれらも",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、フランス劇文学におけるアポローであるモリエールと十七世紀の大古典派の宝ラ・フォンテーヌの作品の美しい絵入り本の出版とその売捌きである。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆的な某誌は、その反動保守的な編輯方針の中で、色刷り插絵入りで、食い物のこと、悲歎に沈む人妻の涙話、お国のために疲れを忘れる勤労女性の実話、男子の興味をそそる筆致をふくめた産児制限談をのせて来た。",
              "citation": {
                "source": "合図の旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父のところには、とにかくそういう英語で、しかも絵入りのがあるので、何か欲しいとせがんだら一冊の紫紺色表紙の本を貸してくれました。",
              "citation": {
                "source": "写真に添えて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の壁に、絵入りのスモーリヌイ勤労者壁新聞が張り出してある。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから人は見るだろう、一日の発行部数十数万の『イズヴェスチア』新聞社の正面昇降機の横にまでも、絵入り手書きの『イズヴェスチア』勤労者壁新聞は、いつもぶら下っているのを。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　絵入りの手書壁新聞が貼られている。",
              "citation": {
                "source": "モスクワ日記から",
                "author": "――新しい社会の母――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪のあるモスクワの辻々に大砲を指揮する法王の絵入りポスターが貼られた。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般民衆にとっては、彼らみずからの工業主義の尊い産物である絵入りの定期刊行物をながめるほうが、彼らが感心したふりをしている初期のイタリア作品や、足利時代の傑作よりも美術鑑賞の糧としてもっと消化しやすいであろう。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭も尻尾も書きかえられて、私の水仙と王子がちゃんと絵入りで出ている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいてい絵入りなり。",
              "citation": {
                "source": "学校の説",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今その体裁を見れば、史書に記載してある通り、赤色若しくは樺色の半紙大絵入り五冊本で、各十二、三枚で各巻は大体二題目より成り、漢字交り総振仮名であって、後世の絵本と同様である。",
              "citation": {
                "source": "春水と三馬",
                "author": "桑木厳翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に、一九〇九年、フェイヤアル書店から、近代文庫の一巻としてラヴィエの挿絵入りで出た。",
              "citation": {
                "source": "「博物誌」の序に代へて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、別に、同じ年に、フラマリオン社からも、「金の栞」叢書のなかへボオディエの口絵入りでこれを加へた。",
              "citation": {
                "source": "「博物誌」の序に代へて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々のカレンダーは絵入りで、四日にはレーニンが学んだというカザン大学が描いてある。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの雑誌やへ行ったら、こっちのロシア人が出して居る『絵入りロシア』というのがある。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年頃には、みな大きな形の絵入りの大きな活字の本ばかりよんでいるのに、彼一人、父の書斎に並んでいる、内容がいかにもむつかしいような岩波文庫をよんでいたのに対して、私は大きな尊敬をいだいた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、問うに落ちて語るに落ちぬ絵入りの禅問答。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "謝肉祭の支那服　――地中海避寒地の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本紀行の本を絵入りで著はしてゐるが、その中のこん棒片手の巡査の像や、江の島の茶店の女中の面影などは、浅井先生を更に縦に掘り下げたやうな、本格水彩で、稀品とするに足る。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "この節では一行広告に「アベック旅館云々」は珍らしからず、「靴のニュウ・ルック」とあって、その絵入りの広告なども見かけることがある。",
              "citation": {
                "source": "ハイカラ考",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "……やがてこんどは長椅子に思いきり手足を伸ばして寝そべり、何か絵入り雑誌を眺める。",
              "citation": {
                "source": "富籤",
                "author": "ВЫИГРЫШНЫЙ　БИЛЕТ",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは絶えいりそうです。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ゃ真面目で談してるんだよ」「俺も真面目さ」「まあ笑談は措いて、きっとこれから金さんの気に入ろうというのを世話するから、私に一つお任せなね」「そりゃ任せようとも、お前に似てさえいりゃ俺の気に入るんだから」「およしよ、からかうのは。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
