        "examples": {
          "standard": [
            {
              "text": "この映画の映画評は、賛否両論に分かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新聞に掲載された映画評を読んで、観る作品を決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "辛口の映画評で有名な評論家が、この作品を絶賛した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の書く映画評は、いつも的確で面白い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（昭和八年五月、映画評論）",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年一月、映画評論）",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年十月、映画評論）",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "百年後に読む人にもおもしろくて有益なような映画評をかくということはなかなか容易な仕事ではないのである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年五月、映画評論）　　　　　十五　乙女心三人姉妹　川端康成の原著は読んだことはないが、この映画の話の筋はきわめて単純なもので、ちょっとした刃傷事件もあるが、そういう部分はむしろはなはだ不出来でありまた話の結末もいっこう収まりがついていない。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この機能を活かし、『市民ケーン』と『キングコング』には、予告編に加えて、撮影風景の写真や映画評が盛り込まれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに『キングコング』には副音声で、映画評論家によるシーンごとの解説が加えらています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『映画評論』一九四一年五月号）",
              "citation": {
                "source": "映画と癩の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『映画評論』昭和十九年三月号）",
              "citation": {
                "source": "映画と民族性",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（九月五日）（『映画評論』昭和十六年十月号）",
              "citation": {
                "source": "思い",
                "author": "――情報局の映画新体制案について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、われわれの方は技術者ばかりで、ただこの文化的に立派な、つまり戦力増強に真に役立つような作品を作りさえすればよかろうと言うんで、経営方面はカラダメでして、がんらい、映画評論やなんかでやってきた私などが、こうして企かくや製作のことで、駆けまわっているありさまなんですからねえ。",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当時の日本映画に、ひょっとしたらちらっとでも描かれていないだろうか、などと私が思いつきを言いまして、後藤さんは映画評論家に聞いて調べたりしたようです。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
