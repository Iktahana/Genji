    },
    "definitions": [
      {
        "index": 1,
        "gloss": "age",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このスマートフォンは、若者向けのデザインと機能で「ティーンエイジ」層に人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は「アダルトエイジ」のライフスタイルに合わせた商品を開発している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あなたはもう「ミドルエイジ」だから、健康にはもっと気をつけないとね」と、友人に言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "部室から聴こえてくる、〈シークレット・エイジェント・マン〉のイントロのリフに、その声はかき消されそうになる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから数日ののち、私たちはオスタンド・ドウヴァ間のＳＳヴィユィユ・リエイジュ号の甲板上に、近づく白堊の英吉利の断崖を見守っている自分達を発見した。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルチョン博士は説明して、「他の細い綱で絞殺して置いて、ぐったりなってから、膝を折り曲げて大腿部へ縛りつけ、窓掛の紐で吊るして縊死を装わしめたものです」　当時、亜米利加の有名な私立探偵局ピンカトン・エイジェンシィの巴里特置員で、バニスタアという辣腕家があった。",
              "citation": {
                "source": "ロウモン街の自殺ホテル",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪大学基礎工学部に籍を置いていた一九七六（昭和五十一）年、山下は『コンピュートピア』の発行元であるコンピュータ・エイジ社が主催したイベントで、早稲田大学の西和彦と出会っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『コンピュートピア』の発行元であるコンピュータ・エイジの主催で、銀座のソニービルを会場に開かれたコンピュータアート展には、松本も安田研究室からの出展の脇に連載記事に書いたＭＹＣＯＭ―８を並べ、バッハのインベンションを演奏させていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "リエイジュの一敗位に懲りる様な独逸ではないから、英仏の連合軍を相手に激しい大会戦が行はれるであらう。",
              "citation": {
                "source": "台風",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際あたくしは、あの人と知り合ってから六年間という永い間を孤独のうちに待たされたのでございます」「イカリ・エイジと仰有いましたね」　探偵の質問は、燃えあがる女客に注いだ一杯の水であった。",
              "citation": {
                "source": "断層顔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そういう都会の真中に、ヴィクトリアン・エイジの破片が、ちゃんと、ミセス・チャアチルという名を持って生きています。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新しき合金」というオストロフスキーの小説の題は、そのことから考えても、本当に新しい題だったのですね、青銅が、ブロンズ・エイジ風の質にしろ、その質として純粋でなくては、金に混ぜることは出来ないでしょうし。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしかしたら、エイジャックス、ユリシーズ、ホメロスが愛したそんな輩だったかもしれない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ではティンエイジャーと稱して親や社會の厄介になつている。",
              "citation": {
                "source": "老人退場説",
                "author": "山浦貫一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何千年にわたって、威厳あるピラミッドは数多い人種の心の中に彼らの生まれた土地のゴールデン・エイジを新しくした。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは彼の「エイジャクスの変身」の付録に彼の執事の名前で出ている。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "女王はこの発明に感心してリッチモンド宮殿にこれを据え付けさせ「エイジャクスの本を壁に吊した」と言われている(24)。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌が終わると、次はミス・ティーンエイジ・アメリカを選出するための予選である、ミス・クリーヴランドの選出大会の案内があった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈２〉　ティーンエイジ・アメリカ　45回転シングル・レコードは、ティーンエージャー専用だった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、大勢はやはりジャズ・エイジであり、はなやかな享楽と繁栄だけをみて、鉄道、トラスト、ウォール街などのかくされた部分は、見ていなかった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギャング・エイジの主役のひとりであるフロイドは、伝説やノスタルジアとしてうたわれるのではなく、トムスン軽機関銃で金銭をうばう者もいれば、大企業のように合法的な手段で人々からおかねをまきあげるものもいる、という事実を語るためだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイトン「アスピリン・エイジ」。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
