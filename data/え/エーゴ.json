          "literary": [
            {
              "text": "Ａ５判横組みの本で、著者は小黒正樹。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂譲次氏は愛機、四十――年型ボーイング機Ｊ・Ｂ３Ａ５を駆って、昨十三日午後十時、大阪国際飛行場を離陸したまま、行方不明になった。",
              "citation": {
                "source": "空飛ぶ悪魔",
                "author": "――機上から投下された手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エーごめんください」　前より少し調子を高くして、八さんを登場させた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「熊『エーごめん下さいエー、そのエー』」　ピシピシピシーリ。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
