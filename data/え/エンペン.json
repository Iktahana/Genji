          ],
          "literary": [
            {
              "text": "もっとも「イソ」はまた冠の縁や楽器の縁辺でもある。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に取って見ると、白く柔らかく、少しの粘りと臭気のある繊維が、五葉の星形の弁の縁辺から放射し分岐して細かい網のように拡がっている。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでながら、切り立ての鋏穴の縁辺は截然として角立っているが、揉んで拡がった穴の周囲は毛端立ってぼやけあるいは捲くれて、多少の手垢や脂汗に汚れている。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてやはり琺瑯引きでとっ手のついた大きい筒形のコップをそのわきに並べて置き、そうしてコップの円筒面を鉢の縁辺に軽く接触させる。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また大陸塊の縁辺のちぎれの上に乗っかって前には深い海溝を控えているおかげで、地震や火山の多いことはまず世界じゅうの大概の地方にひけは取らないつもりである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのような御大家でも縁辺のお話となりますと、一度はキット私の存じ寄りを聞きに御出でになりまっするで、私が、あれなら大丈夫と請合いますると、それからお話が進みまするような事で……ヘエ……」　と自慢そうにモウ一度、鼻の頭をコスリ上げた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると少女は身体の具合が少し悪いと言って鬱いで、奥の間に独、つくねんと座っていましたが、低い声で唱歌をやっているのを僕は縁辺に腰をかけたまま聴いていました。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "真蔵は銘仙の褞袍の上へ兵古帯を巻きつけたまま日射の可い自分の書斎に寝転んで新聞を読んでいたがお午時前になると退屈になり、書斎を出て縁辺をぶらぶら歩いていると「兄様」と障子越しにお清が声をかけた。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　縁辺に席を与えて、まず麦湯一杯、それから一曲を所望した。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "道に逢ふ人も、田畑に見る人も、隣家に住む老人夫妻も、遠きまたは近き血統で、互にすべての村人が縁辺する親戚であり、昔からつながる叔父や伯母の一族である。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりから丘陵の間はやや斜面に展けて赤松の細い幹が縁辺に林立し、怪奇な岩層の風致に一種の繊細味を交えてゆく。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが今度の帰国を幸い、縁辺の話を決定めたいという親類の意見から、暫く役目のお預りを願って、その空屋同然の古屋敷に落付く事になると、賑やかな霞が関のお局や、気散じな旅の空とは打って変った淋しさ不自由さが、今更のように身に泌み泌みとして来た。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……平馬殿……」「……ハッ……」「貴殿の御縁辺の話は、まだ決定っておらぬげなが、程よいお話でも御座るかの……」　平馬は忽ち別の意味で真赤になった。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、後々の事は母方の縁辺により、御老中、久世広周殿に御願申上べき事　以上。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "此度の事は泰平の御代に武道を忘れ、縁辺の手柄を頼に出世を望み給ひし御身の柔弱より出でし事ぞかし。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に取って見ると、白く柔らかく、少しの粘りと臭気のある繊維が、五葉の星形の弁の縁辺から放射し分岐して細かい網のように広がっている。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あんたは御縁辺であらっしゃるかの。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この師匠の見立てが、甚だ適当で、一方お旗下のお嬢様であるお綾さんにはいかにも似合いの縁辺というべきであった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は此等縁辺のものを代る／″＼喰ひ廻つて、そして、高等小学から中学と、漸々文の林の奥へと進んだのであつた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（注一）　ここで海神ポセイドン（Poseidon）の配偶アムフィトリートが地の縁辺を腕で抱えるとあるところから見ると、オヴィドは地が球形でなくて円板の形をしていると考えていたことが分る。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大ブルジョアのその鳥料理屋が彼女の彼と、何かの縁辺になることも、その後だんだんに解って来た。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉自身の家柄との権衡から言えば、あまりドッとした縁辺でもなかった。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、私が弱くされた肉体を曳いて、この世界の縁辺を歩んでゐるやうに感じ出してこのかた、かの女らは、私の載つてゐるのとはちがつた平面の上に在つて（それが私の上にあるのか、下にあるのか、私は知ることが出来ない）、つねにその不動の眼を私の方へ送つてゐたことを思ひ出した。",
              "citation": {
                "source": "鳥獣剥製所",
                "author": "一報告書",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍大将の筆頭で、しかも主君とは縁辺だ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何んと本条殿、あのご老僧は、貴殿のご縁辺ででもござるかな？",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その沸、魚目（一一）のごとく、すこし声あるを一沸となし、縁辺の涌泉蓮珠（一二）のごとくなるを二沸となし、騰波鼓浪（一三）を三沸となしている。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
