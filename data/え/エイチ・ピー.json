        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はスケートボードでＨＰを滑り降りる練習をしています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "スノーボード大会の決勝は、特設された巨大なＨＰで行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちが近所のスケートパークのＨＰで遊んでいる。",
              "citation": {
                "source": "幻辭AI",
