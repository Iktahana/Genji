    "definitions": [
      {
        "index": 1,
        "gloss": "home page",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この製品の詳細は、メーカーのＨＰで確認しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しいプロジェクトの情報を、会社のＨＰに掲載しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は趣味のブログのＨＰを自分で作っています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "デジタルリサーチは、ヒューレット・パッカード（ＨＰ）社へのＣＰ／Ｍの供給交渉を進めている最中だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでもなかなか仲間の輪にとけ込めなかったジョブズだったが、一〇歳を過ぎたころからエレクトロニクスに関心を抱き、近所に住むヒューレットパッカード（ＨＰ）社のエンジニアの家に押しかけては質問の雨を降らせるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョブズは一二歳のとき、エンジニアが連れていってくれたＨＰで、初めてコンピューターに触れた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年で再び大学を去ったウォズニアックは、半導体製造装置を作っていたエレクトログラス社の組み立てラインで半年ほど働いたあと、一九七三年、友人の口利きでＨＰに職を得た★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同校で電子工学を学んだデビット・パッカードとビル・ヒューレットは、恩師の推し進めたプログラムに乗って、一九三九年にヒューレットパッカード（ＨＰ）社を起こした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パロアルトの貸しガレージを根城とし、五〇〇ドルの資金を元手に測定用の音声周波数発信器の開発から出発したＨＰに飛躍のきっかけを与えたのは、ディズニー映画だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作業用に、ガレージからスタートしたばかりのベンチャーの製品ながら、すぐれた性能を備えたＨＰの音声周波数発信器が採用された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "設立の年の暮れ近くになって舞い込んだディズニーからの八台の注文と「ファンタジア」の成功は、高品質の測定器メーカーを目指したＨＰにとって、強い追い風となった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＰ誕生のきっかけを作ったスタンフォード大学のフレデリック・ターマンは、その後、大学の所有する用地に会社を設立するよう卒業生に働きかけるプログラムを進めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二次世界大戦中、ターマンは軍のレーダー探知阻止プロジェクトを担当することになり、必要となるマイクロ波発信器をＨＰに発注した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをきっかけに軍需用の高性能電子測定機器を大量に受注したことで、ＨＰは飛躍的な発展を遂げた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦後の一時的な落ち込みはあったものの、ＨＰはその後、エレクトロニクス台頭の波に乗って、代表的なハイテック企業として成長を遂げていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その成果が一九七二年に発表されたミニコンピューターＨＰ３０００と、同じく同年に発表された科学計算用のポケット電卓ＨＰ35だった★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★『パソコンビジネスの巨星たち』（ティム・スキャネル著、日暮雅通訳、ソフトバンク、一九九一年）所収、第一七章ＨＰの項。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで高性能で高価格の製品のみを扱ってきたＨＰにとって、一台三九五ドルという電卓はきわめて毛色の変わった製品だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "社内にはおもちゃのような製品に手を染めることへの異論もあったが、ＨＰ35は成功を収めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "他社が低価格を武器に電卓市場に乗り出してくると、ＨＰは機能を強化したＨＰ80やＨＰ45で対抗しようと試みた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがＨＰでの作業に満足しきるには、ウォズニアックはあまりに幸福に対して貪欲だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウォズニアックが籍を置いていたＨＰでは、モトローラの６８００を試験的に使ってみる計画が持ち上がっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＰに籍を置いたまま、ウォズニアックはコンピューターコンバーサー社と名付けた二人の会社のために、端末の開発に着手した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこの時点では、ＨＰを離れる気にはならなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＰで働いているウォズニアックは、夜を徹して設計に取り組んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＰでの回路設計の際にも、ウォズニアックはかねてから自由に計算に使えるコンピューターがあればと考えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＰの同僚がミニコンピューター上で６５０２の動作をシミュレートするプログラムを書き、これを使って書き上げたものをチェックした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョブズの提案を「ためしに二、三枚基板を売ってみよう」程度に受け取っていたウォズニアックには、愛着を感じているＨＰをやめようなどという気持ちはさらさらなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＰでまともな給料を取ってはいたものの、コンピューター用の部品とレコードに金をつぎ込んでいたウォズニアックは、持っていたプログラム電卓のＨＰ65を売り払って出資分を作り、ジョブズはフォルクスワーゲンを売った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
