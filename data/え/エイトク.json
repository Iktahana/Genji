[
  {
    "uuid": "c82f9b42-6242-5d74-868e-839c64ad663c",
    "entry": "永徳",
    "reading": {
      "primary": "えいとく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
