  {
    "uuid": "8f2efdcb-5474-5b8e-8851-b636dbe096e9",
    "entry": "盈虚",
    "reading": {
      "primary": "えいきょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
