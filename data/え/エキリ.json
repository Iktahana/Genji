          ],
          "literary": [
            {
              "text": "たぶん今云う疫痢であったろうと思われる。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばある家庭で、同じ疫痢のために二人の女の児を引続いて失ったとする。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに知人のある者は保養地で疫痢のために愛児を亡くしたりした。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、翌翌年かに男の子を産んだ處が、不幸にして半年目かにそれが疫痢に犯されて、とうとうＫ病院で死んだんださうだ。",
              "citation": {
                "source": "Ｓ中尉の話",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "因に弟の峻は、私が八歳の時に疫痢で死んだ。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしい疫痢の為めにしばらくの間牛乳とおも湯の少量より食べることが出来なかったので、少し身体の快復して来たいまは、只、人の顔さへ見れば記憶にのこってゐる、パンとバナナとを欲してゐるのであった。",
              "citation": {
                "source": "秋は淋しい",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、バナナを昌子にやつたから、マサ子が疫痢になつたと、僕の葉書の書き方でそんな風に君にとられたのを思ひ出してさへ、殊にさう思ふ。",
              "citation": {
                "source": "書翰",
                "author": "大正十一年九月（推定）　小島勗宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずか半日半夜のうちに、十二の夏｜疫痢で死んで行った娘の畳の上まで引いた豊かな髪を、味気ない気持で妻がいとおしげに梳ずってやっていたのも、その一室であった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "英男が三つで疫痢を病って入院して居た。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女達も嘗ては球のような新しい身をもって生まれ、何よりも母親たちの恐れる麻疹、天然痘、疫痢、ジフテリア等に、幾種もの小児病を幸いにも無事に経過して来た、尊い肉体である事は、人として異りないものを。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけならばまだ女も、諦めようがあったのでしょうが、どうしても思い切れない事には、せっかく生まれた子供までが、夫の百ヶ｜日も明けない内に、突然｜疫痢で歿くなった事です。",
              "citation": {
                "source": "捨児",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「疫痢ではないでしょうか？",
              "citation": {
                "source": "子供の病気",
                "author": "――一游亭に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、疫痢じゃありません。",
              "citation": {
                "source": "子供の病気",
                "author": "――一游亭に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "疫痢は乳離れをしない内には、――」Ｓさんは案外落ち着いていた。",
              "citation": {
                "source": "子供の病気",
                "author": "――一游亭に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この娘は三つの時に疫痢をやって死にかかったことがあるので、てっきりそれに近い病気だと思った。",
              "citation": {
                "source": "栄螺",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供もやはり赤痢とか疫痢とかで、殆んど同時に死にました。",
              "citation": {
                "source": "林檎",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の子供を二人も疫痢で亡くしているこの女房は、ヨシ子の容態を一目で見てとった。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はまた疫痢にでもなるんではないかと思って……。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「疫痢ではありませんでしょうか。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや疫痢は三四歳以下の幼児には殆んどありません。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "このやさしい兄さんは、その翌年の春、疫痢を患って、わずか一｜日で死んでしまったのでした。",
              "citation": {
                "source": "ゆずの話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その龍眼肉の食べすぎから、少年が疫痢のやうな症状をおこし、一週間ほど生死の境をさまよつたのは、恐らくこの家に移つて間もなくのことだつたらしい。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度は、ビルディングが建つて間もなく、三女のシゲ子が疫痢で死んだ時だつた。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「両親とも医者でゐながら、疫痢で子供を殺す法があるものか」と伯母さんたちは悪口を言つた。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "また例へば醫學なんていふ問題も、まことに微々たるもので、一度疫痢がはやると、もうその手當の方法もなく、近畿一帶、大宮人すらバタバタ斃れて行く。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかの丸いのを盆にのせて仏壇に供えたのだったが、疫痢という噂が立って、だれもきてくれぬ通夜の枕もとにすわって、いつもの停電がすんだあと、お母さんはふと気がついたように、枕刀にした小さなゾーリンゲンの庖丁をとりあげ、いきなり、ぐさりとかぼちゃの横腹につき立てて、大吉たちをおどろかした。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大腸カタル、若しかしたら疫痢かも知れませんよとおかみさんは云った。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾風はおぞぎゃあぎゃあも」「村岡君、疾風というのは疫痢のことだよ」　と隣にいた団さんがお父さんに通訳した。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「疫痢が流行ると見えるね？",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は、腹掛けのどんぶりに、私を折り畳まずにそのままそっといれて、おなかが痛いみたいに左の手のひらを腹掛けに軽く押し当て、道を歩く時にも、電車に乗っている時にも、つまり銀行から家へ帰りつくまで、左の手のひらでどんぶりをおさえきりにおさえていました。",
              "citation": {
                "source": "貨幣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
