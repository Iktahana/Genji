          "literary": [
            {
              "text": "日本語を標準的に扱うことを考慮して、新機種には六四〇Ｋバイトのドライブを一台積んだＦ１と、二台実装したＦ２が用意された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "価格はＦ１が三二万八〇〇〇円、Ｆ２は三九万八〇〇〇円に設定された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
