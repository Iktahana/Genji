          ],
          "literary": [
            {
              "text": "映画俳優はアドルフ・マンジュウとグレタ・ガルボが好き。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔のジャッキー・クーガン以来小さい子供はみんなたいてい映画俳優として成効している。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは映画俳優の演芸が舞台俳優のそれと全くちがった基礎の上に立つべきものだということをわれわれに教えるものではないかと思われる。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア映画で教養も何もない農夫が最も光ったスターとして現われ、アメリカ映画でも土人のほうが白人の映画俳優の下っぱなどより比較にならぬほどいい芝居をして見せるのも同様な現象である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうです、映画俳優です。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも映画俳優としては人間は犬やトナカイの脚下にひざまずいて教えをこう必要がある。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を飛び出して、映画俳優になって自活しようと思った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食えなくなったら映画俳優になるんだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は去年、たぬきという数学の教師に侮辱されて、あっさり学校をよそうとしたが、その時にも、よし映画俳優になって自活してやると決意した。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、映画俳優をあこがれてはいない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は映画俳優になりたいんだよ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本一の映画俳優だったら、立派なものじゃないか。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕もずいぶん考えたんですけど、弟は、ひどく苦しくなると、きまって、映画俳優になろうと決心するらしいんです。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気持の楽な時、うっとり映画俳優をあこがれるなんてのは、話になりませんけど、いのちの瀬戸際になると、ふっと映画俳優を考えつくらしいのですが、僕は、それを神の声のように思っているのです。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画俳優じゃないのかね。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「映画俳優は、サンボルですよ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "プドフキン「映画俳優論」。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「築地小劇場史」だの「演出論」だの「映画俳優術」だの「演出者ノオト」だの、それから兄さんが貸してくれた「花伝書」。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新派には新派の型があり、義太夫には義太夫の型、女剣劇や映画俳優の実演にも型があり、浪花節なども近頃は浪花節専門の声色屋が出来ている。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "平常は冗談口を喋らせると、話術の巧さや、当意即妙の名言や、駄洒落の巧さで、一座をさらって、聴き手に舌を巻かせてしまう映画俳優で、いざカメラの前に立つと、一言も満足に喋れないのが、いるが、ちょうどこれと同様である。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、都合によっては来朝中の某国映画俳優も来てくれるはずになっているということが群衆の噂の焦点になっていた。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、映画俳優の来るのを気長に待っている人々のために示されたこのＳＴＯＰは、いったいいつまで続くのか分からなかった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありがたう――」　といつてわたしは、あまり拙劣過ぎる似顔画なので眺める気もなく、机の上にほうり出して、改めて当人の顔を見ると、やゝ面長で鼻筋がとほり、映画俳優の中野英治を髣髴させるかのやうな爽快な可憐味に富んでゐた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそんな身分のある家族の方々のうちの誰かと婚約が出来た……なぞと平気で言い触らしたりなぞしているかと思うと、おしまいには、やはりズット以前に入院した事のある映画俳優か何かの胤を宿したから、堕胎しなければならぬ……と言ったような事を臆面もなく看護婦長に打ち明け（？",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の教授や有名な小説家や映画俳優がいて、その女は帰ってくると、一々｜際どいところまで詳しく話して、比較をやったりするので、笠原は弱った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の映画俳優は発声に関するかぎり未熟というよりもまつたく無教養であるといつていい。",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の映画俳優は、感情表現を独特な立場から研究しなければなるまいと思う。",
              "citation": {
                "source": "映画の恋愛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画俳優のすき、きらいにも、あんな心理的な答えをして生きている娘さんを、私たちは気の毒だと思う。",
              "citation": {
                "source": "女の歴史",
                "author": "――そこにある判断と責任の姿――",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画俳優のすき、きらいにしたって、つまりは自分の生活の弾力からの判断である。",
              "citation": {
                "source": "女の歴史",
                "author": "――そこにある判断と責任の姿――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
