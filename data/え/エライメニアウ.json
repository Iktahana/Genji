        "examples": {
          "standard": [
            {
              "text": "駅で列車に乗り遅れて、えらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "雨の中で携帯を落としてしまい、えらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "約束の時間に遅刻して、上司に怒られ、えらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "初めてのプレゼンで、機械が故障してえらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "旅先でパスポートをなくしてしまい、えらい目にあったよ。",
              "source": "幻辞"
            },
            {
              "text": "学期末試験に全く勉強しないで臨んで、えらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "大事な書類を紛失してしまい、会社でえらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "友達の結婚式に遅れてしまって、えらい目にあったんです。",
              "source": "幻辞"
            },
            {
              "text": "新人研修でミスをして、えらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "締め切り日を間違えて、プロジェクトでえらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "電車の乗り過ごしで目的地を超えてしまい、えらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "重要な会議を忘れてしまい、ボスにえらい目にあわされた。",
              "source": "幻辞"
            },
            {
              "text": "車のタイヤがパンクして、山道でえらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "取引先との契約書に誤りがあり、営業部はえらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "空港で搭乗口を間違えて、飛行機に乗り遅れ、えらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "給与振込の日に銀行システムが停止して、多くの社員がえらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "子どもが学校の宿題を忘れてしまい、先生に叱られ、えらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "初めての出張で経路を完全に間違えてしまい、えらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "大事なメールの受取人を間違えてしまい、会社全体でえらい目にあった。",
              "source": "幻辞"
            },
            {
              "text": "引っ越しの日に大雨が降り、荷物も濡れてしまい、えらい目にあった。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "知らないで入ると、えらい目にあうぞ。",
