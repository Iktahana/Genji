          "literary": [
            {
              "text": "炎暑、極熱のための疲労には、みめよき女房の面が赤馬の顔に見えたと言う、むかし武士の話がある。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛なる哉、炎暑の色。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺太とはいっても八月の炎暑である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "其二　夏休　天の炎暑を司る、必らずしも人を苦しむるのみにあらず。",
              "citation": {
                "source": "客居偶録",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は午を過ぎて、炎暑漸多くまゝにせんとす。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　森山が、疲労と睡眠不足との身体を炎暑に煎りつけられて、日射病系の急性｜霍乱で死んでから、そこの小作人達は、代る代るに水揚げ水車を踏んだ。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日もむろん前日にまさる炎暑でしたが、勤番は半日交替で午前中にひけるはずでしたから、伝六の怪しげなる腕まえによって調理された朝食を喫すると、あまりぞっとしない顔つきで、むっつりとしながら出仕いたしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "七八月の炎暑はかうして平原の到るところの街々に激しい流行病を仲介し、日ごとに夕燒の赤い反照を浴びせかけるのである。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "饑渇の攻や、貪婪の羽虫の群もなにかあらむ、黒皺皮の満身の膚をこがす炎暑をや。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "饑渇の攻や、貪婪の羽蟲の群もなにかあらむ、黒皺皮の滿身の膚をこがす炎暑をや。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月になると、さしもに凌ぎがたかつた炎暑も次第に凉しくなつて、愛宕から北山にかけて秋の白き雲が靡き、垣根には虫の聲がすだくばかりにきこえた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "炎暑のほとぼりをもった空には低く雲が迷ってい、行手は茫漠として果しもないようであった。",
              "citation": {
                "source": "忘れがたみ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　雨降れ、雨降れ――と純吉は希つたが、日毎に炎暑が増すばかりだつた。",
              "citation": {
                "source": "渚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日炎暑昨日より甚し。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "数十日炎暑旅情風月に奪ひ去らる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、こんな葦の背丈ほどもないような木立のことも、何かで町にイルミネーションの施されたことが新聞に出た折には、『市当局の配慮により、我が市は今や、樹木の鬱蒼と繁茂せる公園によって飾られ、炎暑の候にも清涼の気を満喫し得るに至れり。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等のある一団は炎暑を重く支えている薔薇の葉の上にひしめき合った。",
              "citation": {
                "source": "女",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思えば、島原の芝居は炎暑で不入り、元金七千円金が、昨日の上り高では千五百円の大損、それに引きかえて、同所の、火除け地へ、毎夜出る麦湯の店は百五十軒に過ぎ、氷水売は七十軒、その他の水菓子、甘酒、諸商人の出ること、晴夜には、半宵の物成高五百円位、きわめて景気よしともある。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏の午過の炎暑の中へ更に熱っぽい鉄の匂いがある。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑務所の塀に沿うた町筋などに軒を並べて来た連中の暮しのほどは、およそ推察されるのであるから、急に大きな塀がとりこわされて無くなってしまった後には、※りのこされたように歪んだ長屋や小工場などが生活の内部を炎暑にさらして現れている。",
              "citation": {
                "source": "築地河岸",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨のすくない夏で、樹木の一本もない敷地の赭土の反射は炎暑でもえるようである。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱帯と亜熱帯とに亘る本島の炎暑も、さほどのものではない。",
              "citation": {
                "source": "台湾の姿態",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "野外に眠るし、炎暑の折は水に浴するし、食料としては穀物を与えずとも野草で足りる。",
              "citation": {
                "source": "台湾の姿態",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今は日本に、――炎暑の甚しい東京に汪洋たる長江を懐しがっている。",
              "citation": {
                "source": "長江游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "中野君の説明によれば、北京の苦力は炎暑の候だけ皆他省へ出稼ぎに行き、苦力の細君はその間にこの蘆荻の中にて売婬するよし。",
              "citation": {
                "source": "北京日記抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフリカは、大部分が熱帯にありまして、そのひどい炎暑が人を苦しめます。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度や南洋の土人が平生好んで辛い物を食べるのはやっぱり土地の暑いためで、支那料理の原則に秋は辛味を主とすというのも夏の炎暑で胃腸が弛んでいるからそれを刺撃させるためでしょう。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入ると流石に猛威をふるった炎暑も次第にうすらぎ、帝都の人々は、ただもうグッタリとして涼を求め、睡眠をむさぼった。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとお前さん、大将が私の前までおいでなすって、お前にゃ単た一人の子息じゃったそうだなと、恐入った御挨拶でござえんしょう。",
              "citation": {
                "source": "躯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えんしょ（艶書）や」と言って、その同級生は逃げて行ってしまう。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
