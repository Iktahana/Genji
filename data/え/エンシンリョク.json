[
  {
    "uuid": "8b4f4d83-7093-5067-ba77-88edede27e19",
    "entry": "遠心力",
    "reading": {
      "primary": "えんしんりょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
