          ],
          "literary": [
            {
              "text": "「もう政治とは絶対に縁を切る！",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、私が政治と縁を切ると決めようが、決めまいが私の一時一瞬の生活も、政治の下にあるのだ。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば母が三円投出したのも、親子の縁を切るなど突飛なことを怒鳴って帰ったのも皆なその心が見えすく。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "百円盗んで置きながら親子の縁を切るなど文句が面白ろい。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の謡は場違いだな、こっちから縁を切る。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "インターフェロンは、そんな自分と縁を切る、最後の希望でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイパーカードが二・〇版から作成機能を削って参照機能だけを標準で付ける方針を取ったとき、もう一度「いかんいかん」と吼え、「今後はアップルとは縁を切る」とうなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅さんがああ云ふ災難にお遭なので、それが為に縁を切る意なら、私は、雅さん、……一年が間……塩断なんぞ為はしませんわ」　彼は自らその苦節を憶ひて泣きぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには乳母とも定子とも断然縁を切るから以後他人と思ってくれ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなりゃ、もう先を急がなくちゃならねえんだから、がんがん鳴ると縁を切るぜ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、なかなか過去と縁を切ることができなかったし、そう手っとり早く勉強にかかることもできなかった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄弟の縁を切るなんてことは容易なことじゃ有りません」と岸本は言った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "この伯母さんは、女学校を出て、行燈袴を穿いて、四円の月給の小学教師になったので、私の母から姉妹の縁を切るといわれた女だ。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟姉妹は元々同じ親から出たもので法律的に縁を切るわけには行かぬ。",
              "citation": {
                "source": "イエスキリストの友誼",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき買っとかなけれア手前たちと縁を切るぞぐらいなことを云って脅したんだよ。",
              "citation": {
                "source": "疑問の金塊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく彼女は一座と縁を切るために、殊更自殺したらしく見せかけたものであろう。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日限り、姉妹の縁を切るわよ。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父さんと縁を切るのだよ。",
              "citation": {
                "source": "青い絨毯",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを機会に箱根と縁を切るに越したことはないから、社長室へ挨拶に行って、「ボクは東京へ帰ろうなんて思ってやしなかったんですが、これこれしかじかの次第で、長範の命令一下サルトルとゴリラの馬鹿力にトラックへ押し上げられちゃって、おまけにサルトルが東京までニコヤカに護衛してやんだから処置ねえや。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁を切るという場合には手拭を裂くという。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "母　　それなら、お前は、親子の縁を切るとおいひなのかい。",
              "citation": {
                "source": "ある親子の問答（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日かぎり、主従の縁を切るからさう思へ。",
              "citation": {
                "source": "動員挿話（二幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、今日限り、主従の縁を切る。",
              "citation": {
                "source": "動員挿話［第一稿］",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "身売りの金を手切金に、親子の縁を切るから、母も姉もないものと思って、こんな悲しい家のことは二度と思いだしてもいけませんよッて、そう言われて出たんです」　駒子は姉の厚意を思いだして堪らぬらしく、肩をふるわせているようであった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その八　時計館の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれ親同胞と縁を切ることもできるんだ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
