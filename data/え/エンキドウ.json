        "examples": {
          "standard": [
            {
              "text": "地球は太陽の周りをほぼ円軌道で公転している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人工衛星を円軌道に乗せるには、精密な計算が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "月の円軌道は地球の引力によって保たれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はまるで円軌道を描くように、同じ場所をぐるぐると回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "色々捜して燈を点しよく視ると、昼間鶏が二階のこの室に走り込んで突き破って逃げ飛んだ硝子窓の破処から、吹き込む雪｜雑りの寒風がカーテンに当って上り下りしおりその風の運動が件の両人の立ち廻りと現われ、消え失せた後もなお無形の何かが楕円軌道を循環すると見えた。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち楕円軌道にうつるわけである。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時速一万三千マイルまで下れば、楕円軌道を描いて又上空へとび上る心配はなくなる。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると月の向う側までとどく長細い楕円軌道を描いて、慣性でとんで行く。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "楕円に関する問題は早くからあるけれども、寛政暦作製のときに支那の『暦象考成後篇』によりて楕円軌道の説を採用した前後の頃から、楕円に関する研究は著しく盛んになったかとも思われる。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "暦術において楕円軌道の説は伝わっている。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
