[
  {
    "uuid": "1247182f-b2a9-5ad2-b959-7365599f408a",
    "entry": "叡慮",
    "reading": {
      "primary": "えいりょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
