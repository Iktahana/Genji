        "examples": {
          "standard": [
            {
              "text": "公衆トイレの液体石鹸が切れていたので、水だけで手を洗うしかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この液体石鹸、ハーブの良い香りがするね。洗った後も突っ張らないし」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "詰め替え用の液体石鹸をボトルに注ぐときは、こぼさないように慎重に行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "液体石鹸は泡立ちが良いので、ワンプッシュでもしっかり汚れを落とせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「この液体石鹸は、使う気になれないね」　ハチミが液体石鹸の容器を示した。",
