      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "spread of fire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "隣家で発生した火災が、強風にあおられて瞬く間に延焼した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "森林火災の延焼を防ぐため、消防隊員が懸命に消火活動にあたった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初期消火に成功したおかげで、建物全体への延焼は免れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "新聞記事は例によってまちまちであって、感傷をそそる情的資料は豊富でも考察に必要な正確な物的資料は乏しいのであるが、内務省警保局発表と称する新聞記事によると発火地点や時刻や延焼区域のきわめてだいたいの状況を知ることはできるようである。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の火災の焼失区域を調べてみると、相応な風のあった場合にはほとんどきまって火元を「かなめ」として末広がりに、半開きの扇形に延焼している。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことがまた実に延焼区域を増大せしめるためにまるであつらえたかのように適応しているのである。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火災中にしばしば風向が変わったと報ぜられているがこれは大火には必然な局部的随伴現象であって現場にいる人にとっては重大な意義をもつものであるが、延焼区域の大勢を支配するものではないから、上記の推測に影響を及ぼす性質のものではないと思われる。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火災延焼に関する方則も全然不明である。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "延焼を支配するものは当時の風向風速気温湿度等のみならず、過去の湿度の履歴効果も少なからず関係する。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその延焼区域の住民家屋の種類、密集の程度にもよることもちろんである。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの支配因子が与えられた場合に、火災が自由に延焼するとすればいかなる速度でいかなる面積に広がるかという問題についてたしかな解答を与えることは現在において困難である。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年前山火事に関する若干の調査をしたいと思い立って、目ぼしい山火事のあったときに自分の関係の某官衙から公文書でその山火事のあった府県の官庁に掛け合って、その山火事の延焼の過程をできるだけ詳しく知らせてくれるように頼んでやったことがあった。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸王は国中に臨きて、京に至るを得る無かれ、と云えるは、蓋し其意諸王其の封を去りて京に至らば、前代の遺※、辺土の黠豪等、或は虚に乗じて事を挙ぐるあらば、星火も延焼して、燎原の勢を成すに至らんことを虞るるに似たり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて露領沿海のタラバ蟹に延焼し、加察加の鮭、鰊と宛然に燎原の火の如く、又は蘇国の空軍の如く、無辺際の青空に天翔る形勢を示したが、その途端、何気なく差した湊屋の盃を受けて唇に当てたのが運の尽き、一瞬の中に全局面を、無学文盲の親友に泄われてしまった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十娘はすぐに出て往ったが、翌日になって崑の家は母屋から火が出て幾棟かに延焼し、几案牀榻、何もかも灰になってしまった。",
              "citation": {
                "source": "青蛙神",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下女｜詮方なさにその火を羊の脊に置くと羊熱くなりて狂い廻り、村に火を付け人多く殺し山へ延焼して山中の猴五百疋ことごとく死んだ。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで雷門から蔵前の取っ付きまで綺麗に焼き払ってしまった上、さらに花川戸から馬道に延焼し、芝居町まで焼け込んで行きました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "浅草の大火のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "琉球列島の戦が終った頃、隣県の岡山市に大空襲があり、つづいて、六月三十日の深更から七月一日の未明まで、呉市が延焼した。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "琉球列島の戦が終つた頃、隣県の岡山市に大空襲があり、つづいて、六月三十日の深更から七月一日の未明まで、呉市が延焼した。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "火は幸に伊沢の家を延焼するに及ばなかつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "田端も亦延焼せんことを惧れ、妻は児等の衣をバスケツトに収め、僕は漱石先生の書一軸を風呂敷に包む。",
              "citation": {
                "source": "大正十二年九月一日の大震に際して",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "疎林は落葉し、林床には野火の跡があり、線路近くまで延焼して来てゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して、浜町は土地が低くて湿気も多いし、水も悪いし、大火ある度に風下となって延焼する虞れもあるというので、その後またまたそこを売却されて、現今の芝公園の紅葉館の隣地へ転任せらるる事になった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり工場には番人だけしかおりませんから、爆発が起れば、貴重な機械は完全に壊れるうえに、火災が起っても、人手が足りないから、どんどん延焼していきます」「だがなあ、ワイコフ。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "品川区、荏原区は、目下延焼中であります。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災に比べて、延焼の時間が短かかったので（震災は三日間で焼け、今度は六時間位で焼けた）惨害もひどかったことがうなずける。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに東へ行って元神戸一中に至るあたりが焼け、グラウンドで延焼を喰いとめている様子。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十日の空襲の市街大延焼にて、疎開強化令を出して混乱を生ぜしめた失政軽からず。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "油店からの火災も、附近数百を焼いただけで、それ以上延焼することもなく幸いに鎮火した。",
              "citation": {
                "source": "雷",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けて十九日となると、景蔵は西の蛤御門、中立売御門の方面にわくような砲声を聞き、やがて室町付近より洛中に延焼した火災の囲みの中にいたとある。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政紀元十二月二十八日の夜、酉の下刻、神田多町二丁目北側の乾物屋三河屋半次郎の店から発火して南の方日本橋まで延焼した。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕山が「悼亡」の律詩中に「一火延焼旧草廬。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔一火延焼ス旧草廬ヲ／連宵野宿シ寒ニ中ルノ初〕とある。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
