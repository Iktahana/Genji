[
  {
    "uuid": "451d3c1c-5429-5b30-9624-c24f43b74d1b",
    "entry": "延焼",
    "reading": {
      "primary": "えんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
