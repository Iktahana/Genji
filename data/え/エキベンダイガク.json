        "examples": {
          "standard": [
            {
              "text": "彼は東京の有名大学を落ちて、結局地元の駅弁大学に進学したらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この辺りでは珍しくないよ、駅前に一つくらいは駅弁大学があるもんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "駅弁大学出身だからって、馬鹿にはできないよ。優秀な人もたくさんいるさ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "息子が駅弁大学でもいいから、とにかく大学に行ってほしいと妻が言っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
