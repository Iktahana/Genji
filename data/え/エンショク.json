        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、裏切りの事実を知らされた瞬間、相手に対して明確な怨色を浮かべた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議中、彼の提案が却下されたとき、一瞬彼の目に怨色が宿ったように見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の不満が募り、彼女は彼を見つめる視線に常に怨色を帯びていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
