        "examples": {
          "standard": [
            {
              "text": "絵画の中の聖人の頭上には、神聖な円光が描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "満月の周りに淡い円光がかかり、幻想的な夜空だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜明け前の東の空に、太陽の円光がわずかに見え始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その島の平らないただきに、立派な眼もさめるやうな、白い十字架がたって、それはもう凍った北極の雲で鋳たといったらいゝか、すきっとした金いろの円光をいただいて、しづかに永久に立ってゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞたくさんのくるみの木が葉をさんさんと光らしてその霧の中に立ち黄金の円光をもった電気栗鼠が可愛い顔をその中からちらちらのぞいてゐるだけでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その島の平らないただきに、立派な眼もさめるような、白い十字架がたって、それはもう凍った北極の雲で鋳たといったらいいか、すきっとした金いろの円光をいただいて、しずかに永久に立っているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただたくさんのくるみの木が葉をさんさんと光らしてその霧の中に立ち黄金の円光をもった電気｜栗鼠が可愛い顔をその中からちらちらのぞいているだけでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "立派な瓔珞をかけ黄金の円光を冠りかすかに笑ってみんなのうしろに立ってゐました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その島の平らないただきに、立派な眼もさめるような、白い十字架がたって、それはもう、凍った北極の雲で鋳たといったらいいか、すきっとした金いろの円光をいただいて、しずかに永久に立っているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただたくさんのくるみの木が葉をさんさんと光らしてその霧の中に立ち、黄金の円光をもった電気栗鼠が可愛い顔をその中からちらちらのぞいているだけでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾翔大力、微笑して、金色の円光を以て頭に被れるに、その光、遍く一座を照し、諸鳥歓喜充満せり。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾翔大力微笑して、金色の円光を以て頭に被れるに、その光｜遍く一座を照し、諸鳥歓喜充満せり。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾翔大力、微笑して金色の円光を以て頭に被れるに、諸鳥歓喜充満せり。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その円光はぼんやり黄金いろにかすみうしろにある青い星も見えました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾翔大力、微笑して、金色の円光を以て頭に被れるに、その光、遍く一座を照し、諸鳥｜歓喜充満せり。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾翔大力｜微笑して、金色の円光を以て頭に被れるに、その光｜遍く一座を照し、諸鳥｜歓喜充満せり。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾翔大力、微笑して金色の円光を以て頭に被れるに、諸鳥｜歓喜充満せり。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日影は枯芝の根を染めながら、目近き霧のうら枯を渡るのが、朦朧と、玉子｜形の鶏を包んで、二羽に円光の幻を掛けた。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の打算も無い好意、押し売りでは無い好意、二度と来ないかも知れぬひとへの好意、自分には、その白痴か狂人の淫売婦たちに、マリヤの円光を現実に見た夜もあったのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡丹の大株にも見紛ふ、この芍薬は周囲の平板な自然とは、まるで調子が違つてゐて、由緒あり気な妖麗な円光を昼の光の中に幻出しつゝ浮世離れて咲いてゐた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙はひえっとした先生の仰っしゃるばら／＼になった氷のような骨の潤いになるのかも知れないから――　二重に縺れる水音を聞きながら、眠るともなく覚るともなく夜中の時刻を過すうち、また、ふと気がついてみると、部屋の中へ霧が忍び込み、ランプは夏蜜柑の切口を見るような円光を放っています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "月夜澄みきつた中天にめり込んだ小ひさな満月、白孔雀の尾だ、あの円光は。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "柘榴柘榴は飛ぶ人の手より、空中の円光と赤。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人のおのづからなる円光である。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その髪の毛に円光が立つ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷里ではその子の禎介氏の記念図書館の館長をしていられ、老後を全く壮烈な忠死を遂げた、その子の名誉を己れの円光として生きている人である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うから小さな人影が来た、生きて動いて、何か帽子に幽かな円光を発てて。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろなるは、頭に宝珠瓔珞を纏い、頂に肉髻あり、妙相端厳、仄かに円光を負うておられるは、何さま尋常人ならずと見えた。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えんこう」（河童）を釣る話とかいう種類のものが多かった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一例として「えんこう」の話をとると、夕涼みに江ノ口川の橋の欄干に腰をかけているとこの怪物が水中から手を延ばして肛門を抜きに来る。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時刻にそこから十町も下流の河口を船で通りかかった人が、何かしら水面でぼちゃぼちゃ音がしていると思ってよく見ると、一匹の「えんこう」が、しきりにぐるぐる廻転運動をしているのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり「えんこう」の手は自由自在に伸長されるもので、こんなにまで長くなり得るものだという事が、この「事実」で証明されるというのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのしばてんの一種のえんこうは水に泳いでいる子供の肛門をぬいた。",
              "citation": {
                "source": "鷲",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
