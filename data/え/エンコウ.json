    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flame",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "キャンプファイヤーの炎光が、夜の森を明るく照らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "暖炉で燃える薪から、心地よい温かい炎光が広がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ろうそくの炎光が揺らめき、食卓にロマンチックな雰囲気を添えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「えんこう」（河童）を釣る話とかいう種類のものが多かった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一例として「えんこう」の話をとると、夕涼みに江ノ口川の橋の欄干に腰をかけているとこの怪物が水中から手を延ばして肛門を抜きに来る。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時刻にそこから十町も下流の河口を船で通りかかった人が、何かしら水面でぼちゃぼちゃ音がしていると思ってよく見ると、一匹の「えんこう」が、しきりにぐるぐる廻転運動をしているのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり「えんこう」の手は自由自在に伸長されるもので、こんなにまで長くなり得るものだという事が、この「事実」で証明されるというのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのしばてんの一種のえんこうは水に泳いでいる子供の肛門をぬいた。",
              "citation": {
                "source": "鷲",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの子はえんこうにこうもんを抜かれた」　私の村では、河童をえんこうと云った。",
              "citation": {
                "source": "村の怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい、それは何だ」「これは、昔から日本にもあるといわれてたが、そのありかはなかなか知れていない水鉛鉛鉱だよ」「すいえんえんこう、だって。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "えんこ・えんこうは、猿猴から出たと言ふ考へは、誰しも信じ易い考へなるが為に、当分動す事は出来さうもない。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "石見国の方言にはえんこうばなともいうとある。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            }
          ]
        }
