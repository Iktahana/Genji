          "standard": [
            {
              "text": "革命の嵐を逃れた貴族たちは、パリの裏通りでエミグレとしての不遇な日々を耐え忍んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カフェの隅で、エミグレの詩人が母国の情勢を案じながら、熱っぽく詩を朗読している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "エミグレである彼の作品には、常に喪失感と故郷への痛切な思慕が漂っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "エミグレ紙は大科学者ピョートル・カピッツァの次の言葉を伝えている「ラゴーフとチェルパス、こんなチームができた。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
