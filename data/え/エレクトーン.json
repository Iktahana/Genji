        "examples": {
          "standard": [
            {
              "text": "昔、おじいちゃんの家でエレクトーンを弾かせてもらったのが、音楽に興味を持つきっかけになったんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この曲は、エレクトーンの豊かな音色を活かしてアレンジされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "発表会に向けて、エレクトーンの練習に毎日励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "入るとすぐ右にボックス席があり、左側はエレクトーンやアンプ、マイクなどの置いてある小さなステージ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレクトーンを弾きながら、まあなんとか、いけるのだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくとミーヨをそこにすわらせ、小川は、ウオッカを注いだ小さなグラスを持ち、エレクトーンへ歩いた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
