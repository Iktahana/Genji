          "literary": [
            {
              "text": "入るとすぐ右にボックス席があり、左側はエレクトーンやアンプ、マイクなどの置いてある小さなステージ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレクトーンを弾きながら、まあなんとか、いけるのだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくとミーヨをそこにすわらせ、小川は、ウオッカを注いだ小さなグラスを持ち、エレクトーンへ歩いた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
