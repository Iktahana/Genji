        "examples": {
          "standard": [
            {
              "text": "大学の演習林で、樹木の成長速度を測定するフィールドワークに参加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「演習林の中は電波が入らない場所もあるから、単独行動は控えてね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この演習林では、100年以上前から森の生態系に関するデータが蓄積されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "演習林の管理人さんに、最近の野生動物の出没状況を伺った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "夏期のエキスカーションに演習林へ行く時によく自分と同じ組になって測量などやって歩いた。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夏演習林へ林道敷設の実習に行った時の事である。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
