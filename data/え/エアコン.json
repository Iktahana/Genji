        "examples": {
          "standard": [
            {
              "text": "猛暑日が続くから、家に帰ったらすぐにエアコンをつけて部屋を冷やしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "うちのエアコン、最近変な音がするから、そろそろ買い替え時かもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寝苦しい夜は、エアコンをつけっぱなしにするんじゃなくて、タイマー設定を活用するといいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また電子炊飯機とエアコン、オーディオ機器の使い方が、我慢強い人は当然というかも知れないが、ばらばらであるのも情けない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにも知らないガキにもどったみたいだ」　だれかがエアコンのスウィッチでも入れたように、開け放した窓から、いきなり冷たい風が吹きこみ、網戸をがたつかせた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "エアコンのある事務室ではわからなかったが、いつのまにか、気温が高くなっていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "電子レンジがさまざまな調理パターンや解凍の機能を備え、エアコンがきめの細かな温度調節を引き受けるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
