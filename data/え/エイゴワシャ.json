        "examples": {
          "standard": [
            {
              "text": "道で困っている英語話者を見かけ、流暢な友人がすぐに助けに入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国際会議では、様々な国の英語話者が集まり、活発な議論が交わされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の観光客はほとんどが英語話者なので、案内板も英語表記が中心だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この衝突は英語話者の間にも、方言の間の衝突というより隠微な形で出現している。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
