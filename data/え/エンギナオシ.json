          ],
          "literary": [
            {
              "text": "（白酒をおあがり、晋ちゃん、私が縁起直しに鉢の木を御馳走しよう。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "安い料理屋で縁起直しに一杯飮む。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてお若さんもお炬燵へ、まあ、いらっしゃいまし、何ぞお暖なもので縁起直しに貴下一口差上げましょうから、　あれさ、何は差置きましてもこの雪じゃありませんかねえ。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……縁起直しに、いま古い葡萄酒でも持ってくるわ」　あたしたちは、それから口あたりのいい洋酒の盃を重ねていった。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "冗談は止しにして、ひとつ若旦那、縁起直しに、これから眼の覚めるとこへ、お供をさせておくんなさいまし」「眼の覚めるとことは。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで喜兵衛は心機一転、年が改ると共に自分の誕生日がくるから、ちょうど還暦に当るを幸い、厄払い、縁起直しに思いついたのが生きた葬式である。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙に散つてゐるはねは染める時に除けばいゝし、自分を宇宙のなかの一個の傀儡だと自認しながらも、あのやうな情熱を生活のなかに持ちこたへてゐる老人の筆に成つた絵は、月足らずで弱々しく生れた赤ん坊のためにも何か縁起直しになるやうに思つたのだ。",
              "citation": {
                "source": "南京六月祭",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "合点長屋へ帰ろうとして、藤吉がふと見ると、縁起直しのつもりであろう、弥吉と小僧が尻をからげて、清水で桔梗屋の前構えをせっせと洗っていた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "どりゃ縁起直しに例の水晶の栓でも調べてみよう』　彼はムックリ起き上って暖炉の上へ手をかけた。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みなさん済みませんが手を貸して下さい、なが雨の縁起直しにみんなでひと口やりましょう、少しばかりで恥ずかしいんですが、どうか手分けをして、私も飯ぐらい炊きますから、手料理ということでやろうじゃありませんか」　同宿者たちのあいだに、喜びとも苦しみとも判別のつかない、嘆息のような声が起こった。",
              "citation": {
                "source": "雨あがる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
