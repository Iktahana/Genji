          "literary": [
            {
              "text": "右衛門尉・左衛門尉、右兵衛尉・左兵衛尉というものがその実空官であったけれども、地方の武士を奨励する唯一の栄典であったのです。",
              "citation": {
                "source": "名字の話",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　栄典を授与すること。",
              "citation": {
                "source": "日本国憲法",
                "author": "施行、昭和二二年・五・三",
                "note": "青空文庫"
              }
            },
            {
              "text": "(3)栄誉、勲章その他の栄典の授与は、いかなる特権も伴はない。",
              "citation": {
                "source": "日本国憲法",
                "author": "施行、昭和二二年・五・三",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄典の授与は、現にこれを有し、又は将来これを受ける者の一代に限り、その効力を有する。",
              "citation": {
                "source": "日本国憲法",
                "author": "施行、昭和二二年・五・三",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄誉、勲章その他の栄典の授与は、いかなる特権も伴わない。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
