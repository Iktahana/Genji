        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女がはにかむと、右の頬に可愛らしい笑窪が浮かび上がるのが印象的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「赤ちゃんの笑窪、パパにそっくりね」「本当だ、笑うと急に似てくるな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鏡の前で笑顔の練習をしていたら、自分に笑窪があるのを初めて知って少し驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "連れて来た袖猿に栗をあてがって置いて、彼女等はお互いの着物の皺に出来た大小の笑窪を評し合っている。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑いかけると、左右の頬に、子供のような笑窪が出来た。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人の画家に「大陸的」と極めをつけられてよいのか悪いのか判らないが、気に入った批評として笑窪に入った檜垣の主人まで「そういえば、なるほど、君の芸術は味だな」と相槌を打つ苦々しさ。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女などどこが良いのだろうと、改めて思われて、三好は自分が女の腹から生れた人間だとはいかにも思いたくなく、佐助のアバタが笑窪だなどと思いたがるこんな女など、早く佐助に押しつけてしまおうと、やっきになって佐助の行方を探していたが、空しかった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄養不良らしい青い顔をして、そりの強い眼鏡を掛けてゐてオドオドした娘だつたが、楢雄が行くたび首筋まで赧くして、にこつと笑ふと、笑窪があつた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "目には、曲がり角の朽ちかかった黒板塀を透して、木部から稟けた笑窪のできる笑顔が否応なしに吸い付いて来た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は少しいたずららしい微笑を笑窪のはいるその美しい顔に軽く浮かべながら、階段を足早に降りて行った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぞかしおどろくかと思いのほかに、ちらりと幽かに笑窪を見せながら、ずいとひと足うしろに退ると、不敵なことに得物は同じ鉄扇なのでした。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇姉さ　こつち見なちよいと顔見せな頬の笑窪は誰にもろた　　　◇頬の笑窪はお母さんがくれた転んで失すなと言ふてくれた　　　◇切れる鼻緒の下駄ならいやだころびやお母さんにしかられる　素顔の美人は見ることが出来てもさすがは山間のへき地だけに、東京で見るやうなモダン・ガールは見ることは出来ない。",
              "citation": {
                "source": "大利根八十里を溯る",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際藤野さんは、今想うても餘り類のない程美しい兒だつたので、前髮を眉の邊まで下げた顏が圓く、黒味勝の眼がパッチリと明るくて、色は飽迄白く、笑ふ毎に笑窪が出來た。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お定は打見には一歳も二歳も若く見える方で、背恰好の※乎としたさまは、農家の娘に珍らしい位、丸顏に黒味勝の眼が大きく、鼻は高くないが笑窪が深い。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お定は、打見には一歳も二歳も若く見える方で、背恰好の※乎としたさまは、農家の娘に珍らしい位、丸顔に黒味勝の眼が大きく、鼻は高くないが、笑窪が深い。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際藤野さんは、今想うても余り類のない程美しい児だつたので、前髪を眉の辺まで下げた顔が円く、黒味勝の眼がパツチリと明るくて、色は飽迄白く、笑ふ毎に笑窪が出来た。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚い鮮やかな色の耳が福福しく、下膨れの落ちついた頬に笑窪が洩れる。",
              "citation": {
                "source": "榛名",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中には結婚後八年目に初めて女房の笑窪を発見たものがある。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、すつかり白状して初めて笑窪を見せたといふ事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり亭主は女房の年齢で笑窪を二つ購つた事になつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠州は男だつたから、他人の親切を被ながら、女のやうに唯｜笑窪を見せて済ます訳にも往かなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋や珈琲店へ入ると、女給仕が急に飴ちよこのやうな甘い笑窪を見せてちやほやしてくれた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼鼻だちのぱらりとした笑窪の顔が愛嬌だったし、人見知りをするふうもなくて、よく遊戯をしたり、大きな声で唱歌をうたったりしてみせるので、誰れからも可愛がられた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、真っ赤に面を火照らせて、お茶の支度にうろうろしている寿女のほうへ、笑窪の顔をみせて言った。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に立って誰れかれへ挨拶をしている笑窪のよった愛想のいい洋装の婦人は、写真で見かけたことのある奥住女史に相違なかった。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌うたいは、笑窪のよったあどけない顔で、いろいろな指示をした。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九太の残した丼の汁までちゅうと吸うと、子供のように笑窪のある手の甲で脣のはたを拭いた。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は片笑窪をみせて一寸おじぎをするとそのまゝ奧へ引つこんで行つてしまつたけれども、暫くして出て來ると前よりも丁寧に膝をついた。",
              "citation": {
                "source": "風媒",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい笑窪のある両頬なども熟した杏のようにまるまるしている。",
              "citation": {
                "source": "点鬼簿",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この妓にも、好きな人がひとりあるのっせ」と、軽く弄うようにいうと、若奴は優しい顔に笑窪を見せて羞かしそうにしながら、両掌で頬のあたりを擦って、「ほんまにあのころはよう寄せてもろていましたなあ」と、過ぎ去った時分のことを思いうかべるような顔をしている。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という、何とも言うに言えない句調が、私の心を溶かして了うようで、それを聞いていると、少し細長い笑窪の出来た、物を言う口元が歴々と眼に見える。",
              "citation": {
                "source": "別れたる妻に送る手紙",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　すると婦人が、下ぶくれな顔にえくぼを刻んで、三ツばかりはきはきと続けて頷いた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はかったようにえくぼを左右へ彫り込んだ下膨れの頬。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
