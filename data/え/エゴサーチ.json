          "standard": [
            {
              "text": "有名税だと思って割り切っているが、やはりエゴサーチで叩かれているのを見ると胃が痛む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マーケティングの一環として、自社製品の評判をエゴサーチして不満点を洗い出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「エゴサーチなんて時間の無駄」と断言する彼だが、実は夜な夜なこっそりチェックしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "誤情報が拡散されていないか監視するため、広報チームは一日に何度もエゴサーチを行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
