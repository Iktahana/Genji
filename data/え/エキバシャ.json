[
  {
    "uuid": "2d0cc9fc-0e53-5171-af55-ac52eae7fa3c",
    "entry": "駅馬車",
    "reading": {
      "primary": "えきばしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
