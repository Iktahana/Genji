[
  {
    "uuid": "9e97fb5c-afad-5ea6-9c0f-d93616c66971",
    "entry": "冤罪",
    "reading": {
      "primary": "えんざい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "false charge",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は無実を訴え続けたが、結局冤罪で捕らえられてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "DNA鑑定の結果、長年服役していた彼の冤罪がようやく晴らされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この痛ましい冤罪事件は、司法制度のあり方に一石を投じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "わたくしの致した事を、もし不断の尺度で、日常生活の尺度で量って下さいましたら、それはわたくしのためにひどい冤罪になるのでございますから。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり※祇尼法であったろうことは思遣られるが、他の者に祈られて狐が二匹室町御所から飛出したなどというところを見ると、将軍長病で治らなかった余りに、人に狐を憑けるなどという事が一般に信ぜられていたに乗じて、他の者から仕組まれて被せられた冤罪だったかも知れない。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかげで僕たちが、ほら、いつか、冤罪をこうむった事があったじゃありませんか。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理不尽に引っ括って痛め吟味にでも掛ければ、直ぐにも冤罪を引受けそうな気の弱い連中ばっかりじゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "誓って冤罪はお被せ申しません。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは冤罪です、全く冤罪です。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐が化けるなどは、狐にとって、とんでも無い冤罪であろうと思う。",
              "citation": {
                "source": "女人訓戒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぞ余が冤罪を身に負いて、暫時の間に無量の艱難を閲し尽くす媒なりける。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にあらゆる証拠が揃っていながら「冤罪だな」と名奉行が心付き、又はなんの証拠もなくて反証ばかりあがっていながらテッキリ此奴と名判官が睨むのは、その無私公明、青空止水の如き心鏡に、被告人の鼻の表現がありありと映ったものに違いありませぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妻は睡っていてかえられたものです、実に不思議ですが、その理由がわからないのです、僕が殺したというのは冤罪です」　呉侍御は朱の言葉を信にできないので訴えた。",
              "citation": {
                "source": "陸判",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぞ余が冤罪を身に負ひて、暫時の間に無量の艱難を閲し盡す媒なりける。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大旱に際して聖王湯（中国、殷王朝初代の王）が自分を責めた事実は史上に著明であり、竇娥が冤罪で死んで暑月に霜を飛ばした事は戯曲（中国の元曲、竇娥冤）の好題となっている。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "冤罪であるという自信を持って京に留まっていますことも朝廷へ済まない気がしますし、今以上の厳罰にあわない先に、自分から遠隔の地へ移ったほうがいいと思ったのです」　などと、こまごま源氏は語っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国の朝廷にもずいぶんありますように冤罪にお当たりになったのでございます。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冤罪のために、思いも寄らぬ国へ漂泊って来ていますことを、前生に犯したどんな罪によってであるかとわからなく思っておりましたが、今晩のお話で考え合わせますと、深い因縁によってのことだったとはじめて気がつかれます。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おゝ、××君、君は革命歌をうたつたさうだね』　彼はなんて冤罪だ―と心に怒つた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤君は冤罪を着ているのではないか。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ若杉さんの心理に動いていた感情は、どんなことがあっても、冤罪の人を作ってはならぬという考えでした。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく裁判の話の時に、引き合いになる格言ですが、「たとい九人の有罪者を逸するとも、一人の冤罪者を作ることなかれ」という戒めです。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるおかたがひょっくりお越しなさいまして、おまえはまがいものをこしらえるがじょうずとのうわさじゃ、ないしょに急いで古島雛の男雛を一つ、――ようござんすか、ここがだいじでもあり、あたしの冤罪の晴れる急所でもございますから、よくお聞きくださいましよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹の冤罪で憤怒し狂乱している私の心は全く悪辣になった。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に一匹吐き出したのを、女が早く見つけていたら、飛んだ冤罪を受けずとも済んだかも知れなかったが、男がそっと隠してしまったのでちっとも気が付かなかったらしい。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半鐘はあたかも権太郎の冤罪を証明するように鮮かな音を立てて響いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに彼が冤罪を訴えても、小判二枚を持っていたという証拠がある以上、なかなかその疑いは晴れそうもなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、政吉の冤罪を証明したのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "冤罪を被ッてはこれを弁解する必要が有る。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "林檎の冤罪４・30（夕）　エデンの花園で、蛇に欺されてイヴが食べた果実を、大抵の人は林檎だと思つてゐるらしいが、それは大きな間違で、あの果実が林檎で無かつたのは、誰よりかも私がよく知つてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日は英語で一番綴りの長い語の事を言つたが、今日は林檎の冤罪を雪いだお剰けに、世界中で一番長い名前をお知らせする。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぞ余が冤罪を身に負ひて、暫時の間に無量の艱難を閲し尽す媒なりける。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
