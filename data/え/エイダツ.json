        "examples": {
          "standard": [
            {
              "text": "彼女は数々の賞を受賞し、ついに学界での穎脱を遂げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "若手アーティストの穎脱を支援するプログラムが始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の研究は、長年の努力の末、穎脱の機会を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "是実に、淮陰侯が、井※に成安君を破れるの妙策、錐は遂に悉く穎脱し了れる也。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "況や初任に際して試驗法によるは、必しも爾後に於て穎脱の逸材を拔擢するを妨げざるものなるをや。",
              "citation": {
                "source": "貢院の春",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
