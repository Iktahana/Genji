          "literary": [
            {
              "text": "身上はなかなかえいそうだけれど、あれもやっぱりかわいそうさ。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えいそうかいね、何んせ近年にない豊作やさかい。",
              "citation": {
                "source": "恭三の父",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くもない駅を出てゆくらしい汽車の汽笛が、なんのこだまもなしに遠い遠い感じで消えいそぐと、あとはあんまり洞ろで、人の心を内がわ深いところで孤独のはてに引きいれる。",
              "citation": {
                "source": "北のはての地に",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつは我々両名の者は、小太郎山に砦をきずく用意にかかっておりましたが、はからずも主君伊那丸さまが、穴山梅雪の手にかこまれて、きょう裾野へさしかかるゆえ、出会せよという小幡民部どのからの諜状、それゆえいそぐところでござる」「思いがけないところで、同志のおのおのと落ち会いましたことよ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
