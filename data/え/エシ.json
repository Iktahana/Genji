[
  {
    "uuid": "07242577-85b8-5df2-a58f-757eb242b694",
    "entry": "絵師",
    "reading": {
      "primary": "えし",
      "alternatives": [
        "がし"
      ],
      "is_heteronym": true
    },
    "grammar": {
