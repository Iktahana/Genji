        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供向け絵本の挿絵は、優しいタッチの絵師が担当した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ゲームのキャラクターデザインは、才能あふれる絵師たちのチームによって作られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、ウェブサイトで使うイラストを依頼するために、数人の絵師に声をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人気作家の新作小説の装画を手がけた絵師が話題になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
