        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "基地の入り口にある衛兵所で、身分証の提示を求められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雨宿りをさせてもらおうと、駆け込むようにして古い衛兵所の軒下に入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あそこの衛兵所を通り過ぎれば、もうすぐ王宮の内苑ですよ」と案内人が指差した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "交代の歩哨は衛兵所から列を組んで出ているところだった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう十五分すれば、二人は衛兵所へ帰って休めるのだった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の少し下の方には、衛兵所のような門鑑があった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨時の衛兵所もそこに出来ている。",
              "citation": {
                "source": "その年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、海岸にある衛兵所までくると、まったく、なんとも思いがけない大変化に気がついたのだ。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっという間に、衛兵所の前を通りすぎた。",
              "citation": {
                "source": "人造人間の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は西門で自動車から降されると、衛兵所で○○○○室の所在を尋ねた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃剣がぴかりとして、私たちは衛兵所の前に立つた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "衛兵所の前を通つて、建物の正面に立つと、アーチ形の玄関を距てゝ、泉水のある中庭が見え、この庭を中心に、廊下を繞らした二階が四方からのぞいてゐる。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、日本軍の衛兵所へ、附近の民家で麻雀賭博が行はれてゐる旨を密告するものがあつた。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "城門の一つに配置された衛兵所の傍らに佇んで、そこを出入する民衆の一人々々が所持品を調べられてゐる有様を見てゐると、実に旺んなものだといふ気がする。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼年学校を卒業して士官学校へはひるまでの半年と、士官学校を出てから任官後二年を過したこの久留米といふ町は、なにかにつけて想ひ出の多い町であるが、連隊の兵舎も昔ながらの面影を残し、衛兵所の上へ枝をひろげた榛の木にもたしかに見覚えがあつた。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの衛兵所の、角灯を持った兵士たち。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッピイはいつの間にか入口の衛兵所を離れて僕たちと一緒になり「ああ可哀相に、何をしているんだろう？",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちきれなくなって、また衛兵所へ行った。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の横の衛兵所にはアメリカの憲兵とフィリピンの兵士が詰めかけている。",
              "citation": {
                "source": "十三夜",
                "author": "――マニラ籠城日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "衛兵所へ外出の交渉にいった相川が、意気揚々と引っかえしてきた。",
              "citation": {
                "source": "十三夜",
                "author": "――マニラ籠城日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は私一人を連れて衛兵所に入り、目の前の木製の机の上に書類を何枚か置くと、記入のうえ署名しろと言って反対側に座った。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士は出て行きがてら私の前で衛兵所に鍵をかけた。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
