        "examples": {
          "standard": [
            {
              "text": "長年の経験が彼の作品に深い円熟味を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このウイスキーは、熟成期間を経て素晴らしい円熟味を帯びている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ベテランの職人だけが出せる、その技には円熟味があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の歌声には、人生経験が滲み出るような円熟味がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」「むろん、ウマ年だからです」　中年までは、ピンとはねたドイツ式のヒゲだったのが、のちには、先を刈りこんで、ヒゲまで円熟味を見せていた。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
