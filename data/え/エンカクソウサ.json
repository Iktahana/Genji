        "examples": {
          "standard": [
            {
              "text": "ドローンは、専門のオペレーターによって地上から遠隔操作されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "セキュリティカメラの遠隔操作機能を使えば、外出先から自宅の様子を確認できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新の家電製品は、スマートフォンアプリでエアコンや照明を遠隔操作できるものが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は遠隔操作でロボットアームを動かし、精密な作業をこなした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "地球の当局が遠隔操作で着陸させたのです。",
              "citation": {
                "source": "親友たち",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            },
            {
              "text": "よれよれの帽子に触り、あたかも遠隔操作に答えるかのようにして、果物籠を五個積み重ねて、頭にうまくのせた。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
