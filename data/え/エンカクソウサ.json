          "literary": [
            {
              "text": "地球の当局が遠隔操作で着陸させたのです。",
              "citation": {
                "source": "親友たち",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            },
            {
              "text": "よれよれの帽子に触り、あたかも遠隔操作に答えるかのようにして、果物籠を五個積み重ねて、頭にうまくのせた。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
