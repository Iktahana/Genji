[
  {
    "uuid": "2c974822-e59c-573b-be99-b8cacc4cc50e",
    "entry": "駅員",
    "reading": {
      "primary": "えきいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(train) station attendant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "電車が遅延したので、駅員さんに事情を尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "困っていた旅行者に、駅員さんが親切に道を教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「切符は自動券売機でも購入できます」と駅員さんが案内していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お出口はこちらです」駅員さんの声に促され、ホームを降りた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "駅員の不機嫌顔甚だしきも官線はやはり官線だけの権力とか云うものあるべしと、かしこみて願い奉りようよう切符を頂戴して立ちいずれば吹き上ぐる朝嵐に藁帽飛んでぬかるみを走る事｜数間、ようやく追い付きて取止めたれど泥にまみれてあまり立派ならぬ帽の更に見ばえを落したる重ね／＼の失敗なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査と駅員に守られて一旦乗船したが出船間際に連れ下ろされて行った。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、改札口で切符切りの駅員がきっと特別念入りにその切符を検査するようである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう考え方はしかし決して改札の駅員を侮辱するものではないので、すべての人間はある度まではある場合のある環境のもとにはやはり一種の自動人形としてしか働いていないからである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事によるとこの人は東京駅員で昨夜当直をしたのが今朝有楽町辺の宿へ帰って行くのではないかという仮説をこしらえてみた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場には、駅員の外、誰れもいなくなった。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員の一人は、帽子とゝもに、黒い頸窪ばかりだが、向ふに居て、此方に横顔を見せた方は、衣兜に両手を入れたなり、目を細め、口を開けた、声はしないで、あゝ、笑つてると思ふのが、もの静かで、且つ沁々寂しい。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨に誘はれて影も白し、蛙は其の饂鈍食ふ駅員の靴の下にも鳴く。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄い髪の、かじかんだお盥結びで、襟へ手拭を巻いて居る、……汚い笈摺ばかりを背にして、白木綿の脚絆、褄端折して、草鞋穿なのが、ずつと身を退いて、トあとびしやりをした駅員のあとへ、しよんぼりと立つて、饂飩へ顔を突込むだ。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員は最う見えなかつた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員が黒く、すら／＼と、雨の雫の彼方此方。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "跫音乱れて、スツ／＼と擦れつゝ、響きつゝ、駅員の驚破事ありげな顔が二つ、帽子の堅い廂を籠めて、園の居る窓をむづかしく覗込むだ。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が、少なからず茶の外套氏を驚かして、渠をして駅員に急を告げしめたものに相違ない。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、もし、もし……駅員の方、駅の方――駅夫さん……」とけたゝましく呼んだ。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時過ぎの汽車で帰京しようとして沓掛駅で待ち合わせていたら、今浅間からおりて来たらしい学生をつかまえて駅員が爆発当時の模様を聞き取っていた。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なになんでもないですよ、大丈夫ですよ」と学生がさも請け合ったように言ったのに対して、駅員は急におごそかな表情をして、静かに首を左右にふりながら「いや、そうでないです、そうでないです。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "がやがやいい罵る人ごみの中を駅員があっちでもこっちでも手を上げたり下げたりしたかと思うと、婆やは飛び上らんばかりにたまげさせられた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　年若い駅員が、「貴方がたは？",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員の去ったあとで、「唯今、自動車を差上げますよ。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員に御話しになろうと、巡査にお引渡しになろうと、それはしかし御随意です。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙な時刻に着いたものだと、しょんぼり佇んでいると、カンテラを振りまわしながら眠ったく駅の名をよんでいた駅員が、いきなり私の手から切符をひったくった。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場では降りる時も乗る時も、あらかじめ何時もの僕とは服装を更えて、黒眼鏡までかけていたので、駅員達に見咎められずに済んだ。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と図に乗って饒舌るのを、おかしそうに聞惚れて、夜の潮の、充ち満ちた構内に澪標のごとく千鳥脚を押据えて憚からぬ高話、人もなげな振舞い、小面憎かったものであろう、夢中になった渠等の傍で、駅員が一名、密と寄って、中にもめ組の横腹の辺で唐突に、がんからん、がんからん、がんからん。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひゃあ、」と据眼に呼吸を引いて、たじたじと退ると、駅員は冷々然として衝と去って、入口へ向いて、がらんがらん。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　傍へ来た駅員に、突のめるように、お辞儀をして、「真平御免ねえ、はははは。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と聞いたのであるが、聞いてしまってから、ああ、やっぱり、死ぬるところは江の島ときめていたのだな、と素直に首肯き、少し静かな心地になって、駅員の教えて呉れたとおりの汽車に乗った。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――小村さんは一旦外へ出たが、出ると、すぐ、横の崖か巌を滴る、ひたひたと清水の音に、用心のため引返して、駅員に訊いたのであった。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　双方黒い外套が、こんがらかって引返すと、停車場には早や駅員の影も見えぬ。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をつむって、耳を圧えて、発車を待つのが、三分、五分、十分十五分――やや三十分過ぎて、やがて、駅員にその不通の通達を聞いた時は！",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、いずれにも、しかも、中にも恐縮をしましたのは、汽車の厄に逢った一｜人として、駅員、殊に駅長さんの御立会になった事でありました。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
