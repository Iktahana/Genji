        "examples": {
          "standard": [
            {
              "text": "その映画社は、時代劇の制作に定評がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい映画社が、来年公開のSF大作を手がけるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若手監督が、小さな映画社と組んで初の長編映画を撮った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "老舗の映画社がデジタル化の波に乗り遅れ、経営危機に陥っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ベーロ・ボラージュ、映画美学と映画社会学（前掲「映画の精神」の邦訳、佐々木能理男訳）。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一例をあげると私たちは同志相寄って連合映画社なるものを創立し、業いまだ緒につかざるに先だって一敗地にまみれてしまったが、このメンバーの中にはだれ一人として会社との契約に触れる行動をとったものはない。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文化映画社に入社してまだ間もない彼には、そこの運転は漠然としかわからなかったが、ここでも何かもう追い詰められてゆくものの影があった。",
              "citation": {
                "source": "美しき死の岸に",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の夏に文化映画社に入社して以来、機械や技術の本ばかり読まされていた彼は、ふと仏教の世界が探求してみたくなった。",
              "citation": {
                "source": "死のなかの風景",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドテの上は新聞社、ニュース映画社、放送局、自動車だらけだ。",
              "citation": {
                "source": "集団見合",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっぱら活躍しているのは、新聞社、映画社のカメラマンと、放送局のマイクロフォンである。",
              "citation": {
                "source": "集団見合",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルバート〔骨董品、古本屋の多い広場と街路の名〕のソブキノ〔ソビエト映画社〕を見た。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も私は日本映画社といふところのショクタクで、目下ショクタクといふ漢字を忘れて思ひだせないショクタクだから、お分りであらう。",
              "citation": {
                "source": "魔の退屈",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も私は日本映画社というところのショクタクで、目下ショクタクという漢字を忘れて思いだせないショクタクだから、お分りであろう。",
              "citation": {
                "source": "魔の退屈",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中私は日本映画社というところで嘱託をしていた。",
              "citation": {
                "source": "堕落論〔続堕落論〕",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大新聞も、ニュース映画社も、大雑誌社も、かたく閉したこの門内へふみこむことができなかったという難攻不落のアカズの門。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、当時日本映画社の嘱託だった私は銀座が爆撃された直後、編隊の来襲を銀座の日映の屋上で迎えたが、五階の建物の上に塔があり、この上に三台のカメラが据えてある。",
              "citation": {
                "source": "堕落論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "みや古で池田一夫のコロムビア映画社入りを祝ふ会があるので、行くと大満員だ、会費の他十円寄附した。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時に大阪へ着いちまったので、東宝映画社支店へ寄る、丁度ＪＯの黒川弥太郎が来てゝスナップなど撮る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "国光映画社の小笠原といふのによばれ、鈴木重三郎も林文三郎もゐて築地の何とかいふうちへ行った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
