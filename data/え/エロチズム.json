        "examples": {
          "standard": [
            {
              "text": "バタイユは、宗教的な儀式と性的な高揚の間に共通するエロチズムの構造を鋭く分析した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ジャズの調べと紫煙が立ち込める地下のクラブには、言いようのない大人のエロチズムが満ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "直接的な肌の露出よりも、衣服の隙間から覗く肌の白さにこそ、強烈なエロチズムが宿るものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "（Ｄ）フェルナンデスが智能を空間的なものの訓練に規定するように、行動主義は人間性の原始性（例えばエロチズム）と近代文化の物質力に自らを訓練する。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の、恋愛作品にある肉体哲学もいいだろうけれど、私は、古典のうちのエロチズムを、恋する若い人たちが、もっと、もう一ぺん読んでみて欲しいとおもう。",
              "citation": {
                "source": "梅ちらほら",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
