        "examples": {
          "standard": [
            {
              "text": "天然ガスをタンカーで輸送しやすくするため、超低温で冷却して液体化させる技術が使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この気体、特定の圧力をかけるだけで驚くほど簡単に液体化するんだって」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "物質の液体化に伴う急激な体積の変化を、研究員はグラフに細かく記録した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "特殊な装置の中で、酸素が青白い色を帯びながらゆっくりと液体化していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "空気が濃く重くドロリと液体化して、生温い糊のようにねばねばと皮膚にまといつく。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気が濃く重くドロリと液体化して、生温い糊のやうにねば／＼と皮膚にまとひつく。",
              "citation": {
                "source": "夾竹桃の家の女",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目に見えぬ極微な有機物は、群をなして腸腺を貫き、之を破壊して血管と腹膜に侵入し、そこに瓦斯を発生して、組織を液体化する醗酵素を分泌するのだが、この発生瓦斯の膨脹力は驚くべきものであって、死体の外貌を巨人と変えるばかりでなく、横隔膜を第三｜肋骨の辺まで押上げる力を持っている。",
              "citation": {
                "source": "蟲",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
