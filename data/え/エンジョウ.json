        "examples": {
          "standard": [
            {
              "text": "芸能人の不用意なSNS投稿が拡散され、あっという間にネットで炎上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その会社の広告が差別的だと批判を浴び、大炎上している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ブログ記事の内容が一部の人々の反感を買い、瞬く間に炎上騒ぎになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の問題発言はテレビで取り上げられ、その後も炎上し続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
