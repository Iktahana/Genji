    "definitions": [
      {
        "index": 1,
        "gloss": "ATOK (Advanced Technology Of Kana-kanji transfer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年愛用しているATOKの変換効率が良すぎて、他の入力システムには戻れない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、ATOKの辞書登録を同期し忘れてたから、変な変換になっちゃった」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最新版のATOKにアップデートしたら、AIによる推測変換がさらに賢くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一太郎ユーザーにとって、ATOKは文字入力における最強のパートナーだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だが、ＪＸ用に開発する新しいテキストベースの製品では、文章単位でカタカナも含めて一気に変換してしまう連文節変換まで機能を拡張し、これをＡＴＯＫ３と改名することとした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八五（昭和六十）年八月にＰＣ―９８０１用として発表された〈一太郎〉と名付けられた製品が、ＡＴＯＫと名前を付け替えられた変換モジュールを他のアプリケーションでも利用できる構造を採用していた点は、高い評価を受けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
