[
  {
    "uuid": "509f7393-e98b-5747-b996-1eca516ded0d",
    "entry": "永訣",
    "reading": {
      "primary": "えいけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "last farewell",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "He offered a final, poignant last farewell to his homeland.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "The soldier penned a letter to his family, a silent last farewell.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "It was an emotional last farewell before she boarded the ship.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "\"This is it, then. A last farewell,\" he murmured, turning away.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "八　突然、イベットに永訣しなければならなくなった世にも憐れな落胆者小田島は、また同時に世にも羞しい果報者となってホテルへ帰った。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ大阪の兄が危篤だといふ電報に接して、見舞ひ或ひは永訣――その孰になるかは、東京を立つた時の彼には判らなかつた――のために大阪へ来たついでに、甥にさそはれて立寄つたのを機会に、しばらく逗留したまでであつた。",
              "citation": {
                "source": "閾",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "直に母の大病に言よせて、永訣のためにとて呼び還しぬ。",
              "citation": {
                "source": "大久保湖州",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十日、永訣書を作る。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼もまたこれを漏れ聞き、遂に十月二十日永訣の書を作り、これをその父兄に与えたり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "談、刻を移して、予、暇を告げて去らんとすれば、先生｜猶しばしと引留られしが、やがて玄関まで送り出られたるぞ、豈知らんや、これ一生の永訣ならんとは。",
              "citation": {
                "source": "瘠我慢の説",
                "author": "福沢先生を憶う",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが私にとつて博士と永訣にならうとは、神ならぬ身の知る由もなく、博士に悦ばれたことを、自分も悦んで歸つたのです。",
              "citation": {
                "source": "芳賀先生と日本主義",
                "author": "高橋龍雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先師は彼をその家に見舞われ、窓から彼の手をとって永訣された。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は父との永訣によって心に与えられた悲しみを貫く歓喜の響の複雑さ、美しさに就て、文字で書きつくされないものを感じて居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく世間では急な永訣のとき、虫が知らせるとか、或る徴候があるとかいうが、父と私との場合、ちっともそんなことはなかった。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
