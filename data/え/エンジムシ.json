          "standard": [
            {
              "text": "臙脂虫はサボテンに寄生し、そこから得られる色素は化粧品や食品の着色料として利用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古代アステカ文明では、臙脂虫から抽出される鮮やかな赤色の染料が貴重品として扱われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この天然色素は、臙脂虫を乾燥させて粉砕することで作られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "臙脂虫、油虫、足長蜘蛛、二つの角のある尾を曲げて人をおびやかす黒い昆虫の「鬼」。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
