        "examples": {
          "standard": [
            {
              "text": "病気の友達が近づいてきたら、子どもたちは「えんがちょ切った」と言った。",
              "source": "幻辞"
            },
            {
              "text": "泥んこになって帰ってきた息子に、親は「えんがちょ切った」と冗談を言った。",
              "source": "幻辞"
            },
            {
              "text": "くしゃみをした友達に対して、「えんがちょ切った」という掛け声が上がった。",
              "source": "幻辞"
            },
            {
              "text": "学校の廊下で咳をしている子に、「えんがちょ切った」と言う子どもたち。",
              "source": "幻辞"
            },
            {
              "text": "保育園で、感染症が流行っていた時期、「えんがちょ切った」という言葉が頻繁に聞こえた。",
              "source": "幻辞"
            },
            {
              "text": "兄が妹に対して「えんがちょ切った」と指で十字を作ると、妹は大笑いした。",
              "source": "幻辞"
            },
            {
              "text": "風邪で寝込んでいる父に、子どもが遊び半分で「えんがちょ切った」と言った。",
              "source": "幻辞"
            },
            {
              "text": "運動会の後、汗だくになった子に「えんがちょ切った」という声が上がる。",
              "source": "幻辞"
            },
            {
              "text": "友達が花粉症で鼻をかんでいたら、「えんがちょ切った」と言う同級生がいた。",
              "source": "幻辞"
            },
            {
              "text": "幼稚園の砂場で、子どもたちが「えんがちょ切った」と言い合いながら遊んでいる。",
              "source": "幻辞"
            },
            {
              "text": "昭和の時代、学校ではよく「えんがちょ切った」という掛け声が響き渡った。",
              "source": "幻辞"
            },
            {
              "text": "おばあさんは孫に「えんがちょ切った」と言われて、懐かしい思いに浸った。",
              "source": "幻辞"
            },
            {
              "text": "野球の試合中、汚い物に触った選手に対して、チームメイトが「えんがちょ切った」と言った。",
              "source": "幻辞"
            },
            {
              "text": "教室で誰かがくしゃみをすると、すぐに「えんがちょ切った」という言葉が響く。",
              "source": "幻辞"
            },
            {
              "text": "この懐かしい魔法の言葉「えんがちょ切った」は、多くの子どもたちの思い出の中にある。",
              "source": "幻辞"
            },
            {
              "text": "雨の日に土で汚れた靴で家に入ってこようとする子どもに、「えんがちょ切った」と言う母親。",
              "source": "幻辞"
            },
            {
              "text": "懐かしい遊び文化として、今でも子どもたちは「えんがちょ切った」と言い合っている。",
              "source": "幻辞"
            },
            {
              "text": "友達がトイレから戻ってきた時に、いたずら好きな子が「えんがちょ切った」と言った。",
              "source": "幻辞"
            },
            {
              "text": "この古い言葉「えんがちょ切った」は、日本の子ども文化を象徴している。",
              "source": "幻辞"
            },
            {
              "text": "幼い兄妹が「えんがちょ切った」と言い合いながら遊ぶ様子は、本当に微笑ましい。",
              "source": "幻辞"
            }
