    "definitions": [
      {
        "index": 1,
        "gloss": "hot summer air",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "真夏の昼下がり、アスファルトからはゆらゆらと炎靄が立ち上り、遠くの景色を歪めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "灼熱の砂漠を歩く隊商は、地面から立ち上る炎靄に幻影を見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "工場地帯では、排熱と強い日差しが混じり合い、常に炎靄が漂っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それから、その末に見える空も、一面に、熱くるしく、炎靄をたゞよはせて、雲の峰さへもこの旱に、肩息をついてゐるのかと、疑はれる。",
              "citation": {
                "source": "酒虫",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
