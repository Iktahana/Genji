[
  {
    "uuid": "1df235d6-ce5f-540b-b1af-e0b3485c90b7",
    "entry": "演繹",
    "reading": {
      "primary": "えんえき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
