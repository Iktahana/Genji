        "examples": {
          "standard": [
            {
              "text": "パスワードには、英数記号を組み合わせることを推奨します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ユーザーIDは英数のみで構成されている必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このシステムでは、8文字以上の英数でパスワードを設定してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "でも国漢英数だけは、よくなっている積りだが、発表を見ないうちは、確言できない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私としては、英数漢の三科目を専門に学んで女学校卒業の検定試験を受けた上、女子医専に進もうと独りできめていたのだ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に英数は問題にならぬほどおくれてゐた。",
              "citation": {
                "source": "転校",
                "author": "平山千代子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
