        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "偉大な詩人の永逝は、文学界に大きな悲しみをもたらした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古文書には、王の永逝に関する記述が残されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その知らせを聞いた時、彼の永逝を信じられなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "＊濁点付きの二倍の踊り字は「／″＼」-------------------------------------------------------　寒月氏は今年七十歳を以て二月廿三日に永逝した。",
              "citation": {
                "source": "淡島寒月氏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
