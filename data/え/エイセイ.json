        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "羽生善治は、将棋界で永世名人、永世王座などのタイトルを多数獲得した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "囲碁界では、趙治勲が永世十番碁という記録を打ち立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の偉業は、将棋界に永世〇〇という称号をいくつももたらした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "将棋のタイトル戦で、永世〇〇の資格を得ることは、棋士にとって最高の栄誉の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
