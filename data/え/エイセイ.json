[
  {
    "uuid": "d46cb9ff-68d1-5168-abc0-e830f98d22ab",
    "entry": "永世",
    "reading": {
      "primary": "えいせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
