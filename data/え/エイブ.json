[
  {
    "uuid": "67d386ba-acff-54cc-b7a0-4a15369a023b",
    "entry": "英武",
    "reading": {
      "primary": "えいぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
