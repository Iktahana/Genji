      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "distinguished (surpassing) valor (valour)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その武将は、数々の戦で英武を振るい、人々を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の英武を称える歌が、後世にまで語り継がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝説の剣士は、その英武をもって多くの危機を救ったと伝えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「おお、その英武、実に見事だ！」と、観衆は叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "』其時答へて權勢のアガメムノーン彼に曰ふ、　130『汝、英武のアキリュウス、汝誠に勇なるも、我を欺くこと勿れ、凌ぐを得せじ説きも得じ、汝に戰利保つため我わが戰利失ふを甘んずべしと思へるや？",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』その時英武のアキリュウス彼を遮り答へ曰ふ、『汝の命に從ひて汝にすべて讓らむか、即ち小人卑怯の名、我また辭ふことを得ず、他人にかゝる命下せ、我に命ずること勿れ、　295〔＊今より後に再びと我は汝の令聞かず。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "其副將はレオンチュ，ス、かれアレースの裔にして　745父は英武のコローノス、更に其祖父カイニュウス。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "英武無双のアキリュウス並に彼の聯乘の馬も遙に優れども怒りて陣に退けば、テラモニデース・アイアース今人中に勝れたり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』垂絹長く面を掩ふ艶美の女性答へ曰ふ、『彼アイアース、すぐれたるアカイヤ軍の堅き城、こなたは英武イドメネー、＊クレーテースの衆中に　230神の如くに立ち上り、諸將士彼を取り圍む。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリアモスの子ヘクトール及び英武のオヂュシュウス、其時現場先づ測り、次に青銅の甲を取り、　315中に二條の鬮を入れ、之を搖がし兩人の孰れか先に鋭鎗を投ずべきかを定めんず。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "425アイギス持てるヂュウスの子ヘレネー之に身を托し、目をそむけつゝ良人を咎めて彼に陳じ曰ふ――『＊君戰場を逃げ歸る、そこにはじめのわが夫、英武の彼に斃されて君生命を棄つべきを。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカイア及びトロイアの各人かくぞ陳じたる、今トロイアの陣中をあまねく巡るアテーネー、　85アンテーノールの子ローダコス勇士の姿借り來り、英武恰も神に似るパンダロスを探し行き、＊リュカーオーンの剛勇の子のたゞずむを見出しぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊むかし身獨りテーバイに、使になりてカドモスの、種族の中に往ける時、（われ其時に廳中に彼を酒宴に招かしむ）武勇の示し、競技、彼に對して我はつゆ求めざりしも例の如、　805英武の彼はテーバイの子らに挑みて技競ひ、すべてに於て悉く其一同に打ち勝てり、（＊容易く勝てり、そこに我れ彼に援助を施しき。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "こなた英武のヘクトール、＊西大門と山毛欅の木に着けばトロイア城中の夫人息女ら寄せ來り、子弟と友と良人の消息切に尋ね問ふ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯く雷霆の神の子に彼等は祈る、――かなたにはパリスの華美の邸さして脚を進むるヘクトール、邸はトロイア城中の勝れし工匠もろともに、主公自ら建てしもの、居室と堂と中庭と　315精美を窮め高き地に造られ、王者プリアモス及び英武のヘクトール、彼等の邸は皆近し。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しか計らへる二位の神、神意悦ぶ計らひを王プリアモス生める息＊ヘレノス胸に感知して、　45行きて英武のヘクトール訪ひて向ひて陳じ曰ふ、『王プリアモス生める息、智は神に似るヘクトール、君と我とは同じ胞、君今我に聽くべきか？",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど英武のアイアース、倒れし弟眺め見て、　330奔り來りて彼を守り其大楯に彼を掩ふ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "105思ふ、英武のアキリュウス、その心より物凄き憤怒を棄つることあらば敵將いたく惱むべし。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "こなた英武のヘクトール亦トロイアの勇將の眠許さず、トロイアの首領將軍もろ／＼の　300すぐれし者のある限り皆悉く呼び集め、集めし席に巧みなる謀略のべて陳じ曰ふ、『誰そ今われの曰ふところ、わが爲め約し成し遂げて、多大の恩賞得るものぞ？",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど英武のアキリュウス、アカイア軍を憐まず、　665彼岸上の迅き船、アカイア勢の禦げども、敵の兵火に焚かるるを、又わが將士順々に討たれ亡ぶを待たんとや？",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなた英武の敵將は、勝利を外し槍折りし　165其失敗に憤る脚を囘して隊に入り、やがて陣舍とアカイアの水師に急ぎ立ちかへり、先きに陣中殘し來し巨大の槍を手に取りぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ああチュウクロス、われ／＼の親しき侶は斃れたり、マストリデース、斃れたり、キュテーラよりし訪ひ來り、われらと共に住める時、親の如くにめでし彼れ、　440彼を英武のヘクトール殺せり、いづこ汝の矢？",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "こなた英武のアイアース、さすが耐へず投槍にいたく襲はれ、敗滅を覺悟し乍ら、＊七尺の高き舷橋わたり去り、舟の甲板退きぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "將ヘクト，ルの命により猛火を船に掛けんとし、進み來れるトロイアの兵を英武のアイアース、　745待ち受け長き槍のして防ぎてやまず、かくしつゝ、船のかたへの接戰に敵の十二を傷けぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ア，ンチロコスは自らの涕ながらも警めて、悲嘆のあまり鋭刄に喉を割かん恐より、英武無双のアキリュウス・ペーレーデースの手を抑ゆ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶えて責むべきあと見ざる英武のわが子産み出でて、　55勇者の中に傑れたる（巨幹の如く生ひ立てる）彼を沃土の野に立てる樹木の如くはぐくみつ、やがて曲頸の船の上、トロイア族の戰に、イリオンさして遣はしき、――ああペーリュウスの家の中、再び歸りくる彼を迎ふる時はあらざらむ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルミドネスの諸勇士は、驚怖にうたれ一人も之をまともに眺め得ず、されど英武のアキリュウス、　15これを眺めて憤然と更に勇氣を振りおこし、眼蓋の下の双眼は火焔の如く耀きつ、神の惠の燦爛の武具を手に取り喜べり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて英武のアキリュウス、怒濤の岸を進み行き、　40大音聲に叫びつゝアカイア勇將呼び起す。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "先きに英武のオヂュシュウス親しく君の陣に行き、　140＊約せしところ一切の贈遺を君に致すべし。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』智謀に富めるオヂュシュウス即ち答へて彼に曰ふ、『あゝ英武のアキリュウス、汝誠に勇なるも、　155食を取らずにわが軍を、敵と戰爲さんため、進むる勿れイリオンに、二軍ひとたび向ふ時、而して神が各々に燃ゆる勇氣を鼓する時、わが見るところ戰爭の時期は短きものならず。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』しかく陳じてアキリュウス、友の諸將を去らしめぬ、殘るは二人の＊アトレーダ、及び英武のオヂュシュウス、　310イドメニュースとネストール、老齡の御者プォイニクス、これら等しく慟哭の切なる友を慰めぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "其閃光は空を射り、大地は共に青銅の光のもとに微笑みつ、軍勢進む足もとに響は起る、其中に、鎧ふ英武のアキリュウス、（＊齒ぎしり強く、爛々と光る双眼譬ふれば、　365炎々燃ゆる火の光、憤怒はげしく迫り來て、思に耐へず、トロイアの軍に怒りて、神工のヘープァイストス鑄造りて贈れるものを身に纒ふ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで英武のアキリュウス、影長く曳く槍飛ばし、アイネーアース持てる盾、圓き大盾うちあつる、あつるは盾のはしのへり、青銅薄く掩はれて、　275更に其上又薄き牛皮掩ふを、＊ペーリオン山に伐りたる大槍は貫き、盾は高鳴りぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "三たび英武のアキリュウス、其青銅の槍あげて、　445鋭き脚に進みより、三たび濃霧の中を打つ、四たび續きて神靈の暴るが如く進みつつ、聲を勵まし物凄く羽ある言句陳じ曰ふ、『汝今また、憎き狗！",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
