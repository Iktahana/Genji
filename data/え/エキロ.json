          ],
          "literary": [
            {
              "text": "それにあすこの福和戸のやうながらんどうの温泉、普通の駅路の両側に家が並んだやうな温泉は、どこか埃くさい気がするのと、まとまりのない不安な気がするので、とても落付いた気分になれない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "榎はどこか、深山の崖か、遠い駅路の出入境に有る、繁った大な年｜経る樹らしい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……すがすがしいが、心細い、可哀な、しかし可懐しい、胸を絞るような駅路の鐸の音が、りんりんと響いたので、胸がげっそりと窪んで目が覚めるとね、身体が溶けるような涙が出たんだ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に湯気の蒸した風呂と、庇合の月を思うと、一生の道中記に、荒れた駅路の夜の孤旅が思出される。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上のＦ――町のＯ――家がその筆頭で、川下の旧東海道の駅路に当るＭ――町のＭ――家もそれである。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御殿場のここの駅路、一夜寝て午夜ふけぬれば、まだ深き戸外の闇に、早や目ざめ猟犬が群、勢ひ起き鎖曳きわき、跳り立ち啼き立ち急くに、朝猟の公達か、あな、ひとしきり飛び連れ下りる騒ぞきの、さて出立つらむ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "笛の音の類、朝立ちの駅路の鈴、訪ふ人もなき隠れ家のべるの釦のほのかに白き、小夜ふけてきくりんのたま。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "笛の音の類、朝立ちの駅路の鈴、訪ふ人もなき隠家のべるの釦のほのかに白き、小夜ふけてきくりんのたま。",
              "citation": {
                "source": "第二真珠抄",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "独りが好からう、好い加減に行きついた駅路の宿に泊つて御覧！",
              "citation": {
                "source": "断想的に",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の柳の散る中に、つないだ駒はなかったが、細流を織る木の葉は、手綱の影を浮かして行く……流に添った片側の長い土塀を、向うに隔たる、宗参法師は、間近ながら遥々と、駅路を過ぐる趣して、古鼠の帽子の日向が、白髪を捌いたようである。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たうとう私はそのウワ言をつづけたまま、今度は居酒屋の前を素通りして、屋根裏を逼ひ出すと、たまたま脚を遠く奥州路へと伸ばしたのであつたが、はぢめての途中下車の駅路で思はぬ突風に見舞はれて、在りのままなる高熱の床に倒れる身と化したのだ。",
              "citation": {
                "source": "「学生警鐘」と風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑紫の秋は、駅路の宿りごとに更けて、雑木の森には櫨赤く爛れ、野には稲黄色く稔り、農家の軒には、この辺の名物の柿が真紅の珠を連ねていた。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅路の馬の鈴にちがいない。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くと思えば近くに聞え、近くと思えば遠くに聞えて、姿の見えぬ駅路の馬の鈴が、わびしくまたシャンシャンと鳴りました。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼涙沼や狐塚の界隈であればこそあんな山駕籠も不思議とされぬが、自動車や機関車が文明の煙りを挙げて往き交ふてゐる繁華な駅路へ向つて、ほい／＼／＼！",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "我孫子と小金との中間に、馬橋という駅路がある。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴瀬村を過ぎれば菱山村、甲運村を過ぎれば甲府城下、韮崎過ぎれば穴山の宿、日野春を過ぎれば葛木の駅路、ここから信濃の国となる。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車は黒い煙をところどころに残し、旧い駅路の破壊し尽くされた跡のような鉄道の線路に添うて、その町はずれをも離れた。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと田辺の小父さんは、旧い駅路の荒廃と共に住み慣れた故郷の森林を離れ、地方から家族を引連れて来て都会に運命を開拓しようとした旧士族の一人だ。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "通る度毎に旧い駅路の跡は変っていた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "桔梗が原の尽頭第一の駅路は洗馬である。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨川寺は駅路｜蕎麦店間より二丁｜許の坂を下りている。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "備後安藝の国界は駅路の山上にあり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "対岸に茂っている木々は、Carnavalに仮装をして、脚ばかり出した群のように、いつの間にか夕霧に包まれてしまって駅路の所々にはぽつりぽつりと、水力電気の明りが附き始めた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "対岸に茂っている木々は、Carnaval に仮装をして、脚ばかり出した群のように、いつの間にか夕霧に包まれてしまって駅路の所々にはぽつりぽつりと、水力電気の明りが附き始めた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜甚太郎の泊まったのは笛吹川の川畔の下向山の駅路であったが、翌日は早く発足し滝川街道を古関の方へ例の調子で辿って行った。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば空一面に、すっかり叢雲がたちこめて、埃っぽい駅路は大粒の雨滴に叩かれていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "面を冒して諫止するからには、多少、光秀から気まずい激語をうけようとも、いかに立腹されようとも、断乎として、その袂を抑えきろう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
