[
  {
    "uuid": "44b682f5-e811-5210-94d7-e8547e49da18",
    "entry": "駅近",
    "reading": {
      "primary": "えきちか",
      "alternatives": [
        "えきチカ"
      ],
      "is_heteronym": true
    },
    "grammar": {
