        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あ、茶柱が立ってる！ 朝から縁起がいいね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新しい財布を使い始めるなら、一粒万倍日のような縁起がいい日を選びたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「白蛇の夢を見ると縁起がいいと言われるけど、宝くじでも買ってみようかな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "富士山がきれいに見える日は、なんだかそれだけで一日中縁起がいい気がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「死者の夢を見るのはきっと縁起がいいんだ。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は、セリファンに出来るだけ急ぐようにと命じながら、心の中では、『だが、葬式に出会ったのは縁起がいいぞ、死人に出会えば幸先がいいっていうからな』などと考えていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "狼がいいというものと、大お亀の方が縁起がいいというものと、どっちもごっちゃだ。",
              "citation": {
                "source": "鉄くそぶとり",
                "author": "続旧聞日本橋・その二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして『長生した人のは縁起がいい！",
              "citation": {
                "source": "霜",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁起がいいと言われてる正覚坊が、向こうから訪ねて来てくれたんですもの、漁夫としてこれくらい愉快なことはありません。",
              "citation": {
                "source": "正覚坊",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁起がいい奴だから村中で池の中に飼ってやろう、という相談がまとまりました。",
              "citation": {
                "source": "正覚坊",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そのことを又、皆はたいへん縁起がいいといって喜んだものだった。",
              "citation": {
                "source": "花を持てる女",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坊さんに見込まれたとは縁起がいい、お前は長生きするよ。",
              "citation": {
                "source": "或る女の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間に私は、「これは縁起がいいな」と思った。",
              "citation": {
                "source": "未来の天才",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で考えると、朝蜘蛛は縁起がいいということを聞いたようでもあるし、天井から降りてくる蜘蛛は凶兆だということを聞いたようでもあるが、兎に角、あの瞬間に縁起がいいと思ったのが仕合せだったのだ。",
              "citation": {
                "source": "未来の天才",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄金虫だから、たんすに入れてしまっておくと、縁起がいいと、お母さんがおっしゃってよ。",
              "citation": {
                "source": "玉虫のおばさん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんこれは断ったが、「戻る」では正月早々縁起がいいと喜んでいいものかどうか……と苦笑したものである。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "六のつく日には井戸替えすべからず、七のつく日には知らぬ人を家へ招くべからず、八のつく日に婚礼の話をすると後で夫婦別れが起り、九のつく日に茄子を食うと縁起がいい。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩をまくことは清浄化することと思われているので、偶然塩をこぼすと縁起がいいとされる。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "「銭」でいいではないかと思い、その後、なんとなく細君に言うと「仙」というのは、人に山で、――「人が山と来るというんで縁起がいいそうで」と説明された。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "「取ってあったのか」　どこかへ紛れこんでたのよと、ごまかすように波子は言って、「縁起がいいから持ってこう」「なんだって」「いいのよ」「おい、波子」　気を散らされた感じの俺は露骨な言葉をささやいた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁起がいいからどうしても持って行けと波子は俺に言った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁起がいいというその理由は、俺が聞いても言わないで、波子はただ、おまじないにぜひ持って行ってほしいと言う。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "「素敵に縁起がいいです。",
              "citation": {
                "source": "運命について",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お袋の話だと縁起がいいらしいんだけど。",
              "citation": {
                "source": "夕張の宿",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすは雨かな」「嫁入りの晩と、戦いの出がけに降るのは、縁起がいいというから、ざッと来るのもいいだろう」「敵もそう云っているかも知れまい」「大きにそうだが、同じ大地へ天から降る雨でも、光秀の部下とおれたちとでは、濡れ心地が違うだろう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
