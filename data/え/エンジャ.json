        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "サーカスの演者たちは、観客を魅了する素晴らしいアクロバットを披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "舞台の演者は、開演前に最終のリハーサルに臨んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ロックフェスティバルでは、たくさんの人気演者が次々と登場し、会場を熱狂させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
