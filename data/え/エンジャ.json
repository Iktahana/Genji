[
  {
    "uuid": "a57fbfe4-92d3-5e10-879f-d6c7a0e74e6d",
    "entry": "演者",
    "reading": {
      "primary": "えんじゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
