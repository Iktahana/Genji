        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "友達が駅前の英会話に通い始めて、英語が上達したらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末はいつも、あの英会話で外国人講師と話しているよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "引っ越したら、近くに良い英会話がないか探してみよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
