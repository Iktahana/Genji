        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "海外旅行に備えて、簡単な英会話を練習している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の流暢な英会話を聞いて、私も頑張ろうと思った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "職場で外国人の方と英会話をする機会が増えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "十日ほど前まで鶴雄は三条の英会話講習会へ、月・水・金の夜の一時間、会話の練習に通っていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宿の主人は教養ある人物であり、英会話も見事で、ロンドンのグローヴナ・ホテルで三年、給仕として働いていたそうだ。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼は英会話が完全に自由でなく、それを顧慮して話すフロラの家族の者とだけ稍自由に話し得る程度であつたから――英語を持つて様々な日本語の解釈をするのは難儀であつた。",
              "citation": {
                "source": "鸚鵡のゐる部屋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は英文学を研究してゐるさうだが、英会話は不得意らしいね。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さつき滝本が話したのと違つて、ローラはあまり日本語を用ひないので百合子が左う、大分に教室的英会話風に訊ねると、ローラは気の毒さうな顔をして、殆んどもう忘れてしまつたから、これから精々プラクテイカルに聞き覚へたい希望を持つてゐる、どうぞ親切な教へ手になつて呉れ――と心細さうに云つた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケラアといふ老境のイギリス人は、町瑞れのメソヂスト教会の宣教師で、太郎のオルガンと英会話の教へ手であつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いつものＮは英語を用ゆる時は、英会話の不得意な相手を顧慮して繰り返すことも厭はずに、なるべくギゴチない正発音で教師のやうに話すのが例でしたが、この時は九分通りまでを彼女自身の自由調で述べるのです。",
              "citation": {
                "source": "舞踏会余話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、急に洋服などを着はじめて英会話の練習に通つたりしてゐた。",
              "citation": {
                "source": "蔭ひなた",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕃書調所に入門その前に私が横浜に行た時にキニツフルの店で薄い蘭英会話書を二冊｜買て来た。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の娘は、英会話練習のために、一年間だけ、ニュー・トリア高等学校の四年のクラスにはいった。",
              "citation": {
                "source": "知られざるアメリカ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "英会話の心得　私は非常に運がよくて、大学を出てから、三年目に外国へ留学することができた。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある新興成金の英語個人教授、毎週三日、午前九時から午後一時までの間に三十分乃至一時間、初歩英会話を主として見てやる。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま両手は実際塞がっており、将軍のつたない英会話の指導中だ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりで英会話勉強の心。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
