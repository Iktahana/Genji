[
  {
    "uuid": "eb5fee4c-7004-532b-bd3d-460355897f04",
    "entry": "演出家",
    "reading": {
      "primary": "えんしゅつか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
