    },
    "definitions": [
      {
        "index": 1,
        "gloss": "director (of a film, play, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あの演出家は、役者の個性を最大限に引き出すことで定評があるんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "演出家は台本を片手に、舞台上の立ち位置を細かく役者に指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いつか、自分が書いた戯曲をあの有名な演出家に手掛けてもらいたい」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若手演出家による斬新な解釈のシェイクスピア劇が、大きな話題を呼んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "折角の作者のデヴュに気の毒だって」　田村先生とは演出家の田村礼介のことである。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "田村はもと左翼劇団の演出家であり戯曲のほかに小説も書き、劇壇より文壇で有名であったが、思想運動の嫌疑で検挙され、保釈出獄以来執筆は許されず、匿名で「演劇集団」の演出をしているのだった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の処女作の上演の初日が演出家の公判の判決の当日に当るとは……。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、明日は演出家の田村が検事局で判決の言い渡しがあるので来られないだろう。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "演出家の田村は稽古をそんなに早く仕上げてしまった自分に、さすがに照れているのか、信吉と眼が合うと、ふと苦笑した。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは劇団の幹部や演出家が、雑談をしたり、演技や効果の注意事項をノートしながら、見物できる特別の部屋だったから、そんな部屋へはいって行って、いかにも作者を気取っているのは、信吉の好みに合わなかったが、しかし、煙草を吸いながら見物できる点が、煙草好きの信吉にはありがたかったのだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "監事部屋には、演出家の田村礼介がいた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんなかに坐っている太った男は、最近めっきり流行して来た劇作家兼演出家の、横沢太郎氏にちがいない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてついに今｜唖のごとき演出家ができあがって多くの俳優を苦しめているというわけである。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがつて作家としての私は投票場のシーンを描写する能力がなく演出家としての私は投票場のシーンを演出する能力がない。",
              "citation": {
                "source": "政治に関する随想",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝沢氏は批評の貧困を熱心に語っておられ、現在では批評家よりも演技者、演出家が語っている言葉の方が生き生きしていると、ある時期のプロレタリア作家の間に生じた批評に対する意見に類似した意見を語っていられる。",
              "citation": {
                "source": "一つの感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "演劇の世界が封建的なしきたりからぬけ切っていないことは土方与志さんのような世界を歩いて来た演出家でさえ、日本の今日の芝居の社会で口をきくときは東宝さん、何々さん、と昔風な仁義の口調をつかっておられるのを見てもわかる。",
              "citation": {
                "source": "俳優生活について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺ぐらいの俳優になれば、或は演出家その他になれば、どんなことがあっても大丈夫だ、というだけですむのだろうか。",
              "citation": {
                "source": "俳優生活について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト同盟の「人民芸術家」としてもう完成された演出家である。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "演劇の面には、小山内薫時代からの山本安英などのほかに、原泉子をはじめ、数多い女優が現れ、声楽家関鑑子は、演出家小野宮吉と結婚して、次第に人間的深みを加えつつあった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多少無理でも、演出家として経験ある新人に依嘱するより外あるまい。",
              "citation": {
                "source": "俳優教育について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、或る時は「演出家の為めの演劇」が栄え、「舞台装置家の為めの演劇」が出現し、「右翼思想の為めの演劇」があると同時に「左傾思想の為めの演劇」が存在を主張するといふ有様です。",
              "citation": {
                "source": "演劇漫話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは、作者自ら舞台指揮者たることを正当と認め、事情によつては、臨時に、或る脚本の舞台指揮を或る「演出家」に依頼するつもりである。",
              "citation": {
                "source": "新劇協会公演に先だつて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、作者は固より、演出家、俳優をも含めて、一般新劇関係者は、先づ、今日の商業演劇に対して絶縁状を叩きつけること。",
              "citation": {
                "source": "新劇の始末",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "また不都合だといふのは、演出家には、それぞれ動かせない流儀があり、いろいろの戯曲をその流儀に当て嵌めて「書き直す」ことは、それが故意に行はれただけ、原作者に対して越権である。",
              "citation": {
                "source": "戯曲の翻訳",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、演出の方法、即ち、演出家の独りよがり、気まぐれな試み、無意味な野心などは、演劇の「広さ」をわざわざ「狭く」するものである。",
              "citation": {
                "source": "演劇の大衆性",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に舞台の方では西洋の近代劇運動につづいて起つたさまざまな演出上の新機軸が、日本の若い演出家の間に試みられ、所謂「演出家万能時代」といふものを作つた。",
              "citation": {
                "source": "新劇界の昨今",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、演出家の戯曲冒涜と、俳優機械視である。",
              "citation": {
                "source": "近代劇論",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは演出家の意図に従つて、舞台美術家が考案製作に従事すべきものであるが、これを演劇の最も重要な要素と考へることは、これまた近代演劇の過渡期に於ける迷妄である。",
              "citation": {
                "source": "近代劇論",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのグルウプは、作家、俳優、演出家、及び、純然たる素人から成るものであつて、何れも「語られる言葉の美」に関心をもち、「物言ふ術」の具体的研究に興味と野心を有する人々に限られる。",
              "citation": {
                "source": "なんとかせねばならぬ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の日本は、戯曲家が腕をふるふ前に、演出家が舞台にのさばる前に、先づ、俳優らしい俳優が一人、起ち上らねばならぬ。",
              "citation": {
                "source": "なんとかせねばならぬ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代演劇は、脚本作家と俳優、この両者の協同以外に、演出家（〔metteur en sce`ne〕）といふ専門家の出現を促した。",
              "citation": {
                "source": "演劇・法律・文化",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "演出家の権利擁護　そこで、再び演出家の問題に還るが、現在「演出」なる仕事の領域は、まだ理論的にも実際的にも、限定されてゐないのである。",
              "citation": {
                "source": "演劇・法律・文化",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
