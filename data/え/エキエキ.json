    },
    "definitions": [
      {
        "index": 1,
        "gloss": "brilliant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "満天の星空は、まるで宝石を散りばめたかのように奕々としていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の瞳は、希望に満ちて奕々と輝いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "舞台の照明が舞台装置を奕々と照らし出し、観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "今｜遜志斎集を執って之を読むに、蜀王が所謂正学先生の精神面目｜奕々として儼存するを覚ゆ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽地にして其の金光の一道は二道となり、三道となり、四道五道となり、奕々灼々として、火龍舞ひ、朱蛇驚き、萬斛の黄金の熾盛、烈々※々たる炎を揚ぐるが如くになると、紅玉熔け爛れんとする大日輪が滄波の間から輾り出す。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その色彩何ぞ奕々たる。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、多くの世人から、光明優婆塞と名を呼ばれた、神彩｜奕々たる大行者が、富士の裾野から世に下った。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩蓋煙を含み危根石を倒すの状、描き得て霊彩奕々たりと云ふべし。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし神采奕々たる人間全体を指摘するのは一代の才人を待たなければならぬ。",
              "citation": {
                "source": "大久保湖州",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "匂やかな若衆すがたは、今、まるで生きているその人のように、生彩｜奕々として素絹の上にほほえみつつ、その日の思い出を永劫に生かそうとてか、片手にかざした白つつじの花ひと枝――　片里はながめ入りながら、酔ったような目つきをしました。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄金の兜、黄金の鎧、蝋燭の光に照らされて天上の虹が落ちたかのように燦々奕々と光を放し香の匂いさえ漂っている。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高貴の御方だということは、神采奕々とでも形容しようか、その御方ただご一人が、そこに粛然と立たせられたばかりに、周囲の自然――花木緑葉が、清浄にすがすがしく感じられる、そのことだけでも頷かれた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まさに神采奕々として、梟雄弾正太夫をさえ、叱※し去らん勢いである。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "英雄僧の真面目が奕々として光を放ち、五右衛門はもちろん座にある者一度にハッと威厳に打たれて息を深く呑んだほどであった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、読経の声が絶え、窟の口へ百地三太夫｜神彩奕々として現われたが、「鬼王丸、機嫌はいかに？",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見すると支那の神農、しかし仔細に見る時は、紛れもない日本人、それも穢い老乞食、だが全幅に漲る気品は、奕々として神のようである。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この泉石像は、日本画の肖像画として、顔に洋風の陰影をつけ風神｜奕々たるものとして有名である。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の心の前には、「奕々たる美」に、燦然と輝きながら、千年の地下の眠りから呼び覚まされたアフロジテの像に、静かな表情でコンパスと定規をあてて「……私は切に知りたいのですから……」と云った人の姿が尊く浮み上った。",
              "citation": {
                "source": "地は饒なり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにせよ、不思議なばかり奕々たる人気の彩霞が、本能寺の惣門から甍にまで棚曳いているのは事実である。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見、直ちに、さすがはと、その人らしく見られる者では、滝川一益など風采｜奕々たるほうで、一流の武将とうけとるに誰も吝かとしないであろう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そしてここはまだ天下｜混沌といっていいところだが、奕々と天の一方からは、理想の到達に誇ッた凱歌のあしおとが近づいて来つつあった。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
