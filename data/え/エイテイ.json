          ],
          "literary": [
            {
              "text": "若ものたちは、送ってきた親や、同志たちと、営庭で別れる。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "給料を一文も費わないばかりか、営庭の掃除の時に見付けた尾錠や釦を拾い溜めては、そんなものをなくして困っている同僚に一個一銭｜宛で売りつけて貯金をする。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳を澄ましていると、靴音は段だん高くなって、衛門の前へ来たが、そこになると靴音は一段と高くドッ、ドッ、ドッと歩調を取るようにして営庭へ入って往くのであるが、無論何も見えない。",
              "citation": {
                "source": "戦死者の凱旋",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士はうやまひあつし竹刀とりお前にとうと声｜徹り撃つ激しくうちあふ竹刀眼には入れこの畏こさに面も小手もわかず営庭にて三聯隊の兵全部凹形に整列し、隊歌を合唱す。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "営庭の老木の桜過ぎにけりわれは立ちつくす光る真土に立ち待つと心澄みゐる昼さなか兵あらはれて来り列竝むわが前に歩兵第三聯隊竝び立ち隊歌うたふと声大いにあがる葉ざくらは風やや強し耳とめて宮の御声を聴きまつらくは夜宴あり。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "健児社の連中は、広い営庭の遥か向うの獄舎に武部先生が繋がれている事をどこからともなく聞き知った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日毎晩、今か今かとその時機を待っているうちに或る朝の事、霜の真白い、月の白い営庭の向うの獄舎へ提灯が近付いてゴトゴト人声がし始めたので、素破こそと皆｜蹶起して正座し、その方向に向って両手を支えた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　中尉の号令を待ちかねていたかのように、部隊はサッと小暗い営庭に整列した。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "太鼓がタッ・タララッ・タッと鳴ると、営庭へ囚人たちがなだれを打って出てくる。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "」の叫びを営庭一ぱいに跳ね返せ！",
              "citation": {
                "source": "一九三二・二・二六",
                "author": "―白テロに斃た××聯隊の革命的兵士に―",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い石の拱門を入ったところがコンクリートの営庭で、コの字に囲んだ三方の二階の窓に、半裸体の俘虜が重なりあい、喝采しながら山内を迎えている。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同が引き出されたところは、広々とした砲台の営庭だった。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はまだすっかり明け切らず、薄い朝霧が、煙のように営庭の中に流れていた。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "時雨もやいの朝寒におびえて鳥肌をたてている、眼ばかり美しい山川の細い白い顔を見ていると、この男は、もう生きて帰ってくることはあるまいという冷酷な感慨がわき、人並な挨拶をして営庭に入って行ったのを最後に、みなのこころのなかで、山川の思い出が死んでしまった。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗きに起きて、兵を発たしむ健やかに征きてかへれと　告げて後、たち征きにしが、まだ暗き営庭若くして　心｜真直に征きにける伍長一人を　心にたもつこの日頃　二きほひ来し学徒も　今はおちつきて、おのも　しづけき兵となりゆく近々と　山の残雪のさびしきに、夕方早く　雨となりたりこの日ごろ。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "対空射撃に出て、二夜｜徹さむとす若々と　幾百の兵｜帰郷りゆく営庭にのぞみて、思ひ正しき帰郷する兵らを　送り出しやり、営門を入る。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "営庭の椿の立ち樹　咲きつくしたり師のみ言を　心にもちて、ひとゝ居るわれのしぐさの　堪へがたきかも立野个原草の上に雨ふりにけり。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "営庭の草の上に坐って、折々雨が通ると傘をひろげて話しました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ彼はもう朝陽とともに起き出して、兵馬に満つる営庭を逍遥していた。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だだっぴろい寒い営庭で、合同慰霊式のようなものが取行われた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜もよく眠らず、営庭に立ち通しだったので、疲れるのも当然だ。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊共は営庭でぶら／＼歩いてゐる。",
              "citation": {
                "source": "樺太脱獄記",
                "author": "コロレンコ　Vladimir Galaktionovick Korolenko",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、直ぐに営庭に飛び出して、中隊からぞろ／＼出て来る新兵たちの動作を見守つた。",
              "citation": {
                "source": "怒れる高村軍曹",
                "author": "新井紀一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早駆け用意――ツ」と云ひながら高村軍曹は営庭の一番隅にある一本の松の木を示して「よーしツ」と振り上げてゐた右手を颯つと下におろした。",
              "citation": {
                "source": "怒れる高村軍曹",
                "author": "新井紀一",
                "note": "青空文庫"
              }
            },
            {
              "text": "営庭に午前と同じやうな隊形で各班は陣取つた。",
              "citation": {
                "source": "怒れる高村軍曹",
                "author": "新井紀一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、鎮台の城寨を一歩入ってみると、この日、なんとなく営庭から庁閣にいたるまでが物々しい空気である。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それ者どもこの両名を、用意の檻車へすぐ打ち込め」　二｜輛の囚人車は、すでに営庭の一隅に支度されてあったのだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
