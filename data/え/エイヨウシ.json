        "examples": {
          "standard": [
            {
              "text": "病院の栄養士が、患者一人ひとりの病状に合わせた献立を作成しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "娘は将来、スポーツ選手の食事管理をする栄養士になりたいと言っています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "健康診断の結果を受けて、地域の栄養士による食生活相談会に参加しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "社員食堂では、栄養士の監修のもと、健康的でバランスの取れた食事が提供されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "なんでも某大学の医学部かなにかの先生の放送だったから、美味いと言った人は、そこのお医者さんか栄養士であろう。",
              "citation": {
                "source": "道は次第に狭し",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
