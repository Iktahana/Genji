          ],
          "literary": [
            {
              "text": "淺間山麓一面を埋めて居るとよく似た豌豆大の粒の集積したものである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分に蜻蛉を捕るのに、細い糸の両端に豌豆大の小石を結び、それをひょいと空中へ投げ上げると、蜻蛉はその小石を多分｜餌だと思って追っかけて来る。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると、たぶん、ついそこの荷揚場から揚げる時にこぼれたものだろう、一握りばかりの豌豆がこぼれている。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらまめのは其色を嫌ふ人もあるべけれど、豌豆のは誰か其姿を愛でざらむ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "コメススキや白山女郎花の花咲く砂原の上に大きな豌豆ぐらいの粒が十ぐらいずつかたまってころがっている。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽井沢一帯を一メートル以上の厚さにおおっているあの豌豆大の軽石の粒も普通の記録ではやはり降灰の一種と呼ばれるであろう。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ折々聞るものは豌豆の莢が熱い日に彈けて豆の飛ぶ音か、草間の泉の私語やうな音、それでなくば食ひ飽た鳥が繁茂の中で物疎さうに羽搏をする羽音ばかり。",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもねもとのダイナマイトの付近だけはたしかに爆裂するので、二三百メートルの距離までも豌豆大の煉瓦の破片が一つ二つ飛んで来て石垣にぶつかったのを見た。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以外には南瓜の畑も、豌豆の畑も、玉葱の畑も、カイベツ（甘藍）の畑も、一樣にくすんだ夜の色になつてゐる。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の状我が國に豌豆豆を噛るに似たり。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、もう床が取ってある……　枕元の火鉢に、はかり炭を継いで、目の破れた金網を斜に載せて、お千さんが懐紙であおぎながら、豌豆餅を焼いてくれた。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今来た入口に、下駄屋と駄菓子屋が向合って、駄菓子屋に、ふかし芋と、茹でた豌豆を売るのも、下駄屋の前ならびに、子供の履ものの目立って紅いのも、もの侘しい。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "茄子畑があると思えば、すぐ隣に豌豆の畑があった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "床柱にも名があろう……壁に掛けた籠に豌豆のふっくりと咲いた真白な花、蔓を短かく投込みに活けたのが、窓明りに明く灯を点したように見えて、桃の花より一層ほんのりと部屋も暖い。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "向直った顔が、斜めに白い、その豌豆の花に面した時、眉を開いて、熟と視た。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時きりりと、銀の無地の扇子を開いて、かざした袖の手のしないに、ひらひらと池を招く、と澄透る水に映って、ちらちらと揺めいたが、波を浮いたか、霞を落ちたか、その大さ、やがて扇ばかりな真白な一羽の胡蝶、ふわふわと船の上に顕われて、つかず、離れず、豌豆の花に舞う。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははあ煮たて豌豆、古道具、古着の類。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、男は近くの米屋から四合十銭の米と、八百屋から五銭の青豌豆を買ってきて、豌豆飯を炊いて、食べさせてくれました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔓は豌豆、藤かづら。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに豌豆の花、背の低い唐黍。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔓は豌豆、藤かづら、芥子に恨みはなけれども、その葉ゆゑこそ香も清く、ひとに未練はなけれども、思ひ出のみに身はほそる。",
              "citation": {
                "source": "第二真珠抄",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸の畑には豌豆の花が咲き麦には穂が出ているが、海の風は寒かった。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの畑でとれるもの――キャベツ、トマト、アスパラガス、豌豆、オレンジ、パイナップル、グースベリィ、コール・ラビ、バーバディン、等。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分にとんぼを捕るのに、細い糸の両端に豌豆大の小石を結び、それをひょいと空中へ投げ上げると、とんぼはその小石をたぶん餌だと思って追っかけて来る。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下宿の女主人が七時半の豌豆の事を何だかぶつくさぶつくさ言っていたな。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「コンフエツチイ」の丸は石灰を豌豆豆」］の大さに煉りたるなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "麥は穗を孕み、豌豆には濃い紫の花が咲いてゐる。",
              "citation": {
                "source": "樹木とその葉",
                "author": "或る日の晝餐",
                "note": "青空文庫"
              }
            },
            {
              "text": "目玉は黄いろい大豌豆のやうである。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔は黒ずんだ嗅煙草色３で、鼻は鉤形に曲っていて長く、眼は豌豆のようで、口は大きく、歯並は立派、それを見せびらかしたいらしく口を耳まで開けてにたにた笑っている。",
              "citation": {
                "source": "鐘塔の悪魔",
                "author": "THE DIVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、古手屋の遠助が、きょうは大根屁だとか、きょうはいも屁だとか、きょうは、えんどう豆屁だとか、正確にかぎわけて、手がら顔にいうのである。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
