          "literary": [
            {
              "text": "概ね円墳で、ハニワが出るのは他の関東の古墳に通じている。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにいわゆる古墳なるものは、確かに有史時代までも立派に築造せられているもので、かの横口式石室を有する普通の円墳のごときは、大化のころには盛んに行われていたと考えられるものである。",
              "citation": {
                "source": "日本における史前時代の歴史研究について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "用途は大きい前方後円墳の周囲の垣根であった。",
              "citation": {
                "source": "人物埴輪の眼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど前方後円墳といふのはかういふ落ちついた感じのものかとしみ／″＼感じた。",
              "citation": {
                "source": "西の京の思ひ出",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
