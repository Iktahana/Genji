          ],
          "literary": [
            {
              "text": "希望の飛行機が経済的事情にぶつかって、うまく飛行が運ばない時の気分のエアポケット。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと広間の周囲の空気からは、ここはエアポケットに陥ったように感ぜられつつある。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神的なエアポケットに落ち込んだように、心は支えを失い宙に浮いている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは今まであまりいわれなかったが、従来の料理論のエアポケットだ。",
              "citation": {
                "source": "味覚馬鹿",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
