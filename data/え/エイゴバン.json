          ],
          "literary": [
            {
              "text": "本稿執筆時点の一九九三年一月現在で入手可能なのは、英語版のみ。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同社によれば、英語版購入のユーザーにも実費程度で日本語版を提供するという。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイパーカードを利用した英語版を、日本語に対応させた製品です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に、米ボイジャーの作品を、英語版のまま売ること。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ずは英語版のツールキットを日本語化しよう」という意見が勝って、発表された活動方針が定められます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語版も用意したい――。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴岡雄二はこの本の訳者であるが、これには英語版の「原書」はない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語版も用意したい―。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語版の原書が存在しない中で、関係者の悪戦苦闘の末にオリジナル版の同書が生まれるにいたった経緯は、浜野保樹が目配りの利いたアラン・ケイの評伝を寄せた同書の訳者後書きに詳しい。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネッパーは英語版の前書きにあるように、「マイクロソフト社の驚異的成功の道筋が一冊の本にまとまれば、アメリカ人もむろん読みたいと思うだろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディスプレイ上の表示の意味を説明するために英語版のマニュアルにあった画面のコピーには、キルドールの手書きの書き込みがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（オッペルトの『禁断国』は英独両語版とも、上野図書館にあるが、たしか英語版の方だったと思う、「明治十四年十二月七日購求、教育博物館印」と大きく押してあった。",
              "citation": {
                "source": "撥陵遠征隊",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは国際雪氷協会の大会に送った英語版のものであった。",
              "citation": {
                "source": "鳥井さんのことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「バドリオ」として東条の監視の下にあった伯が、戦争中に、大勢の客を集めて、英語版の映画を見せるというようなことは、相当な勇気を必要とする。",
              "citation": {
                "source": "鳥井さんのことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東宝でももちろん感激して、現像にも特別の注意を払って、英語版の立派なものを一本作って献上することになった。",
              "citation": {
                "source": "雪今昔物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時期に、英語版の学術映画に対して、そういうお心遣いがあったことは、一般に知っていてよいことであろう。",
              "citation": {
                "source": "雪今昔物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの研究の全経過を映画にとって、その英語版をオスロの総会に提出することにした。",
              "citation": {
                "source": "国際雪氷委員会のことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この『霜の花』と、前にいった『大雪山の雪』と、それに『雪の結晶』の仮版と、合計六巻の英語版が仕上ったのは、八月五日頃であった。",
              "citation": {
                "source": "国際雪氷委員会のことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の映画は、アメリカへ送った英語版であった。",
              "citation": {
                "source": "牧野伸顕伯の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の戦争中のあの空気の中で、牧野さんの邸宅で英語版の映画を見せることは、少し無鉄砲だったかもしれないが、牧野さんは非常に喜ばれた。",
              "citation": {
                "source": "牧野伸顕伯の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「医学静力学について（De Statica Medicina）」はサントリオの最良の著書ではなく、英語版はこの偉大な研究者の記念にはならない。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二三年ダブルデイ・ペイジ＆カンパニーから出版された英語版を底本にとった。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　チャペックはチェコスロヴァキアの作家で、原典はもちろんチェコ語で書かれているのだが、訳者の都合上、英語版をもとに翻訳することにした。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、今回底本に選んだ英語版はチェコ語の原典を様々の箇所で内容に差違が見られる。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
