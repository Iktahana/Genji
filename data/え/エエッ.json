        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ええっ、本当ですか。意外だなあ。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、もう夜中だ。時間が経つのが早い。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、彼が辞めるって？急な話だな。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、このケーキ自分で作ったんですか。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、あの映画がこんなに面白いとは知らなかった。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、まさかあのチームが優勝するとは。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、この古い建物が国宝だなんて。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、その本がもう売り切れなの。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、あの静かな子がスターだったなんて。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、転勤は海外なんですか。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、二十年振りに会ったのに変わっていないね。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、あの値段でこんなに良い品物が。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、その音楽が懐かしい。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、もう春ですか。冬はどこへ。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、その話を今聞くなんて初めてだ。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、その人が犯人だったんですか。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、こんなにたくさんの人がいるなんて。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、あの味が再現できるなんて。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、その日付は明日ですよ。",
              "source": "幻辞"
            },
            {
              "text": "ええっ、もう十月になるんですか。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ところで俺は、ええっと、どうしたらいいかな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええっと、どなたでしたっけ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "題が、いけなかったんだよ、ええっと、何だったっけな、「或る踊子の問わず語り」こっちが狼狽して赤面したね。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええっと、どなただったかな？",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前達がそんなにあやまるならば、今度は背骨だけでなく、身体中すっかりたたき直して、ビックリする位立派な人間に作りかえてやろう」「ええっ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と自分が問うと、堀木は口を曲げて考え、「ええっと、花月という料理屋があったから、月だ」「いや、それはアントになっていない。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええっと、三鷹を英語で言うなら、スリー、……スリー、スリー、ええっと、英語で鷹を何と言いましたかね、ドイツ語なら、デルファルケだけれども、英語は、イーグル、いやあれは違うか、とにかく十二になる筈です。",
              "citation": {
                "source": "女神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええっ……」　銀之丞の美しい眼尻には涙どころか、血が鈍染んでいた。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええっと、眼なんてちっとも残っていねえんでがすが」「このまぬけめが！",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "理想的なコンピューターのイメージとして打ち出したダイナブックの名を使われて、あなたの腹は立たぬのであるか、ええっ」と切りかかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大石にも、不当に殺される者の怒りが分からんのか）と思ったとき、「ええっ！",
              "citation": {
                "source": "吉良上野の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しいことをした」「もしもし、惜しいといえば、テイラー博士がさっき死去されましたよ」「ええっ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで近く秘書を辞職することになるでしょう」愛人「ええっ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこの次帰ってくるときには、マニラの葉巻と布とを持ってくるとさ」「ええっ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからあたし、そんなこと申し上げられやしないわ」「ええっ、轟博士がへんなのですか。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとすると、これは火星の生物かもしれませんよ」「ええっ、火星の生物ですって」「しかし、火星の生物が、轟博士に化けていたとはどういうわけだろう」　この恐ろしい疑問は、僕がふたたび手帖をひろげて、先刻の手記のつづきをよんだ結果、解けた。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええっと『十万円の懸賞』だとゆくんだ。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとすると、そのドン助というのは、そのときこの○○獣に喰われてしまったかもしれないよ」「ええっ、ドン助が○○獣に喰べられてしまいましたか」　それを聞くと、敬二は頭がぼーっとしてきた。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "月島二丁目に住んでいる正木正太という左官なんです」「ええっ、左官。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええっ、するとこの飛行島は、なんです」「ねえハバノフさん。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわしの見るところでは、一般に考えられているところとはちがって、目下の事態は刻々悪い方へ動きつつあるように思う」「ええっ、悪い方へ？",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様が杖とも柱とも頼む川上機関大尉の死体だ」「ええっ、な、な、何だって？",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは日本の軍艦だ」「ええっ、日本の軍艦だって？",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ第四エンジン室内の電灯は消え、銃声ばかりがはげしく鳴っておりますそうでして――」「ええっ、――」　ときもとき、日本潜水艦の追跡をうけている最中だというのに、突如として飛行島内に起ったフランク大尉の暴挙！",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たしか麹町の殿様半次とか云っていました」「ええっ、殿様半次だと、――」　と警官連は半次の仕業と知ると、云いあわせたように仰天した。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生　（おどろき）ええっ、な、な、なにごとか起ったというのか。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして電話機のところへ駈けよろうとしたが、そのとき帆村が、『おい待て、電話機に手をかけるな』『ええっ、なぜ――』『俺の後についてこい。",
              "citation": {
                "source": "街の探偵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実は、川上糸子がこの先の二丁目の空家で殺されていたのです」「ええっ！",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「抛っといたらええってば。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
