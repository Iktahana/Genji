    "definitions": [
      {
        "index": 1,
        "gloss": "English-Japanese",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "英和の翻訳作業は思ったより時間がかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は英和辞書を片手に、英文を読んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "英和対訳の書籍は、語学学習者に人気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "英語の書物を読むには英和の字書で済むが、英語の会話を学ぶには和英の字書がなくてはならぬ。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、ふと、ダンデスムという言葉を思い出し、そうしてこの言葉の語根は、ダンテというのではなかろうか、と多少のときめきを以て、机上の辞書を調べたが、私の貧しい英和中辞典は、なんにも教えて呉れなかった。",
              "citation": {
                "source": "思案の敗北",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る文字を引かうとして英和辭典をバラ／＼と繰りながら、偶然開かれたページの Opera といふ文字に目がとまつた時、私は、瞬間ハツと何か明るい華やかな若々しいものが前を過ぎたやうな氣がした。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "普段英語を読むときは、研究社の『リーダーズ英和辞典』が離せません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、『岩波国語辞典』と『リーダーズ英和辞典』という最も使用頻度の高い二つは、マシンで引いています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が家の愛用の辞書は、研究社の『リーダーズ英和辞典』です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、研究社のホームページで、電子化された『リーダーズ英和辞典』を引けると知りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語を使用する極東の島国の民として生まれた筆者は、英和辞典を引きひき Alice の注釈に悲鳴を上げる程度の英語力しか持ち合わせていない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その筆者にとって、読む環境の整備という点での当面の願いは、研究社の「リーダーズ英和辞典」が電子化され、ディスプレイ上の英単語をクリックすれば一発で意味と用例が出てくる事である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで『井上英和辭典』を引いて見ると、斯うある。",
              "citation": {
                "source": "櫻と狆と愛國心",
                "author": "コスモポリタンの心理",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あとでさ、英和辞典見て、ちゃんと調べようよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも彼は、今度は成るべく活字の大きさうな二三册の部厚な洋書と、ウエブスタアと更に英和辭書を抱え込んでゐた。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所は四福音書と、安物の英和辞書と渡米案内の転がつてゐる教会の一室であつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私瑠美子を仏英和の幼稚園へ入れようと思うんですけれど、あすこからではこの人には少し無理でしょうと思って……。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校は、今の社会の風潮が浮薄であるということだけを強調して、その社会的根源を究明しようとする力は持たず、表面的にそのような世相を反撥して地味な制服を着ろとか、家事を見習えとか云い、仏英和女学校などでは女学生のスカートの長さが規定どおりか否かを一々物尺で計って教師が調べる有様である。",
              "citation": {
                "source": "昨今の話題を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、小さな英語辞書、英和辞典でさへ間に合ふものを、わざわざウェブスターやセンチュリーを引かせることは、あまりにペダンチックではないか、などと云つて、私どもは内々不平であつた。",
              "citation": {
                "source": "辞書の客観性",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "公平入道常見が陣頭の宣言畢りて、逍遙子は又英和字典膳といふ假設人物を出し、これにいと勇ましき軍歌を歌はせ、その響と共にわが論陣を攻めたるが、その時の雅俗折衷之助が軍配に對するわが反撃は左の如し。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "コピーを自宅に持ち帰り、英和辞典片手に一気に読み終えたとき、後藤はこの表題にもそしてこの挿し絵にも、素直にうなずくことができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその床の間に近く、表向きの障子に向っては一つの机が置かれていて、その上にはザラ紙の原稿紙や封筒や二、三冊の法律書の他に、夜店にさらされているような旧式な英和辞書がきちんと積み重ねられてあった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞店にいた頃、古本屋で一円五十銭で買った代数の参考書と、三円いくらした英和辞典とのみが金に代りそうな品物であった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に正木先生はもしこの恩が報じたければ福岡へ住んで俺が帰るのを待っておれと云われまして沢山の旅費まで頂きましたので、帰国｜匆々当地の英和学院の柔道師範を奉職していたのですが、正木先生が大学に来られるとすぐに辞職して治療場の監視をお引き受けした位です。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "このマソヒズムと云う……」「ええ、どうも普通の英和辞書には出て居らんように思いますが。",
              "citation": {
                "source": "文章",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの英和｜字彙があるならお貸し遊ばしてちょうだい。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "加藤弘之先生の直話に拠れば「自由」という訳字は、幕府の外国方英語通辞の頭をしていた森山多吉郎という人が案出したのが最初であるという事であるが、文久二年初版慶応三年正月再版訳了の「英和対訳辞書」（堀達三郎著）には、既に自由という訳字を用いている。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏英和女学校の附属小学校のオカツパの生徒が一人、女中に連れられて習ひに来てくれたことはせめてもの慰めであつた。",
              "citation": {
                "source": "芝居と僕",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お、やっぱりドン百姓でも生れた村の方がえいわい。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　六「あれに連れて行て貰うよりゃ、いっそうら等二人で行く方が安気でえいわい。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭が仰山あるせになんぼでも入れたらえいわいな。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう通らなんだら、私立を受けさしてまで中学へやらいでもえいわやの。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早よ呼び戻したらえいわ。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
