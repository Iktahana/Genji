          "literary": [
            {
              "text": "映写室から発火したといふ話でした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "映写室から発火したという話でした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "監事部屋というのは、一階の客席のうしろの、いわば映画館の映写室の位置に当るところに作られている部屋で、舞台に面して窓があり、そこから舞台が見られるようになっていた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそこの技師を知っていますから、映写室から見せてあげましょう」　なぞと連れ出す。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何年かまえ松竹座を除いてはまだ京都中の映画館にも映画会社にもトーキーの再生装置がなかつたとき、本願寺の大谷さんのおやしきの一隅にはちやんとトーキーの映写室がありウェスタンの再生機がすわつていた。",
              "citation": {
                "source": "映画の普及力とは",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜこんなことを知つているかというと、私は映写室を探して迷宮のような本願寺中をさまよい歩いたのである。",
              "citation": {
                "source": "映画の普及力とは",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな所にトーキーの映写室くらいあつても我々の家に犬小舎が置いてあるほどの感じしかない。",
              "citation": {
                "source": "映画の普及力とは",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "映写室でも大きいのになると、千人も入れるのがある。",
              "citation": {
                "source": "ソヴェトの「労働者クラブ」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "映写室のフロアにすわりこんだ僕たちは、ろくに呼吸も出来ないほどの状態で、スクリーンを見つめていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "見事なパフォーマンスをしてくれたラリー・デイヴィスに感謝しなくてはいけません」　監督のシュローダーが映写室からマイクでそう言った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "音入れをおこなっているスタジオの映写室で、僕たちはこうしてジェニファーの映画を見ている。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "映写室の明かりがついた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとでしらべてみますと、恐怖王は映画のフィルムをぬすみだして、その一こま一こまを虫めがねで見ながら、赤いえのぐをぬって、また、もとの映写室へもどしておいたことがわかりました。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
