        "examples": {
          "standard": [
            {
              "text": "採血したサンプルは、すぐに遠心分離にかけて血漿と血球に分ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "遠心分離することで、混合物の中から特定の成分だけを取り出すことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "細胞培養の作業で、何度か遠心分離を行う必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その後二、三カ月して札幌へ帰って、遠心分離器で便の集卵をやってもらったが、やはり完全に卵は見えなくなっていた。",
              "citation": {
                "source": "ジストマ退治の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ぼくの回転は徐々に急速となり、めまぐるしく、意識が遠心分離機にかかって遠くへ振り飛ばされるみたいに、二、三回、胆の冷えるような夢幻的な思いがはしって、やがて力無く、ぼくのからだは一箇の死体のように停る。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
