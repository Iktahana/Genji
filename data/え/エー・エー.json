          ],
          "literary": [
            {
              "text": "あの肥った、そら、いま乾板現像液で茶色に染まってる手を出して、他人の賭金を誤魔化してさらえ込もうとしている――ＡＡ！",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの川は何といいますか」「あれですか、Aach 川です」「どう綴りますか」「ＡＡＣＨと綴ります。",
              "citation": {
                "source": "ドナウ源流行",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＷＡＷＡＷＡＡＡＨ！",
              "citation": {
                "source": "霓博士の廃頽",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　　　×　　　×　見取図には便宜上方角を明らかにする為にＡＡ’、ＢＢ’等の符号を附した。",
              "citation": {
                "source": "あの世の入口",
                "author": "――いわゆる地獄穴について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルビー色の航空灯が明滅している江ノ島のうえの空を、定時のＰＡＡが鼻唄のような爆音をひびかせながら、低く飛んでいる。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたがアラディンのランプを持っているなら、明日からでもすぐ働けるところと、前渡金をすこしもらえるようにしていただきたいもんですね」　芳夫は脇にひきつけていたＰＡＡの空色の飛行鞄のジッパーをあけて、中のものを見せた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
