        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "米軍基地のゲート周辺をＭＰがパトロールしており、フェンス越しにも物々しい雰囲気が伝わってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「街中で軍人がトラブルを起こしたらしい」「さっきＭＰの車両がサイレンを鳴らして急行していったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "憲兵隊、いわゆるＭＰは軍内部の規律を維持し、軍に関わる犯罪の捜査を行う権限を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "member of parliament (UK, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
