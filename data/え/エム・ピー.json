          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「うわ、回復魔法を使いたいのにＭＰが足りない！」「早くアイテムを使って補充してくれ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "強力なスキルを連発したせいで、ボスの体力を削りきる前にＭＰが尽きてしまい、絶体絶命のピンチに陥った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "レベルアップによって最大ＭＰが増えたおかげで、ダンジョンの奥深くまでの探索がぐっと楽になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "『ＣＯＭＰＵＴＥＲ』という雑誌の一九七七年三月号に載った「パーソナル・ダイナミック・メディア」という記念碑的な論文の最後に、彼がユタ大学に博士論文として提出した「ザ・リアクティブ・エンジン」や、所属していたゼロックス社パロアルト研究所の技術レポートとしてまとめた文献に関する記述がありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九九四（平成六）年に東芝ＥＭＩから発売された『ＴＨＥ　ＣＯＭＰＬＥＴＥ　ＯＺＵ』と、ボイジャーから出た『寺山修司／書を捨てよ、町に出よう』という二つのエキスパンドブックは、それまでのものと同じく、ハイパーカードを利用しています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "改良日本語版を使った『ＴＨＥ　ＣＯＭＰＬＥＴＥ　ＯＺＵ』の制作が一段落付いた一九九四（平成六）年の春、祝田さんは仲間たちに「見せたいものがある」と声をかけました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時期に彼は、完成品としては日本初の、日本電気から発売されたＣＯＭＰＯ―ＢＳ／80に出合った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずさんであるとかとんでもなく詰めが甘いとか色々批判を浴びながらも、突っ込みには見るべきところのあった『Ｔｈｅ　ＣＯＭＰＵＴＥＲ』も、休刊になるとの知らせが届いた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ホームコンピューター』の虚妄を現実に変えるＡＭＤ３８６互換チップの宣戦布告『Ｔｈｅ　ＣＯＭＰＵＴＥＲ』から「Ｗｉｎｄｏｗｓ３・０は流行るか」という、いまさらなにをとぼけているかといいたくなる座談会のお座敷がかかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊いつぞや「Ｗｉｎｄｏｗｓ３・０は流行るか」と何をいまさらの座談会で評判を落とした『Ｔｈｅ　ＣＯＭＰＵＴＥＲ』から、今度は「本当にＷｉｎｄｏｗｓが必要か」を論議するのだと言ってきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "創刊以来、世話になってきた『Ｔｈｅ　ＣＯＭＰＵＴＥＲ』とコラムを載せてもらった『パソコン・マガジン』も同時に休刊になった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "天罰たちどころに到って――現実にＢＵＭＰ！",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ultra modern !　ＢＵＭＰ！",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ＧＲＲＲＲ・轟々爆々―― and then, ＢＵＭＰ！",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢＵＭＰと称する小急下降運動は、ちょうど船に波浪が作用するように、気流の上下動に乗って機が小刻みに揺れるだけのことです。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "刺激・陶酔・優超感・魘されるこころ――このＧＲＲＲＲと、そしてＢＵＭＰ！",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日はまた、これは旅客機ではないが、この�T・Ａの飛行機がＢＵＭＰと落ちて、ちょっと Joy-ride としゃれていた会社の女タイピストと事務員の一行を飛行家とともに全部恨みっこなしに殺している。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンピイは海から来た男で、そしてＰＩＭＰだった――あとで解る――それはいいが、ついうっかりしてるうちに僕も捲き込まれて、その跛足リンプの助手みたいな仕事をしなければならないことになった。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "加うるに、この出張売春婦のＰＩＭＰをつかさどるかたわら、第三にそして最後に、彼はほんとの「しっぷ・ちゃん」をも兼ねていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＩＭＰという一つの職業がある。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、女肉を常食とする点で、リンピイもＰＩＭＰはぴんぷだった。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、マルガリイダもＰＩＭＰもなかった。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおブッシュの開発したさまざまな機械の姿は、『Ａ ＣＯＭＰＵＴＥＲ ＰＥＲＳＰＥＣＴＩＶＥ　計算機創造の軌跡』（The office of Charles and Ray Eames 著、山本敦子訳、アスキー、一九九四年）で見ることができる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "モトローラ・セミコンダクターズ・ジャパンは、６８００にＲＡＭとＲＯＭ、周辺装置制御用のＬＳＩを加えた一式をＭＰＵキットと名付け、五万円とした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "光つた白い帽子をかぶつた、背の高いＭＰが二人、ホームのはづれに立つてゐる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "セラダの死後、小夜子サンは出頭を命ぜられてＭＰの取調べをうけました。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アパリでは見たことのないＭＰやＳＰが、警備についていた。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると一人のＭＰがドカドカとランプを上って来て、いきなり僕に「お前は日本語分るか」といった。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては手前はまだ米国人をリック〔やっつける〕することが出来ると思ってやがるんだな」と、ＭＰは大きな声を出した。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本兵としては、投降して以来、別してＬＳＴでは、米国兵が親切にしてくれるので、有難いとは思っても、別に恐怖すべき経験をしていないから、「こわくない」と答えたのだが、ＭＰはそんな意味で聞いたのではなかった。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "末席をけがすとエム・ピー・テクノロジー社長の吉本万寿夫さんに、「こんな話はマッキントッシュが出た時点で、五、六年前にやっておくべきですよね」とかまされた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
