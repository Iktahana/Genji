          "literary": [
            {
              "text": "少年たちは甲斐のほうを見たが、七十郎にせきたてられて去り、家紋を蒔絵にした柄樽を持って来、そしてひきさがった。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皮は、へえだるらしいが、料理は、奥さん、できるかね？",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
