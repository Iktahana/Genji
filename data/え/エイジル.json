[
  {
    "uuid": "da1ca01d-ec0c-5c3a-9534-bef0fae361fc",
    "entry": "映じる",
    "reading": {
      "primary": "えいじる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be reflected (in)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "湖面に月が静かに映じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "窓ガラスに、夜景がぼんやりと映じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "太陽の光が、濡れた葉にキラキラと映じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、象牙の塔のガラス窓の中から仮想ディノソーラス「ジャーナリズム」の怪奇な姿をこわごわ観察している偏屈な老学究の滑稽なる風貌が、さくら音頭の銀座から遠望した本職のジャーナリストの目にいかに映じるかは賢明なる読者の想像に任せるほかはないのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『戦争と平和』に出て来る、ある人物の眼に映じる美しい大自然のながめ、静まりかえった心境、――そういったものが、この己の死際にも、はたして訪れて来るだろうか。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "『戦争と平和』に出て来る、ある人物の眼に映じる美しい大自然のながめ、静まりかへつた心境、――さういつたものが、この己の死際にも、はたして訪れて来るだらうか。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "（象形文字と音符文字と全く性格の異つた両様の文字を混用した日本文は、眼に映じる所が非常にきたない。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに眼に映じる自然のありのままの実在が如何に美しく、複雑に組立てられているかという事を現すのに適当な技法である。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはまた、そう云う現象が、第三者の眼にも映じると云う、実例になりましょう。",
              "citation": {
                "source": "二つの手紙",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "今私達の目に映じる遠近の諸山は総てその山脈に属するのであるが、吉林に近い山山は何れも優雅な姿をして、其中をＳ字形に松花江がコバルトを流してゐるのは美くしい景観である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ冒險の幾場面が、無數に目の前に映じるのであつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病蝶に対する何らの主観も読まず、只目に映じる色彩、形、実在の真を明確に描写せんと努力するのみである。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "その目に映じるものは風景にすぎない。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはしかし、日本の政治そのものの実質がさうみられるやうなものであるのか、または、実質とは関係なく、日本人たる国民の眼にたゞさう映じるだけなのであらうか？",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が其の恋愛をしてみたところで、それは真の恋愛をしているその瞬間の快楽よりも、そうすることの得意さ、人の目に映じる自分の姿に対する自己満足にすぎないように思われた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがわれわれの目に映じるところの茶界の姿である。",
              "citation": {
                "source": "現代茶人批判",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "空想の翼のひろがるだけ、春の青空が以前よりも青く広く目に映じる。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、この日本の学者の始めた道を武内博士は進んで行こうとせられるのであるが、ちょうどその道こそ原典批判の正道としてわれわれの眼に映じるのである。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "噴水の鶴が鳴くとか鳴かんとか莫迦莫迦しいことをいっておるが」　真名古は例によって陰気な声で、「あれは犯罪です」　林は笑い出し、「あんたの眼から見たら森羅万象ことごとく犯罪に見えるのでしょう」「左様、あなた方には見えぬ陰微の犯罪も私にはアリアリと映じるのです。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、形象は深く模糊の中に沈み、たまさか反射だけがチラリとわれわれの眼に映じるのである。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は法文経の大学教授などにも見うけられなくはない現象だが、多くの科学者や技術家に取ってはジャーナリスティックな活動は「余技」として、或いは一種の堕落として、さえ映じるのである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかでもない、計画が断固たる性質を帯びれば帯びるほど、彼の目にはますます醜悪な、ますます愚劣なものに映じるのであった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "空も海も、そして海の波も、目に映じるあらゆるものが、くっきりと鮮明だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨシオの目に映じる彼女の脚は、昨年よりもさらに美しさを深めていた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "目に映じるすべてのものが、明かるくて強い陽光のなかにある。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんなものが、以前より、もっとくっきり、心に映じるようになった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――また、組む者、馬上から落ちる者、姉川の水は、血か、映じる朝陽か、鮮紅燦々と揺れに揺れた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to impress (a person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の情熱的なスピーチは、聴衆の心に強く映じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの日の光景が、今でも鮮明に私の記憶に映じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の聡明さが、相手に好印象を映じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
