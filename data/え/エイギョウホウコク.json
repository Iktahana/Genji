          "literary": [
            {
              "text": "一番上には第一回営業報告とある。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二冊目は第二回で、三冊目は第三回で、四冊目は第四回の営業報告に違ない。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今この胃の痛い最中にこの大部の営業報告を研究しなければすまない事になっては、とうてい持ち切れる訳のものではない。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はまだ営業報告を開けないうちに、早速｜一工夫してこう云った。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
