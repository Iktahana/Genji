        "examples": {
          "standard": [
            {
              "text": "月末には、各支店長から本社の経営陣へ月次の営業報告が提出される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回の営業報告では、新商品の販売が好調で、当初の予測を大きく上回ったことが強調された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来週の役員会で社長が直接、前期の営業報告を行うことになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームミーティングでは、各自が担当エリアの営業報告を行い、情報共有を図った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一番上には第一回営業報告とある。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二冊目は第二回で、三冊目は第三回で、四冊目は第四回の営業報告に違ない。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今この胃の痛い最中にこの大部の営業報告を研究しなければすまない事になっては、とうてい持ち切れる訳のものではない。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はまだ営業報告を開けないうちに、早速｜一工夫してこう云った。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
