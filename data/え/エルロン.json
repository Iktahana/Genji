          "literary": [
            {
              "text": "両軍の両翼は、ジュナップの道とニヴェルの道との左右に延びている、そしてエルロンはピクトンに対峙し、レイユはヒルに対峙している。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルロン伯の攻撃に対してサックス・ワイマール大侯がフリシュモンとスモーアンとを維持したこと。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
