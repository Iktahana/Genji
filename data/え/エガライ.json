          "literary": [
            {
              "text": "そこがねえ辛いと言うもんです」　古い洋傘の毛繻子の今は炬燵掛と化けたのを叩いて、隠居は掻口説いた。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "話しをするのはおろか、人の話しを聴くのさえ辛い。",
              "citation": {
                "source": "グーセフ",
                "author": "ГУСЕВ",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝王のために一個人を裏切ることさえ辛いのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
