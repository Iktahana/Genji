              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "わたしは、駅舎で芝居をやっていたんです。",
              "citation": {
                "source": "人形つかい",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅舎の一夜　孟不疑という挙人（進士の試験に応ずる資格のある者）があった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "孟がひと足さきに出たあとで、張の供の者どもは、出発の用意を整えて、主人と共に駅舎を出た。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ大騒ぎになって、再び駅舎へ引っ返して詮議すると、西の部屋に白骨が見いだされた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから更にゆく手を急ごうとすると、駅舎の前にはひとりの老人が桶を作っていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄衣婦人　唐の柳宗元先生が永州の司馬に左遷される途中、荊門を通過して駅舎に宿ると、その夜の夢に黄衣の一婦人があらわれた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある田舎の駅舎で落合つて、一夜語り明して、『己はこれから波斯に行く……。",
              "citation": {
                "source": "ペチヨリンとゲザ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂは古い駅舎の※の上に毛布を敷いて夜ごとに佗しく寝るＨ夫妻を想像した。",
              "citation": {
                "source": "犬",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "32よく帰ってきたねきみが嗤った昔なじみのこの土地に名前はみな変わってしまったけれど夢だけはのこっているよ〈ウェルカム・バック〉ジョン・セバスチャン（ラヴィン・スプーンフル）　ＪＲの駅舎から出た慶一は、困惑と屈辱のなかで立ちつくした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、捕盗の役人を送って行って、駅舎に一宿した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな駅舎が観音寺に続く古い道と交差する角の近くあたりに建てられた。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大村駅舎逢鏑雲潭。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "水駅は、人の上にも解せられるが、主として、馬に飲ふ駅舎に見立てたのだらう。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれをみんな、まだニジニ・ノーヴゴロドにも着かない先に、護送の下士どもにばらまいてしまった、道中をセルゲイと肩をならべて歩かせてもらい、闇の夜には囚人駅舎の寒い廊下の隅っこに彼と抱きあって小一時もいさせてもらう――その目こぼしにあずかるためにである。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、駅舎から全市街の大半が焼かれていた。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物を小荷物に託し、二人は身軽になって駅舎を出た。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉瓦建ての駅舎や倉庫があり、電柱が点々と立っている。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は駅舎へはいったが、ちょっとあたりを見回して駅長の細君の顔を見ると、急に引っ返して玄関へ出た。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "お宝を駅舎から運び出し、すぐに三個の貴重な旅行｜鞄を、三台の馬車に乗せ、別々の目的地へさっさと輸送した。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅舎には相変らず人々が忙しげに出入りし、駅前にはタクシーやバスが着いたり、走り出したりしている。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きさとしては駅舎をしのぐそれらの巨大構造物は、まるで気配を消すかのように風景に溶け込んでしまっている。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱庭の中に夜が訪れ、そこには、携帯電話での通話を終えて、蝙蝠傘と鞄を提げて立ち上がり、駅舎へ向かう林芙美子像の姿がある。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてのんびりしたこの筋違の広場にも、やがて甲武鉄道の延長から赤煉瓦の駅舎出現、名代のめがね橋とり毀しなど三十年頃からそろそろごたつく。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
