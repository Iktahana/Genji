        "examples": {
          "standard": [
            {
              "text": "この建物のエレベーションは、周囲の住宅街の景観を損なわないよう低く抑えて計画されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "設計変更の指示があり、西側エレベーションのデザインを当初の案から大幅に見直すことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "詳細なエレベーションを確認することで、外壁タイルの割り付けやサッシの納まりを正確に把握できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「建物の顔となる正面のエレベーションには、もっと象徴的な素材を使いたいですね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "周囲の樹木の色との関係で平面に見たときああいう色は便宜なのだろうと理解されますが、道行人はエレベーションで見たのですから全く陰気な印象です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
