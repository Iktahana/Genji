    "definitions": [
      {
        "index": 1,
        "gloss": "Eiroku era (1558.2.28-1570.4.23)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "永禄年間に織田信長が台頭した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この茶碗は永禄時代の作と伝えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "永禄の変は歴史上有名な事件だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "永禄あるいは文禄年間に琉球から伝わった蛇皮線を日本人の手で作りかえた、それがだんだんポピュラーになったものらしい。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "永禄十年三月、十八歳の時、伯父津軽為則の養子となり、近衛前久の猶子となれり。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも先々女房には化粧をさせたり、子供には可憐な衣服をさせたりして、親父殿も晩酌の一杯ぐらいは楽んでいられて、ドンドン、ジャンジャン、ソーレ敵軍が押寄せて来たぞ、酷い目にあわぬ中に早く逃げろ、なぞということは無いが、永禄、元亀、天正の頃は、とても今の者が想像出来るような生優しい世では無かった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "永禄の前は弘治、弘治の前は天文だが、天文よりもまだ前の前のことだ、京畿地方は権力者の争い騒ぐところで有ったから、早くより戦乱の巷となった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "永禄年中三好家の堺を領せる時は、三十六人衆と称し、能登屋臙脂屋が其｜首であった。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "永禄三年五月二十日今川殿｜陣亡遊ばされ候時、景通も御供いたし候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "父｜才八は永禄元年出生｜候て、三歳にして怙を失い、母の手に養育いたされ候て人と成り候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年世良田合戦、御影寺合戦（永禄三年）終って間もなく、浅井家の家中寄り合い、諸士の手柄話の噂などした。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚したのが、永禄十一年四月だから、生れていたかどうか、多分まだ腹の中にいたのである。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲越二将が、手切れとなったのは、天文二十二年で、爾来二十六年間の交戦状態に於て、川中島に於ける交戦は数回あったが、其の主なるものは、弘治元年七月十九日｜犀川河畔の戦闘と永禄四年九月十日の川中島合戦との二回だけである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その責任上、永禄三年兵を関東平野に進め、関東の諸大名を威服し、永禄四年に北条｜氏康を小田原城に囲んで、その城濠｜蓮池のほとりで、馬から降り、城兵が鉄砲で狙い打つにも拘らず、悠々閑々として牀几に腰かけ、お茶を三杯まで飲んだ。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "永禄四年川中島合戦には、謙信は上杉憲政から、一字を貰って、政虎と云っていたのである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "謙信は、永禄四年春小田原攻囲中、信玄動くと聴き、今度こそは信玄と有無の一戦すべしとして、越後に馳せ帰ったのである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、永禄七年の戦に、甲越両軍多年の勝負を角力に決せんとし、甲軍より大兵の安間彦六、越軍より小兵の長谷川与五左衛門を出して組み打ちさせ、与五左衛門勝って、川中島四郡越後に属したとあるが、之は嘘らしい。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "松平元康が、どんなに優秀な前軍を勤めたかを簡単に示すならば、弘治三年四月には刈屋を攻め、七月｜大府に向い、翌永禄元年二月には、義元に叛き信長に通じた寺部城主鈴木｜重教を攻め、同じく四月には兵糧を大高城に入れた。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "永禄三年五月｜朔日今川義元、いよいよ全軍出発の命を下した。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "永禄三年五月十八日の夜は殺気を山野に満したまま更けて行った。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大左文字はすぐに信長に分捕られた上にその銘に、表には永禄三年五月十九日義元｜討捕刻彼所持刀、裏には織田尾張守信長と刻込まれて仕舞った。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "後永禄五年五月、水野信元のとりなしで信長と清須城に会して連合を約し、幼少から隠忍した甲斐あって次第に勢を伸す基礎を得た。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信雄信孝とは永禄元年の同月に生れ、信孝の方が二十日余りも早かったのだが、信雄が信忠と母を同じくしたのに引かえ、信孝は異腹であったので、人々信雄を尊んで、早速に信長に報告し、次男と云うことになって仕舞った。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "義元を打倒した信長は、義元の壮図だけを承け継いで、その戦勝の余威に乗じて、上洛行動の準備を為し、先づ今川から自立した徳川家康と攻守同盟を結んで、後顧の憂を絶ち、美濃の斎藤を追うて道を開き、近江の浅井長政に妹を嫁して、途中の不安を除き、その上洛の志を達したのが、永禄十一年である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「織田軍記」には義竜のことを記して、「今はあらそふ者もなければ、義竜自ら濃州の守護となつて、悪人ながら威勢ありしに、ためしすくなき大罪人のむくいにや、幾程なく永禄四年に義竜たちまち悪病を煩ひ、死去しけり」と、云ってある。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐橋家の家譜等では、甚五郎ははやく永禄六年一向宗徒に与して討死している。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "永禄二年公家藤原某作てふ『塵塚物語』巻三に卜部兼倶説として、大黒というはもと大国主の命なり、大己貴と連族にて昔天下を経営したもう神なり。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "永禄十二年十月武田信玄三増山の備えを小田原勢が撃って大敗した時、北条美濃守｜氏輝、既に危うきに臨み心中に飯綱権現を頼み、只今助けくれたら十年間婦女を遠ざけますと誓うた。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその日本に輸入されたのは、永禄年間であるから、これが七百年前の平氏の遺骨でないことは、火を観るよりも明かであるといった。",
              "citation": {
                "source": "土塊石片録",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくは永禄六七年の交の事であらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "永禄四年女婿秀次の事に坐して北国に謫せられ、慶長元年赦されて還り、元和三年七十九歳で薨じた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことのあったのは永禄元年のことであるが、この夜買った紅巾の祟りで、土屋庄三郎の身の上には幾多の波瀾が重畳した。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも事のおこりというのは、長政公が十五におなりになったとし、えいろく二ねんしょうがつと云うのに元服をなされて、それまでは新九郎と申し上げたのが、そのときに備前のかみながまさとお名のりなされ、江南の佐々木｜抜関斎の老臣平井加賀守どのゝ姫君をお迎えなされました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
