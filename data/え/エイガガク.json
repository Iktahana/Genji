        "examples": {
          "standard": [
            {
              "text": "大学の専攻で映画学を選び、理論と歴史を学んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は映画学の視点から、特定の監督の作品を深く分析している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この研究室では、世界の様々な時代の映画学的なアプローチを追求している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "労働者クラブのキネマ研究会と国立の映画学校では、男と半数の女とが新しいプロレタリア映画の完成のために教育を受けている。",
              "citation": {
                "source": "ソヴェト同盟の芝居・キネマ・ラジオ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、官立音楽学校、美術学校に対して、速かに、官立演劇映画学校を設立すること。",
              "citation": {
                "source": "一国民としての希望",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "30　人相学と映画学とは一脈相通じる。",
              "citation": {
                "source": "鈍走記（草稿）",
                "author": "竹内浩三",
                "note": "青空文庫"
              }
            }
          ]
        }
