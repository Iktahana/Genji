        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の静かな笑みに、その場の緊張がふっと解けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔を懐かしむように、祖父は穏やかな笑みを浮かべた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、合格してた！」掲示板の前で、彼女はこぼれるような笑みを見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "柔らかな陽光を浴びて、赤ん坊が眠りの中で微かな笑みを漏らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ああすべて惱ましき光の中に桃の笑みてふくらむ情慾の一時にやぶれてどくどくと流れ出でたり。",
              "citation": {
                "source": "春晝",
                "author": "――敍情小曲――",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はいつになくはればれと微笑み、私の肩をぽんと叩いて、「日本で一番よいまちだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と忍びやかにうち出でさせ給へるに、言の葉なくて、玉枝の君はうち笑みおはしぬ。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源はそれを聞いて微笑みながら、だまつてその星のある方を指さした。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言つてお鈴さんは、お照さんと顏を見合せて微笑み、「でも、普通のひとには見えないんです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかげでおいしい朝の煙草が一服吸える」　父はそこで私に珍らしく微笑みかけるのであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は俄にやさしくなって、「お前達に何の訣もないことはお母さんも知ってるがネ、人の口がうるさいから、ただこれから少し気をつけてと云うのです」　色青ざめた母の顔にもいつしか僕等を真から可愛がる笑みが湛えて居る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳まいらせん」と懐あくれば、笑みてさぐるも憎くからず、「勿躰なや、この子といふ可愛きもあり。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにしてさはおぼしつるぞ、いとよき御聞きざま」と、友は口おほひもしあへず笑みくつがへる。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひら立ち上って、Ｔ「近え中に又来るぜ」　とほくそ笑み乍ら庭へ去る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘両手にて画家の目を塞ぎ、顔次第に晴やかになりて微笑み、少し苦情らしき調子にて。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあらゆるものを通して、太陽に、それから木々に微笑みかけてゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "この湿気のある踊場風景のなかに、赤色ジョウゼットの夜会服をつつんだ、栗鼠の豪奢な毛皮の外套をつけたアトラクティブな夜の女の華車な姿が、化粧鏡を恋愛の媾曳のための、こころの置場として、僕に微笑みかけているのだ。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿の熟したような色をしたその顔が、さもさも喜びに堪えないといったように、心の笑みを絞り出した表情をしている。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それは、彼には、中津が、卑猥な会心の笑みをもらしている有りさまさえ想像せられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてその子の顔がこちらを向いたので私は微笑みかけました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　枕を並べた上人の姿も朧げに明は暗くなっていた、早速｜燈心を明くすると、上人は微笑みながら続けたのである。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（貴僧、さぞおかしかったでござんしょうね、）と自分でも思い出したように快く微笑みながら、（しようがないのでございますよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　看護員は微笑みながら、「繰返すに及びません。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　謂い懸けて片頬笑みつ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は声高に、「お香、今夜の婚礼はどうだった」と少しく笑みを含みて問いぬ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこれを読んで会心の笑みをもらす人は、またきっとうらやむべく頭の悪い立派な科学者であろう。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　雪は、晴れやかに微笑みつつ、胸を張って空気を吸いこんだ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は無理に微笑み、ただ首肯いて聞いていました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐵縁の眼鏡を掛けた刑事は、肉の厚い額に皺を二三本もりあがらせて微笑みつつ、鬚の肩を叩いた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞野を見て微笑みかけた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は微笑みつつ、わざとゆつくりその帽子を拾ひに歩きはじめた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は微笑みつつ、わざとゆっくりその帽子を拾いに歩きはじめた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明日は癒えん、ここに来たれ、物語して聞かすべし」しいてうちえみ、紀州を枕辺に坐らせて、といきつくづくいろいろの物語して聞かしぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、山崎と並んで、も一人、額の禿げた大柄な顔が、一寸彼を見てほゝえみかけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
