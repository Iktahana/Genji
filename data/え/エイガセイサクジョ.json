        "examples": {
          "standard": [
            {
              "text": "その映画製作所は、数々の名作アニメーションを生み出してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい映画製作所が、郊外に広大な敷地を確保した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの監督は、独立系の映画製作所で自由に作品を作っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新技術を導入した映画製作所が話題を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "文化的な仕事しかしていない東宝という映画製作所の闘争で、数千の武装警官と機銃をのせた甲虫が登場した光景は、フィルムにもおさめられた。",
              "citation": {
                "source": "新しい潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場、労働者クラブ、産院、託児所、子供の家、学校、劇場、映画製作所、ソヴェトの運営などと、見学しつづけた伸子は、労働者男女が互にわけあっている社会保障の現実を社会主義の社会というもののよさとして、うけいれずにはいられなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
