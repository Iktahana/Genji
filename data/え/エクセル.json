        "examples": {
          "standard": [
            {
              "text": "この月次レポートは、エクセルで作成するのが一番早い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女はエクセルを使って複雑なデータ分析を行うのが得意だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "来週の会議のために、売上データをエクセルでまとめておくように指示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "エクセルでマクロを組んで、作業の自動化を図ろうと思っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "おまけに先ずＷｉｎｄｏｗｓ３・０の目玉となるアプリケーションとしてマイクロソフトが出してくるのが、マック用にかねてから提供してきたワードやエクセルだもんな。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルチプランやのちにマイクロソフトが開発することになる表計算ソフト、エクセルは、Ｐコードをインタープリターによって実行する構造を持っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、エクセルシオの二番へ泊った。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンナ・エクセルは７才の健康な女の子で上に述べた患者の一人であり、はっきりと腕の３箇所に病毒を差し込んで感染を起こした。",
              "citation": {
                "source": "イングランドの西部の諸州とくにグルスターシャーで見つかった病気で、牛痘の名で知られているウシ天然痘の原因および効果についての研究",
                "author": "AN INQUIRY INTO THE CAUSES AND EFFECTS OF THE VARIOLAE VACCINAE, A DISEASE DISCOVERED IN SOME OF THE WESTERN COUNTIES OF ENGLAND, PARTICULARLY GLOUCESTERSHIRE, AND KNOWN BY THE NAME OF THE COW POX.",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かご用がありましたら、ホテル・エクセルシオルへ使なり手紙なりいただけばわかるやうにしておきます。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は英字新聞「エクセルショア」をもったまま、梨の木の下をあちらからこちらへ、こちらからあちらへ、と幾度も歩いた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "難解であって読むのが困難な手書き原稿がフランクフルトの出版社に送られ有名な論文「動物の心臓および血液の運動についての解剖学的研究」（＊エクセルキタティオと略称）の表題で出版された。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
