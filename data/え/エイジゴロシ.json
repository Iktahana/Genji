        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その国の刑法では嬰児殺しは重大な罪とされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史を紐解くと、厳しい時代には嬰児殺しが悲しい現実として存在した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "社会的な支援不足が、ときに嬰児殺しという悲劇につながることがあると指摘されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "中には何が何やらわからない新劇もあるが、そんなものでも誰云うとなく「嬰児殺し」だの「夜の宿」だのとわかって来るようになったので、しまいには一組も稽古に来ないようになってしまった。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これまでのいろんな予審調書や判決例を見ても、男の犯罪の裏には女、女の犯罪の裏には男、というようなのが非常に多いのですが、概して若い女の嬰児殺しなどという事件の裏にはきっと情夫がいて、何かやっているのが多いんです」　若い検事は署長を相手に、自分の観察をそう述べた。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の山の林で、嬰児殺しがあったという噂が温泉場に知れ渡った。",
              "citation": {
                "source": "ネギ一束",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月、「嬰児殺し」を『第一義』に発表。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嬰児殺し」有楽座で初演。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今人々の耳目をゆるがしている牛込の産婆の嬰児殺しも、この未解決な社会問題にからんでいる。",
              "citation": {
                "source": "砂糖・健忘症",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八歳未満が、窃盗二人、嬰児殺し一人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五歳未満が、窃盗四人、詐欺二人、殺人一人、嬰児殺し二人、放火四人、治安維持法違反一人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十五歳未満は、窃盗四人、詐欺二人、傷害一人、殺人六人、嬰児殺し三人、放火五人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十歳未満では、窃盗八人、詐欺二人、殺人一人、嬰児殺し三人、放火六人、治安維持法違反一人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十歳未満、窃盗十八人、詐欺五人、殺人四人、嬰児殺し五人、放火十人、賭博一人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十歳未満は、窃盗十五人、詐欺一人、殺人六人、嬰児殺し三人、堕胎一人、放火九人、贓物収受一人、文書偽造一人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十歳未満では、窃盗四人、殺人一人、嬰児殺し一人、放火三人、賭博一人、兌換券偽造一人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居としての出し物は、菊池寛作「父帰る」、山本有三作「嬰児殺し」、それに「神崎与五郎東下り」と、喜劇「おしやべり小僧」の四つで、なほ附け加へれば、題未詳のパントマイム二つ。",
              "citation": {
                "source": "ある村の素人劇団",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嬰児殺し」は巡査の妹が、起ち上る拍子に、日に焼けた男の太股を出したのが失敗で、見物はしたたか幻滅を感じさせられたが、女土工は、徹頭徹尾見物にうしろを向けた工夫が当つて、大きなぼろを出さず、無事に交番へ連れて行かれた。",
              "citation": {
                "source": "ある村の素人劇団",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嬰児殺し」「同志の人々」「坂崎出羽守」等は前者に属し、「女中の病気」「海彦山彦」「西郷と大久保」等は後者に属してゐる。",
              "citation": {
                "source": "作家山本人間有三",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、同氏の第一戯曲集たる『嬰児殺し』中に収められてある諸作から、今度の『同志の人々』中に収められてある諸作へと、或る著しい進化が認められ、此の進化が、僕の戯曲論を裏附ける為めに、極めて便利な性質をもつたものであるからである。",
              "citation": {
                "source": "『同志の人々』",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　この作品集に仮に題名を与へるとすれば、例へば、「『短夜』から『華々しき一族』まで」でもよし、「『父帰る』から『馬』まで」でもよし、さらに、「『嬰児殺し』から『おふくろ』まで」でもよいのである。",
              "citation": {
                "source": "二つの戯曲時代",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさうと戯曲家山本有三の「嬰児殺し」から「米百俵」に至る制作年譜は、殆ど同時に、その上演年譜をふくむとみて差支へないものである。",
              "citation": {
                "source": "二つの戯曲時代",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子であったか、女の子であったか、そのことは存じませんが、だいそれた自分の手で、虫も殺さない処女ぶった娘さんが、嬰児殺しをやりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に描かれる嬰児殺しの場面に至っては、醜悪はその頂点に達する。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤った恥辱心から時々起る嬰児殺しが、国民の大部分の心情の最善最有用の感情を犠牲にしてのみ行われ得るというのであるならば、この救済の代償たるや極めて高価であるといわなければならぬ。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビクビクしながらも、まさかあの恐ろしい嬰児殺しの秘密がばれていようとは知る由もなく、たかを括って客間に通った。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
