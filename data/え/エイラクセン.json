    "definitions": [
      {
        "index": 1,
        "gloss": "Chinese coinage produced during the reign of the Yongle Emperor (used in Japan from the Muromachi period to the early Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "Ancient pottery shards found at the site were accompanied by several Yongle coins.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "Historical records indicate that Japanese merchants frequently used Yongle coinage for trade.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "The museum's exhibit on East Asian trade prominently features Yongle currency.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "A shipwreck survey uncovered a significant number of Yongle coins, confirming maritime trade routes.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "尤も、戦国時代には、一銭｜斬りと云って、永楽銭一銭を盗むと斬ってしまったのである。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際室町時代特に足利義満、義政等が国外へ向って濫費した黄金だけでも大変なもので、その頃日本の国内で流通した永楽銭が、黄金と引換に支那から買入れたのですから、黄金の国外流出は思いやられます。",
              "citation": {
                "source": "古城の真昼",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいつは災難だったね、何が一体飛込んで来たんだ」「銭だよ」「えッ」「ちょっと見は、棒で突いたようだが、後で見ると、縁の下に、肉の厚い永楽銭が一枚落ちていたんだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "永楽銭の謎",
                "note": "青空文庫"
              }
            },
            {
              "text": "側には、肉の厚い永楽銭が一枚落ちていたが、額の疵とピタリと合う」「えッ」　平次も驚きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "永楽銭の謎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草入と永楽銭の細工は、私をどうかしようという企みに決りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "永楽銭の謎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永楽銭や文銭では埒があかぬと見たか、取って置きの小判が一枚、二枚、――夜の水の上に閃きます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "双生児の呪",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わず袖へ手が入ると、今しがた剰銭にとった永楽銭が一枚、右手の食指と拇指の間に立てて、ろくに狙いも定めずピュウと投げると、手練は恐ろしいもので、身を投げようとする男の横鬢をハッと打ちます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "振袖源太",
                "note": "青空文庫"
              }
            },
            {
              "text": "命と釣替えなら、こめかみへ穴が明いたって我慢が出来ねえこともあるめえ」「不法な人があったものだね、どうも」　老爺さん甚だ平らかじゃありませんが、永楽銭一枚の痛手で、とにかく死ぬ気がなくなってしまったことだけは事実のようです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "振袖源太",
                "note": "青空文庫"
              }
            },
            {
              "text": "二の腕の関節を永楽銭に打たれて、思わず匕首を取落したところへ、飛込んだ平次、好い塩梅に飛んで来てくれたお染の加勢で、この兇暴な手代もキリキリと縛り上げてしまったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪伝白い鼠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チェッ」　舌打を一つ、袂から取出したのは、その頃通用した永楽銭が一枚です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金色の処女",
                "note": "青空文庫"
              }
            },
            {
              "text": "上下一尺五寸ほどは黒く染めて、上部の黒の中には永楽銭の紋を染め出し、その竿頭には「まねき」と呼ぶ一幅三尺ぐらいな五色の布を虹のごとく吹き流してある。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、従来の永楽銭の紋のほかに、藤の花を巴にした紋を定紋に加えた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
