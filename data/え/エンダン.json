          ],
          "literary": [
            {
              "text": "校長は、しばらく演壇で立往生した。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹く風誘はず、地の上の敷きある屍――空、演壇に立ちあがる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し演壇をあちこち歩き廻ったり、拳固を振りまわす労力はこの外であるのは勿論の事だ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その左に小さな演壇、右手にオーケストラバンド、指揮者と楽手二名だけ見える。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」フ〔ァ〕ゼロ（泣き出しさうになりなが〔ら〕演壇にのぼり、唱ふ）「つめくさの花の　かほる夜は　ポランの広場の　夏まつり　ポランの広場の　夏のまつり　酒くせのわるい　山猫が　黄いろのシャツで出かけてくると　ポランの広場に　雨がふる　ポランの広場に　雨が落ちる」山猫博士（憤然として）「何だ失敬な。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "拍手、コンフェットウ、）葡萄園農夫（演壇に立つ。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして演壇に立って以来鎮まらずにいる熱い血液が、またもや音を立てて皮膚の下を力強く流れるのを感じた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が陳氏に立って敬意を示している間に演壇にはもう次の論士が立っていました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を云うんだったと思ったときはもう演壇に立ってみんなを見下していました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そのあとはもう異教徒席も異派席もしいんとしてしまって誰も演壇に立つものがありませんでした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイドパークの青芝を踏まへて六つの演壇が出来てゐる。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スケート館に大会のあるときは決死隊の一人になって演壇に背中を向けて入口を睨み立ち列んでいる。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　インドの女詩人は順番がやっと来たので勇んで演壇に飛び上ってしゃべり出す弁士のように両眼を輝やかし鞣皮細工のような形の宜い首を前へつき出した。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが偶然にＤといっしょに日本へ来たので、同時に肩を並べて歩き、同じ演壇で講演をした。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは「チベリナ」學士會院（アカデミア、チベリナ）の演壇の、我が上りて詩稾を讀み、又即興詩を吟ずることを許しゝがためなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜日の演壇に立つたことも數次であつたのだ。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "シナリオの作者が何か弁つてゐたが、それがすむと、五人の女優が交々演壇に立つた。",
              "citation": {
                "source": "女流作家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、演壇または青天井の下で山犬のように吠立って憲政擁護を叫ぶ熱弁、若くは建板に水を流すようにあるいは油紙に火を点けたようにペラペラ喋べり立てる達弁ではなかったが、丁度甲州流の戦法のように隙間なく槍の穂尖を揃えてジリジリと平押しに押寄せるというような論鋒は頗る目鮮ましかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子には、父が貴族院の演壇で獅子吼する有様が、何処となく偲ばれた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、本会の秋季大会には、報告できるようになるだろうと思います」　博士は急霰のような拍手を浴びながら演壇を下った。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝野の学界の名士新聞記者は演壇の両側にいならんでいた。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "――実際、僕たちの仕事が、工場の中へ、中へと沈んで行って、見えなくなってしまわなければならなかったのに、それを演壇の上にかけのぼって、諸君は！",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "演壇の左側には、払下げをうけた、古ぼけた旧式な鉄砲が三挺組合せて飾ってある。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "演壇には「Ｓ相互扶助会」発会式の順序と、その両側に少し離して、この会が主旨とする所の標語が貼り出されていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　七之助が演壇の方を顎でしゃくった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも武田らしく演壇に、兵隊人形のように直立して、演説でもするように、固ッ苦しい声で始めた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "健は始めて「演壇」に上がった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "伴の女房も演壇に立った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　警官が長靴をドカッドカッとさせて、演壇に駆け上った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "素早く武藤は演壇を楯に向い合うと、組合員が総立ちになっている中へ飛びこんでしまった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
