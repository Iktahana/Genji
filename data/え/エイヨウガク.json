[
  {
    "uuid": "e61755bc-d7d1-5214-977e-04a6504b0c0c",
    "entry": "栄養学",
    "reading": {
      "primary": "えいようがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
