        "examples": {
          "standard": [
            {
              "text": "駅前通りはイルミネーションで飾られ、すっかりクリスマスムードだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "朝のラッシュ時は、駅前通りが人でごった返している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "自転車で駅前通りを走っていたら、突然飛び出してきた車に驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは、とぎれ、とぎれに、遠く、駅前通りの方にまでつゞいていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は若い二人を駅前通りまで案内しながら、二度とあんなところへ夜行ってはいけませんよ、と注意してあげました。",
              "citation": {
                "source": "私の飼った犬",
                "author": "斎藤弘吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　日進堂というのは、駅前通りから曾根少佐の家の方にまがる角の本屋なのである。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
