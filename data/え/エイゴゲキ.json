        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「文化祭の英語劇で主役に選ばれちゃって、今からセリフを覚えるのが憂鬱だよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "去年の英語劇は演出が凝っていて、英語が分からない観客からも大絶賛されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おい、今のセリフ、もっと感情を込めて言わないと英語劇としての魅力が半減しちゃうぞ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は英語劇の練習を通じて、人前で話す度胸と正しいアクセントを身につけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「――じゃ、小山に入ってもらうか」　英語劇「ジュリアス・シーザー」――それが近づく学芸会に、女学部三年が出すプログラムだった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいぶむかしのことですが、高等学校で、シェークスピアの『アントニーとクレオパトラ』の英語劇を演ったとき、わたしはクレオパトラを演じまして全校を悩殺したことがあるんだから、そういうほうには少々心得があるのです。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時、芝居の方では學生演劇などで僕の方が一足先に多少經驗濟みだつたが、遊び半分の英語劇などでは滿足出來ない程氣持だけは深入りしてゐたので、早速彼と一緒に小さなグループを作つて本腰に芝居の勉強を始めたわけである。",
              "citation": {
                "source": "芥川比呂志",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語劇『アドリアの海』の背景ということで、頼み手は、のちに田子一民氏の夫人となった福岡易之助君の姉さんである。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
