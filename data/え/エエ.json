[
  {
    "uuid": "3d5c3891-5b3c-5990-ae96-ac6c745c1432",
    "entry": "ええ",
    "reading": {
      "primary": "ええ",
      "alternatives": [
        "えー",
        "えーー",
        "えーっ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "感動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "yes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「明日のパーティーに来てくれますか？」「ええ、喜んで参加させていただきます。」",
              "source": "幻辞"
            },
            {
              "text": "友人が質問を投げかけたとき、彼は「ええ、その通りです」と同意した。",
              "source": "幻辞"
            },
            {
              "text": "「このプロジェクトは成功しましたね」「ええ、チーム全員の協力のおかげです。」",
              "source": "幻辞"
            },
            {
              "text": "相手の意見に対して、「ええ、確かにそうですね」と返事をした。",
              "source": "幻辞"
            },
            {
              "text": "祖母に誘われて、孫は「ええ、一緒に行きます」と答えた。",
              "source": "幻辞"
            },
            {
              "text": "疑問が生じたとき、彼は「ええ？」と首をかしげた。",
              "source": "幻辞"
            },
            {
              "text": "不意の知らせに、彼女は「ええ、本当ですか？」と驚いて尋ねた。",
              "source": "幻辞"
            },
            {
              "text": "背後から呼ばれたとき、「ええ？」という声が聞こえた。",
              "source": "幻辞"
            },
            {
              "text": "考えをまとめるために、彼は「ええ、つまり...」と言葉を継いだ。",
              "source": "幻辞"
            },
            {
              "text": "先生の説明の最中、生徒は「ええ、分かりました」と理解を示した。",
              "source": "幻辞"
            },
            {
              "text": "会議中に意見を求められて、部長は「ええ、良い提案だと思います」と述べた。",
              "source": "幻辞"
            },
            {
              "text": "突然の訃報に、遺族は「ええ？」と信じられない顔をした。",
              "source": "幻辞"
            },
            {
              "text": "長年の友人に再会したとき、「ええ、懐かしい」とつぶやいた。",
              "source": "幻辞"
            },
            {
              "text": "医者の診察台で、患者は「ええ、分かりました」と医師の指示に従った。",
              "source": "幻辞"
            },
            {
              "text": "理不尽な要求に対して、彼は「ええ？」と疑問を呈した。",
              "source": "幻辞"
            },
            {
              "text": "恋人からプロポーズされて、彼女は涙を流しながら「ええ、はい」と答えた。",
              "source": "幻辞"
            },
            {
              "text": "「今日は疲れましたね」という同僚の言葉に、「ええ、本当に疲れた」と同意した。",
              "source": "幻辞"
            },
            {
              "text": "不意の電話に、彼は「ええ、どちらさまですか？」と戸惑いながら聞いた。",
              "source": "幻辞"
            },
            {
              "text": "レストランで食事中に、友人が「このデザートおいしいね」と言うと、「ええ、本当だ」と同意した。",
              "source": "幻辞"
            },
            {
              "text": "親戚の話を聞きながら、叔父は「ええ、そんなことがあったのか」と興味深く聞いていた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私が枡に足を蹈み込んだばかりに、肥つた四十年配の女が二人、飛び込んで来て、「ああよかつた、端ッこでもあつてこそよございました、もう五分早ければよございました、惜しいことをしました、私は今朝から一服もしません、ええでも一幕見てから一服することにいたしませう」なぞと、イキセキ切つて云ふのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の肥つた女達は、私のや私の前の男のネクタイを見ながら、「まあ勉強しますわねえ、八十銭であんな物まで附けるのですものねえ……ええェ」と云つた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、よっぽどまえからと囁いた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、好きですよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘さんは私の背後で床の間を拭きながら、ええ、惡くなつた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、でも、」上の姉さんは伏目になって、「決してお気になさらないで下さい。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、もう、長いんですの。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、それよりも、」私は、國民新聞を取り出して「ここに、ちよつといいことが出てゐます。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、さうです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、知らなかつたの？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、兎には違ひありませんが、私は男の藥賣りです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、もう三十何年間、この邊をかうして賣り歩いてゐます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、それはね、このひとのおかみさんよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、おそろしかつたわ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、とても優しい、いいかたよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、さうですとも、さうですとも、私はどうせ、慾張りですからね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、かまひません。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで俺は、ええっと、どうしたらいいかな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それええだ、おらお蘭さ嫁に貰うべえ」　お蘭は呆れた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には自分で腑甲斐無いと思えば思うほど「ええ、何もかもおしまいだ、姫と駆落でもしてしまおう」こんな反動的な情火がむらむらと起るので、自分ながら危なくて仕様がありません。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷と後光宮澤賢治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）苹果-------------------------------------------------------「ええ。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さん、七五郎さんよ」　七五郎、表から覗いて、　「とっつあん、留守か」　「え、おはいんなさいよ」　「大変だったッてねお静坊、吃驚しただろう」　「ええ、とても怖かったわ」　石松、奥より出て来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「ええ」　お半、泌々言う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お静に、　「石松、今日もまだ帰って来ねえのか」　「ええ、まだよ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お静が、　「今日は」　「姐さん、石松つあん未だ帰って来ねえのか」　「ええ、まだですの」　「おや七五郎？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「義姉さんによろしくね」　「うん、閑になったらお前も一度清水へ遊びにおいでよ」　「ええ、きっと行くわ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ええ、それがお互のおっ母さんだというわけですね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "粋な銀座の裏街のホテルの一室で――ええ、そうよ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、ありましたわ。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、盲膓の方はどうしてもなさらなきやいけないの。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
