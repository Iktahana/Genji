          "literary": [
            {
              "text": "女に云うて肯く程なら、遠くから影を見ても、上衣の熊の毛まですくすく立つお前んに、誰、誰が頼む、考えんかい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんばん、宮中のえんかいに、君を招待するのは、大いによろこばしいことです。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ降参しねえんかい？",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえさんもスナオに考えんかい。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
