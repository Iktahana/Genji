          ],
          "literary": [
            {
              "text": "私は山岸の永年の苦惱を、そのやうなところに在ると解してゐる。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "シバヤナギ、タチヤナギ、いろいろな名があろう、幹の皮は、皺だらけで、永年洗い落したことのない垢……青苔が、厚くこびり粘いている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの種の観測事業は一年や二年で完了するものでなく、永年にわたって極めて持久的に系統的に行ってはじめて効果をあげることが出来るものであろう。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小そのが永年の辛苦で一通りの財産も出来、座敷の勤めも自由な選択が許されるようになった十年ほど前から、何となく健康で常識的な生活を望むようになった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「折角の学問の才を切れ端にして使い散らさないように――」　と始終忠告していた父が、その実意からしても死ぬ少し前、主人を養子に引取って永年苦心の蒐集品と、助手の私を主人に譲ったのは道理である。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんは永年お民さんをかわいがって御いでですから、お民さんの気質は解って居りましょう。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論昔のことでありますから、『万葉集』にしても寛永年間に刊行された版本を見ただけであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その猫背は彼が永年盆や膳を削って来た刳物台のせいである。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "デエコン煮えたかア――」と怒鳴る船乗の声は、永年波と風と、海の広さを相手として鍛えられたおかげで、立派に押えの利いた甲張りになっている。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、従来永年この農場の差配を担任していた監督の吉川氏が、諸君の境遇も知悉し、周囲の事情にも明らかなことですから、幾年かの間氏をわずらわして（もとより一組合員の資格をもって）実務に当たってもらうのがいちばんいいかと私は思っています。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永年の交際において、私は氏がその任務をはずかしめるような人ではないと信じますから一言します。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様は早速人夫頭を呼んで言いますには、「全く掛け声しないのも永年の習慣で気が済むまい。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただただ永年夜食として食べ慣れたどぜう汁と飯一椀、わしはこれを摂らんと冬のひと夜を凌ぎ兼ねます。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ多少の欠点（旧人から見れば新人はみな欠点を持っている）には眼をつむって、大いにほめてやることが、彼を自信づけ、彼が永年胸にためていたものを、遠慮なく吐き出させることになるのだ。",
              "citation": {
                "source": "文学的饒舌",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、永年科白で苦労していい加減科白に嫌気がさしていたので、小説では会話をすくなくした。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり照枝と松本はなんぞあったんやと、永年想いまどうて来たいまわしい考えが、松本の顔を見たいま、疑う余地もなくはっきりしていた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、追い出して、新しく若い細君を貰うには、さすがに永年つれそうて来た真紀子には未練があった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "北國の雪解の時分と來たら、全て眼に入るものに、恰で永年牢屋にぶち込まれた囚人が、急に放たれて自由の體となツたといふ趣が見える。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "この菜の花の平野に囲まれた清艶な小都市に、復一は滞在して、いろいろ専門学上の参考になる実地の経験を得たが、特に彼の心に響いたものは、この郡山の金魚は寛永年間にすでに新種を拵えかけていて、以後しばしば秀逸の魚を出しかけた気配が記録によって覗えることである。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、すべてを過去の罪障のなす業と諦めた病主人は、罪障消滅のためにも、一つは永年の恩義に酬ゆるため、妻を失ってしばらく鰥暮しでいた鼈四郎の父へ、せめて身の周りの世話でもさせたいと、娘を父の寺へ上せて身罷ったという。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子が生れてすぐ死に、二番目の規矩男が生れたときは、父親は既にまったく老境に入って、しかも、永年の飲酒生活の結果は、耄けて偏屈にさえなっていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノーウエーとの永年の不和が、とうとう爆発したのです。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃ安永年間にできたもんだ。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに徳兵衛の貧乏いよいよ迫り、ことしの暮は夜逃げの他に才覚つかず、しのびしのび諸道具売払うを、町内の顔役たちが目ざとく見つけ、永年のよしみ、捨て置けず、それとなく徳兵衛に様子を聞けば、わずか七、八十両の借金に首がまわらず夜逃げの覚悟と泣きながら言う。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の講義はどれもこれも新鮮で、自分の永年の志望も、ここへ来て、やっとかなえてもらえたような気がしている。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来、藩にてはこの方針を襲ひ、鋭意植林に努めた結果、寛永年間にはいはゆる屏風樹林の成木を見て、またこれに依つて耕地八千三百余町歩の開墾を見るに到つた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "永年連添う間には、何家でも夫婦の間に晴天和風ばかりは無い。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我之を繙どきてさながら永年相見ざりし骨肉の兄に逢ひたる様の心地したり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから応永年間も地震の多い年で、約八十回にわたる記録が見える。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
