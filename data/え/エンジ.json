[
  {
    "uuid": "b6387f4d-d591-5981-90e4-fe099402326f",
    "entry": "園児",
    "reading": {
      "primary": "えんじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "kindergarten pupil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "運動会で、園児たちが一生懸命走る姿に大きな拍手が送られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "先生は、園児一人ひとりの個性を尊重しながら、丁寧に指導していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "入園説明会には、多くの親御さんと園児たちが参加し、賑わいを見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "台頭する低価格ソフトは「パーソナルコンピューターを一億人の必需品に変える」と吼えた　新宿の雑踏に紛れ込んだ田舎者を見つけるのは、幼稚園児の列に加わったジャイアント馬場を発見するよりたやすいことだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの小説の作者が、感化院の園児の脱走という、最も特徴的な、心理的な生活の面を、もっと慎重に突き入って注目しなかったことを残念に思うのである。",
              "citation": {
                "source": "作品のテーマと人生のテーマ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人患者の場合は、記憶喪失とともに子供にかえり（彼女は二十五であった）幼稚園児童のように折紙細工をしたり童謡をうたったりしていたそうだ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「保護観察」というのは、之も亦刑法上の問題であって、幼稚園の園児や小学校の児童に就いての規定だと思ってはならない。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいい園児を相手にして、ムカシ、ムカシ、サルトカニガ……とやっているうちに、話をすることに興味と自信が出来て、とうとう本職になってしまったのだ。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後のこの時間には、園児たちはすでに自宅へ帰っていた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐人の阿魔なんぞに惚れられやあがって、この合の子め、手前、何だとか、彼だとかいうけれどな、南京に惚れられたもんだから、それで支那の介抱をしたり、贔負をしたりして、内幕を知っててもいわねえんじゃあねえか。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のする方が、かえって目方が揃うくらい、大病だって何だって、そんな覚束ない薬で快くなろうとは思えんじゃありませんか。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニュウグランド・ホテルの前を通って、陽の眩ゆい草原の道を真直ぐに進みながら、小さい兄妹はえんじ色にうれた野苺を見つけて、わざと草深い中を歩きながら両手にあまるほど苺を摘んだ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生、そ、それですがお夏さんの団扇じゃあ恐しく胆が※えました、理窟はねえんです、いえ、理窟がねえんじゃあございませんや、けれどもその理窟は分りません。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしがもらって上げます』とも言えんじゃないか。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、わざわざでけえ音をたてるこたあねえんじゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらだんなが変わり者だからって、あれじゃまだせいぜい九つか十ぐれえにしかならねえんじゃねえですか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにひらひらやっている干し物を、ようみろい、けいこ着、下じゅばん、どれもこれも男物ばかりで、女物はなにひとつ見えんじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、それじゃ、せっかく今までご恩をうけただんなに合わす顔がねえんじゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれがお出ましになったとなると、このとおりぞうさがねえんだから、たわいがねえじゃないか」「だって、こりゃ、松の木がへいぎわにはえている白壁のお屋敷というだけのことで、なにもまだ目鼻はつかねえんじゃござんせんか」「だから、おめえはいつまでたってもあいきょう者だっていうんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、まだ話を中途まで聞いただけで、この女がどうしてまたあんなだいそれたまねをしやがったか、それさえわからねえんじゃござんせんか」「血のめぐりのおそいやつだな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなもの、なにもありがてえ傷あとでもなんでもねえんじゃごわせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊ぶとなりゃ、あっしだって、顔やがらで遊ぶんじゃねえんです」「そんなら、なにもしり込みするこたあねえんじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "千枝太郎はもとの一人になって、えんじゅの青い影の下に立っていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　だが城之介がえんじない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、備前屋じゃあどさくさまぎれで、まだその事をよく知らねえんじゃねえか」「なに、知らないことがあるもんですか」と、女房は鉄漿の歯をむき出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡奉行様が一揆に殺されたのが弦打村の地境の内だからというて、弦打村から下手人を出せというて、あんまり聞えんじゃないか。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手人を磔にして、御威光を見せれば、ええんじゃ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母ア、黙っとりゃええんじゃ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "南のが引き取りゃそれでええんじゃ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな碌でもない奴は、人目につかん処で死にさらしゃええんじゃ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だって、君は貧乏しているようには見えんじゃないか。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡台の引出しには「菊童」という、さらりとした薄い粉白粉と、しょうえんじがお皿に入れてあった。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えんじゃ、そうして居られん。",
              "citation": {
                "source": "恭三の父",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
