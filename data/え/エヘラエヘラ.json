          ],
          "literary": [
            {
              "text": "かれは、いつもぐにゃぐにゃし、えへらえへらわらっていた。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉平次は、相好を崩しながら、えへらえへらと笑った。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ光線をあてると、野蛮人か文化人か分らぬ様々な顔が、どちらを向いているのでもなく、あぐらをかいてえへらえへらと笑っている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はえへらえへらと、締のない口元に笑った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し次の瞬間、尹さんは先の仰山な用件はけろりと忘れたものか、「学生さん」と急に話題を変え、えへらえへらひょうきんに笑い出すのである。",
              "citation": {
                "source": "荷",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わっしも一つ儲けて城内に家を建てて移らんことにはなあ、ひっひひひ、ひっひひひ」と思うと、そのことはもう忘れ去ったように、今度は淫らなものを見た坊主のごとくひとりえへらえへらと笑い出した。",
              "citation": {
                "source": "尹主事",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "支械軍はますます面白がってえへらえへら笑ったり、口々に脅かしてみたり小突いたりした。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かけあひで惡口を云つて、えへらえへら笑つた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとのんびりとしていたほうがいい」「だって、こんなふしぎな目、おそろしい目にあって、えへらえへらと笑ってもいられないですよ」「とりこし苦労はよくないのさ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそくとも明日の昼ごろまでには、しょっぴいて、いやさおつれ申して帰りますから」　といって、またひとりでえへらえへら笑いながら、「念のために申しあげておきますがね、江戸の洲崎は洲崎の浜などとは言わないんです。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "野伏大名",
                "note": "青空文庫"
              }
            },
            {
              "text": "健は両手をさしのべて、えへらえへら笑った。",
              "citation": {
                "source": "大根の葉",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ひとしきり泣いたのち扶佐子は、急に、えへらえへらと笑いだし、「奥さんをおどかしたのよ。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "小槌屋は、「そうでおまっしゃろなあ」と云って、えへらえへら笑っていたが、幸子は聞いていて厭な気がした。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「馬鹿云いねえ、月謝は出さねえが、これでもちゃんと踊れるから不思議だ」と、大きな団子ッ鼻の孔をひろげて、唇を「へ」の字なりに、えへらえへら笑って見せて、「根が御器用でいらっしゃるからね」「ふん、威張るなよ！",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
