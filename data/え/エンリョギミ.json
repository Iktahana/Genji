          "literary": [
            {
              "text": "」とお桐は幾らか遠慮気味であつた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは当時の編輯者Ｙ君が、特に臨時別冊発行の予定もあつて、十分に枚数をとれと気前をみせてくれた結果であるが、それでゐて、私は、百三十枚の原稿をやゝ遠慮気味で渡したのである。",
              "citation": {
                "source": "「速水女塾」あとがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は遠慮気味に窓から窓へ会釈をかわした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
