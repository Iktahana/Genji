[
  {
    "uuid": "f64c95fa-6ba6-53c2-b638-9c32009f1959",
    "entry": "縁組",
    "reading": {
      "primary": "えんぐみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
