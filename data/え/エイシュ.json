          ],
          "literary": [
            {
              "text": "而して域内の事、また英主の世を御せんことを幸とせずんばあらず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐の昭宗皇帝は英主であったが、晩唐の国勢振わず、この洛陽で叛臣｜朱全忠のために弑せられたのである。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づこの町の全景を見渡すことの出來るやうな稻荷神社の境内へ、土地の誇りとする嘉樂園へ、舊藩の英主龜井公の碑の前へ、中學校、小學校の庭へ、それから舊藩の文武の學校で津和野藩の人材が皆養成されたといふ養老館の跡へ。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "〃　ケイホスロウ――ケイアニイ王朝中興の英主。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐の太宗は古今の英主である。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "去る者は日に疎しといふが、千古の大英主たる明治天皇の御鴻徳のみは、深く我が國民の腦裡に印して、決して忘るることが出來ぬのみか、却つて時を經る儘に、愈※景仰の念を増すばかりである。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギボンは彼を評して「世界併呑の鴻図を懐き偉業未だ成らずして中道にして崩じたる古代の英主の如し」といっておる。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "武は内乱の鎮定であるが、聖は神武の聖徳をつぎ、それにも劣らぬ天下興隆の英主としての聖の字であつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、尾州家は最初のうちは英主が出たが、いけなくなったのは五代｜継友あたりからのこと。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴族政治の時代には、貴族が權力を握る習慣であるから、隋の文帝・唐の太宗の如き英主が出で、制度の上に於ては貴族の權力を認めぬ事にしても、實際の政治には尚其形式が殘つて、政治は貴族との協議體となつた。",
              "citation": {
                "source": "概括的唐宋時代觀",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "中納言家はこの時四十歳であったが、宗武卿以来聡明の血が伝わり、代々英主を出したが、当中納言家もその選に漏れず、聡明にして闊達であり、それが風貌にも現われていて鳳眼隆鼻高雅であった。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰来急に『六国史』を取ってこれを読み、古の聖君英主海外蛮夷を懾服したるの雄略を観て、慨然として曰く、「吾今にして皇国の皇国たる所以を知れり」と。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "武は内乱の鎮定であるが、聖は神武の聖徳をつぎ、それにも劣らぬ天下興隆の英主としての聖の字であった。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに藩主｜鍋島閑叟は英主であったから、時勢を観て、藩学だけでは足りないと早くも気付いた。",
              "citation": {
                "source": "青年の天下",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず考えてみると、欧羅巴でも近頃起った露西亜という如き国は、かの「ピートル」〔ピョートル〕大帝という不世出の英主が出で、西の方｜欧羅巴の文明を導こうとして、あらゆる学術文芸を西の方から露西亜に導き入れたのである。",
              "citation": {
                "source": "学問の独立と東京専門学校の創立",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁抹の生んだ大彫刻家、トルヴァゼンに扮したもの……海水着の美女たちが、豊満な肢体も露に群集の喝采に会釈して行くもの……丁抹中興の英主、クリスチャン五世に扮して、剣を按じたもの……殊に精巧なのは、四番目の仮装であった。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠利その人を心から、英主と仰いでいるのだった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "反英主義的アメリカ人は、一つのスラングを、それが英国起源だと知るや拒絶するようになるだろう。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "反英主義からいきなり英国支持に回るのも結構よく見る。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ、ケルトのナショナリズムは反英主義と同一ではない。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇否定的ナショナリズム一、反英主義。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "反英主義の掌はいつでも裏返せる。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に、あなたの眼前には織田信長様という英主が立っている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "霹靂車一　呉を興した英主孫策を失って、呉は一たん喪色の底に沈んだが、そのため却って、若い孫権を中心に輔佐の人材があつまり、国防内政ともに、いちじるしく強化された。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳凰は、千里を翔けても珠なき樹には棲まずというわれ困じて一方を守り英主にあらねば依らじとし自ら隴畝を耕していささか琴書に心をなぐさめ詩を詠じて鬱を放ち以て天の時を待つ一朝明主に逢うあらば何の遅きことやあらん……　玄徳はそっと階をのぼって、廊の端にたたずんでいた。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も知っている通りに、武蔵はその余生を熊本の城下に送り、当時の英主細川｜忠利に晩節を捧げていた。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
