        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はまるで永遠の旅人のように、世界中を放浪している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その小説の主人公は、失われた故郷を探す永遠の旅人だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「私はただの永遠の旅人さ」と、彼は寂しげに微笑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、各地で出会った人々の物語を収集する永遠の旅人だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "けれども、地に曳く青ざめた影を振返ると、みんなが、淋しい、淋しい永遠の旅人を自覚する。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
