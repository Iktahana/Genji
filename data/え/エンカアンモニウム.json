          "literary": [
            {
              "text": "あるとき、ろしゃ（塩化アンモニウムのべつの名）をつくってみることになりました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "10年ほど後にドイツでヴェーラーはシアン酸銀を塩化アンモニウムと加熱して尿素が得られることを見いだした。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
