        "examples": {
          "standard": [
            {
              "text": "冬の風物詩であるストームグラスの中身は、塩化アンモニウムや樟脳の結晶が温度変化で形を変えるものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔ながらの使い捨てカイロの反応を早める助剤として、塩化アンモニウムが使われていた時期があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "北欧のお菓子「サルミアッキ」の独特の塩気とアンモニア臭は、食用塩化アンモニウムによるものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あるとき、ろしゃ（塩化アンモニウムのべつの名）をつくってみることになりました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "10年ほど後にドイツでヴェーラーはシアン酸銀を塩化アンモニウムと加熱して尿素が得られることを見いだした。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
