          "literary": [
            {
              "text": "同誌のエディトリアル・ディレクター、アーサー・サルスバーグは、アルテアを紹介した号の「ホームコンピューターがやってきた」と題した巻頭言で、アルテア作りを同誌が読者に提案する〈プロジェクト〉と位置づけている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
