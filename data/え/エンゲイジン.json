          "literary": [
            {
              "text": "小説家、評論家、詩人、音楽家、画家、演芸人、舞踊家、編輯者など、雑多な人々の集りで、戦後の日本に新たな世界的文化気運を起すために、過去のすべてを葬ってすべてのものを新たに創造するという、大変な意気込みだそうでした。",
              "citation": {
                "source": "旅だち",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "段々目あきの演芸人が出来た。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            }
          ]
