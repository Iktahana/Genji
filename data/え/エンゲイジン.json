        "examples": {
          "standard": [
            {
              "text": "「彼は幼い頃から演芸に親しみ、将来は演芸人になりたいと思っていた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「テレビで活躍するあの演芸人も、最初は小さな演芸場でキャリアをスタートさせたらしい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ステージに立つ演芸人たちの、観客を惹きつける力は素晴らしい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「「すごい！」と観客がどよめく、ベテラン演芸人の話術には感服した。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "小説家、評論家、詩人、音楽家、画家、演芸人、舞踊家、編輯者など、雑多な人々の集りで、戦後の日本に新たな世界的文化気運を起すために、過去のすべてを葬ってすべてのものを新たに創造するという、大変な意気込みだそうでした。",
              "citation": {
                "source": "旅だち",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "段々目あきの演芸人が出来た。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            }
          ]
        }
