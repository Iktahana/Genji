[
  {
    "uuid": "11f2d1cb-bc6d-50d3-8955-ccff343f9e3c",
    "entry": "円曲",
    "reading": {
      "primary": "えんきょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "roundabout way (of speaking or working)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は直接的な批判を避け、常に円曲な言葉で意図を伝えようとする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この交渉は、相手方の円曲な態度に終始し、なかなか進展しなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "円曲な言い方ばかりでは、かえって相手に不信感を与えかねない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "もとの記憶には産土のわきを円曲に曲がって、両端には青い草がきれいにあざみやたんぽぽの花など咲いていた。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍のものが、あんぽんたんの顔をみいみい、円曲に、母のことに話をむけてゆくと、「心の鬼の角をおりに来て、ざんげなさるのはよいが、後生がようござりますまい。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
