  {
    "uuid": "2a4f7c15-f600-5a8f-b430-5c7dcca472bd",
    "entry": "泳者",
    "reading": {
      "primary": "えいしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "a swimmer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長距離の泳者たちは、一斉にスタートの合図を待っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は大会で最年少の泳者として注目を集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海難事故の際、救助にあたった泳者の勇気ある行動が称賛された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこは荒海で、未熟な水泳者には危険な海だつた。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし百の游泳者や千のランナアを眺めたにしろ、忽ち游泳を覚えたり、ランニングに通じたりするものではない。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずその游泳者は悉く水を飲んでおり、その又ランナアは一人残らず競技場の土にまみれている。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずその游泳者は悉水を飲んでをり、その又ランナアは一人残らず競技場の土にまみれてゐる。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を呑んだ游泳者も涙と笑とを催させるであらう。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に俺は又俺の周圍に、他人の賞讚によつて僅に自信を支へてゐる「弱者」と、媚を先輩に呈することによつて僅にその存在を保つ「寄生蟲」と、斷えず流行の假聲を使ふことによつて漸く文壇を泳いで行く「游泳者」とを見た。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は此等の自己肯定者、デカダン、弱者、游泳者、寄生蟲と自分とを等位に置くことによつて、僅かに俺の中に實現したる「眞理」を辱しめる。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その岩にすがりつきたく、波の上に頭をつき出してるその游泳者に取りつきたく、もしくは自分といっしょにそれをおぼらしてしまいたかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにいる男達全員が、恐ろしい危険を知っており、干満の罠や渦巻きを知っており、潮の偽流も知っており、たとえ凪であっても、普通の泳者は死んでしまうからだ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "短い距離の自由形の泳者としてトレーニングを受けはじめたが、途中でリレーの泳者に希望して転向した。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "放課後、祐一たちを含めてリレーの泳者全員が、いつものようにプールで練習をした。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦に泳いでいる何人もの泳者のあいだを、むこうの縁から彼女は泳いで来た。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
