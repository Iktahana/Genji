        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母の遺品を整理していたら、金泥で四季の花々が描かれた見事な絵扇が出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "能楽の舞台で、演者が手にする華やかな絵扇が照明を浴びてキラキラと輝いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、なんて綺麗な扇子なの！」と、浮世絵が施された絵扇を手にした観光客が声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "床の間に飾られた絵扇は、部屋全体に江戸時代のような情緒を醸し出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "服装は今の身分伯爵夫人に相応しい第二帝政時代風のローブ・ド・ステールで絵扇を持って居る。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三月三十日）『明星』所載落合氏の歌舞姫が底にうつして絵扇の影見てをるよ加茂の河水　この歌は場所明かならず。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ、何でもないのだけれど――」　小さい絵扇で、顔をかくすようにして目をそむけるのだった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
