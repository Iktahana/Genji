      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "courage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は危険を顧みず、鋭気を鼓舞して敵陣に突入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その若者は、不正に対して鋭気を燃やし、立ち上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「大丈夫、私ならできる！」と、鋭気を込めて自分に言い聞かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "暑ければ暑い程鋭気に満ちて来る。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "執事は大助を彼方の一室へ案内し、はたと閉ざして立去りける跡に、大助は多時無事に苦みつ、どうどうとしこを踏みて四壁を動かし、獅子のごとき力声を発して、満腔の鋭気を洩しながら、なお徒然に堪えざりけり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉備高島には、古事記に依れば、八年御滞在になつたとの事であるが、此の地方に、古墳等の遺跡の多いのを考へても、此処を仮の都として、山陽四国地方の経営に当られ、武器を整備し、鋭気を養ふと同時に、大和地方の情勢を偵察されたのではあるまいか。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ――」　と彼は大きく点頭いたが、鷲のやうな感じのする自分の鼻先を鋭気な眼つきで凝と見降すやうに眼蓋を伏せて、「鼾声雷の如しなんていふ自惚れは凡そ現代には通用せん厄病だよ。",
              "citation": {
                "source": "奇友往来",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでは鋭気をやしないながら、飛行島の様子を通じて相手国の出ようをにらんでいなければならぬ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱情的な農民等が、明治維新によって目醒された自由平等の理想に鼓舞されて、延びよう延びようとする鋭気を、事々に「お上」の法によって制せられ、幻滅を感じるが如何うにかして新生活を開拓しようと努めた跡が、ありありと見える。",
              "citation": {
                "source": "蠹魚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし又君の為に然らずとせんか、かの近来の赤大根は君の小説に感奮し、君の評論に蹶起したる新鋭気鋭の青年にあらずや。",
              "citation": {
                "source": "八宝飯",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして、古今集の歌風は、宇多の趣味・醍醐の鋭気に保護せられて、奈良以来の旧貴族階級の歌風を圧倒した。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "点検が済んだら、すべからく寝て鋭気を養うべしだ」言いつつ菓子皿に残れるカステーラの一片を頬ばり「むむ、少し……甲板に出ておると……腹が減るには驚く。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのときには、しばしば英国全艦隊がこの港内に集結して鋭気を養っていたそうで、すでに試験ずみの安全港であるそうな。",
              "citation": {
                "source": "沈没男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に存八をあしらう時に鋭気が一段と光り発するようである。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地震津浪は途方もない大きいものであったから、三陸沖鯰は百年くらいは休養して鋭気を養うだろうとたかをくくっていると、意外にもわずか三十七年後の昭和八年三月三日ほぼ同じ地点からほぼ同じ程度の大地震大津浪が起こり、約三千人の溺死者を生じた。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに諸君が今日大いに活動を始め、党勢拡張もしくは種々の規則の改正、また先刻の討論を聴いても甚だ鋭気｜勃々たる有様を見て、私は喜びに堪えぬのである。",
              "citation": {
                "source": "〔憲政本党〕総理退任の辞",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、剣術本来の第一精神があらぬ方へ韜晦された風があり、武芸者達も老年に及んで鋭気が衰えれば家庭的な韜晦もしたくなろうし、剣の用法も次第に形式主義に走って、本来殺伐、あくまで必殺の剣が、何か悟道的な円熟を目的とするかのような変化を見せたのであろうと思われる。",
              "citation": {
                "source": "青春論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭気衰えて『五輪書』などは下の下である。",
              "citation": {
                "source": "青春論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでにじゅうぶん鋭気をやしなっておかねばなりません。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日、二十七日は、まだまだ鋭気もあったが五十日、六十日となると、肉は落ち、眼は澄み、皮膚は垢を持ちながら蝋のように白くのみあった。",
              "citation": {
                "source": "剣の四君子",
                "author": "林崎甚助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さッ、来い」　返り血に染まった伝吉は、いよいよ鋭気を増して、辻堂を後ろに、五人の穂芒を前に受けた――と、密かに、辻堂の縁を廻ってきた舞鶴の新造は、一段高い足場から、卑怯な欺斬り――前の敵に気を奪われている伝吉の脳天を狙って、音もさせずに大脇差をふりかぶった。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駈け崩された諸隊の兵も、光秀先陣に立てりと聞けば、ふたたび結集して鋭気を取り戻そう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "気負う鋭気を危ぶむかのように熟慮の眼をふさいだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "何せよ、秀吉に続く数多の将士が、秀吉におくれじと、また、余人に先は譲らじと、鋭気を競い、先を争うて急ぐこと、戦国の日、諸所に大小の合戦は繰り返されたが、まだかつて今日ほど、その先争いの烈しかったことはなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝助はそれへ向って、その鋭気を挫くような音声で云った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはわが旅人の鋭気の盛り、北の世の中の極端に悪いころであって、いろいろと心を動かす話があるのだが省略する。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "七本松の黒々とわだかまった闇の蔭にシーッと息をこらしているかのような氷刃の鋭気。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことから、もし倒幕の鋭気がくじけるようなことにでもなっては、一天のおんために、また悪政の釜中にあえいでいる下々のためにも、悲しむべきことといわねばならぬ」　こういう意味のことは、さっきから密議のうちにもたびたび聞いた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "後陣の呂布は、「何たるざまだ」と、激怒して、「戦の第一に、全軍の鋭気をくじいた罪は浅くない」と、李粛を斬ってしまった。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭気や若さはありますが、財力、軍の結束などまだ足りません」「やめろというのか」「勅を拝して、今さら命に背けば、異心ありとみなされます」「では、どうする？",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――で、楊大将の考えとしては、皇帝の眷族と、本軍の大部分を水害地区の外にうつし、ひとつに兵糧持久の策とし、二つには目前の敵の鋭気を避け、遠征軍には苦手な冬季を越える覚悟で、時々奇襲戦術をもって酬い、おもむろに事態の変化を待とうというのである。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがバラを害する以上は、あなたがつかまへるつかまへないは、あなたの幸福にえいきようするのですよ。",
              "citation": {
                "source": "かたつむり",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ、たまには、これくらいの苦しい経験をするほうが身の薬だと喜ぶようにさえいきいきとしていました。",
              "citation": {
                "source": "台風の子",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
