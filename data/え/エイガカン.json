          ],
          "literary": [
            {
              "text": "私にしても、心の弱っている時に、ふらと映画館に吸い込まれる。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をしても不安でならぬ時には、映画館へ飛び込むと、少しホッとする。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画館の一隅に坐っている数刻だけは、全く世間と離れている。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年前、千葉県船橋の映画館で「新佐渡情話」という時代劇を見たが、ひどく泣いた。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が映画館へ行く時は、よっぽど疲れている時である。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神明館（字は違ふかも知れない）といふ映画館があつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　一と頃、学生の観客の多い映画館で、ニュース映画の中にたまたまソビエトの赤旗の行列などがスクリーンに現われると、観客席の暗闇から盛んな拍手が起るのであった。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような実例の小規模なものは従来小さな映画館の火事の場合に記録されている。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画館の火事でそういう実例がたびたびあった。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱帯魚を見物したあとで、とある映画館へはいった。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような神経の異常を治療するのにいちばん手軽な方法は、講演会場から車を飛ばしてどこかの常設映画館に入場することである。",
              "citation": {
                "source": "映画と生理",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベナレスの聖地で難行苦行を生涯の唯一の仕事としている信徒を、映画館から映画館、歌舞伎から百貨店と、享楽のみをあさり歩く現代文明国の士女と対照してみるのもおもしろいことである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに抽象的で特殊な少数の観客だけにしか評価されないようなものは結局映画館と撮影所とを閉鎖の運命に導く役目しか勤めない。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オフィス、デパート、工場、映画館、はだかレヴュウ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三条河原町一　学生たちがセンター（中心）と言っている三条河原町に夜がするすると落ちて来ると、もとの京宝劇場の、進駐軍専用映画館の、「ＫＹＯＴＯ　ＴＨＥＡＴＥＲ」の電飾文字の灯りが、ピンク、ブルー、レモンイエローの三色に点滅して、河原町の夜空に瞬きはじめる。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある映画館の前まで来ると、小郷はいきなり足を停めた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小郷は何思ったのか、「おい、はいろう」　君勇をうながして、その映画館の中へふらふらとはいって行った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　小郷が望月三郎のアトラクションの掛っているその映画館へはいったのは、むろん嫉妬から出た自虐的な好奇心だった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな歌うたいだろう」　という好奇心で、その映画館へはいることは、むろん小郷にとっては辛いことだった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の機嫌を取るために、映画館へ女を誘うというような、そんな青ッちょろい人間ではなかったのだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな彼が、嫉妬からとはいいながら、映画館の暗がりの中で、ぽかんと坐っていなければならないとは……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨二十二日午後二時ごろ左京区下鴨××町実業家小郷虎吉氏は京極の映画館××館の公衆電話のなかで、何者かの手で心臓部へ鋭利な刃物を突き刺されて苦悶中を発見、最寄りの××病院へかつぎ込んで手当を加えたが、二時三十分落命した。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小郷が京極の映画館で殺されたことと、鶴雄が警察へ呼び出されたこと――両者の間には、何か密接な関係があるに違いない。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "京極の映画館の電話室で、小郷が殺されているのを、一番さきに見つけたのは、君勇だった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小郷は君勇と二人で映画館へはいったのでしょう。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小郷と映画館へはいった時、誰が金を払った？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あてが払いました」「映画館へ行く前プルニエへ行ったんだろう」「へえ」「その金は……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ふと小郷事件のあった映画館を見て置こうと思って、四条通りから花遊小路の中へはいって行った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画館の中へもつけて行って、小郷が電話室へはいったところを、やったんですね」「へえ……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
