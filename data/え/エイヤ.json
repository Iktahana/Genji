        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "綱引きの試合で、チームメンバーが「えいや」と気合を入れながらロープを引いた。",
              "source": "幻辞"
            },
            {
              "text": "水に飛び込む際、少年は思い切って「えいや」と叫んで飛び込んだ。",
              "source": "幻辞"
            },
            {
              "text": "重い荷物を持ち上げるとき、彼は「えいや」と掛け声を出して力を込めた。",
              "source": "幻辞"
            },
            {
              "text": "決断の瞬間、彼女は「えいや」とつぶやいて一歩を踏み出した。",
              "source": "幻辞"
            },
            {
              "text": "体操の大会で、選手が着地の際に「えいや」と気合を入れた。",
              "source": "幻辞"
            },
            {
              "text": "力仕事をする職人たちは、慣習的に「えいや」という掛け声を使う。",
              "source": "幻辞"
            },
            {
              "text": "難しい問題に取り組むとき、彼は心の中で「えいや」と言い聞かせた。",
              "source": "幻辞"
            },
            {
              "text": "怖い場面では、子どもたちが勇気を出して「えいや」と言いながら進んだ。",
              "source": "幻辞"
            },
            {
              "text": "引っ越しで大きなソファを運ぶ際、「えいや」という掛け声が何度も聞こえた。",
              "source": "幻辞"
            },
            {
              "text": "木から飛び降りるとき、少年は「えいや」と飛び込んだ。",
              "source": "幻辞"
            },
            {
              "text": "新しい仕事に挑戦する決意を示すために、彼は「えいや」とつぶやいた。",
              "source": "幻辞"
            },
            {
              "text": "団体競技で、チーム全員が「えいや」と掛け声をかけながら動いた。",
              "source": "幻辞"
            },
            {
              "text": "困難な状況を乗り切るため、彼女は「えいや」と気合を入れ直した。",
              "source": "幻辞"
            },
            {
              "text": "高いところから飛び降りるスポーツで、選手たちは「えいや」と掛け声をした。",
              "source": "幻辞"
            },
            {
              "text": "達成が困難な目標に向かって、彼は「えいや」と決意を新たにした。",
              "source": "幻辞"
            },
            {
              "text": "体力的に限界を感じながらも、ランナーは「えいや」と言い聞かせて走り続けた。",
              "source": "幻辞"
            },
            {
              "text": "新しい道を切り開く覚悟で、起業家は「えいや」と言い放った。",
              "source": "幻辞"
            },
            {
              "text": "痛い治療に耐えるため、患者は「えいや」と歯を食いしばった。",
              "source": "幻辞"
            },
            {
              "text": "高さ100メートルのジップラインに乗る直前、観光客は「えいや」と勇気を出した。",
              "source": "幻辞"
            },
            {
              "text": "人生の大きな決断を下すとき、主人公は一呼吸置いて「えいや」と決めた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "正月の何日頃であったか、表の呉縁に朝日が暖くさしてる所で、自分が一人遊んで居ると、姉が雑巾がけに来て「坊やはねえやが居なくても姉さんが可愛がってあげるからね」と云ったら「ねえやなんか居なくたってえいや」と云ってたけれど、目には涙を溜めてたそうである。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は自分を見るや泣き声を絞って、何だってもう浮いていたんですものどうしてえいやらわからないけれど、隣の人が藁火であたためなければっていうもんですから、これで生き返るでしょうか……。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに汚いところじゃって、のんびり手足を伸せる方がなんぼえいやら知れん。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理学者はたとえいやいやながらでもこの例にならわなければならない。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目見て死ぬほど惚れて、二度目には顔を見るさえいやになる、そんな情熱こそはほんとうに高雅な情熱だって書かれていたわねえ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と叱言を言いながら、岸へ来たのを拾おう、と私、えいやっと蹲んだが。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巳之助は人力車のながえにつながれた綱を肩にかついで、夏の入陽のじりじり照りつける道を、えいやえいやと走った。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな、薄汚い新聞記者と、喧嘩させて、だまって面白がって見ていやがって、僕は、あんなやつとは、口きくのさえいやなんだぜ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "えいや、ほう、ぽん、えいや、こころばかりで敲つのやら。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌青銭の穴あき銭をかなしよと父のみ前に貫きて数へつ魚市魚市は師走の市、歳のすゑ、大つごもり前の三日、雪よ霰ふる中を、塩鰤や、我が家の市、競り市や、魚市場、戦や、船に馬に大八車、わさりこ、えいやえいや、かららよ、えいやえいや、人だかりわらわら、はいよ、天秤、担棒、走る走る、えや肩掻きわけて。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお書き続けていっていくつかの節目を迎えたとして、原稿の終わりに「えいやっ」とエピローグを置く踏ん切りが、自分で付けられたかどうか。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでＰＣの流れとＵＮＩＸワークステーションをえいやとくっつけて、「これが次世代のふたまた標準だ」と称して迫力を出そうというのが、今回のＡＣＥ構想である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来なら赤ペン片手にある種の決意をもって「えいやっ」と直しを書き入れていたものが、キーボードの操作で跡を残さず変えられるとなって、変更に対する精神的な縛りが一挙に弱まった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし餅はきらい」「それじゃおとよさん、明後日は家へおいでなさいよ」「それだら省さんがお隣へ餅をたべにいっておとよさんが家へ鮓をたべにくるとえいや」　こういうのはおはまだ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女の前でよその女をほめるのは、ちっと失敬なわけだけど、えいやねい、おはまさん、おはまさんはおとよさんびいきだからねい」　おはまはわきを見て相手にならない。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱い母は、「そんならお前のすきにするがえいや」「ウム立派に剛情を張りとおせ。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "表面の事なんかどうでもえいや、つまらん事から無造作に料簡を動かして、出たり引っこんだりするのか淫奔の親方だよ。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなに花をたくさんとっちゃいかんじゃないか」「えいやね、東京では花だってかってにゃとれないだろう。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は自分を見るや泣聲を絞つて、何だつてもう浮いてゐたんですもの、どうしてえいやら判らないけれど、隣の人が藁火で暖めなければつて云ふもんですから、これで生き返へるでせうか………………。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の引出しさ三つ取ってあらあ、こりで五つだ姉さん、お母さんに拵えてやるとえいや」　どれと姉が手にとるが否や、国吉は再び背戸の方へ飛び出してしまった。",
              "citation": {
                "source": "新万葉物語",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "えいやい休みだから」　お政はそこをおりていったが、裏のほうからすぐ長女の七つになるのを連れてきた。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はしかたがなく、「まあえいや、そんなことあとの話にしよう、えいや花前」「保証人がなくていけなければ帰ります」「いや、帰られてはこまる、えいから花前やってくれや、じゃこうしよう、おれが保証人になることにしよう、だからやってくれや」　細君は、目をぱちつかせて主人の顔を見る。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お牢屋同心てえいや、伝馬町の囚罪人を預かっていらっしゃるやかましい役がらなんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "一両二分ってえいや、江戸じゅう乗りまわされるくれえの高なんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
