        "examples": {
          "standard": [
            {
              "text": "効果的な英語学習のためには、インプットとアウトプットのバランスが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最近は、YouTubeなどの無料リソースを使った英語学習が人気を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "留学は、集中的な英語学習には最適な環境だが、費用もかかるからよく検討する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供向けの英語学習アプリは、ゲーム感覚で単語やフレーズを覚えられるように工夫されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "例へば、英語ならば「英米人のやうに」書ける、喋れるといふことが、英語学習の理想であつた。",
              "citation": {
                "source": "外国語教育",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
