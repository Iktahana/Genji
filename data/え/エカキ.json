    "definitions": [
      {
        "index": 1,
        "gloss": "painter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供の頃から夢だった、プロの絵かきになるために専門学校に通い始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの美術館には、有名な絵かきの作品が多数展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は独特の世界観を持つ新進気鋭の絵かきとして注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "旅先で出会った地元の絵かきに、一枚の風景画を依頼した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "幕があくと舞台は銀座街頭の場面だそうで、とあるバーの前に似顔絵かきと靴磨き二人と夕刊売りの少女が居る。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか道灌山へ夏目先生と二人で散歩に行った時、そこの崖の上で下の平野を写生していた素人絵かきがあった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外の絵かきもやっているでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくこの辺では私のような素人絵かきはあまりに珍しくなさ過ぎるのかもしれない。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生はただ美しいとばかりで不注意に見過ごしている秋の森の複雑な色の諧調は全く臆病な素人絵かきを途方にくれさせる。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それでもわたしは絵かきです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの本は、月が絵かきに物語る話という形を取ってはいるものの、その特徴とするところは絵画の素材を与えるための、眼まぐるしいばかりの場面の展開にあるのではない。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、偉い絵かきだから、君の顔を、そのまま、いつでも画いて見せることができる。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男か、女か、その区別さえわからないようで、そんな工合で、偉い絵かきとは、言えまい。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は油絵かきにならなかつたのを悔んだ。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいう絵をかく絵かきは、しかし、ある意味でえらいと思う。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の絵かきは自然や人間の天然の姿を洞察することにおいて常人の水準以上に卓越することを理想としていたらしく見える。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲームで遊ぶやつや音楽、お絵かきに使うやつも出た。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたゝかく、風のない朝、十時時分、僕は蜜柑山の芝のスロウプに腰かけて、海を眺めてゐると、絵かきの朝居閑太郎が、僕の妻に案内されて、僕の前に立ち、情熱のこもつた息苦し気な調子で、そして対者に遠慮する微笑を浮べて「エカキが――」と云つた。",
              "citation": {
                "source": "朝居の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑太郎、君は純粋な絵かきだ。",
              "citation": {
                "source": "朝居の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その女というのは絵かきでしょうね」と、亀吉は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうで偽物をこしらえるのだから、絵かきも味方に入れなけりゃあならねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "男というのは絵馬屋の亭主で、女は出入りの絵かきだろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の絵かきで、年ごろも人相も判っているのだから、すぐに知れましょう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから如才もあるめえが、大津屋を調べるついでに、女の絵かきの探索も頼むぜ」と、云いかけて半七は急に又笑い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大津屋へ出入りの女絵かきは、孤芳という号を付けている女で、年は二十三四、容貌もまんざらで無く、まだ独身で、新宿の閻魔さまのそばに世帯を持っているそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷹の絵は女絵かきの孤芳にかかせましたが、その絵といい、絵馬の木地といい、よっぽど上手に出来ていたと見えて、丸多も見ごとに一杯食わされてしまったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家は大津屋の家作で、この頃は女絵かきの孤芳が引っ越して来ていることを、亀吉ももう承知していましたから、さてこそ案の通りというので、これもすぐにわたくしの所へ注進に来ました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「通りかゝりの子供がね、おや／＼この絵かきは空に魚なんぞ描いてゐやがる――なんて冷かすので気づくと……」「睡眠不足ぢやないのか？",
              "citation": {
                "source": "サンニー・サイド・ハウス",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ひかへれば、絵かきの絵らしさといふものが、ひとつの夾雑物として邪魔をする。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵かきの中にも看板絵書き、職人的絵書きと呼ばれる、事物の描き方が世俗的な常識的世界を一歩も出ない人々が少くないこれらの職人的画家達の批評家としては、職人的美術批評家の存在はゆるされるだらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家はまた斯う弁解するであらう、絵かきといふものはさう連続的に絵ができるものではない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "『触手ある風景』は絵かきを驚ろかすことができるが文学者には首をひねらす絵である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何故一般人に大観の絵が何故よいかといふ質問を発した場合に絵かきに問ひを発した場合よりハッキリと『解らない、たゞ何となくよい』と答へるだらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの絵に対する熱心だけから言うと、絵かきになるためには充分すぎるほどなのだが、それだけの才能があるかどうかという事になると判断のしようが無くなる。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
