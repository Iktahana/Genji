[
  {
    "uuid": "d197d240-fba4-5035-8a0e-56283e84aea3",
    "entry": "永久凍土",
    "reading": {
      "primary": "えいきゅうとうど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
