          "standard": [
            {
              "text": "今日のプレゼンテーション、エクセレントだったよ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このレストランの料理はどれもエクセレントで、満足度が高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の英語力はエクセレントで、ネイティブスピーカーと遜色ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このアイデア、エクセレントだね！ぜひ採用しよう！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "規模から見ても利益率から見ても、日本のエクセレントカンパニーと呼ぶにふさわしい存在であろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてさらに、日電にはエクセレントと呼ばれるにふさわしい、もう一つの要素がある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
