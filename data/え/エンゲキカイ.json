[
  {
    "uuid": "3ec91576-ec34-58a7-b41e-81f7a4d448e1",
    "entry": "演劇界",
    "reading": {
      "primary": "えんげきかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
