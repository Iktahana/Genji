        "examples": {
          "standard": [
            {
              "text": "シルクロードを旅する人々は、しばしば隊商宿で休息をとりました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古代の隊商宿は、商人やその家畜に宿泊施設と補給品を提供しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "砂漠で古い隊商宿の遺跡を発見しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ロシア人がレモンの切れを用いるのは――彼らはシナの隊商宿から茶を飲むことを覚えたのであるが――この古代の茶の飲み方が残っていることを示している。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは彼が世界の街道において、すべての国の哲学者が泊まることのできる隊商宿をいとなむべきであり、その看板には「人間款待、ただし人間のうちの獣性はおことわり。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
