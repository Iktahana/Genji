        "examples": {
          "standard": [
            {
              "text": "「最近の分譲マンションは、どれも耐震家屋として設計されている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「地震が多い地域では、耐震家屋であることが物件選びの重要な条件となる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "Wow! あの古い家が、こんなに立派な耐震家屋に生まれ変わったなんて！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "地震の時にこわれないためにいわゆる耐震家屋というものが学者の研究の結果として設計されている。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学構内、耐震家屋のそばを通っていると、枯れ樹の枝に妙な花が咲いていて散りかかる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、屋外への避難耐震的構造　地震に出會つてそれが非常の地震であることを意識したものは、餘程修養を積んだ人でない限り、たとひ耐震家屋内にゐても、又屋外避難の不利益な場合でも、しかせんと力めるであらう。",
              "citation": {
                "source": "地震の話",
                "author": "今村明恒",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つて眞に耐震家屋について考慮し出したのは、あまり古いことでない。",
              "citation": {
                "source": "日本建築の發達と地震",
                "author": "伊東忠太",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
