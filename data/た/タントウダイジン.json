        "examples": {
          "standard": [
            {
              "text": "経済の立て直しに向けて、担当大臣が国会で答弁した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "福島の復興担当大臣が現地を視察し、被災者と意見交換を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この法案は、担当大臣の強力なリーダーシップで可決された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "英国の日刊新聞であれば、いずれかの担当大臣に確認せず発行するほど、堕落した非国民じゃございません。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
