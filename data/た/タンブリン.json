        "examples": {
          "standard": [
            {
              "text": "クリスマス会で子供たちがタンブリンを振りながら歌を披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はリズム感が良く、タンブリン一つで場を盛り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "楽譜にはタンブリンのパートも記載されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "『タンブリン・マン』はあるから、あとで〈クライ〉をかける」　慶一はあの曲を思いだし、「でも、そんなことは、以前にもなんどもあったこと」だから、「泣かなくてもいいんだ」と考えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はいろいろ手間どり、美しい手足を一つずつながめては差伸ばし、顔を洗いながら十四連の感傷的な歌曲を歌い、窓につかまってタンブリンの音をまねてるクリストフの顔に水をはねかけ、出かける時には、庭に咲き残ってる薔薇の花を摘み取り、そして二人は船に乗った。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
