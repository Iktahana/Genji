          "standard": [
            {
              "text": "タントラは、インドに起源を持つ密教的な思想や実践体系である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はタントラの教えに深く傾倒し、瞑想の日々を送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "タントラ哲学は、宇宙の根源的なエネルギーを追求する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "生や死や愛や信仰について語った哲学はいくらでもあるが、道端に落ちている十円玉について、インスタントラーメンの空き袋について、ゴミ箱の中のカオスについて語った哲学はない。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
