        "examples": {
          "standard": [
            {
              "text": "疑惑の渦中にある議員が、急遽、地元放送局のスタジオを訪れて単独会見を開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「他社の記者の同席は認められません。今回はあくまで単独会見の形式を取ります」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "メジャーリーグへの移籍を決めた投手が、スポーツ紙の記者を前に晴れやかな顔で単独会見を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "梅玉堂はさッそく初音サンに単独会見を申入れて許可を得、粋な料亭へでも行きたいところを、ここが時代精神であると心に期して、交響曲の長時間レコードをかなでている優雅な喫茶店に落付き、二十の扉のような質問を連発した。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "編集長が私に各社を出し抜いて単独会見をやれと云ふのですよ。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "アストリア王と単独会見させると約束したよな」「おや、約束を破ったかしら。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーキュリー紙の編集長が偽物と単独会見していたその時、本物の国王は間違いなくメリヘイブン邸宅にいた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
