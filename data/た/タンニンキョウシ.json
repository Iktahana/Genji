        "examples": {
          "standard": [
            {
              "text": "不登校が続いている生徒の自宅を、心配した担任教師が放課後に何度も訪問して声をかけ続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「高校時代の担任教師の何気ない励ましの一言がきっかけで、私は教師の道を志したんです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "学校内で起きたSNS上のトラブルについて、保護者が担任教師に事実確認の連絡を入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一年と二年とはどうやら無事で、算盤の下手な担任教師が斉藤平大の通信簿の点数の勘定を間違った為に首尾よく卒業いたしました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか、お気になることがありましたら、あの学校の担任教師に聞いてあげましょうか。",
              "citation": {
                "source": "化生のもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "学期末の試験が済むと、各科目の担任教師は、一定の期日までに採点して報告しなければならなかった。",
              "citation": {
                "source": "或る素描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもあんまり開きがありすぎて点のつけやうに困る――と、担任教師が母に向つて言つたといふことまで、いつのまにかちやんと小耳にはさんでゐた。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は担任教師から専攻の学科に関して、次の週までにある事項を調べて来いと命ぜられたのです。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
