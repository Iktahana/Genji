        "examples": {
          "standard": [
            {
              "text": "彼は一人でピザ一枚を全部食べられる、大食漢です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の体格にもかかわらず、彼は驚くほどの大食漢です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "そのレストランは、特大のポーションで大食漢に対応しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "同伴者がペコペコに腹が減っていたのだから無論、大食漢の頭山満氏も空腹を感じていたに相違ないのであるが、何しろ飯屋は愚か、百姓家すら見当らないので、皆空腹を抱えながら日の暮れ方まで歩き続けた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "地から生れた食意地の張った大食漢でなくって、誰があんなものを持っているでしょう。",
              "citation": {
                "source": "初蛙",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大食大食漢を罰すだ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
