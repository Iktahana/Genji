        "examples": {
          "standard": [
            {
              "text": "兵士たちは強力な対空砲を操作していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い砦の遺跡には、今も古い対空砲が残されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "対空砲からの正確な一撃が、爆撃機を撃墜した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "すなわち特攻隊の通路に三重四重に戦闘機隊の網をはる事、弾幕を完全なものにするため船舶の対空砲火を増大する事、内地の航空基地の攻撃激化、Ｂ29等による本土空爆の強化、これに附帯した謀略戦などである。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その形から推して、大砲のようなものもあり、対空砲のようなものもある。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
