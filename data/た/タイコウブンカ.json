        "examples": {
          "standard": [
            {
              "text": "1960年代に広まった対抗文化は、既存の社会規範や価値観に疑問を投げかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "音楽やファッションは、しばしば対抗文化の象徴として社会に影響を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、既存の体制に反対する対抗文化のムーブメントに強く共感していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "忘れられた、と言っていい状態にあったエルヴィスは、たとえばいわゆる対抗文化のメディアのひとつである、アンダグラウンド新聞や雑誌などの、まともな批評や論評の対象にもなっていった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
