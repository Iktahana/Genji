        "examples": {
          "standard": [
            {
              "text": "胎蔵界は、金剛界と並ぶ密教の二大曼荼羅の一つです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "仏教美術における胎蔵界の図像学は非常に複雑だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この経典は、胎蔵界の教えを詳しく説いている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "勝軍地蔵か祇尼は古くからいい伝えていること、勝軍地蔵は新らしく出来たもの、だきには胎蔵界曼陀羅の外金剛部院の一尊であり、勝軍地蔵はただこれ地蔵の一変身である。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
