    },
    "definitions": [
      {
        "index": 1,
        "gloss": "band",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この無線通信システムは、特定の帯域を使用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "光ファイバーは、広い帯域でデータを伝送できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "テレビの放送帯域は国によって異なる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "人の心とコンピューターが、ともに広い帯域幅を与えられながら、キーボードを介することで、交換できる情報量を極端に制限しているのはなんと奇妙なことだろうと指摘したマッサーロは、「こうした状況も市場に出てくるスターや、ＰＥＲＱなどの新しいマシンによって変化するだろう」と続けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電波の帯域を広く取らないよう考慮した上で、かろうじて見られる絵をだましだまし描けるくらいですませている。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "放送とは無縁だから、帯域を抑える必要はない。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人一人を区別できるほどの、限りなく狭隘で限りなく微細な帯域からの放射を追求したも者はこれまでいなかった。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の女王は、わたしたち子ばとに、つめたいいきをふきかけて、ころしてしまいました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイネが三つの時代的要因の間に動揺したいいきさつもよくわかって面白うございます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "bandwidth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
