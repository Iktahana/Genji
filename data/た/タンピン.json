    "definitions": [
      {
        "index": 1,
        "gloss": "individual item (i.e. not part of a set)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この商品は単品でも購入できますが、セットで買うとお得です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ケーキは単品で頼むよりも、ドリンクセットにした方が安いです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このレゴブロックは単品では遊べず、他のセットと組み合わせて初めて機能します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だが多くのマニアたちは、一足先に単品で発売されたＬＳＩを使ってゲーム機の手作りを楽しんだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "寡婦が親切にも荷解きと整頓を手伝ってあげた時、大匙、シチュー用スプーン、テーブルセット、食卓用小瓶、ソース注し、何枚もの皿、鮮紅色のモーニングカップ、そして程度の差はあるが綺麗でかなりの重さになる単品の食器類があって、彼はそれらを処分しようとしないのだった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "single item out of a set",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "壊れた部品だけ単品で取り寄せることが可能ですか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コップを一つ割ってしまったので、このデザインの単品を探しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "セット販売の化粧品ですが、使い切った乳液だけ単品で補充したいです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
