        "examples": {
          "standard": [
            {
              "text": "騒ぎは大きかったが、大山鳴動して鼠一匹とはこのことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "期待していたほどの結果は出ず、まさに大山鳴動して鼠一匹だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は大山鳴動して鼠一匹というような、大げさな騒ぎをよく起こす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「大山鳴動して鼠一匹という寓話を聞かれたことがありますか？",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその、ごッたすッたの間に、八方｜筒抜けの蓆小屋の事とて、当然、逃げるべきものは遁れ、避難する見物は避難して、あとに残ったのは小屋者の男衆のみで、大山鳴動して鼠一匹のかたちがないでもない。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
