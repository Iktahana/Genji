        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は、平和への強い意志の体現者として世界中を旅している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その偉大な芸術家は、まさに革新の体現者だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの選手は、チームの精神的支柱であり、情熱の体現者だ。」監督が称賛した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "使命を自覚したる者は権威の体現者なり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、生涯寂しい孤独に住まわれた神の使命の体現者クリストのその信仰は、万人の胸に生き来る真理でありました。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "四季の体現者としての夏子。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポワレはかつて役人で、疑いもなく市民道徳の体現者、それでいて思想は持たないといった人間だった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "――五指は彼の部下であり、五指をもって一拳の力となすには、自身、陣頭に立つことであるを知っている統率の体現者であった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
