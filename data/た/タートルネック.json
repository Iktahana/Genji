        "examples": {
          "standard": [
            {
              "text": "外出時にマフラーを巻くのが面倒な日は、厚手のタートルネックを選ぶことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は黒のタートルネックに大ぶりのネックレスを合わせるスタイルを好んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "敏感肌なので、首に触れるタートルネックの素材には人一倍こだわりがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いつものオールドミスのようなかっこうではなく、ぴったりしたウグイス色のタートルネックに、ベージュのスカートというのも、慶一を困惑させる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
