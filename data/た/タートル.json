    "definitions": [
      {
        "index": 1,
        "gloss": "turtle (esp. a sea turtle)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "海岸近くで泳いでいたら、大きなタートルが優雅に海中を横切っていくのが見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "砂浜に掘られた穴の中で、タートルの卵が孵化するのをボランティアが見守っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "水族館の巨大水槽では、タートルがゆっくりと旋回しながら餌を待っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いつものオールドミスのようなかっこうではなく、ぴったりしたウグイス色のタートルネックに、ベージュのスカートというのも、慶一を困惑させる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、山がなくなるって、どういうこと」　タートルズの〈ハッピー・トゥゲザー〉のマイナー・コードのイントロが流れはじめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターで考えることを子供に受け入れさせる道具として、パパートは一匹の亀（タートル）を用意した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディスプレイの中に棲んでいるタートルは、与えられた命令のとおりに動く。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「前へ一〇〇」とキーボードから命令を入れると、タートルは一歩をおよそ一ミリメートルとして一〇〇歩進む。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この動作を四回繰り返すと、タートルは一辺が一〇〇ミリの正方形を描く。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして子供たちは、いくつもの命令を組み合わせてタートルを動かし、定義した新しい命令によって複雑な動きを一まとまりにして、画面の中の小さな世界を完全にコントロールすることを学ぶ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで自分自身をタートルに任じて命令を与え、部屋の中を歩き回った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫定版のダイナブックのハードウエアを用意したアラン・ケイは、このシステムで使う言語にロゴにおけるタートルのような、人とコンピューターとが交流し合うための道具を組み込もうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "タートル・シェルズ・オン・ザ・ウォール。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
