        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "首元まで暖かいカシミアのタートルを着て、冷え込む朝の散歩に出かける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ジャケットのインナーに白いタートルを合わせると、上品で知的な印象になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お気に入りのタートルが洗濯で少し縮んでしまい、首の周りが窮屈になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
