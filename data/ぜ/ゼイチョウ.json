          "standard": [
            {
              "text": "与党の税調は、年末に向けて税制改革の議論を本格化させるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来年度の予算編成に向けて、税調で活発な意見交換が行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は長年、政府の税調に所属し、日本の税制に大きな影響を与えてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "＊２　戸口調査名簿　ピョートル大帝によって一七二二年に創始され、一八六〇年までに十回にわたって行われた一種の国税調査に、その都度地主から政府に提出した農奴数の届書をいう。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
