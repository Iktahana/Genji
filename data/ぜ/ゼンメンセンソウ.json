          "standard": [
            {
              "text": "国境付近での小競り合いがエスカレートし、ついに両国は全面戦争に突入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "全面戦争を回避するため、国際連合が仲介に入って必死の外交交渉が続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "全面戦争となれば、前線の兵士だけでなく一般市民にも多大な犠牲が出る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "三十分ほどするとＮ新聞のＴさんから、閣議中から陸軍部内に動揺の色が見えていたが、クウ・デタによる和平阻止の策動が露骨になり、四時ごろ阿南陸相をだしぬいて〈軍は全面戦争を決議せり〉という大本営発表をしようとした。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
