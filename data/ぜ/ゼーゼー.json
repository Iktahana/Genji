        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「はぁ、ゼーゼー……待ってよ、そんなに早く歩けないよ！」と彼女は息を切らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "階段を五階まで一気に駆け上がったら、肺がゼーゼー鳴ってしばらく動けなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ゼーゼー、やっと着いた……」山頂に到着した彼は、膝をついて激しく呼吸した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ふだんでも息するごとにゼーゼーかすかに音をさせてゐるが、時々首を前へのばし、背中を一層まるめてこんこん續けさまに咳をする。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "スーラーブは、侘しい退屈な心持で、そのゼーゼーいう音をきき、雪の上をちょいちょい歩く二三羽の鶫を看ていた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからゼーゼーになったんでしょう？",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧式の機関車がその道路の真中に立ちはだかって、老いぼれの喘息病みみたいに、ゼーゼーと白い息を吐いている。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
