        "examples": {
          "standard": [
            {
              "text": "新しく導入したスピーカーは全方位から音が響くので、どこにいても臨場感がすごい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その政治家は支持層を広げるため、全方位に配慮した慎重な発言を繰り返している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "防犯カメラを設置するなら、死角のない全方位タイプを選ぶのがベストだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "３６０という名称には、すべての用途とすべての規模の要求に、三六〇度の全方位の対応力を持った互換性のあるシリーズで応えうるとの意味が込められていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ナショナリズムが全方位で勝利を収めているわけではないと、皆が皆、己の願望の赴くままに判断を下しているのではないと認めるにしても、次の事実は確実に残る。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
