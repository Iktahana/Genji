    "definitions": [
      {
        "index": 1,
        "gloss": "person who lives an extravagant lifestyle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
