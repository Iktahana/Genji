        "examples": {
          "standard": [
            {
              "text": "自転車の前車輪がパンクしたので、修理に出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "車の前車輪がパンクしたため、スペアタイヤに交換した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "レーシングカーは、高速走行に耐えうる頑丈な前車輪を備えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "第三コーナーまで後方にいた武田が外ワクからグングン他をぬいて最後の直線で中川にせまり、前車輪一ツの差まで追いつめた。",
              "citation": {
                "source": "光を覆うものなし",
                "author": "――競輪不正事件――",
                "note": "青空文庫"
              }
            },
            {
              "text": "前車輪一ツの差がどうしてもちぢまらない。",
              "citation": {
                "source": "光を覆うものなし",
                "author": "――競輪不正事件――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピッタリ接近して前車輪一ツの差がどうにもちぢまらぬゴールインだから、肉眼でも狂いのないレースであった。",
              "citation": {
                "source": "光を覆うものなし",
                "author": "――競輪不正事件――",
                "note": "青空文庫"
              }
            }
          ]
        }
