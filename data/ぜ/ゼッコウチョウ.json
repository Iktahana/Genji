        "examples": {
          "standard": [
            {
              "text": "今日の彼は絶好調で、次々とヒットを飛ばしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームはシーズン開幕から絶好調を維持している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今日の君、絶好調だね！」「ええ、昨晩よく眠れたから！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ところがこの絶好調の中で一九七七（昭和五十二）年四月、西自身は雑誌作りを放棄してアメリカに渡り、そこで「パソコン元年」の激動を目撃することになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、この白い脚毛と星印を取り除いて、絶好調のリアルト号を、半故障のコンフェティ号に実際に変えてくれ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "確実に良くなりましたので……」「絶好調だよ」　とトリタイアが蛇足。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "若かろうと年寄りだろうと、中風だろうと絶好調だろうと、うん、確かに……まあ、そうだな！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
