        "examples": {
          "standard": [
            {
              "text": "冬場は、室内の絶対湿度が低くなりがちなので加湿器を使う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "気象学では、空気中の水蒸気量を表す指標として絶対湿度が用いられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "絶対湿度が高い日は、洗濯物が乾きにくい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "われわれの大気中には常に水蒸気が多少含まれていて、一立方｜米の空気中にある水蒸気の目方を瓦で表わし、これを湿量あるいは絶対湿度といっている。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
