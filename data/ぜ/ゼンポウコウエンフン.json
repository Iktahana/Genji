          "standard": [
            {
              "text": "教科書で見た仁徳天皇陵のような巨大な前方後円墳を、一度は間近で見てみたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "前方後円墳の形状は、当時の権力者の勢力を象徴するものだったと考えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この地域には大小さまざまな前方後円墳が点在しており、古代のロマンを感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "用途は大きい前方後円墳の周囲の垣根であった。",
              "citation": {
                "source": "人物埴輪の眼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど前方後円墳といふのはかういふ落ちついた感じのものかとしみ／″＼感じた。",
              "citation": {
                "source": "西の京の思ひ出",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
