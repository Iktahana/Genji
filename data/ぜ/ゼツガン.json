        "examples": {
          "standard": [
            {
              "text": "「舌にできた違和感が消えないので検査を受けたら、初期の舌癌と診断された。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「父は舌癌の手術を受けて、今はリハビリをしながら元気に過ごしている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「舌癌の早期発見のために、定期的な歯科検診を受けることが推奨されている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "舌癌で舌の右だか左だかの半分を剪断するというので、麻酔をかけようとしたら、そんなものは要らないと云ってどうしても聞かない。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと舌癌にかかったからと云うて踵で飯を食う訳には行かず、不幸にして痳疾を患いたからと申して臍で用を弁ずる事ができなくなりました。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
