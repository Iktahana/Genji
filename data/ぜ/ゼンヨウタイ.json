        "examples": {
          "standard": [
            {
              "text": "シダ植物のライフサイクルでは、配偶体は前面体として存在している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "前面体は、精子と卵子が形成される重要な段階だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "研究室では、シダ植物の前面体の培養に成功した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "生殖は隠花植物、殊に羊歯植物門類似で、翼端に胞子嚢があり明らかに葉状体ないしは前葉体から進化したものだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのものどもは胞子によって――レイクの推測通り羊歯植物に似た方法で――増殖したが、非常な強靭さと長命ぶりの結果補充すべき人口がなかったため、新たな植民地が現れない限り大規模な前葉体の発生は奨励されなかった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
