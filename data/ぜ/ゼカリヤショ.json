        "examples": {
          "standard": [
            {
              "text": "旧約聖書の預言書の一つに、ゼカリヤ書がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゼカリヤ書には、メシアの到来に関する預言が含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毎週の聖書研究会で、私たちはゼカリヤ書を読み進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "すなわちゼカリヤ書の九章に、　シオンの女よ、大いに喜べ、エルサレムの女よ、呼ばわれ、視よ、汝の王汝に来たる。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一四の二七、二八）　これはゼカリヤ書一三の七を引用せられたのです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一四の四八、四九）　これはイザヤ書五十三章や、ゼカリヤ書十三章七節等を連想して言われたのでしょう。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
